import "../../../std/collections.zorb"
import "../../../std/fs.zorb"
import "../../../std/mem.zorb"
import "../../../src-zorb/ast.zorb"
import "../../../src-zorb/lexer.zorb"
import "../../../src-zorb/parser.zorb"
import "../../../src-zorb/token.zorb"

fn main() -> i64 {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(1048576) catch |err| {
        return err
    }

    source: []u8 = std.fs.read_all("input.zorb", &heap) catch |err| {
        return err
    }

    tokens: ZTokenList = ZTokenList.init(&heap, 8) catch |err| {
        return err
    }

    interner: std.collections.StringInterner = std.collections.StringInterner.init(&heap, 8) catch |err| {
        return err
    }

    lexer: ZLexer = ZLexer.init(source)
    ZLexer.tokenize(&lexer, &heap, &tokens, &interner) catch |err| {
        return err
    }

    parser: ZParser = ZParser.init(&tokens)
    module: ZAstModule = ZAstModule.init(&heap, 8) catch |err| {
        return err
    }
    ZParser.parse_program(&parser, &heap, &module) catch |err| {
        return err
    }

    return 0
}
