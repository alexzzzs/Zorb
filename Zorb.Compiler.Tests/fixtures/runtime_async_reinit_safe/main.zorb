import "../../../std/io.zorb"
import "../../../std/os.zorb"
import "../../../std/mem.zorb"
import "../../../std/task.zorb"
import "../../../std/async.zorb"

fn job(arg: *void) {
    std.io.print("ok\n")
}

fn _start() {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(131072) catch |init_err| {
        std.os.exit(init_err)
        return
    }

    std.async.init()
    std.async.init()

    std.task.spawn(&heap, job, cast(*void, 0)) catch |spawn_err| {
        std.os.exit(spawn_err)
        return
    }

    std.async.loop()
    std.os.exit(0)
}
