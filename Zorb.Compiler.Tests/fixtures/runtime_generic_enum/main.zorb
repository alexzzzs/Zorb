import "../../../std/io.zorb"
import "../../../std/os.zorb"

enum Token<T>: i32 {
    Start,
    End
}

fn score(token: Token<i64>) -> i64 {
    match token {
        case Token<i64>.Start {
            return 1
        }
        case Token<i64>.End {
            return 2
        }
    }
}

fn _start() {
    start: Token<i64> = Token<i64>.Start
    end: Token<i64> = Token<i64>.End

    if start == Token<i64>.Start {
        std.io.print_i64(score(end))
        std.io.print("\n")
    }

    std.os.exit(0)
}
