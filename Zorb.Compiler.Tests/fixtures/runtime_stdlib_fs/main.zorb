import "../../../std/fs.zorb"
import "../../../std/io.zorb"
import "../../../std/mem.zorb"
import "../../../std/os.zorb"
import "../../../std/str.zorb"

fn main() -> i64 {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(65536) catch |err| {
        return err
    }

    bytes: []u8 = std.fs.read_all("input.txt", &heap) catch |err| {
        return err
    }

    expected: []u8
    expected.ptr = cast(*u8, "file contents\nsecond line\n")
    expected.len = 26
    if !std.str.slice_eql(bytes, expected) {
        return 8
    }

    std.io.write(1, bytes)
    return 0
}
