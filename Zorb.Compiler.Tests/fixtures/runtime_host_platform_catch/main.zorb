import "../../../std/io.zorb"
import "../../../std/os.zorb"

error LinuxHost = 31
error WindowsHost = 52

fn host_failure() !i64 {
    if Builtin.IsWindows {
        return error.WindowsHost
    }

    if Builtin.IsLinux {
        return error.LinuxHost
    }

    return 0
}

fn _start() {
    value: i64 = host_failure() catch |err| {
        std.io.print("caught ")
        std.io.print_i64(err)
        std.io.print("\n")
        std.os.exit(0)
        return
    }

    std.io.print_i64(value)
    std.io.print("\n")
    std.os.exit(1)
}
