import "../../../std/io.zorb"
import "../../../std/os.zorb"

union Value {
    Number: i64,
    Flag: bool
}

fn score(value: Value) -> i64 {
    switch value.tag {
        case Value.Tag.Number {
            return value.Number
        }
        case Value.Tag.Flag {
            if value.Flag {
                return 1
            }

            return 0
        }
    }
}

fn _start() {
    number: Value = Value{ Number: 9 }
    flag: Value = Value{ Flag: true }

    std.io.print_i64(score(number))
    std.io.print("\n")
    std.io.print_i64(score(flag))
    std.io.print("\n")
    std.os.exit(0)
}
