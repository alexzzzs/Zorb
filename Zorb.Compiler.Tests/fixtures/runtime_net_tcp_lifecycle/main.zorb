import "../../../std/io.zorb"
import "../../../std/os.zorb"
import "../../../std/net.zorb"

fn _start() {
    if !std.net.is_supported() {
        std.io.print("net unsupported\n")
        std.os.exit(0)
        return
    }

    server_fd_raw: i64 = std.net.socket_tcp_v4()
    if server_fd_raw < 0 {
        std.os.exit(std.net.errno(server_fd_raw))
        return
    }

    server_fd: i32 = cast(i32, server_fd_raw)
    bind_addr: std.net.SockAddrV4 = std.net.sockaddr_v4_loopback(0)

    bind_result: i64 = std.net.bind_v4(server_fd, &bind_addr)
    if bind_result < 0 {
        std.net.close(server_fd)
        std.os.exit(std.net.errno(bind_result))
        return
    }

    listen_result: i64 = std.net.listen(server_fd, 8)
    if listen_result < 0 {
        std.net.close(server_fd)
        std.os.exit(std.net.errno(listen_result))
        return
    }

    close_result: i64 = std.net.close(server_fd)
    if close_result < 0 {
        std.os.exit(std.net.errno(close_result))
        return
    }

    std.io.print("net ok\n")
    std.os.exit(0)
}
