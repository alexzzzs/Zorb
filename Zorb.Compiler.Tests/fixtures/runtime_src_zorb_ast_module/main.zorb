import "../../../std/collections.zorb"
import "../../../std/errors.zorb"
import "../../../std/fs.zorb"
import "../../../std/mem.zorb"
import "../../../std/str.zorb"
import "../../../src-zorb/ast.zorb"
import "../../../src-zorb/lexer.zorb"
import "../../../src-zorb/parser.zorb"
import "../../../src-zorb/token.zorb"

fn ast_text_eql(text: ZAstText, value: string) -> bool {
    view: []u8
    view.ptr = text.ptr
    view.len = text.len

    expected: []u8
    expected.ptr = cast(*u8, value)
    expected.len = std.str.len(value)
    return std.str.slice_eql(view, expected)
}

fn expect(value: bool) !i64 {
    if !value {
        return error.InvalidArgument
    }
    return 0
}

fn main() -> i64 {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(1048576) catch |err| {
        return err
    }

    source: []u8 = std.fs.read_all("input.zorb", &heap) catch |err| {
        return err
    }

    tokens: ZTokenList = ZTokenList.init(&heap, 8) catch |err| {
        return err
    }

    interner: std.collections.StringInterner = std.collections.StringInterner.init(&heap, 8) catch |err| {
        return err
    }

    lexer: ZLexer = ZLexer.init(source)
    ZLexer.tokenize(&lexer, &heap, &tokens, &interner) catch |err| {
        return err
    }

    module: ZAstModule = ZAstModule.init(&heap, 4) catch |err| {
        return err
    }

    parser: ZParser = ZParser.init(&tokens)
    ZParser.parse_program(&parser, &heap, &module) catch |err| {
        return err
    }

    expect(module.len == 12) catch |err| { return err }
    expect(module.import_count == 2) catch |err| { return err }
    expect(module.extern_count == 1) catch |err| { return err }
    expect(module.error_count == 1) catch |err| { return err }
    expect(module.const_count == 1) catch |err| { return err }
    expect(module.global_count == 1) catch |err| { return err }
    expect(module.struct_count == 1) catch |err| { return err }
    expect(module.enum_count == 1) catch |err| { return err }
    expect(module.union_count == 1) catch |err| { return err }
    expect(module.function_count == 3) catch |err| { return err }

    expect(module.decls[0].kind == ZAstDeclImport) catch |err| { return err }
    expect(module.decls[0].is_c_import) catch |err| { return err }
    expect(ast_text_eql(module.decls[0].path, "stdio.h")) catch |err| { return err }

    expect(module.decls[1].kind == ZAstDeclImport) catch |err| { return err }
    expect(ast_text_eql(module.decls[1].path, "pkg/math.zorb")) catch |err| { return err }
    expect(ast_text_eql(module.decls[1].alias, "math")) catch |err| { return err }

    expect(module.decls[2].kind == ZAstDeclError) catch |err| { return err }
    expect(module.decls[2].exported) catch |err| { return err }
    expect(ast_text_eql(module.decls[2].name, "Bad")) catch |err| { return err }

    expect(module.decls[3].kind == ZAstDeclConst) catch |err| { return err }
    expect(module.decls[3].exported) catch |err| { return err }
    expect(ast_text_eql(module.decls[3].name, "answer")) catch |err| { return err }

    expect(module.decls[4].kind == ZAstDeclGlobal) catch |err| { return err }
    expect(ast_text_eql(module.decls[4].name, "counter")) catch |err| { return err }

    expect(module.decls[5].kind == ZAstDeclStruct) catch |err| { return err }
    expect(module.decls[5].member_count == 2) catch |err| { return err }

    expect(module.decls[6].kind == ZAstDeclEnum) catch |err| { return err }
    expect(module.decls[6].member_count == 2) catch |err| { return err }

    expect(module.decls[7].kind == ZAstDeclUnion) catch |err| { return err }
    expect(module.decls[7].member_count == 2) catch |err| { return err }

    expect(module.decls[8].kind == ZAstDeclExternFunction) catch |err| { return err }
    expect(module.decls[8].param_count == 1) catch |err| { return err }
    expect(ast_text_eql(module.params[module.decls[8].param_start].name, "text")) catch |err| { return err }
    expect(ast_text_eql(module.types[module.params[module.decls[8].param_start].type_index].text, "string")) catch |err| { return err }
    expect(ast_text_eql(module.types[module.decls[8].return_type_index].text, "i32")) catch |err| { return err }

    expect(module.decls[9].kind == ZAstDeclFunction) catch |err| { return err }
    expect(ast_text_eql(module.decls[9].name, "helper")) catch |err| { return err }
    expect(module.decls[9].param_count == 1) catch |err| { return err }
    expect(module.decls[9].return_count == 1) catch |err| { return err }
    expect(module.decls[9].stmt_count == 1) catch |err| { return err }
    expect(ast_text_eql(module.params[module.decls[9].param_start].name, "value")) catch |err| { return err }
    expect(ast_text_eql(module.types[module.decls[9].return_type_index].text, "i64")) catch |err| { return err }
    expect(module.stmts[module.decls[9].stmt_start].kind == ZAstStmtReturn) catch |err| { return err }
    expect(module.exprs[module.stmts[module.decls[9].stmt_start].expr_index].kind == ZAstExprIdentifier) catch |err| { return err }

    expect(module.decls[10].kind == ZAstDeclFunction) catch |err| { return err }
    expect(ast_text_eql(module.decls[10].name, "use_pair")) catch |err| { return err }
    expect(module.decls[10].param_count == 2) catch |err| { return err }
    expect(module.decls[10].local_count == 7) catch |err| { return err }
    expect(module.decls[10].return_count == 1) catch |err| { return err }
    expect(module.decls[10].binary_count == 2) catch |err| { return err }
    expect(module.decls[10].stmt_count == 9) catch |err| { return err }

    pair_field_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start]
    expect(pair_field_stmt.kind == ZAstStmtVar) catch |err| { return err }
    expect(module.exprs[pair_field_stmt.expr_index].kind == ZAstExprField) catch |err| { return err }
    expect(ast_text_eql(module.exprs[pair_field_stmt.expr_index].name, "lhs")) catch |err| { return err }

    index_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start + 1]
    expect(index_stmt.kind == ZAstStmtVar) catch |err| { return err }
    expect(module.exprs[index_stmt.expr_index].kind == ZAstExprIndex) catch |err| { return err }

    assign_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start + 2]
    expect(assign_stmt.kind == ZAstStmtAssign) catch |err| { return err }
    expect(module.exprs[assign_stmt.expr_index].kind == ZAstExprField) catch |err| { return err }
    expect(module.exprs[assign_stmt.value_expr].kind == ZAstExprIdentifier) catch |err| { return err }

    deref_field_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start + 4]
    expect(deref_field_stmt.kind == ZAstStmtVar) catch |err| { return err }
    expect(module.exprs[deref_field_stmt.expr_index].kind == ZAstExprField) catch |err| { return err }
    expect(module.exprs[module.exprs[deref_field_stmt.expr_index].left].kind == ZAstExprUnary) catch |err| { return err }

    precedence_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start + 5]
    expect(precedence_stmt.kind == ZAstStmtVar) catch |err| { return err }
    precedence_root: ZAstExpr = module.exprs[precedence_stmt.expr_index]
    expect(precedence_root.kind == ZAstExprBinary) catch |err| { return err }
    expect(precedence_root.op == ZTokenPlus) catch |err| { return err }
    expect(module.exprs[precedence_root.right].kind == ZAstExprBinary) catch |err| { return err }
    expect(module.exprs[precedence_root.right].op == ZTokenStar) catch |err| { return err }

    cast_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start + 6]
    expect(cast_stmt.kind == ZAstStmtVar) catch |err| { return err }
    expect(module.exprs[cast_stmt.expr_index].kind == ZAstExprCast) catch |err| { return err }

    error_stmt: ZAstStmt = module.stmts[module.decls[10].stmt_start + 7]
    expect(error_stmt.kind == ZAstStmtVar) catch |err| { return err }
    expect(module.exprs[error_stmt.expr_index].kind == ZAstExprError) catch |err| { return err }
    expect(ast_text_eql(module.exprs[error_stmt.expr_index].name, "Bad")) catch |err| { return err }

    expect(module.decls[11].kind == ZAstDeclFunction) catch |err| { return err }
    expect(module.decls[11].exported) catch |err| { return err }
    expect(ast_text_eql(module.decls[11].name, "add")) catch |err| { return err }
    expect(module.decls[11].param_count == 2) catch |err| { return err }
    expect(module.decls[11].local_count == 4) catch |err| { return err }
    expect(module.decls[11].return_count == 2) catch |err| { return err }
    expect(module.decls[11].call_count == 2) catch |err| { return err }
    expect(module.decls[11].binary_count == 3) catch |err| { return err }
    expect(module.decls[11].stmt_count == 7) catch |err| { return err }
    expect(ast_text_eql(module.params[module.decls[11].param_start].name, "lhs")) catch |err| { return err }
    expect(ast_text_eql(module.params[module.decls[11].param_start + 1].name, "rhs")) catch |err| { return err }

    first_add_stmt: ZAstStmt = module.stmts[module.decls[11].stmt_start]
    expect(first_add_stmt.kind == ZAstStmtVar) catch |err| { return err }
    expect(ast_text_eql(first_add_stmt.name, "total")) catch |err| { return err }
    expect(module.exprs[first_add_stmt.expr_index].kind == ZAstExprBinary) catch |err| { return err }

    call_stmt: ZAstStmt = module.stmts[module.decls[11].stmt_start + 3]
    expect(ast_text_eql(call_stmt.name, "more")) catch |err| { return err }
    expect(module.exprs[call_stmt.expr_index].kind == ZAstExprCall) catch |err| { return err }
    expect(ast_text_eql(module.exprs[call_stmt.expr_index].name, "helper")) catch |err| { return err }
    expect(module.exprs[call_stmt.expr_index].arg_count == 1) catch |err| { return err }

    expect(module.members[module.decls[5].member_start].type_index != ZAstNoIndex) catch |err| { return err }
    expect(ast_text_eql(module.members[module.decls[5].member_start].name, "lhs")) catch |err| { return err }
    expect(ast_text_eql(module.members[module.decls[7].member_start + 1].name, "Flag")) catch |err| { return err }
    ZAstModule.check_semantics(&module) catch |err| {
        return err
    }

    return 0
}
