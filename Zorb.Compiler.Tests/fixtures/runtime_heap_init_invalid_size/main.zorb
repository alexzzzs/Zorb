import "../../../std/io.zorb"
import "../../../std/os.zorb"
import "../../../std/mem.zorb"
import "../../../std/errors.zorb"

fn _start() {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(0) catch |err| {
        if err == error.InvalidSize {
            std.io.print("invalid size\n")
            std.os.exit(0)
            return
        }

        std.os.exit(err)
        return
    }

    std.io.print("unexpected\n")
    std.os.exit(1)
}
