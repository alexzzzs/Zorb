import "../../../std/io.zorb"
import "../../../std/os.zorb"

union Result<T, E> {
    Ok: T,
    Err: E
}

fn describe(value: Result<i64, bool>) -> i64 {
    if value.tag == Result<i64, bool>.Tag.Ok {
        return value.Ok
    }

    match value {
        case Result<i64, bool>.Ok(number) {
            return number
        }
        case Result<i64, bool>.Err(flag) {
            if flag {
                return -1
            }

            return -2
        }
    }
}

fn _start() {
    ok: Result<i64, bool> = Result<i64, bool>{ Ok: 41 }
    err: Result<i64, bool> = Result<i64, bool>{ Err: false }

    std.io.print_i64(describe(ok) + 1)
    std.io.print("\n")
    std.io.print_i64(describe(err))
    std.io.print("\n")
    std.os.exit(0)
}
