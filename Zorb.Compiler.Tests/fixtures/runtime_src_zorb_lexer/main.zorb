import "../../../std/collections.zorb"
import "../../../std/fs.zorb"
import "../../../std/io.zorb"
import "../../../std/mem.zorb"
import "../../../src-zorb/lexer.zorb"
import "../../../src-zorb/token.zorb"

fn main() -> i64 {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(1048576) catch |err| {
        return err
    }

    source: []u8 = std.fs.read_all("input.zorb", &heap) catch |err| {
        return err
    }

    tokens: ZTokenList = ZTokenList.init(&heap, 4) catch |err| {
        return err
    }

    interner: std.collections.StringInterner = std.collections.StringInterner.init(&heap, 4) catch |err| {
        return err
    }

    lexer: ZLexer = ZLexer.init(source)
    count: i64 = ZLexer.tokenize(&lexer, &heap, &tokens, &interner) catch |err| {
        return err
    }

    if count != tokens.len {
        return 91
    }

    if tokens.ptr[2].ptr != tokens.ptr[21].ptr {
        return 92
    }

    ZTokenListPrint(&tokens)
    return 0
}
