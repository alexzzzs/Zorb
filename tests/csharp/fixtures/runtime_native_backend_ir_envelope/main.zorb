import "../../../../runtime/std/os.zorb"
import "../../../../compiler/backend-ir/model.zorb"
import "../../../../compiler/backend-ir/serialization.zorb"

fn _start() {
    target: ZBackendIrTarget = ZBackendIrTarget.init("x86_64-pc-linux-gnu")
    module: ZBackendIrModule = ZBackendIrModule{
        module_name: "native-envelope",
        target: target,
        output_kind: "llvm_ir",
        output_path: "out.ll",
        types: cast(*ZBackendIrType, 0),
        type_count: 0,
        functions: cast(*ZBackendIrFunction, 0),
        function_count: 0
    }
    ZBackendIrSerialization.write_empty_module(module)
    std.os.exit(0)
}
