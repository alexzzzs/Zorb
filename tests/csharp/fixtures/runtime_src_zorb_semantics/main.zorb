import "../../../../runtime/std/collections.zorb"
import "../../../../runtime/std/errors.zorb"
import "../../../../runtime/std/mem.zorb"
import "../../../../runtime/std/str.zorb"
import "../../../../compiler/ast.zorb"
import "../../../../compiler/lexer.zorb"
import "../../../../compiler/parser.zorb"
import "../../../../compiler/token.zorb"

fn source_slice(value: string) -> []u8 {
    source: []u8
    source.ptr = cast(*u8, value)
    source.len = std.str.len(value)
    return source
}

fn parse_and_check(source_text: string) !i64 {
    heap: std.mem.HeapAllocator = std.mem.HeapAllocator.init(1048576) catch |err| {
        return err
    }

    source: []u8 = source_slice(source_text)
    tokens: ZTokenList = ZTokenList.init(&heap, 8) catch |err| {
        return err
    }
    interner: std.collections.StringInterner = std.collections.StringInterner.init(&heap, 8) catch |err| {
        return err
    }

    lexer: ZLexer = ZLexer.init(source)
    ZLexer.tokenize(&lexer, &heap, &tokens, &interner) catch |err| {
        return err
    }

    module: ZAstModule = ZAstModule.init(&heap, 8) catch |err| {
        return err
    }
    parser: ZParser = ZParser.init(&tokens)
    ZParser.parse_program(&parser, &heap, &module) catch |err| {
        return err
    }

    ZAstModule.check_semantics(&module) catch |err| {
        return err
    }
    return 0
}

fn expect_error(source_text: string, expected: i64) !i64 {
    parse_and_check(source_text) catch |err| {
        if err == expected {
            return 0
        }
        return err
    }
    return error.InvalidArgument
}

fn main() -> i64 {
    parse_and_check("fn id(value: i64) -> i64 { return value }\nfn main() -> i64 { local: i64 = id(1) return local }\n") catch |err| {
        return err
    }

    expect_error("fn dup() -> i64 { return 1 }\nfn dup() -> i64 { return 2 }\n", error.AlreadyExists) catch |err| {
        return err
    }

    expect_error("fn main() -> i64 { return missing }\n", error.NotFound) catch |err| {
        return err
    }

    expect_error("fn one(value: i64) -> i64 { return value }\nfn main() -> i64 { return one(1, 2) }\n", error.NotFound) catch |err| {
        return err
    }

    expect_error("fn main() -> bool { return \"no\" }\n", error.InvalidArgument) catch |err| {
        return err
    }

    expect_error("fn main() -> i32 { return error.Missing }\n", error.NotFound) catch |err| {
        return err
    }

    expect_error("struct Pair { lhs: i64 }\nfn main() -> i64 { pair: Pair return pair.rhs }\n", error.NotFound) catch |err| {
        return err
    }

    expect_error("fn main() -> i64 { value: i64 = 1 return value[0] }\n", error.NotFound) catch |err| {
        return err
    }

    expect_error("fn main() -> i64 { values: [4]i64 first: i64 = values[\"bad\"] return first }\n", error.NotFound) catch |err| {
        return err
    }

    expect_error("fn main() -> i64 { value: i64 = 1 flag: bool = true value = flag return value }\n", error.InvalidArgument) catch |err| {
        return err
    }

    return 0
}
