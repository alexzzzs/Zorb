import "../../../../runtime/std/io.zorb"
import "../../../../runtime/std/os.zorb"
import "../../../../runtime/std/net.zorb"
import "../../../../runtime/std/str.zorb"

fn string_bytes(value: string) -> []u8 {
    bytes: []u8
    bytes.ptr = cast(*u8, value)
    bytes.len = std.str.len(value)
    return bytes
}

fn send_exact(fd: i32, buf: []u8) -> bool {
    sent: i64 = 0
    while sent < buf.len {
        chunk: []u8 = buf
        chunk.ptr = buf.ptr + sent
        chunk.len = buf.len - sent
        wrote: i64 = std.net.send(fd, chunk)
        if wrote <= 0 {
            return false
        }
        sent = sent + wrote
    }

    return true
}

fn recv_exact(fd: i32, buf: []u8) -> bool {
    received: i64 = 0
    while received < buf.len {
        chunk: []u8 = buf
        chunk.ptr = buf.ptr + received
        chunk.len = buf.len - received
        read: i64 = std.net.recv(fd, chunk)
        if read <= 0 {
            return false
        }
        received = received + read
    }

    return true
}

fn close_checked(fd: i32) -> bool {
    result: i64 = std.net.close(fd)
    return result >= 0
}

fn bind_loopback_port(server_fd: i32, addr: *std.net.SockAddrV4) -> bool {
    port: i64 = 19080
    while port < 19120 {
        candidate: std.net.SockAddrV4 = std.net.sockaddr_v4_loopback(cast(u16, port))
        bind_result: i64 = std.net.bind_v4(server_fd, &candidate)
        if bind_result >= 0 {
            addr.family = candidate.family
            addr.port = candidate.port
            addr.addr = candidate.addr
            i: i64 = 0
            while i < 8 {
                addr.zero[i] = candidate.zero[i]
                i = i + 1
            }
            return true
        }
        port = port + 1
    }

    return false
}

fn expect_slice_eq(buf: []u8, expected: string) -> bool {
    return std.str.slice_eql(buf, string_bytes(expected))
}

fn _start() {
    if !std.net.is_supported() {
        std.io.print("net unsupported\n")
        std.os.exit(0)
        return
    }

    server_fd_raw: i64 = std.net.socket_tcp_v4()
    if server_fd_raw < 0 {
        std.os.exit(std.net.errno(server_fd_raw))
        return
    }

    client_fd_raw: i64 = std.net.socket_tcp_v4()
    if client_fd_raw < 0 {
        close_checked(cast(i32, server_fd_raw))
        std.os.exit(std.net.errno(client_fd_raw))
        return
    }

    server_fd: i32 = cast(i32, server_fd_raw)
    client_fd: i32 = cast(i32, client_fd_raw)

    listen_addr: std.net.SockAddrV4
    if !bind_loopback_port(server_fd, &listen_addr) {
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(1)
        return
    }

    if std.net.listen(server_fd, 1) < 0 {
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(2)
        return
    }

    if std.net.connect_v4(client_fd, &listen_addr) < 0 {
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(3)
        return
    }

    conn_fd_raw: i64 = std.net.accept(server_fd)
    if conn_fd_raw < 0 {
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(std.net.errno(conn_fd_raw))
        return
    }

    conn_fd: i32 = cast(i32, conn_fd_raw)

    ping: []u8 = string_bytes("PING\n")
    pong: []u8 = string_bytes("PONG\n")
    quit: []u8 = string_bytes("QUIT\n")
    bye: []u8 = string_bytes("BYE\n")

    server_buf_storage: [8]u8
    client_buf_storage: [8]u8
    server_buf: []u8 = server_buf_storage
    client_buf: []u8 = client_buf_storage

    server_buf.len = ping.len
    client_buf.len = pong.len

    if !send_exact(client_fd, ping) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(4)
        return
    }

    if !recv_exact(conn_fd, server_buf) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(5)
        return
    }

    if !expect_slice_eq(server_buf, "PING\n") {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(6)
        return
    }

    if !send_exact(conn_fd, pong) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(7)
        return
    }

    if !recv_exact(client_fd, client_buf) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(8)
        return
    }

    if !expect_slice_eq(client_buf, "PONG\n") {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(9)
        return
    }

    server_buf.len = quit.len
    client_buf.len = bye.len

    if !send_exact(client_fd, quit) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(10)
        return
    }

    if !recv_exact(conn_fd, server_buf) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(11)
        return
    }

    if !expect_slice_eq(server_buf, "QUIT\n") {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(12)
        return
    }

    if !send_exact(conn_fd, bye) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(13)
        return
    }

    if !recv_exact(client_fd, client_buf) {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(14)
        return
    }

    if !expect_slice_eq(client_buf, "BYE\n") {
        close_checked(conn_fd)
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(15)
        return
    }

    if !close_checked(conn_fd) {
        close_checked(client_fd)
        close_checked(server_fd)
        std.os.exit(16)
        return
    }

    if !close_checked(client_fd) {
        close_checked(server_fd)
        std.os.exit(17)
        return
    }

    if !close_checked(server_fd) {
        std.os.exit(18)
        return
    }

    std.io.print("net line ok\n")
    std.os.exit(0)
}
