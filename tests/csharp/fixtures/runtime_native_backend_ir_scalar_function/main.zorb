import "../../../../runtime/std/os.zorb"
import "../../../../compiler/backend-ir/model.zorb"
import "../../../../compiler/backend-ir/serialization.zorb"

fn _start() {
    types_storage: [1]ZBackendIrType = [1]ZBackendIrType{
        ZBackendIrType{ id: 1, kind: "scalar", scalar: "i32" }
    }
    instructions_storage: [1]ZBackendIrInstruction = [1]ZBackendIrInstruction{
        ZBackendIrInstruction{ id: 1, op: "integer_constant", type_id: 1, integer: 42, binary_op: "", compare_op: "", lhs: 0, rhs: 0, callee: 0, arguments: cast(*i64, 0), argument_count: 0 }
    }
    terminator: ZBackendIrTerminator = ZBackendIrTerminator{ op: "return_value", value: 1, target: 0, condition: 0, true_target: 0, false_target: 0 }
    blocks_storage: [1]ZBackendIrBlock = [1]ZBackendIrBlock{
        ZBackendIrBlock{ id: 1, name: "entry", instructions: instructions_storage, instruction_count: 1, terminator: terminator }
    }
    blocks: []ZBackendIrBlock = blocks_storage
    functions_storage: [1]ZBackendIrFunction = [1]ZBackendIrFunction{
        ZBackendIrFunction{ id: 1, name: "answer", linkage: "external", return_type: 1, parameters: cast(*ZBackendIrParameter, 0), parameter_count: 0, blocks: blocks_storage, block_count: 1 }
    }

    target: ZBackendIrTarget = ZBackendIrTarget.init("x86_64-pc-linux-gnu")
    module: ZBackendIrModule = ZBackendIrModule{
        module_name: "native-scalar",
        target: target,
        output_kind: "llvm_ir",
        output_path: "out.ll",
        types: types_storage,
        type_count: 1,
        functions: functions_storage,
        function_count: 1
    }
    ZBackendIrSerialization.write_module(module)
    std.os.exit(0)
}
