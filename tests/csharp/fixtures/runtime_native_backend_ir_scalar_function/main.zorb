import "../../../../runtime/std/os.zorb"
import "../../../../compiler/backend-ir/model.zorb"
import "../../../../compiler/backend-ir/serialization.zorb"

fn _start() {
    types_storage: [1]ZBackendIrType = [1]ZBackendIrType{
        ZBackendIrType{ id: 1, kind: "scalar", scalar: "i32" }
    }
    instructions_storage: [1]ZBackendIrInstruction = [1]ZBackendIrInstruction{
        ZBackendIrInstruction{ id: 1, op: "integer_constant", type_id: 1, integer: 42 }
    }
    instructions: []ZBackendIrInstruction = instructions_storage
    terminator: ZBackendIrTerminator = ZBackendIrTerminator{ op: "return_value", value: 1 }
    blocks_storage: [1]ZBackendIrBlock = [1]ZBackendIrBlock{
        ZBackendIrBlock{ id: 1, name: "entry", instructions: instructions, terminator: terminator }
    }
    blocks: []ZBackendIrBlock = blocks_storage
    functions_storage: [1]ZBackendIrFunction = [1]ZBackendIrFunction{
        ZBackendIrFunction{ id: 1, name: "answer", linkage: "external", return_type: 1, blocks: blocks }
    }

    target: ZBackendIrTarget = ZBackendIrTarget.init("x86_64-pc-linux-gnu")
    module: ZBackendIrModule = ZBackendIrModule.init("native-scalar", target, "llvm_ir", "out.ll")
    module.types = types_storage
    module.functions = functions_storage
    ZBackendIrSerialization.write_module(module)
    std.os.exit(0)
}
