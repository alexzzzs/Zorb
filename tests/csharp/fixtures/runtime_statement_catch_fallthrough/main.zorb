import "../../../../runtime/std/io.zorb"
import "../../../../runtime/std/os.zorb"

error Fail = 100

fn may_fail(flag: i64) !i64 {
    if flag != 0 {
        return error.Fail
    }

    return 7
}

fn _start() {
    may_fail(1) catch |err| {
        ignored: i32 = err
        std.io.print("handled\n")
    }

    std.io.print("after\n")
    std.os.exit(0)
}
