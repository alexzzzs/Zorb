export struct ZToken {
    kind: i64,
    ptr: *u8,
    len: i64,
    line: i64,
    column: i64
}

export struct ZTokenList {
    ptr: *ZToken,
    len: i64,
    capacity: i64
}

export fn ZTokenList.init(allocator: *std.mem.HeapAllocator, initial_capacity: i64) !ZTokenList {
    list: ZTokenList = ZTokenList{
        ptr: cast(*ZToken, 0),
        len: 0,
        capacity: 0
    }

    if initial_capacity < 0 {
        return error.InvalidSize
    }

    if initial_capacity > 0 {
        raw: *u8 = std.mem.HeapAllocator.alloc(allocator, initial_capacity * Builtin.sizeof(ZToken)) catch |err| {
            return error.OutOfMemory
        }
        list.ptr = cast(*ZToken, raw)
        list.capacity = initial_capacity
    }

    return list
}

fn ztoken_next_capacity(current: i64, needed: i64) -> i64 {
    capacity: i64 = current
    if capacity < 64 {
        capacity = 64
    }

    while capacity < needed {
        capacity = capacity * 2
    }

    return capacity
}

export fn ZTokenList.reserve(self: *ZTokenList, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed < 0 {
        return error.InvalidSize
    }

    if needed <= self.capacity {
        return 0
    }

    new_capacity: i64 = ztoken_next_capacity(self.capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZToken)) catch |err| {
        return error.OutOfMemory
    }
    new_ptr: *ZToken = cast(*ZToken, raw)

    i: i64 = 0
    while i < self.len {
        new_ptr[i] = self.ptr[i]
        i = i + 1
    }

    self.ptr = new_ptr
    self.capacity = new_capacity
    return 0
}

export fn ZTokenList.append(self: *ZTokenList, allocator: *std.mem.HeapAllocator, token: ZToken) !i64 {
    ZTokenList.reserve(self, allocator, self.len + 1) catch |err| {
        if err == error.InvalidSize {
            return error.InvalidSize
        }
        return error.OutOfMemory
    }

    self.ptr[self.len] = token
    self.len = self.len + 1
    return 0
}
