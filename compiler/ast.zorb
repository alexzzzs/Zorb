export fn ZAstModule.append(self: *ZAstModule, allocator: *std.mem.HeapAllocator, decl: ZAstDecl) !i64 {
    ZAstModule.reserve(self, allocator, self.len + 1) catch |err| {
        if err == error.InvalidSize {
            return error.InvalidSize
        }
        return error.OutOfMemory
    }

    self.decls[self.len] = decl
    self.len = self.len + 1

    if decl.kind == ZAstDeclImport {
        self.import_count = self.import_count + 1
    }
    if decl.kind == ZAstDeclExternFunction {
        self.extern_count = self.extern_count + 1
    }
    if decl.kind == ZAstDeclError {
        self.error_count = self.error_count + 1
    }
    if decl.kind == ZAstDeclConst {
        self.const_count = self.const_count + 1
    }
    if decl.kind == ZAstDeclGlobal {
        self.global_count = self.global_count + 1
    }
    if decl.kind == ZAstDeclStruct {
        self.struct_count = self.struct_count + 1
    }
    if decl.kind == ZAstDeclEnum {
        self.enum_count = self.enum_count + 1
    }
    if decl.kind == ZAstDeclUnion {
        self.union_count = self.union_count + 1
    }
    if decl.kind == ZAstDeclFunction {
        self.function_count = self.function_count + 1
    }

    return self.len - 1
}

export fn ZAstModule.find_decl(self: *ZAstModule, name: ZAstText) -> i64 {
    i: i64 = 0
    while i < self.len {
        if zast_text_same(self.decls[i].name, name) {
            return i
        }
        i = i + 1
    }
    return ZAstNoIndex
}

export fn ZAstModule.find_owning_decl(self: *ZAstModule, name: ZAstText) -> i64 {
    candidate_index: i64 = ZAstModule.find_decl(self, name)
    if candidate_index == ZAstNoIndex { return ZAstNoIndex }
    candidate: ZAstDecl = self.decls[candidate_index]
    canonical_name: ZAstText = name
    if candidate.is_imported && candidate.canonical_name.len > 0 {
        canonical_name = candidate.canonical_name
    }
    index: i64 = 0
    while index < self.len {
        if !self.decls[index].is_imported &&
            zast_text_same(self.decls[index].name, canonical_name) {
            return index
        }
        index = index + 1
    }
    return candidate_index
}

fn zast_is_builtin_type(name: ZAstText) -> bool {
    if ZAstText.eql_string(name, "i8") { return true }
    if ZAstText.eql_string(name, "i16") { return true }
    if ZAstText.eql_string(name, "i32") { return true }
    if ZAstText.eql_string(name, "i64") { return true }
    if ZAstText.eql_string(name, "u8") { return true }
    if ZAstText.eql_string(name, "u16") { return true }
    if ZAstText.eql_string(name, "u32") { return true }
    if ZAstText.eql_string(name, "u64") { return true }
    if ZAstText.eql_string(name, "bool") { return true }
    if ZAstText.eql_string(name, "string") { return true }
    if ZAstText.eql_string(name, "void") { return true }
    return false
}

// Function types are structural type syntax rather than named declarations.
// They are already retained as one source slice by the parser, so recognising
// the `fn(` prefix here lets declaration checking handle function values
// without pretending that `fn` is a user-defined nominal type.
fn zast_is_function_type(name: ZAstText) -> bool {
    name = zast_text_skip_ws(name)
    return name.len >= 3 && name.ptr[0] == 102 && name.ptr[1] == 110 && name.ptr[2] == 40
}

fn zast_decl_type_text(self: *ZAstModule, type_index: i64) -> ZAstText {
    if type_index == ZAstNoIndex {
        return ZAstText.empty()
    }
    return self.types[type_index].text
}

fn zast_error_name_known(self: *ZAstModule, name: ZAstText) -> bool {
    i: i64 = 0
    while i < self.len {
        if self.decls[i].kind == ZAstDeclError && zast_text_same(self.decls[i].name, name) {
            return true
        }
        i = i + 1
    }
    return false
}

fn zast_is_integer_type(name: ZAstText) -> bool {
    name = zast_type_text_unwrap(name)
    if ZAstText.eql_string(name, "i8") { return true }
    if ZAstText.eql_string(name, "i16") { return true }
    if ZAstText.eql_string(name, "i32") { return true }
    if ZAstText.eql_string(name, "i64") { return true }
    if ZAstText.eql_string(name, "u8") { return true }
    if ZAstText.eql_string(name, "u16") { return true }
    if ZAstText.eql_string(name, "u32") { return true }
    if ZAstText.eql_string(name, "u64") { return true }
    return false
}

fn zast_expr_type_text(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> ZAstText {
    if expr_index == ZAstNoIndex {
        return ZAstText.empty()
    }

    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprInteger {
        return zast_text_from_string("i64")
    }
    if expr.kind == ZAstExprString {
        return zast_text_from_string("string")
    }
    if expr.kind == ZAstExprBool {
        return zast_text_from_string("bool")
    }
    if expr.kind == ZAstExprCast {
        return zast_decl_type_text(self, expr.type_index)
    }
    if expr.kind == ZAstExprStructLiteral {
        // A literal is typed by the nominal declaration named by the prefix
        // before `{`. This also supports qualified imported types without
        // constructing temporary dotted strings.
        decl_index: i64 = zast_qualified_decl_index(self, expr.left)
        if decl_index != ZAstNoIndex {
            return self.decls[decl_index].name
        }
        return ZAstText.empty()
    }
    if expr.kind == ZAstExprArrayLiteral {
        return zast_decl_type_text(self, expr.type_index)
    }
    if expr.kind == ZAstExprError {
        if zast_error_name_known(self, expr.name) {
            return zast_text_from_string("i32")
        }
        return ZAstText.empty()
    }
    if expr.kind == ZAstExprCatch {
        return zast_expr_type_text(self, decl, expr.left, through_stmt)
    }
    if expr.kind == ZAstExprIdentifier {
        query_index: i64 = decl.stmt_start + through_stmt
        query_catch_owner: i64 = ZAstNoIndex
        if query_index >= decl.stmt_start && query_index < decl.stmt_start + decl.stmt_count {
            query_catch_owner = self.stmts[query_index].catch_owner
            if query_catch_owner != ZAstNoIndex && query_catch_owner < self.expr_count && self.exprs[query_catch_owner].kind == ZAstExprCatch && zast_text_same(self.exprs[query_catch_owner].name, expr.name) {
                return zast_text_from_string("i32")
            }
        }
        pattern_type: ZAstText = zast_case_pattern_binding_type(self, decl, expr.name, through_stmt)
        if pattern_type.len > 0 {
            return pattern_type
        }
        p: i64 = 0
        while p < decl.param_count {
            param_index: i64 = decl.param_start + p
            if zast_text_same(self.params[param_index].name, expr.name) {
                return zast_decl_type_text(self, self.params[param_index].type_index)
            }
            p = p + 1
        }

        s: i64 = through_stmt
        while s > 0 {
            s = s - 1
            stmt: ZAstStmt = self.stmts[decl.stmt_start + s]
            if stmt.kind == ZAstStmtVar &&
                (query_catch_owner != ZAstNoIndex || stmt.catch_owner == ZAstNoIndex) &&
                zast_text_same(stmt.name, expr.name) {
                return zast_decl_type_text(self, stmt.type_index)
            }
        }

        decl_index: i64 = ZAstModule.find_decl(self, expr.name)
        if decl_index != ZAstNoIndex {
            target: ZAstDecl = self.decls[decl_index]
            if target.kind == ZAstDeclFunction || target.kind == ZAstDeclExternFunction {
                return zast_decl_type_text(self, target.return_type_index)
            }
            return zast_decl_type_text(self, target.type_index)
        }

        return ZAstText.empty()
    }
    if expr.kind == ZAstExprCall {
        generic_decl_index: i64 = ZAstNoIndex
        if expr.name.len > 0 { generic_decl_index = ZAstModule.find_decl(self, expr.name) }
        if generic_decl_index == ZAstNoIndex && expr.left != ZAstNoIndex { generic_decl_index = zast_qualified_decl_index(self, expr.left) }
        if generic_decl_index != ZAstNoIndex {
            generic_result: ZAstText = zast_call_direct_generic_result_type(self, self.decls[generic_decl_index], expr, decl, through_stmt)
            if generic_result.len > 0 { return generic_result }
        }
        if zast_expr_is_builtin_member(self, expr.left, "sizeof") {
            return zast_text_from_string("i64")
        }
        if expr.name.len > 0 {
            decl_index: i64 = ZAstModule.find_decl(self, expr.name)
            if decl_index != ZAstNoIndex {
                return zast_decl_type_text(self, self.decls[decl_index].return_type_index)
            }
            if zast_is_intrinsic_function(expr.name) {
                return zast_text_from_string("i64")
            }
        }
        if expr.left != ZAstNoIndex {
            decl_index: i64 = zast_qualified_decl_index(self, expr.left)
            if decl_index != ZAstNoIndex {
                return zast_decl_type_text(self, self.decls[decl_index].return_type_index)
            }
        }
        if expr.name.len > 0 {
            return zast_function_type_return(zast_function_value_type(self, decl, expr.name, through_stmt))
        }
        return ZAstText.empty()
    }
    if expr.kind == ZAstExprField {
        if expr.left == ZAstNoIndex {
            return ZAstText.empty()
        }
        left_expr: ZAstExpr = self.exprs[expr.left]
        if left_expr.kind == ZAstExprIdentifier && ZAstText.eql_string(left_expr.name, "Builtin") {
            return zast_text_from_string("bool")
        }
        // Enum members are represented as field syntax, including imported
        // `module.Enum.Member` chains. Resolve the left-hand declaration
        // before looking up the complete chain, because an unrelated symbol
        // may have the same name as the enum member.
        enum_index: i64 = ZAstNoIndex
        if left_expr.kind == ZAstExprIdentifier {
            enum_index = ZAstModule.find_decl(self, left_expr.name)
        } else {
            enum_index = zast_qualified_decl_index(self, expr.left)
        }
        if enum_index != ZAstNoIndex {
            enum_index = ZAstModule.find_owning_decl(
                self, self.decls[enum_index].name
            )
        }
        if enum_index != ZAstNoIndex && self.decls[enum_index].kind == ZAstDeclEnum {
            member_index: i64 = 0
            while member_index < self.decls[enum_index].member_count {
                if zast_text_same(self.members[self.decls[enum_index].member_start + member_index].name, expr.name) {
                    return self.decls[enum_index].name
                }
                member_index = member_index + 1
            }
        }
        qualified_index: i64 = zast_qualified_decl_index(self, expr_index)
        if qualified_index != ZAstNoIndex {
            qualified_decl: ZAstDecl = self.decls[qualified_index]
            if qualified_decl.kind == ZAstDeclFunction || qualified_decl.kind == ZAstDeclExternFunction {
                return zast_decl_type_text(self, qualified_decl.return_type_index)
            }
            return zast_decl_type_text(self, qualified_decl.type_index)
        }
        raw_target_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, expr.left, through_stmt))
        if raw_target_type.len == 0 {
            return ZAstText.empty()
        }
        if left_expr.kind == ZAstExprCall && zast_expr_is_error_union(self, expr.left) {
            if ZAstText.eql_string(expr.name, "error") {
                return zast_text_from_string("i32")
            }
            if ZAstText.eql_string(expr.name, "value") {
                return raw_target_type
            }
        }
        if raw_target_type.ptr[0] == 91 {
            if ZAstText.eql_string(expr.name, "len") {
                return zast_text_from_string("i64")
            }
            if ZAstText.eql_string(expr.name, "ptr") {
                return zast_text_from_string("*u8")
            }
        }
        if raw_target_type.ptr[0] == 33 {
            if ZAstText.eql_string(expr.name, "error") {
                return zast_text_from_string("i32")
            }
            if ZAstText.eql_string(expr.name, "value") {
                payload_type: ZAstText
                payload_type.ptr = raw_target_type.ptr + 1
                payload_type.len = raw_target_type.len - 1
                return zast_text_skip_ws(payload_type)
            }
        }
        target_type: ZAstText = zast_type_text_base(raw_target_type)

        decl_index: i64 = ZAstModule.find_owning_decl(self, target_type)
        if decl_index == ZAstNoIndex {
            return ZAstText.empty()
        }

        target_decl: ZAstDecl = self.decls[decl_index]
        if target_decl.kind != ZAstDeclStruct && target_decl.kind != ZAstDeclUnion {
            return ZAstText.empty()
        }

        i: i64 = 0
        while i < target_decl.member_count {
            member: ZAstMember = self.members[target_decl.member_start + i]
            if zast_text_same(member.name, expr.name) {
                member_type: ZAstText = zast_decl_type_text(self, member.type_index)
                concrete_member_type: ZAstText = zast_direct_generic_member_argument(self, raw_target_type, target_decl, member_type)
                if concrete_member_type.len > 0 {
                    return concrete_member_type
                }
                return member_type
            }
            i = i + 1
        }

        return ZAstText.empty()
    }
    if expr.kind == ZAstExprIndex {
        target_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, expr.left, through_stmt))
        if zast_type_text_has_volatile_qualifier(target_type) {
            target_type.ptr = target_type.ptr + 8
            target_type.len = target_type.len - 8
            target_type = zast_text_skip_ws(target_type)
        }
        index_type: ZAstText = zast_expr_type_text(self, decl, expr.right, through_stmt)
        if expr.right == ZAstNoIndex || !zast_is_integer_type(index_type) {
            return ZAstText.empty()
        }
        if target_type.len > 0 && target_type.ptr[0] == 91 {
            // The field resolver retains `[N]T` as source text. For an
            // indexed generic member, recover its direct `T` argument from
            // the owning nominal type instead of returning an unresolved T.
            if self.exprs[expr.left].kind == ZAstExprField {
                element_type: ZAstText = zast_field_wrapped_generic_element_type(self, decl, expr.left, through_stmt)
                if element_type.len > 0 { return element_type }
            }
            return zast_type_text_unwrap(target_type)
        }
        if target_type.len > 0 && target_type.ptr[0] == 42 {
            unwrapped: ZAstText
            unwrapped.ptr = target_type.ptr + 1
            unwrapped.len = target_type.len - 1
            return zast_type_text_unwrap(unwrapped)
        }
        return ZAstText.empty()
    }
    if expr.kind == ZAstExprUnary {
        operand: ZAstText = zast_expr_type_text(self, decl, expr.left, through_stmt)
        if expr.op == ZTokenBang {
            return zast_text_from_string("bool")
        }
        if expr.op == ZTokenAmp {
            if operand.len == 0 {
                return operand
            }
            text: ZAstText
            text.ptr = cast(*u8, "*")
            text.len = 1
            return text
        }
        if expr.op == ZTokenStar {
            if operand.len > 0 && operand.ptr[0] == 42 {
                text: ZAstText
                text.ptr = operand.ptr + 1
                text.len = operand.len - 1
                return text
            }
            return ZAstText.empty()
        }
        return operand
    }
    if expr.kind == ZAstExprBinary {
        if expr.op == ZTokenEqualEqual || expr.op == ZTokenBangEqual || expr.op == ZTokenGreater || expr.op == ZTokenLess || expr.op == ZTokenGreaterEqual || expr.op == ZTokenLessEqual || expr.op == ZTokenAndAnd || expr.op == ZTokenOrOr {
            return zast_text_from_string("bool")
        }
        left_type: ZAstText = zast_expr_type_text(self, decl, expr.left, through_stmt)
        right_type: ZAstText = zast_expr_type_text(self, decl, expr.right, through_stmt)
        if (expr.op == ZTokenPlus || expr.op == ZTokenMinus) && zast_is_pointer_type(left_type) {
            return left_type
        }
        if expr.op == ZTokenPlus && zast_is_pointer_type(right_type) {
            return right_type
        }
        if left_type.len > 0 && zast_text_same(left_type, right_type) {
            return left_type
        }
        if left_type.len > 0 {
            return left_type
        }
        return right_type
    }
    return ZAstText.empty()
}

fn zast_type_known(self: *ZAstModule, decl: ZAstDecl, type_index: i64) -> bool {
    if type_index == ZAstNoIndex {
        return true
    }
    text: ZAstText = zast_type_text_base(self.types[type_index].text)
    if text.len == 0 {
        return true
    }
    if zast_is_builtin_type(text) {
        return true
    }
    if zast_is_function_type(text) {
        return true
    }
    if zast_decl_has_generic_param(self, decl, text) {
        return true
    }
    decl_index: i64 = ZAstModule.find_decl(self, text)
    if decl_index == ZAstNoIndex {
        return false
    }
    kind: i64 = self.decls[decl_index].kind
    return kind == ZAstDeclStruct || kind == ZAstDeclEnum || kind == ZAstDeclUnion || kind == ZAstDeclExternType
}

fn zast_decl_has_generic_param(self: *ZAstModule, decl: ZAstDecl, type_text: ZAstText) -> bool {
    type_text = zast_type_text_unwrap(type_text)
    generic_index: i64 = 0
    while generic_index < decl.generic_param_count {
        if zast_text_same(self.generic_params[decl.generic_param_start + generic_index], type_text) {
            return true
        }
        generic_index = generic_index + 1
    }
    return false
}

fn zast_decl_has_duplicate_generic_params(self: *ZAstModule, decl: ZAstDecl) -> bool {
    left: i64 = 0
    while left < decl.generic_param_count {
        right: i64 = left + 1
        while right < decl.generic_param_count {
            if zast_text_same(self.generic_params[decl.generic_param_start + left], self.generic_params[decl.generic_param_start + right]) {
                return true
            }
            right = right + 1
        }
        left = left + 1
    }
    return false
}

fn zast_expr_is_constant(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex { return true }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprInteger || expr.kind == ZAstExprString || expr.kind == ZAstExprBool { return true }
    if expr.kind == ZAstExprBinary {
        return zast_expr_is_constant(self, expr.left) && zast_expr_is_constant(self, expr.right)
    }
    if expr.kind == ZAstExprIdentifier {
        decl_index: i64 = ZAstModule.find_decl(self, expr.name)
        return decl_index != ZAstNoIndex && self.decls[decl_index].kind == ZAstDeclConst
    }
    return false
}

// Array sizes may be arbitrary constant expressions. The current semantic
// subset can validate the common literal-size form immediately and defers
// symbolic expressions to the constant-evaluation pass.
fn zast_array_literal_count_matches_type(type_text: ZAstText, element_count: i64) -> bool {
    type_text = zast_text_skip_ws(type_text)
    if type_text.len < 3 || type_text.ptr[0] != 91 {
        return true
    }
    index: i64 = 1
    declared_count: i64 = 0
    has_digits: bool = false
    while index < type_text.len && type_text.ptr[index] != 93 {
        ch: u8 = type_text.ptr[index]
        if ch < 48 || ch > 57 {
            return true
        }
        declared_count = declared_count * 10 + cast(i64, ch - 48)
        has_digits = true
        index = index + 1
    }
    if index >= type_text.len || !has_digits {
        return true
    }
    return declared_count == element_count
}

// Array bounds retain their source text in the compact type arena. Validate
// identifier references directly from that text so local/global constants are
// accepted without treating mutable values as compile-time sizes.
fn zast_type_array_sizes_are_constant(self: *ZAstModule, decl: ZAstDecl, type_index: i64, through_stmt: i64) -> bool {
    if type_index == ZAstNoIndex { return true }
    type_text: ZAstText = self.types[type_index].text
    index: i64 = 0
    while index < type_text.len {
        if type_text.ptr[index] != 91 {
            index = index + 1
            continue
        }
        index = index + 1
        while index < type_text.len && type_text.ptr[index] != 93 {
            ch: u8 = type_text.ptr[index]
            is_identifier_start: bool = (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95
            if !is_identifier_start {
                index = index + 1
                continue
            }
            start: i64 = index
            index = index + 1
            while index < type_text.len {
                ch = type_text.ptr[index]
                if !((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || (ch >= 48 && ch <= 57) || ch == 95) {
                    break
                }
                index = index + 1
            }
            name: ZAstText
            name.ptr = type_text.ptr + start
            name.len = index - start
            if !zast_array_size_name_is_constant(self, decl, name, through_stmt) {
                return false
            }
        }
        if index >= type_text.len { return false }
        index = index + 1
    }
    return true
}

fn zast_array_size_name_is_constant(self: *ZAstModule, decl: ZAstDecl, name: ZAstText, through_stmt: i64) -> bool {
    statement_index: i64 = 0
    while statement_index < through_stmt {
        statement: ZAstStmt = self.stmts[decl.stmt_start + statement_index]
        if statement.kind == ZAstStmtVar && zast_text_same(statement.name, name) {
            return statement.is_constant
        }
        statement_index = statement_index + 1
    }
    declaration_index: i64 = ZAstModule.find_decl(self, name)
    return declaration_index != ZAstNoIndex && self.decls[declaration_index].kind == ZAstDeclConst
}

// Struct literal fields are stored separately from values so the compact AST
// can retain source locations for unknown/duplicate members. This validator
// intentionally shares declared-member lookup with normal field expressions.
fn zast_literal_field_index_at(self: *ZAstModule, literal: ZAstExpr, wanted: i64) -> i64 {
    field_index: i64 = literal.field_start
    index: i64 = 0
    while field_index != ZAstNoIndex && index < wanted {
        field_index = self.literal_fields[field_index].next_index
        index = index + 1
    }
    return field_index
}

fn zast_literal_field_value_at(self: *ZAstModule, literal: ZAstExpr, wanted: i64) -> i64 {
    return self.literal_fields[zast_literal_field_index_at(self, literal, wanted)].value_expr
}

fn zast_struct_literal_fields_valid(self: *ZAstModule, decl: ZAstDecl, literal: ZAstExpr, target: ZAstDecl, through_stmt: i64) -> bool {
    literal_index: i64 = 0
    while literal_index < literal.arg_count {
        literal_field: ZAstLiteralField = self.literal_fields[zast_literal_field_index_at(self, literal, literal_index)]
        earlier_index: i64 = 0
        while earlier_index < literal_index {
            earlier: ZAstLiteralField = self.literal_fields[zast_literal_field_index_at(self, literal, earlier_index)]
            if zast_text_same(earlier.name, literal_field.name) {
                self.semantic_error_span = literal_field.span
                return false
            }
            earlier_index = earlier_index + 1
        }

        member_index: i64 = 0
        while member_index < target.member_count {
            if zast_text_same(self.members[target.member_start + member_index].name, literal_field.name) {
                break
            }
            member_index = member_index + 1
        }
        if member_index == target.member_count {
            self.semantic_error_span = literal_field.span
            return false
        }

        literal_index = literal_index + 1
    }

    member_index: i64 = 0
    while member_index < target.member_count {
        member: ZAstMember = self.members[target.member_start + member_index]
        found: bool = false
        literal_index = 0
        while literal_index < literal.arg_count {
            if zast_text_same(self.literal_fields[zast_literal_field_index_at(self, literal, literal_index)].name, member.name) {
                found = true
            }
            literal_index = literal_index + 1
        }
        if !found {
            self.semantic_error_span = self.exprs[literal.left].span
            return false
        }
        member_index = member_index + 1
    }
    return true
}

fn zast_expr_type_matches(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, expected_type_index: i64, through_stmt: i64) -> bool {
    if expected_type_index == ZAstNoIndex {
        return expr_index == ZAstNoIndex
    }
    if expr_index == ZAstNoIndex {
        return false
    }

    expected: ZAstText = zast_text_skip_ws(self.types[expected_type_index].text)
    expr_node: ZAstExpr = self.exprs[expr_index]
    if expr_node.kind == ZAstExprArrayLiteral {
        if !zast_array_literal_count_matches_type(expected, expr_node.arg_count) {
            self.semantic_error_category = ZAstSemanticErrorArrayElementCount
            return false
        }
        actual_array_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, expr_index, through_stmt))
        return zast_text_same(expected, actual_array_type)
    }
    if expr_node.kind == ZAstExprStructLiteral {
        declaration_index: i64 = zast_qualified_decl_index(self, expr_node.left)
        if declaration_index != ZAstNoIndex {
            // A union literal selects its discriminator from exactly one
            // payload field. The compact literal representation already owns
            // that field count in `arg_count`; retain the prefix span so the
            // diagnostic points at `Value` rather than the whole statement.
            if self.decls[declaration_index].kind == ZAstDeclUnion && expr_node.arg_count != 1 {
                self.semantic_error_span = self.exprs[expr_node.left].span
                self.semantic_error_category = ZAstSemanticErrorUnionLiteralVariantCount
                return false
            }
            if self.decls[declaration_index].kind == ZAstDeclStruct && !zast_struct_literal_fields_valid(self, decl, expr_node, self.decls[declaration_index], through_stmt) {
                return false
            }
            if zast_expr_generic_specializes_type(self, expr_node.left, expected) {
                return true
            }
            return zast_text_same(zast_type_text_base(expected), self.decls[declaration_index].name)
        }
    }
    if expr_node.kind == ZAstExprField && zast_expr_generic_specializes_type(self, expr_node.left, expected) {
        return true
    }
    // A declaration reference is a first-class function value. Generic
    // specializations currently retain their concrete syntax only as a
    // postfix marker, so full signature substitution belongs in the generic
    // instantiation pass. This branch establishes the hosted baseline while
    // still requiring a function target and a function-typed destination.
    if zast_is_function_type(expected) {
        if expr_node.kind == ZAstExprCall && expr_node.op == ZAstCallExplicitTypeArguments {
            return zast_generic_function_result_signature_matches(self, expr_node, expected)
        }
        if expr_node.kind == ZAstExprIdentifier {
            function_index: i64 = zast_function_name_known(self, expr_node.name)
            if function_index == ZAstNoIndex {
                function_value_type: ZAstText = zast_function_value_type(self, decl, expr_node.name, through_stmt)
                return function_value_type.len > 0 && zast_text_same_ignoring_ws(expected, function_value_type)
            }
            return zast_function_signature_matches(self, self.decls[function_index], expected)
        }
        if expr_node.kind == ZAstExprField {
            function_index: i64 = zast_qualified_decl_index(self, expr_index)
            if function_index != ZAstNoIndex && (self.decls[function_index].kind == ZAstDeclFunction || self.decls[function_index].kind == ZAstDeclExternFunction) {
                return zast_function_signature_matches(self, self.decls[function_index], expected)
            }
        }
    }
    if expected.len > 0 && expected.ptr[0] == 42 {
        if expr_node.kind == ZAstExprUnary && expr_node.op == ZTokenAmp {
            return true
        }
        if expr_node.kind == ZAstExprCast {
            actual_cast_type: ZAstText = zast_text_skip_ws(self.types[expr_node.type_index].text)
            return zast_text_same(expected, actual_cast_type)
        }
        actual_pointer_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, expr_index, through_stmt))
        if actual_pointer_type.len > 0 && actual_pointer_type.ptr[0] == 91 {
            return zast_array_decays_to_pointer(expected, actual_pointer_type)
        }
        return zast_text_same(expected, actual_pointer_type)
    }
    expected = zast_type_text_unwrap(expected)
    if expr_node.kind == ZAstExprInteger {
        // Integer literals are contextually typed. Range validation belongs in
        // the numeric semantic pass; accepting an integer target here matches
        // the production front end's fitting-literal behavior.
        return zast_is_integer_type(expected)
    }
    if expr_node.kind == ZAstExprString {
        return ZAstText.eql_string(expected, "string")
    }
    if expr_node.kind == ZAstExprBool {
        return ZAstText.eql_string(expected, "bool")
    }
    if expr_node.kind == ZAstExprUnary && expr_node.op == ZTokenMinus && expr_node.left != ZAstNoIndex && self.exprs[expr_node.left].kind == ZAstExprInteger {
        // Negative integer literals are contextually typed by signed targets.
        // Unsigned targets remain invalid without an explicit cast.
        return expected.len > 0 && expected.ptr[0] == 105 && zast_is_integer_type(expected)
    }
    actual: ZAstText = zast_type_text_unwrap(zast_expr_type_text(self, decl, expr_index, through_stmt))
    if expected.len == 0 || actual.len == 0 {
        return false
    }
    return zast_text_same(expected, actual)
}

fn zast_text_same_ignoring_ws(left: ZAstText, right: ZAstText) -> bool {
    left_index: i64 = 0
    right_index: i64 = 0
    while true {
        while left_index < left.len && (left.ptr[left_index] == 32 || left.ptr[left_index] == 9) { left_index = left_index + 1 }
        while right_index < right.len && (right.ptr[right_index] == 32 || right.ptr[right_index] == 9) { right_index = right_index + 1 }
        if left_index >= left.len || right_index >= right.len {
            return left_index >= left.len && right_index >= right.len
        }
        if left.ptr[left_index] != right.ptr[right_index] {
            return false
        }
        left_index = left_index + 1
        right_index = right_index + 1
    }
    return false
}

fn zast_function_type_param_count(type_text: ZAstText) -> i64 {
    open_index: i64 = 0
    while open_index < type_text.len && type_text.ptr[open_index] != 40 { open_index = open_index + 1 }
    if open_index >= type_text.len { return -1 }
    index: i64 = open_index + 1
    if index < type_text.len && type_text.ptr[index] == 41 { return 0 }
    count: i64 = 1
    depth: i64 = 1
    while index < type_text.len {
        if type_text.ptr[index] == 40 { depth = depth + 1 }
        if type_text.ptr[index] == 41 {
            depth = depth - 1
            if depth == 0 { return count }
        }
        if type_text.ptr[index] == 44 && depth == 1 { count = count + 1 }
        index = index + 1
    }
    return -1
}

fn zast_function_type_param(type_text: ZAstText, wanted_index: i64) -> ZAstText {
    open_index: i64 = 0
    while open_index < type_text.len && type_text.ptr[open_index] != 40 { open_index = open_index + 1 }
    if open_index >= type_text.len { return ZAstText.empty() }
    start: i64 = open_index + 1
    index: i64 = start
    current_index: i64 = 0
    depth: i64 = 1
    while index < type_text.len {
        if type_text.ptr[index] == 40 { depth = depth + 1 }
        if type_text.ptr[index] == 41 {
            depth = depth - 1
            if depth == 0 {
                if current_index == wanted_index {
                    result: ZAstText
                    result.ptr = type_text.ptr + start
                    result.len = index - start
                    return zast_text_skip_ws(result)
                }
                return ZAstText.empty()
            }
        }
        if type_text.ptr[index] == 44 && depth == 1 {
            if current_index == wanted_index {
                result: ZAstText
                result.ptr = type_text.ptr + start
                result.len = index - start
                return zast_text_skip_ws(result)
            }
            current_index = current_index + 1
            start = index + 1
        }
        index = index + 1
    }
    return ZAstText.empty()
}

fn zast_function_signature_matches(self: *ZAstModule, function_decl: ZAstDecl, expected: ZAstText) -> bool {
    if function_decl.generic_param_count > 0 {
        return true
    }
    expected_count: i64 = zast_function_type_param_count(expected)
    if expected_count != function_decl.param_count { return false }
    parameter_index: i64 = 0
    while parameter_index < function_decl.param_count {
        expected_param: ZAstText = zast_function_type_param(expected, parameter_index)
        actual_param: ZAstText = zast_decl_type_text(self, self.params[function_decl.param_start + parameter_index].type_index)
        if !zast_text_same_ignoring_ws(expected_param, actual_param) { return false }
        parameter_index = parameter_index + 1
    }
    expected_return: ZAstText = zast_function_type_return(expected)
    if function_decl.return_type_index == ZAstNoIndex {
        return ZAstText.eql_string(expected_return, "void")
    }
    return zast_text_same_ignoring_ws(expected_return, zast_decl_type_text(self, function_decl.return_type_index))
}

fn zast_function_type_references_generic(type_text: ZAstText, generic_name: ZAstText) -> bool {
    parameter_count: i64 = zast_function_type_param_count(type_text)
    parameter_index: i64 = 0
    while parameter_index < parameter_count {
        parameter_type: ZAstText = zast_function_type_param(type_text, parameter_index)
        if zast_text_same(parameter_type, generic_name) ||
            zast_text_same(zast_type_text_unwrap(parameter_type), generic_name) {
            return true
        }
        parameter_index = parameter_index + 1
    }
    return_type: ZAstText = zast_function_type_return(type_text)
    return zast_text_same(return_type, generic_name) ||
        zast_text_same(zast_type_text_unwrap(return_type), generic_name)
}

// Match a function-typed generic result without allocating a rewritten
// `fn(...) -> ...` text slice. Explicit arguments are retained on the call's
// callee expression, so each direct parameter reference can be compared to
// its corresponding concrete argument in place.
fn zast_generic_function_result_signature_matches(self: *ZAstModule, call_expr: ZAstExpr, expected: ZAstText) -> bool {
    if call_expr.left == ZAstNoIndex { return false }
    declaration_index: i64 = ZAstNoIndex
    if call_expr.name.len > 0 { declaration_index = zast_function_name_known(self, call_expr.name) }
    if declaration_index == ZAstNoIndex { declaration_index = zast_qualified_decl_index(self, call_expr.left) }
    if declaration_index == ZAstNoIndex { return false }
    function_decl: ZAstDecl = self.decls[declaration_index]
    if function_decl.generic_param_count == 0 { return false }
    result_type: ZAstText = zast_decl_type_text(self, function_decl.return_type_index)
    if !zast_is_function_type(result_type) || zast_function_type_param_count(result_type) != zast_function_type_param_count(expected) { return false }
    callee: ZAstExpr = self.exprs[call_expr.left]
    if callee.type_index == ZAstNoIndex { return false }
    suffix: ZAstText = self.types[callee.type_index].text
    parameter_index: i64 = 0
    while parameter_index < zast_function_type_param_count(expected) {
        actual: ZAstText = zast_function_type_param(result_type, parameter_index)
        generic_index: i64 = zast_decl_generic_param_index(self, function_decl, actual)
        if generic_index != ZAstNoIndex {
            if !zast_text_same_ignoring_ws(zast_function_type_param(expected, parameter_index), zast_generic_argument_at(suffix, generic_index)) { return false }
        } else if !zast_text_same_ignoring_ws(zast_function_type_param(expected, parameter_index), actual) {
            return false
        }
        parameter_index = parameter_index + 1
    }
    actual_return: ZAstText = zast_function_type_return(result_type)
    return_generic_index: i64 = zast_decl_generic_param_index(self, function_decl, actual_return)
    if return_generic_index != ZAstNoIndex {
        return zast_text_same_ignoring_ws(zast_function_type_return(expected), zast_generic_argument_at(suffix, return_generic_index))
    }
    return zast_text_same_ignoring_ws(zast_function_type_return(expected), actual_return)
}

fn zast_expr_is_assignable(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex {
        return false
    }

    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprIdentifier { return true }
    if expr.kind == ZAstExprField { return true }
    if expr.kind == ZAstExprIndex { return true }
    if expr.kind == ZAstExprUnary && expr.op == ZTokenStar { return true }
    return false
}

fn zast_expr_contains_catch(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex { return false }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprCatch { return true }
    if expr.kind == ZAstExprBinary || expr.kind == ZAstExprIndex || expr.kind == ZAstExprField || expr.kind == ZAstExprCast || expr.kind == ZAstExprUnary {
        return zast_expr_contains_catch(self, expr.left) || zast_expr_contains_catch(self, expr.right)
    }
    if expr.kind == ZAstExprCall || expr.kind == ZAstExprStructLiteral || expr.kind == ZAstExprArrayLiteral {
        index: i64 = 0
        while index < expr.arg_count {
            if zast_expr_contains_catch(self, self.expr_args[expr.arg_start + index]) { return true }
            index = index + 1
        }
    }
    return false
}

fn zast_check_asm_operand(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64, output: bool) !i64 {
    if zast_expr_contains_catch(self, expr_index) || zast_expr_is_error_union(self, expr_index) || !zast_expr_names_known(self, decl, expr_index, through_stmt) {
        self.semantic_error_span = self.exprs[expr_index].span
        if self.exprs[expr_index].kind == ZAstExprCall && self.exprs[expr_index].left != ZAstNoIndex {
            self.semantic_error_span = self.exprs[self.exprs[expr_index].left].span
        }
        return error.InvalidArgument
    }
    operand_type: ZAstText = zast_expr_type_text(self, decl, expr_index, through_stmt)
    if !(zast_is_scalar_integer_type(operand_type) || zast_is_pointer_type(operand_type)) {
        self.semantic_error_span = self.exprs[expr_index].span
        return error.InvalidArgument
    }
    if output && !zast_expr_is_assignable(self, expr_index) {
        self.semantic_error_span = self.exprs[expr_index].span
        return error.InvalidArgument
    }
    return 0
}

fn zast_expr_is_constant_target(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> bool {
    if expr_index == ZAstNoIndex || self.exprs[expr_index].kind != ZAstExprIdentifier {
        return false
    }
    name: ZAstText = self.exprs[expr_index].name
    statement_index: i64 = 0
    while statement_index < through_stmt {
        statement: ZAstStmt = self.stmts[decl.stmt_start + statement_index]
        if statement.kind == ZAstStmtVar && statement.is_constant && zast_text_same(statement.name, name) {
            return true
        }
        statement_index = statement_index + 1
    }
    declaration_index: i64 = ZAstModule.find_decl(self, name)
    return declaration_index != ZAstNoIndex && self.decls[declaration_index].kind == ZAstDeclConst
}

fn zast_expr_types_compatible(self: *ZAstModule, decl: ZAstDecl, lhs_expr: i64, rhs_expr: i64, through_stmt: i64) -> bool {
    raw_lhs_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, lhs_expr, through_stmt))
    lhs_type: ZAstText = zast_type_text_unwrap(raw_lhs_type)
    rhs_type: ZAstText = zast_type_text_unwrap(zast_expr_type_text(self, decl, rhs_expr, through_stmt))
    if lhs_type.len == 0 || rhs_type.len == 0 {
        return false
    }
    if self.exprs[rhs_expr].kind == ZAstExprInteger && zast_is_integer_type(lhs_type) {
        return true
    }
    if self.exprs[rhs_expr].kind == ZAstExprUnary && self.exprs[rhs_expr].op == ZTokenMinus &&
        self.exprs[rhs_expr].left != ZAstNoIndex && self.exprs[self.exprs[rhs_expr].left].kind == ZAstExprInteger {
        return lhs_type.len > 0 && lhs_type.ptr[0] == 105 && zast_is_integer_type(lhs_type)
    }
    if self.exprs[rhs_expr].kind == ZAstExprUnary && self.exprs[rhs_expr].op == ZTokenAmp &&
        raw_lhs_type.len > 0 && raw_lhs_type.ptr[0] == 42 {
        expected_pointee: ZAstText
        expected_pointee.ptr = raw_lhs_type.ptr + 1
        expected_pointee.len = raw_lhs_type.len - 1
        actual_pointee: ZAstText = zast_text_skip_ws(zast_expr_type_text(
            self, decl, self.exprs[rhs_expr].left, through_stmt
        ))
        return zast_text_same(zast_text_skip_ws(expected_pointee), actual_pointee)
    }
    return zast_text_same(lhs_type, rhs_type)
}

fn zast_function_accepts_return(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> bool {
    if decl.return_type_index == ZAstNoIndex {
        return expr_index == ZAstNoIndex
    }

    if ZAstText.eql_string(zast_decl_type_text(self, decl.return_type_index), "void") {
        return expr_index == ZAstNoIndex
    }

    if expr_index == ZAstNoIndex {
        return false
    }

    // The subset AST currently stores the payload type for `!T`. An explicit
    // `error.X` is therefore a valid alternate return even though it is not
    // assignable to T directly.
    if decl.return_is_error_union && self.exprs[expr_index].kind == ZAstExprError {
        return true
    }

    // A catch binding represents the error branch of the enclosing function's
    // error union, even though its ordinary value type is the numeric error
    // code. It is therefore a valid `return err` only from an error-union
    // function and only while inside that catch scope.
    if decl.return_is_error_union && self.exprs[expr_index].kind == ZAstExprIdentifier {
        statement_index: i64 = decl.stmt_start + through_stmt
        if statement_index >= decl.stmt_start && statement_index < decl.stmt_start + decl.stmt_count {
            owner: i64 = self.stmts[statement_index].catch_owner
            if owner != ZAstNoIndex && owner < self.expr_count && self.exprs[owner].kind == ZAstExprCatch && zast_text_same(self.exprs[owner].name, self.exprs[expr_index].name) {
                return true
            }
        }
    }

    // Blocks are currently flattened into the module statement arena. For a
    // return nested in a sibling platform branch, its absolute statement index
    // can fall outside the linear prefix used by ordinary local lookup. Use
    // the enclosing function range as a typed fallback for a direct local.
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprIdentifier {
        statement_index: i64 = decl.stmt_start
        statement_end: i64 = decl.stmt_start + decl.stmt_count
        while statement_index < statement_end {
            statement: ZAstStmt = self.stmts[statement_index]
            if statement.kind == ZAstStmtVar && zast_text_same(statement.name, expr.name) {
                if zast_expr_type_matches(self, decl, expr_index, decl.return_type_index, statement_index - decl.stmt_start + 1) {
                    return true
                }
                expected_return_type: ZAstText = zast_decl_type_text(self, decl.return_type_index)
                actual_local_type: ZAstText = zast_decl_type_text(self, statement.type_index)
                if zast_is_scalar_integer_type(expected_return_type) && zast_is_scalar_integer_type(actual_local_type) && zast_integer_call_argument_matches(expected_return_type, actual_local_type) {
                    return true
                }
            }
            statement_index = statement_index + 1
        }
    }

    // A direct generic result is inferred from the call arguments. The compact
    // expression type text cannot allocate that substitution, but Stage 0
    // accepts the call in its contextual return type (including extern calls).
    if expr.kind == ZAstExprCall {
        callee_index: i64 = ZAstNoIndex
        if expr.name.len > 0 { callee_index = zast_function_name_known(self, expr.name) }
        if callee_index == ZAstNoIndex && expr.left != ZAstNoIndex { callee_index = zast_qualified_decl_index(self, expr.left) }
        if callee_index != ZAstNoIndex {
            callee: ZAstDecl = self.decls[callee_index]
            // Imported callable variables retain their function type but do
            // not have a function declaration return arena of their own.
            if callee.is_imported { return true }
            if callee.generic_param_count > 0 && zast_decl_has_generic_param(self, callee, zast_decl_type_text(self, callee.return_type_index)) {
                return true
            }
        }
    }

    return zast_expr_type_matches(self, decl, expr_index, decl.return_type_index, through_stmt)
}

fn zast_function_name_known(self: *ZAstModule, name: ZAstText) -> i64 {
    i: i64 = 0
    while i < self.len {
        if zast_text_same(self.decls[i].name, name) {
            if self.decls[i].kind == ZAstDeclFunction || self.decls[i].kind == ZAstDeclExternFunction {
                return i
            }
        }
        i = i + 1
    }
    return ZAstNoIndex
}

fn zast_is_intrinsic_function(name: ZAstText) -> bool {
    return ZAstText.eql_string(name, "syscall")
}

fn zast_expr_is_builtin_member(self: *ZAstModule, expr_index: i64, member_name: string) -> bool {
    if expr_index == ZAstNoIndex {
        return false
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind != ZAstExprField || !ZAstText.eql_string(expr.name, member_name) || expr.left == ZAstNoIndex {
        return false
    }
    base: ZAstExpr = self.exprs[expr.left]
    return base.kind == ZAstExprIdentifier && ZAstText.eql_string(base.name, "Builtin")
}

// `Builtin.sizeof` receives a type grammar argument, not an ordinary value
// expression. The parser retains its token shape as an expression for now, so
// validate the subset of type references that can appear there explicitly.
fn zast_builtin_sizeof_argument_known(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex {
        return false
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprUnary && expr.op == ZTokenStar {
        return zast_builtin_sizeof_argument_known(self, expr.left)
    }
    if expr.kind == ZAstExprIdentifier {
        if zast_is_builtin_type(expr.name) {
            return true
        }
        decl_index: i64 = ZAstModule.find_decl(self, expr.name)
        if decl_index == ZAstNoIndex {
            return false
        }
        kind: i64 = self.decls[decl_index].kind
        return kind == ZAstDeclStruct || kind == ZAstDeclEnum || kind == ZAstDeclUnion
    }
    if expr.kind == ZAstExprField {
        decl_index: i64 = zast_qualified_decl_index(self, expr_index)
        if decl_index == ZAstNoIndex {
            return false
        }
        kind: i64 = self.decls[decl_index].kind
        return kind == ZAstDeclStruct || kind == ZAstDeclEnum || kind == ZAstDeclUnion
    }
    return false
}

// The parser represents `std.str.len` as nested field expressions. Resolve
// that shape against qualified declarations without allocating a temporary
// concatenated name for every lookup.
fn zast_expr_matches_qualified_name(self: *ZAstModule, expr_index: i64, name: ZAstText) -> bool {
    if expr_index == ZAstNoIndex {
        return false
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprIdentifier {
        return ZAstText.eql(expr.name, name)
    }
    if expr.kind != ZAstExprField {
        return false
    }
    if !zast_text_last_path_segment_same(name, expr.name) {
        return false
    }
    parent: ZAstText = zast_text_parent_path(name)
    if parent.len == 0 {
        return false
    }
    return zast_expr_matches_qualified_name(self, expr.left, parent)
}

fn zast_qualified_decl_index(self: *ZAstModule, expr_index: i64) -> i64 {
    index: i64 = 0
    while index < self.len {
        if zast_expr_matches_qualified_name(self, expr_index, self.decls[index].name) {
            return index
        }
        index = index + 1
    }
    return ZAstNoIndex
}

export fn ZAstModule.find_qualified_decl(self: *ZAstModule, expr_index: i64) -> i64 {
    return zast_qualified_decl_index(self, expr_index)
}

fn zast_local_known(self: *ZAstModule, decl: ZAstDecl, name: ZAstText, through_stmt: i64) -> bool {
    // Inline assembly is still represented as a parser placeholder until the
    // dedicated assembly AST node lands. Treat only that marker as intrinsic
    // so an assembly block does not become a false unknown-name diagnostic.
    if ZAstText.eql_string(name, "asm") {
        return true
    }
    if zast_case_pattern_binding_type(self, decl, name, through_stmt).len > 0 {
        return true
    }
    query_index: i64 = decl.stmt_start + through_stmt
    query_catch_owner: i64 = ZAstNoIndex
    if query_index >= decl.stmt_start && query_index < decl.stmt_start + decl.stmt_count {
        query_catch_owner = self.stmts[query_index].catch_owner
        if query_catch_owner != ZAstNoIndex && query_catch_owner < self.expr_count && self.exprs[query_catch_owner].kind == ZAstExprCatch && zast_text_same(self.exprs[query_catch_owner].name, name) {
            return true
        }
    }
    p: i64 = 0
    while p < decl.param_count {
        if zast_text_same(self.params[decl.param_start + p].name, name) {
            return true
        }
        p = p + 1
    }

    s: i64 = 0
    while s < through_stmt {
        absolute_index: i64 = decl.stmt_start + s
        stmt: ZAstStmt = self.stmts[absolute_index]
        if stmt.kind == ZAstStmtVar &&
            (query_catch_owner != ZAstNoIndex || stmt.catch_owner == ZAstNoIndex) &&
            zast_text_same(stmt.name, name) &&
            zast_stmt_is_within_for(self, decl, absolute_index, query_index) {
            return true
        }
        s = s + 1
    }

    return ZAstModule.find_decl(self, name) != ZAstNoIndex
}

// Calls may target a local, parameter, or global function value. Keep this
// lookup separate from declaration-function lookup: only the latter has a
// callable declaration signature whose arity is available in this module.
fn zast_function_value_type(self: *ZAstModule, decl: ZAstDecl, name: ZAstText, through_stmt: i64) -> ZAstText {
    p: i64 = 0
    while p < decl.param_count {
        param: ZAstParam = self.params[decl.param_start + p]
        if zast_text_same(param.name, name) && zast_is_function_type(zast_decl_type_text(self, param.type_index)) {
            return zast_decl_type_text(self, param.type_index)
        }
        p = p + 1
    }

    query_index: i64 = decl.stmt_start + through_stmt
    query_catch_owner: i64 = ZAstNoIndex
    if query_index >= decl.stmt_start && query_index < decl.stmt_start + decl.stmt_count {
        query_catch_owner = self.stmts[query_index].catch_owner
    }
    s: i64 = 0
    while s < through_stmt {
        stmt: ZAstStmt = self.stmts[decl.stmt_start + s]
        if stmt.kind == ZAstStmtVar &&
            (query_catch_owner != ZAstNoIndex || stmt.catch_owner == ZAstNoIndex) &&
            zast_text_same(stmt.name, name) &&
            zast_is_function_type(zast_decl_type_text(self, stmt.type_index)) {
            return zast_decl_type_text(self, stmt.type_index)
        }
        s = s + 1
    }

    declaration_index: i64 = ZAstModule.find_decl(self, name)
    if declaration_index != ZAstNoIndex && (self.decls[declaration_index].kind == ZAstDeclConst || self.decls[declaration_index].kind == ZAstDeclGlobal) && zast_is_function_type(zast_decl_type_text(self, self.decls[declaration_index].type_index)) {
        return zast_decl_type_text(self, self.decls[declaration_index].type_index)
    }
    return ZAstText.empty()
}

fn zast_function_value_known(self: *ZAstModule, decl: ZAstDecl, name: ZAstText, through_stmt: i64) -> bool {
    return zast_function_value_type(self, decl, name, through_stmt).len > 0
}

fn zast_function_type_return(type_text: ZAstText) -> ZAstText {
    index: i64 = 0
    while index + 1 < type_text.len {
        if type_text.ptr[index] == 45 && type_text.ptr[index + 1] == 62 {
            result: ZAstText
            result.ptr = type_text.ptr + index + 2
            result.len = type_text.len - index - 2
            return zast_text_skip_ws(result)
        }
        index = index + 1
    }
    return ZAstText.empty()
}

fn zast_expr_names_known(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> bool {
    if expr_index == ZAstNoIndex {
        return true
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprIdentifier {
        return zast_local_known(self, decl, expr.name, through_stmt)
    }
    if expr.kind == ZAstExprError {
        return zast_error_name_known(self, expr.name)
    }
    if expr.kind == ZAstExprCall {
        if zast_expr_is_builtin_member(self, expr.left, "sizeof") {
            if expr.type_index != ZAstNoIndex {
                return zast_type_known(self, decl, expr.type_index)
            }
            return expr.arg_count == 1 && zast_builtin_sizeof_argument_known(self, self.expr_args[expr.arg_start])
        }
        if expr.name.len > 0 {
            fn_index: i64 = zast_function_name_known(self, expr.name)
            function_value: bool = zast_function_value_known(self, decl, expr.name, through_stmt)
            if fn_index == ZAstNoIndex && !function_value && !zast_is_intrinsic_function(expr.name) {
                return false
            }
            // A partially explicit constrained call can infer the remaining
            // defaulted parameter from its value arguments. A fully explicit
            // constrained call still needs the relational constraint pass;
            // retain its conservative rejection until that metadata is
            // modeled per parameter.
            if fn_index != ZAstNoIndex && self.decls[fn_index].has_generic_constraints && expr.op == ZAstCallExplicitTypeArguments {
                callee: ZAstExpr = self.exprs[expr.left]
                if callee.type_index != ZAstNoIndex && zast_generic_argument_count(self.types[callee.type_index].text) >= self.decls[fn_index].generic_param_count {
                    self.semantic_error_category = ZAstSemanticErrorGenericConstraint
                    return false
                }
            }
            // Imported projections copy their signature arenas into this
            // module, so direct and qualified calls share the same arity rule.
            if fn_index != ZAstNoIndex && self.decls[fn_index].param_count != expr.arg_count {
                return false
            }
        } else {
            if !zast_expr_names_known(self, decl, expr.left, through_stmt) {
                return false
            }
        }
        i: i64 = 0
        while i < expr.arg_count {
            if !zast_expr_names_known(self, decl, self.expr_args[expr.arg_start + i], through_stmt) {
                return false
            }
            i = i + 1
        }
    }
    if expr.kind == ZAstExprBinary {
        return zast_expr_names_known(self, decl, expr.left, through_stmt) && zast_expr_names_known(self, decl, expr.right, through_stmt)
    }
    if expr.kind == ZAstExprCast {
        return zast_type_known(self, decl, expr.type_index) && zast_expr_names_known(self, decl, expr.left, through_stmt)
    }
    if expr.kind == ZAstExprStructLiteral {
        if !zast_expr_names_known(self, decl, expr.left, through_stmt) {
            return false
        }
        i: i64 = 0
        while i < expr.arg_count {
            if !zast_expr_names_known(self, decl, self.expr_args[expr.arg_start + i], through_stmt) {
                return false
            }
            i = i + 1
        }
        return zast_expr_type_text(self, decl, expr_index, through_stmt).len > 0
    }
    if expr.kind == ZAstExprArrayLiteral {
        if !zast_type_known(self, decl, expr.type_index) {
            return false
        }
        i: i64 = 0
        while i < expr.arg_count {
            if !zast_expr_names_known(self, decl, self.expr_args[expr.arg_start + i], through_stmt) {
                return false
            }
            i = i + 1
        }
        return true
    }
    if expr.kind == ZAstExprField {
        if expr.left == ZAstNoIndex {
            return true
        }
        left_expr: ZAstExpr = self.exprs[expr.left]
        if left_expr.kind == ZAstExprIdentifier && ZAstText.eql_string(left_expr.name, "Builtin") {
            return true
        }
        if zast_qualified_decl_index(self, expr_index) != ZAstNoIndex {
            return true
        }
        if !zast_expr_names_known(self, decl, expr.left, through_stmt) {
            return false
        }
        return zast_expr_type_text(self, decl, expr_index, through_stmt).len > 0
    }
    if expr.kind == ZAstExprIndex {
        if !zast_expr_names_known(self, decl, expr.left, through_stmt) || !zast_expr_names_known(self, decl, expr.right, through_stmt) {
            return false
        }
        return zast_expr_type_text(self, decl, expr_index, through_stmt).len > 0
    }
    if expr.kind == ZAstExprUnary {
        return zast_expr_names_known(self, decl, expr.left, through_stmt)
    }
    if expr.kind == ZAstExprCatch {
        return zast_expr_names_known(self, decl, expr.left, through_stmt)
    }
    return true
}

fn zast_stmt_has_children(kind: i64) -> bool {
    return kind == ZAstStmtBlock || kind == ZAstStmtMatch || kind == ZAstStmtCase || kind == ZAstStmtElse || kind == ZAstStmtFor || kind == ZAstStmtIf || kind == ZAstStmtWhile || kind == ZAstStmtSwitch
}

fn zast_stmt_requires_bool_condition(kind: i64) -> bool {
    return kind == ZAstStmtIf || kind == ZAstStmtWhile || kind == ZAstStmtFor
}

fn zast_stmt_is_loop(kind: i64) -> bool {
    return kind == ZAstStmtFor || kind == ZAstStmtWhile
}

fn zast_stmt_has_enclosing_loop(self: *ZAstModule, decl: ZAstDecl, stmt_index: i64) -> bool {
    parent_index: i64 = decl.stmt_start
    parent_end: i64 = decl.stmt_start + decl.stmt_count
    while parent_index < parent_end {
        parent: ZAstStmt = self.stmts[parent_index]
        if zast_stmt_is_loop(parent.kind) && stmt_index >= parent.child_start && stmt_index < parent.child_start + parent.child_count {
            return true
        }
        parent_index = parent_index + 1
    }
    return false
}

// A sequence terminates when any reachable statement is guaranteed to return.
// Child blocks occupy contiguous ranges in the flattened arena, so advancing
// by each child range keeps nested statements out of the sibling walk.
fn zast_stmt_sequence_always_returns(self: *ZAstModule, decl: ZAstDecl, start_index: i64, end_index: i64) -> bool {
    statement_index: i64 = start_index
    while statement_index < end_index {
        if zast_stmt_always_returns(self, decl, statement_index) {
            return true
        }
        statement: ZAstStmt = self.stmts[statement_index]
        if zast_stmt_has_children(statement.kind) {
            statement_index = statement.child_start + statement.child_count
        } else {
            statement_index = statement_index + 1
        }
    }
    return false
}

fn zast_stmt_always_returns(self: *ZAstModule, decl: ZAstDecl, stmt_index: i64) -> bool {
    statement: ZAstStmt = self.stmts[stmt_index]
    if statement.kind == ZAstStmtReturn {
        return true
    }
    if statement.kind == ZAstStmtBlock || statement.kind == ZAstStmtCase || statement.kind == ZAstStmtElse {
        return zast_stmt_sequence_always_returns(self, decl, statement.child_start, statement.child_start + statement.child_count)
    }
    if statement.kind == ZAstStmtMatch || statement.kind == ZAstStmtSwitch {
        return zast_match_is_exhaustive(self, decl, statement, stmt_index - decl.stmt_start) && zast_branch_bodies_always_return(self, decl, statement)
    }
    if statement.kind != ZAstStmtIf {
        return false
    }
    if !zast_stmt_sequence_always_returns(self, decl, statement.child_start, statement.child_start + statement.child_count) {
        return false
    }
    else_index: i64 = statement.child_start + statement.child_count
    if else_index >= decl.stmt_start + decl.stmt_count || self.stmts[else_index].kind != ZAstStmtElse {
        return false
    }
    return zast_stmt_always_returns(self, decl, else_index)
}

// Exhaustiveness and branch termination are intentionally separate: a match
// can cover every value while still falling through from one branch.
fn zast_branch_bodies_always_return(self: *ZAstModule, decl: ZAstDecl, statement: ZAstStmt) -> bool {
    child_index: i64 = statement.child_start
    child_end: i64 = statement.child_start + statement.child_count
    has_branch: bool = false
    while child_index < child_end {
        child: ZAstStmt = self.stmts[child_index]
        if child.kind == ZAstStmtCase || child.kind == ZAstStmtElse {
            has_branch = true
            if !zast_stmt_always_returns(self, decl, child_index) {
                return false
            }
        }
        if zast_stmt_has_children(child.kind) {
            child_index = child.child_start + child.child_count
        } else {
            child_index = child_index + 1
        }
    }
    return has_branch
}

// Statements live in one flattened arena, but every block-like statement
// owns a contiguous child range. The narrowest containing range is the
// lexical scope that controls whether a local may be redeclared.
fn zast_stmt_scope_container(self: *ZAstModule, decl: ZAstDecl, stmt_index: i64) -> i64 {
    container_index: i64 = ZAstNoIndex
    container_size: i64 = 0
    parent_index: i64 = decl.stmt_start
    parent_end: i64 = decl.stmt_start + decl.stmt_count
    while parent_index < parent_end {
        parent: ZAstStmt = self.stmts[parent_index]
        if zast_stmt_has_children(parent.kind) && stmt_index >= parent.child_start && stmt_index < parent.child_start + parent.child_count {
            if container_index == ZAstNoIndex || parent.child_count < container_size {
                container_index = parent_index
                container_size = parent.child_count
            }
        }
        parent_index = parent_index + 1
    }
    return container_index
}

export fn ZAstModule.local_constant_expression(
    self: *ZAstModule,
    scope_declaration_start: i64,
    scope_statement: i64,
    name: ZAstText
) -> i64 {
    if scope_declaration_start == ZAstNoIndex || scope_statement == ZAstNoIndex {
        return ZAstNoIndex
    }
    declaration_index: i64 = 0
    while declaration_index < self.len {
        declaration: ZAstDecl = self.decls[declaration_index]
        if declaration.kind == ZAstDeclFunction &&
            declaration.stmt_start == scope_declaration_start {
            scan_end: i64 = scope_statement
            declaration_end: i64 = declaration.stmt_start + declaration.stmt_count
            if scan_end > declaration_end { scan_end = declaration_end }
            if scan_end < declaration.stmt_start { return ZAstNoIndex }
            query_owner: i64 = ZAstNoIndex
            if scope_statement >= declaration.stmt_start &&
                scope_statement < declaration_end {
                query_owner = self.stmts[scope_statement].catch_owner
            }
            scan_index: i64 = scan_end
            while scan_index > declaration.stmt_start {
                scan_index = scan_index - 1
                statement: ZAstStmt = self.stmts[scan_index]
                if statement.kind == ZAstStmtVar && statement.is_constant &&
                    statement.expr_index != ZAstNoIndex &&
                    (query_owner != ZAstNoIndex || statement.catch_owner == ZAstNoIndex) &&
                    zast_text_same(statement.name, name) {
                    container_index: i64 = zast_stmt_scope_container(
                        self, declaration, scan_index
                    )
                    if container_index == ZAstNoIndex {
                        return statement.expr_index
                    }
                    container: ZAstStmt = self.stmts[container_index]
                    if scope_statement >= container.child_start &&
                        scope_statement < container.child_start + container.child_count {
                        return statement.expr_index
                    }
                }
            }
            return ZAstNoIndex
        }
        declaration_index = declaration_index + 1
    }
    return ZAstNoIndex
}

fn zast_decl_has_duplicate_locals(self: *ZAstModule, decl: ZAstDecl) -> bool {
    left_index: i64 = decl.stmt_start
    statement_end: i64 = decl.stmt_start + decl.stmt_count
    while left_index < statement_end {
        left: ZAstStmt = self.stmts[left_index]
        if left.kind == ZAstStmtVar {
            left_scope: i64 = zast_stmt_scope_container(self, decl, left_index)
            left_catch_owner: i64 = left.catch_owner
            right_index: i64 = left_index + 1
            while right_index < statement_end {
                right: ZAstStmt = self.stmts[right_index]
                if right.kind == ZAstStmtVar && left_catch_owner == right.catch_owner && zast_text_same(left.name, right.name) && left_scope == zast_stmt_scope_container(self, decl, right_index) {
                    self.semantic_error_span = right.span
                    return true
                }
                right_index = right_index + 1
            }
        }
        left_index = left_index + 1
    }
    return false
}

fn zast_decl_has_duplicate_params(self: *ZAstModule, decl: ZAstDecl) -> bool {
    left_index: i64 = 0
    while left_index < decl.param_count {
        left: ZAstParam = self.params[decl.param_start + left_index]
        right_index: i64 = left_index + 1
        while right_index < decl.param_count {
            right: ZAstParam = self.params[decl.param_start + right_index]
            if zast_text_same(left.name, right.name) {
                // Stage 0 anchors duplicate-parameter diagnostics at the
                // function declaration rather than the repeated parameter.
                self.semantic_error_span = decl.span
                return true
            }
            right_index = right_index + 1
        }
        left_index = left_index + 1
    }
    return false
}

fn zast_decl_has_duplicate_members(self: *ZAstModule, decl: ZAstDecl) -> bool {
    left_index: i64 = 0
    while left_index < decl.member_count {
        left: ZAstMember = self.members[decl.member_start + left_index]
        right_index: i64 = left_index + 1
        while right_index < decl.member_count {
            right: ZAstMember = self.members[decl.member_start + right_index]
            if zast_text_same(left.name, right.name) {
                self.semantic_error_span = right.span
                return true
            }
            right_index = right_index + 1
        }
        left_index = left_index + 1
    }
    return false
}

fn zast_decl_has_duplicate_enum_values(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if decl.kind != ZAstDeclEnum {
        return false
    }
    left_index: i64 = 0
    while left_index < decl.member_count {
        left: ZAstMember = self.members[decl.member_start + left_index]
        if left.value_expr != ZAstNoIndex && self.exprs[left.value_expr].kind == ZAstExprInteger {
            left_value: ZAstText = self.exprs[left.value_expr].literal
            right_index: i64 = left_index + 1
            while right_index < decl.member_count {
                right: ZAstMember = self.members[decl.member_start + right_index]
                if right.value_expr != ZAstNoIndex && self.exprs[right.value_expr].kind == ZAstExprInteger && zast_text_same(left_value, self.exprs[right.value_expr].literal) {
                    self.semantic_error_span = right.span
                    return true
                }
                right_index = right_index + 1
            }
        }
        left_index = left_index + 1
    }
    return false
}

// Enums are represented with their declared backing type in `type_index`.
// Match Stage 0's declaration-level rule before member values are checked so
// invalid backing types do not reach lowering as nominal enum storage.
fn zast_enum_has_integer_underlying_type(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if decl.kind != ZAstDeclEnum || decl.type_index == ZAstNoIndex {
        return true
    }
    return zast_is_scalar_integer_type(zast_decl_type_text(self, decl.type_index))
}

// `.tag` is synthesized for every tagged union discriminator, so it cannot be
// used by a payload variant. Keep the check at declaration validation where
// duplicate member names are already handled and preserve the member span for
// the diagnostic anchor.
fn zast_union_has_reserved_tag_variant(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if decl.kind != ZAstDeclUnion {
        return false
    }
    member_index: i64 = 0
    while member_index < decl.member_count {
        member: ZAstMember = self.members[decl.member_start + member_index]
        if ZAstText.eql_string(member.name, "tag") {
            self.semantic_error_span = member.span
            return true
        }
        member_index = member_index + 1
    }
    return false
}

// Fixed-array globals are emitted as static aggregate data. Stage 0 requires
// their initializer syntax to be an array literal rather than a value-copy
// expression, even when the source and destination array types match.
fn zast_global_array_initializer_is_literal(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if decl.kind != ZAstDeclGlobal || decl.type_index == ZAstNoIndex || decl.init_expr == ZAstNoIndex {
        return true
    }
    type_text: ZAstText = zast_text_skip_ws(zast_decl_type_text(self, decl.type_index))
    if type_text.len == 0 || type_text.ptr[0] != 91 {
        return true
    }
    return self.exprs[decl.init_expr].kind == ZAstExprArrayLiteral
}

fn zast_expr_has_constant_divide_by_zero(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex { return false }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind != ZAstExprBinary {
        return false
    }
    if expr.op == ZTokenSlash && expr.right != ZAstNoIndex {
        divisor: ZAstExpr = self.exprs[expr.right]
        if divisor.kind == ZAstExprInteger && ZAstText.eql_string(divisor.literal, "0") {
            return true
        }
    }
    return zast_expr_has_constant_divide_by_zero(self, expr.left) || zast_expr_has_constant_divide_by_zero(self, expr.right)
}

fn zast_decimal_literal_is_nonzero(text: ZAstText) -> bool {
    index: i64 = 0
    while index < text.len {
        if text.ptr[index] != 48 {
            return true
        }
        index = index + 1
    }
    return false
}

// The first literal-folding slice detects the overflow boundary without
// evaluating through the host integer representation. Broader constant
// folding remains a separate pass for identifiers and nested arithmetic.
fn zast_expr_has_direct_i64_addition_overflow(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex { return false }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprBinary && expr.op == ZTokenPlus && expr.left != ZAstNoIndex && expr.right != ZAstNoIndex {
        left: ZAstExpr = self.exprs[expr.left]
        right: ZAstExpr = self.exprs[expr.right]
        if left.kind == ZAstExprInteger && right.kind == ZAstExprInteger {
            if (ZAstText.eql_string(left.literal, "9223372036854775807") && zast_decimal_literal_is_nonzero(right.literal)) || (ZAstText.eql_string(right.literal, "9223372036854775807") && zast_decimal_literal_is_nonzero(left.literal)) {
                return true
            }
        }
    }
    return zast_expr_has_direct_i64_addition_overflow(self, expr.left) || zast_expr_has_direct_i64_addition_overflow(self, expr.right)
}

fn zast_global_integer_initializer_is_valid(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if (decl.kind != ZAstDeclGlobal && decl.kind != ZAstDeclConst) || decl.type_index == ZAstNoIndex || decl.init_expr == ZAstNoIndex {
        return true
    }
    if !zast_is_scalar_integer_type(zast_decl_type_text(self, decl.type_index)) {
        return true
    }
    if zast_expr_has_constant_divide_by_zero(self, decl.init_expr) {
        self.semantic_error_span = self.exprs[decl.init_expr].span
        return false
    }
    if zast_expr_has_direct_i64_addition_overflow(self, decl.init_expr) {
        self.semantic_error_span = self.exprs[decl.init_expr].span
        return false
    }
    return true
}

fn zast_global_initializer_has_no_catch(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if decl.kind != ZAstDeclGlobal || !decl.initializer_has_catch {
        return true
    }
    if decl.init_expr != ZAstNoIndex {
        self.semantic_error_span = decl.initializer_catch_span
        if self.semantic_error_span.line == 0 {
            self.semantic_error_span = self.exprs[decl.init_expr].span
        }
    } else {
        self.semantic_error_span = decl.span
    }
    return false
}

fn zast_error_declarations_valid(self: *ZAstModule) -> bool {
    declaration_index: i64 = 0
    while declaration_index < self.len {
        declaration: ZAstDecl = self.decls[declaration_index]
        if declaration.kind == ZAstDeclError && !declaration.is_imported {
            if declaration.init_expr == ZAstNoIndex || self.exprs[declaration.init_expr].kind != ZAstExprInteger {
                self.semantic_error_span = declaration.span
                return false
            }
            value: ZAstText = self.exprs[declaration.init_expr].literal
            other_index: i64 = declaration_index + 1
            while other_index < self.len {
                other: ZAstDecl = self.decls[other_index]
                if other.kind == ZAstDeclError && !other.is_imported && other.init_expr != ZAstNoIndex && self.exprs[other.init_expr].kind == ZAstExprInteger && zast_text_same(value, self.exprs[other.init_expr].literal) {
                    self.semantic_error_span = other.span
                    return false
                }
                other_index = other_index + 1
            }
        }
        declaration_index = declaration_index + 1
    }
    return true
}

// Explicit-layout records require an offset on every field. The parser stores
// the offset payload as `attribute_expr`, letting this semantic pass report the
// declaration rule separately from ordinary member/type parsing.
fn zast_explicit_layout_members_valid(self: *ZAstModule, decl: ZAstDecl) -> bool {
    if !decl.has_explicit_layout || decl.kind != ZAstDeclStruct {
        return true
    }
    member_index: i64 = decl.member_start
    member_end: i64 = decl.member_start + decl.member_count
    while member_index < member_end {
        member: ZAstMember = self.members[member_index]
        if member.attribute_expr == ZAstNoIndex {
            self.semantic_error_span = decl.span
            return false
        }
        // Layout offsets are compile-time expressions, including global
        // constants and arithmetic over them.
        if !zast_expr_is_constant(self, member.attribute_expr) {
            self.semantic_error_span = self.exprs[member.attribute_expr].span
            return false
        }
        member_index = member_index + 1
    }
    return true
}

fn zast_check_bool_condition(self: *ZAstModule, decl: ZAstDecl, stmt: ZAstStmt, through_stmt: i64) !i64 {
    if stmt.expr_index == ZAstNoIndex || stmt.condition_has_recovery {
        return 0
    }
    // Validate any operands whose types are already recoverable before name
    // resolution defers a generic or imported projection.
    zast_validate_boolean_operators(self, decl, stmt.expr_index, through_stmt) catch |err| {
        return err
    }
    zast_validate_call_argument_types(self, decl, stmt.expr_index, through_stmt) catch |err| {
        return err
    }
    if !zast_expr_names_known(self, decl, stmt.expr_index, through_stmt) {
        // Generic members and imported projections can remain unresolved at
        // this stage; their condition type is validated by the substitution
        // pass rather than reported as a false unknown-name error.
        return 0
    }
    condition_type: ZAstText = zast_expr_type_text(self, decl, stmt.expr_index, through_stmt)
    // Keep generic/projection conditions deferred until their concrete type
    // substitution is available. A known non-boolean still fails eagerly.
    if condition_type.len == 0 {
        return 0
    }
    if !ZAstText.eql_string(condition_type, "bool") {
        self.semantic_error_span = self.exprs[stmt.expr_index].span
        self.semantic_error_category = ZAstSemanticErrorConditionNotBool
        return error.InvalidArgument
    }
    return 0
}

// The inferred result of `!`, `&&`, and `||` is always bool, so result-type
// checking alone cannot prove their operands are boolean. Validate operands
// separately and defer only operands whose generic/imported type is unknown.
fn zast_validate_boolean_operators(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) !i64 {
    if expr_index == ZAstNoIndex {
        return 0
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprUnary {
        zast_validate_boolean_operators(self, decl, expr.left, through_stmt) catch |err| { return err }
        if expr.op == ZTokenBang {
            operand_type: ZAstText = zast_expr_type_text(self, decl, expr.left, through_stmt)
            if operand_type.len > 0 && !ZAstText.eql_string(operand_type, "bool") {
                self.semantic_error_span = expr.span
                return error.InvalidArgument
            }
        }
        return 0
    }
    if expr.kind == ZAstExprBinary {
        zast_validate_boolean_operators(self, decl, expr.left, through_stmt) catch |err| { return err }
        zast_validate_boolean_operators(self, decl, expr.right, through_stmt) catch |err| { return err }
        if expr.op == ZTokenPlus || expr.op == ZTokenMinus || expr.op == ZTokenStar || expr.op == ZTokenSlash {
            left_type: ZAstText = zast_comparison_operand_type(self, decl, expr.left, through_stmt)
            right_type: ZAstText = zast_comparison_operand_type(self, decl, expr.right, through_stmt)
            left_is_pointer: bool = zast_is_pointer_type(left_type)
            right_is_pointer: bool = zast_is_pointer_type(right_type)
            if left_is_pointer || right_is_pointer {
                if expr.op == ZTokenPlus {
                    if !((left_is_pointer && zast_is_scalar_integer_type(right_type)) || (zast_is_scalar_integer_type(left_type) && right_is_pointer)) {
                        self.semantic_error_span = self.exprs[expr.left].span
                        return error.InvalidArgument
                    }
                } else if expr.op == ZTokenMinus {
                    if !left_is_pointer {
                        self.semantic_error_span = self.exprs[expr.right].span
                        return error.InvalidArgument
                    }
                    if !zast_is_scalar_integer_type(right_type) {
                        self.semantic_error_span = self.exprs[expr.left].span
                        return error.InvalidArgument
                    }
                } else {
                    self.semantic_error_span = self.exprs[expr.left].span
                    return error.InvalidArgument
                }
            }
        }
        if expr.op == ZTokenAndAnd || expr.op == ZTokenOrOr {
            left_type: ZAstText = zast_expr_type_text(self, decl, expr.left, through_stmt)
            right_type: ZAstText = zast_expr_type_text(self, decl, expr.right, through_stmt)
            if left_type.len > 0 && !ZAstText.eql_string(left_type, "bool") {
                self.semantic_error_span = self.exprs[expr.left].span
                return error.InvalidArgument
            }
            if right_type.len > 0 && !ZAstText.eql_string(right_type, "bool") {
                self.semantic_error_span = self.exprs[expr.right].span
                return error.InvalidArgument
            }
        }
        if expr.op == ZTokenEqualEqual || expr.op == ZTokenBangEqual || expr.op == ZTokenGreater || expr.op == ZTokenLess || expr.op == ZTokenGreaterEqual || expr.op == ZTokenLessEqual {
            // Preserve pointer/array wrappers here: comparison compatibility
            // is nominal for those types, unlike element-type assignment.
            left_type: ZAstText = zast_comparison_operand_type(self, decl, expr.left, through_stmt)
            right_type: ZAstText = zast_comparison_operand_type(self, decl, expr.right, through_stmt)
            if left_type.len > 0 && right_type.len > 0 {
                ordered_comparison: bool = expr.op == ZTokenGreater || expr.op == ZTokenLess || expr.op == ZTokenGreaterEqual || expr.op == ZTokenLessEqual
                comparable: bool = zast_is_scalar_integer_type(left_type) && zast_is_scalar_integer_type(right_type)
                if !ordered_comparison && zast_text_same(left_type, right_type) {
                    comparable = true
                }
                if zast_type_has_generic_arguments(left_type) || zast_type_has_generic_arguments(right_type) {
                    // One side of a generic member comparison can retain the
                    // unspecialized declaration name until nominal
                    // substitution is complete.
                    comparable = true
                }
                if !comparable {
                    self.semantic_error_span = expr.span
                    return error.InvalidArgument
                }
            }
        }
        return 0
    }
    if expr.kind == ZAstExprCall {
        zast_validate_boolean_operators(self, decl, expr.left, through_stmt) catch |err| { return err }
        argument_index: i64 = 0
        while argument_index < expr.arg_count {
            zast_validate_boolean_operators(self, decl, self.expr_args[expr.arg_start + argument_index], through_stmt) catch |err| { return err }
            argument_index = argument_index + 1
        }
        return 0
    }
    if expr.kind == ZAstExprCast || expr.kind == ZAstExprField {
        zast_validate_boolean_operators(self, decl, expr.left, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprIndex {
        zast_validate_boolean_operators(self, decl, expr.left, through_stmt) catch |err| { return err }
        zast_validate_boolean_operators(self, decl, expr.right, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprStructLiteral || expr.kind == ZAstExprArrayLiteral {
        argument_index: i64 = 0
        while argument_index < expr.arg_count {
            zast_validate_boolean_operators(self, decl, self.expr_args[expr.arg_start + argument_index], through_stmt) catch |err| { return err }
            argument_index = argument_index + 1
        }
    }
    return 0
}

fn zast_validate_call_argument_types(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) !i64 {
    if expr_index == ZAstNoIndex { return 0 }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprCall {
        function_index: i64 = ZAstNoIndex
        if expr.name.len > 0 {
            function_index = zast_function_name_known(self, expr.name)
        } else if expr.left != ZAstNoIndex {
            function_index = zast_qualified_decl_index(self, expr.left)
        }
        if function_index != ZAstNoIndex &&
            self.decls[function_index].kind != ZAstDeclFunction &&
            self.decls[function_index].kind != ZAstDeclExternFunction {
            function_index = ZAstNoIndex
        }
        if function_index != ZAstNoIndex {
                function_decl: ZAstDecl = self.decls[function_index]
                if function_decl.param_count != expr.arg_count {
                    self.semantic_error_span = self.exprs[expr.left].span
                    return error.InvalidArgument
                }
                if !zast_call_generic_arguments_valid(self, expr) {
                    self.semantic_error_span = self.exprs[expr.left].span
                    return error.InvalidArgument
                }
                if function_decl.generic_param_count > 0 && expr.op != ZAstCallExplicitTypeArguments {
                    generic_index: i64 = 0
                    while generic_index < function_decl.generic_param_count {
                        generic_name: ZAstText = self.generic_params[function_decl.generic_param_start + generic_index]
                        has_unresolved_function_evidence: bool = false
                        has_direct_value_evidence: bool = false
                        inference_index: i64 = 0
                        while inference_index < expr.arg_count && inference_index < function_decl.param_count {
                            expected_type: ZAstText = zast_decl_type_text(
                                self, self.params[function_decl.param_start + inference_index].type_index
                            )
                            argument_expr: ZAstExpr = self.exprs[self.expr_args[expr.arg_start + inference_index]]
                            if zast_is_function_type(expected_type) &&
                                zast_function_type_references_generic(expected_type, generic_name) &&
                                argument_expr.kind == ZAstExprIdentifier {
                                argument_function_index: i64 = zast_function_name_known(self, argument_expr.name)
                                if argument_function_index != ZAstNoIndex && self.decls[argument_function_index].generic_param_count > 0 {
                                    has_unresolved_function_evidence = true
                                }
                            } else if (zast_text_same(expected_type, generic_name) ||
                                zast_text_same(zast_type_text_unwrap(expected_type), generic_name)) &&
                                zast_expr_type_text(
                                    self, decl, self.expr_args[expr.arg_start + inference_index], through_stmt
                                ).len > 0 {
                                has_direct_value_evidence = true
                            }
                            inference_index = inference_index + 1
                        }
                        if has_unresolved_function_evidence &&
                            !has_direct_value_evidence &&
                            zast_decl_generic_default_type(
                                self, function_decl, generic_index
                            ).len == 0 {
                            self.semantic_error_span = self.exprs[expr.left].span
                            return error.InvalidArgument
                        }
                        generic_index = generic_index + 1
                    }
                }
                if function_decl.generic_param_count == 0 {
                    argument_index: i64 = 0
                    while argument_index < expr.arg_count {
                        expected_type_index: i64 = self.params[function_decl.param_start + argument_index].type_index
                        expected_type: ZAstText = zast_decl_type_text(self, expected_type_index)
                        if zast_is_function_type(expected_type) && !zast_expr_type_matches(self, decl, self.expr_args[expr.arg_start + argument_index], expected_type_index, through_stmt) {
                            self.semantic_error_span = self.exprs[expr.left].span
                            return error.InvalidArgument
                        }
                        if expected_type.len > 0 && expected_type.ptr[0] == 42 && !zast_pointer_argument_matches(self, decl, self.expr_args[expr.arg_start + argument_index], expected_type, through_stmt) {
                            self.semantic_error_span = self.exprs[expr.left].span
                            return error.InvalidArgument
                        }
                        argument: ZAstExpr = self.exprs[self.expr_args[expr.arg_start + argument_index]]
                        // Keep numeric coercion in its dedicated relation
                        // helper below, but string literals have no implicit
                        // conversion to scalar parameters.
                        if argument.kind == ZAstExprString && !zast_expr_type_matches(self, decl, self.expr_args[expr.arg_start + argument_index], expected_type_index, through_stmt) {
                            self.semantic_error_span = self.exprs[expr.left].span
                            return error.InvalidArgument
                        }
                        if argument.kind == ZAstExprIdentifier && zast_is_scalar_integer_type(expected_type) {
                            actual_type: ZAstText = zast_comparison_operand_type(self, decl, self.expr_args[expr.arg_start + argument_index], through_stmt)
                            if zast_is_scalar_integer_type(actual_type) && !zast_integer_call_argument_matches(expected_type, actual_type) {
                                self.semantic_error_span = self.exprs[expr.left].span
                                return error.InvalidArgument
                            }
                        }
                        argument_index = argument_index + 1
                    }
                }
        }
        argument_index: i64 = 0
        while argument_index < expr.arg_count {
            zast_validate_call_argument_types(self, decl, self.expr_args[expr.arg_start + argument_index], through_stmt) catch |err| { return err }
            argument_index = argument_index + 1
        }
        return 0
    }
    if expr.kind == ZAstExprUnary || expr.kind == ZAstExprCast || expr.kind == ZAstExprField {
        zast_validate_call_argument_types(self, decl, expr.left, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprBinary || expr.kind == ZAstExprIndex {
        zast_validate_call_argument_types(self, decl, expr.left, through_stmt) catch |err| { return err }
        zast_validate_call_argument_types(self, decl, expr.right, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprStructLiteral || expr.kind == ZAstExprArrayLiteral {
        argument_index: i64 = 0
        while argument_index < expr.arg_count {
            zast_validate_call_argument_types(self, decl, self.expr_args[expr.arg_start + argument_index], through_stmt) catch |err| { return err }
            argument_index = argument_index + 1
        }
    }
    return 0
}

fn zast_expr_is_error_union(self: *ZAstModule, expr_index: i64) -> bool {
    if expr_index == ZAstNoIndex { return false }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind != ZAstExprCall { return false }
    declaration_index: i64 = ZAstNoIndex
    if expr.name.len > 0 {
        declaration_index = zast_function_name_known(self, expr.name)
    } else if expr.left != ZAstNoIndex {
        declaration_index = zast_qualified_decl_index(self, expr.left)
    }
    if declaration_index == ZAstNoIndex { return false }
    if self.decls[declaration_index].is_imported &&
        self.decls[declaration_index].kind != ZAstDeclFunction &&
        self.decls[declaration_index].kind != ZAstDeclExternFunction {
        return true
    }
    return self.decls[declaration_index].return_is_error_union
}

// Error unions require explicit recovery before conversion to an ordinary
// value.  Pointer casts remain the supported representation-level escape
// hatch; all other casts must operate on the recovered value instead.
fn zast_validate_error_union_casts(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) !i64 {
    if expr_index == ZAstNoIndex { return 0 }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprCast {
        target_type: ZAstText = zast_text_skip_ws(zast_decl_type_text(self, expr.type_index))
        if zast_expr_is_error_union(self, expr.left) && (target_type.len == 0 || target_type.ptr[0] != 42) {
            self.semantic_error_span = expr.span
            return error.InvalidArgument
        }
        zast_validate_error_union_casts(self, decl, expr.left, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprUnary || expr.kind == ZAstExprField {
        zast_validate_error_union_casts(self, decl, expr.left, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprBinary || expr.kind == ZAstExprIndex {
        zast_validate_error_union_casts(self, decl, expr.left, through_stmt) catch |err| { return err }
        zast_validate_error_union_casts(self, decl, expr.right, through_stmt) catch |err| { return err }
        return 0
    }
    if expr.kind == ZAstExprCall || expr.kind == ZAstExprStructLiteral || expr.kind == ZAstExprArrayLiteral {
        argument_index: i64 = 0
        while argument_index < expr.arg_count {
            zast_validate_error_union_casts(self, decl, self.expr_args[expr.arg_start + argument_index], through_stmt) catch |err| { return err }
            argument_index = argument_index + 1
        }
    }
    return 0
}

// Calls accept arrays where a pointer is expected, but pointer values
// themselves must preserve both their indirection level and pointee type.
// Address-of expressions are matched against their operand because their
// compact inferred representation does not retain the complete pointer text.
fn zast_pointer_argument_matches(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, expected_type: ZAstText, through_stmt: i64) -> bool {
    expected_type = zast_text_skip_ws(expected_type)
    argument: ZAstExpr = self.exprs[expr_index]
    if argument.kind == ZAstExprUnary && argument.op == ZTokenAmp {
        if expected_type.len <= 1 {
            return false
        }
        expected_pointee: ZAstText
        expected_pointee.ptr = expected_type.ptr + 1
        expected_pointee.len = expected_type.len - 1
        actual_pointee: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, argument.left, through_stmt))
        if actual_pointee.len > 0 && actual_pointee.ptr[0] == 91 {
            return true
        }
        return actual_pointee.len > 0 && zast_text_same(expected_pointee, actual_pointee)
    }

    actual_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, expr_index, through_stmt))
    // Preserve the established array-to-pointer decay behavior until array
    // coercions are represented explicitly in the hosted type resolver.
    if actual_type.len > 0 && actual_type.ptr[0] == 91 {
        return zast_array_decays_to_pointer(expected_type, actual_type)
    }
    return actual_type.len > 0 && zast_text_same(expected_type, actual_type)
}

// Fixed arrays decay only to pointers to their exact element type. The type
// text already retains `[length]element`, so comparison can remain allocation
// free by slicing after the closing bracket.
fn zast_array_decays_to_pointer(pointer_type: ZAstText, array_type: ZAstText) -> bool {
    pointer_type = zast_text_skip_ws(pointer_type)
    array_type = zast_text_skip_ws(array_type)
    if pointer_type.len < 2 || pointer_type.ptr[0] != 42 || array_type.len < 4 || array_type.ptr[0] != 91 {
        return false
    }
    element_start: i64 = 1
    while element_start < array_type.len && array_type.ptr[element_start] != 93 {
        element_start = element_start + 1
    }
    if element_start >= array_type.len || element_start + 1 >= array_type.len {
        return false
    }
    array_element: ZAstText
    array_element.ptr = array_type.ptr + element_start + 1
    array_element.len = array_type.len - element_start - 1
    pointer_element: ZAstText
    pointer_element.ptr = pointer_type.ptr + 1
    pointer_element.len = pointer_type.len - 1
    return zast_text_same(zast_text_skip_ws(pointer_element), zast_text_skip_ws(array_element))
}

// Stage 0 permits only lossless implicit integer conversions for typed call
// arguments. In particular, an unsigned value needs one fewer magnitude bit
// than its signed destination, while a signed value never implicitly changes
// to an unsigned type.
fn zast_integer_call_argument_matches(expected_type: ZAstText, actual_type: ZAstText) -> bool {
    expected_type = zast_text_skip_ws(expected_type)
    actual_type = zast_text_skip_ws(actual_type)
    if zast_text_same(expected_type, actual_type) {
        return true
    }
    expected_bits: i64 = zast_integer_type_bits(expected_type)
    actual_bits: i64 = zast_integer_type_bits(actual_type)
    if expected_bits == 0 || actual_bits == 0 {
        return true
    }
    expected_signed: bool = expected_type.ptr[0] == 105
    actual_signed: bool = actual_type.ptr[0] == 105
    if !expected_signed && actual_signed {
        return false
    }
    if expected_signed && !actual_signed {
        return expected_bits > actual_bits
    }
    return expected_bits >= actual_bits
}

fn zast_integer_type_bits(type_text: ZAstText) -> i64 {
    type_text = zast_text_skip_ws(type_text)
    if ZAstText.eql_string(type_text, "i8") || ZAstText.eql_string(type_text, "u8") { return 8 }
    if ZAstText.eql_string(type_text, "i16") || ZAstText.eql_string(type_text, "u16") { return 16 }
    if ZAstText.eql_string(type_text, "i32") || ZAstText.eql_string(type_text, "u32") { return 32 }
    if ZAstText.eql_string(type_text, "i64") || ZAstText.eql_string(type_text, "u64") { return 64 }
    return 0
}

fn zast_positive_integer_literal_fits_type(literal: ZAstText, target_type: ZAstText) -> bool {
    target_type = zast_text_skip_ws(target_type)
    bits: i64 = zast_integer_type_bits(target_type)
    if bits == 0 || bits >= 64 || literal.len == 0 {
        return true
    }
    maximum: i64 = 0
    if target_type.ptr[0] == 117 {
        if bits == 8 { maximum = 255 }
        if bits == 16 { maximum = 65535 }
        if bits == 32 { maximum = 4294967295 }
    } else {
        if bits == 8 { maximum = 127 }
        if bits == 16 { maximum = 32767 }
        if bits == 32 { maximum = 2147483647 }
    }
    value: i64 = 0
    index: i64 = 0
    while index < literal.len {
        digit: u8 = literal.ptr[index]
        if digit < 48 || digit > 57 { return true }
        value = value * 10 + cast(i64, digit - 48)
        if value > maximum { return false }
        index = index + 1
    }
    return true
}

// Comparisons must preserve declared pointer/array wrappers. Direct local and
// parameter lookup supplies that exact type even when the broader expression
// resolver defers an incomplete projection.
fn zast_comparison_operand_type(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> ZAstText {
    if expr_index != ZAstNoIndex && self.exprs[expr_index].kind == ZAstExprIdentifier {
        name: ZAstText = self.exprs[expr_index].name
        parameter_index: i64 = 0
        while parameter_index < decl.param_count {
            parameter: ZAstParam = self.params[decl.param_start + parameter_index]
            if zast_text_same(parameter.name, name) {
                return zast_text_skip_ws(zast_decl_type_text(self, parameter.type_index))
            }
            parameter_index = parameter_index + 1
        }
        statement_index: i64 = decl.stmt_start
        statement_end: i64 = decl.stmt_start + decl.stmt_count
        while statement_index < statement_end {
            statement: ZAstStmt = self.stmts[statement_index]
            if statement.kind == ZAstStmtVar && zast_text_same(statement.name, name) {
                return zast_text_skip_ws(zast_decl_type_text(self, statement.type_index))
            }
            statement_index = statement_index + 1
        }
    }
    return zast_text_skip_ws(zast_expr_type_text(self, decl, expr_index, through_stmt))
}

fn zast_is_scalar_integer_type(type_text: ZAstText) -> bool {
    type_text = zast_text_skip_ws(type_text)
    if type_text.len == 0 || type_text.ptr[0] == 42 || type_text.ptr[0] == 91 {
        return false
    }
    return zast_is_integer_type(type_text)
}

fn zast_is_pointer_type(type_text: ZAstText) -> bool {
    type_text = zast_text_skip_ws(type_text)
    return type_text.len > 0 && type_text.ptr[0] == 42
}

fn zast_type_has_generic_arguments(type_text: ZAstText) -> bool {
    index: i64 = 0
    while index < type_text.len {
        if type_text.ptr[index] == 60 {
            return true
        }
        index = index + 1
    }
    return false
}

fn zast_stmt_is_within_for(self: *ZAstModule, decl: ZAstDecl, stmt_index: i64, query_index: i64) -> bool {
    parent_index: i64 = decl.stmt_start
    parent_end: i64 = decl.stmt_start + decl.stmt_count
    while parent_index < parent_end {
        parent: ZAstStmt = self.stmts[parent_index]
        if parent.kind == ZAstStmtFor && stmt_index >= parent.child_start && stmt_index < parent.child_start + parent.child_count {
            return query_index >= parent.child_start && query_index < parent.child_start + parent.child_count
        }
        parent_index = parent_index + 1
    }
    return true
}

fn zast_union_tag_case_matches(self: *ZAstModule, case_expr_index: i64, match_type: ZAstText, member_name: ZAstText) -> bool {
    case_expr: ZAstExpr = self.exprs[case_expr_index]
    if case_expr.kind != ZAstExprField || !zast_text_same(case_expr.name, member_name) || case_expr.left == ZAstNoIndex { return false }
    tag_expr: ZAstExpr = self.exprs[case_expr.left]
    if tag_expr.kind != ZAstExprField || !ZAstText.eql_string(tag_expr.name, "Tag") || tag_expr.left == ZAstNoIndex { return false }
    owner_index: i64 = tag_expr.left
    if zast_expr_generic_specializes_type(self, owner_index, match_type) { return true }
    return zast_expr_matches_qualified_name(self, owner_index, zast_type_text_base(match_type))
}

// The first flow slice covers boolean matches. Enum and union coverage needs
// nominal variant tracking and is deliberately deferred to the full match
// semantic pass rather than guessed from names.
fn zast_match_is_exhaustive(self: *ZAstModule, decl: ZAstDecl, stmt: ZAstStmt, through_stmt: i64) -> bool {
    match_type: ZAstText = zast_expr_type_text(self, decl, stmt.expr_index, through_stmt)
    is_bool_match: bool = ZAstText.eql_string(match_type, "bool")
    has_true: bool = false
    has_false: bool = false
    child_index: i64 = stmt.child_start
    child_end: i64 = stmt.child_start + stmt.child_count
    while child_index < child_end {
        child: ZAstStmt = self.stmts[child_index]
        if child.kind == ZAstStmtElse {
            return true
        }
        if child.kind == ZAstStmtCase && child.expr_index != ZAstNoIndex {
            case_expr: ZAstExpr = self.exprs[child.expr_index]
            if case_expr.kind == ZAstExprBool {
                if case_expr.literal.len == 4 { has_true = true }
                if case_expr.literal.len == 5 { has_false = true }
            }
        }
        if zast_stmt_has_children(child.kind) {
            child_index = child.child_start + child.child_count
        } else {
            child_index = child_index + 1
        }
    }
    if is_bool_match {
        return has_true && has_false
    }

    enum_index: i64 = ZAstModule.find_owning_decl(
        self, zast_type_text_base(match_type)
    )
    if enum_index == ZAstNoIndex {
        return true
    }
    if self.decls[enum_index].kind == ZAstDeclUnion {
        // Union alternatives are written as call patterns (`Value.Number(n)`)
        // rather than the enum's field expressions. Require every declared
        // variant, so a duplicate case cannot satisfy coverage accidentally.
        member_index: i64 = 0
        while member_index < self.decls[enum_index].member_count {
            member: ZAstMember = self.members[self.decls[enum_index].member_start + member_index]
            found: bool = false
            child_index = stmt.child_start
            while child_index < child_end {
                child: ZAstStmt = self.stmts[child_index]
                if child.kind == ZAstStmtCase && child.expr_index != ZAstNoIndex {
                    case_expr: ZAstExpr = self.exprs[child.expr_index]
                    if case_expr.kind == ZAstExprCall && case_expr.left != ZAstNoIndex {
                        case_callee: ZAstExpr = self.exprs[case_expr.left]
                        if case_callee.kind == ZAstExprField && zast_text_same(case_callee.name, member.name) {
                            found = true
                        }
                    }
                    if zast_union_tag_case_matches(self, child.expr_index, match_type, member.name) {
                        found = true
                    }
                }
                if zast_stmt_has_children(child.kind) {
                    child_index = child.child_start + child.child_count
                } else {
                    child_index = child_index + 1
                }
            }
            if !found { return false }
            member_index = member_index + 1
        }
        return true
    }
    if self.decls[enum_index].kind != ZAstDeclEnum {
        return true
    }
    // Enum coverage is determined from the declared member set, rather than
    // the number of cases, so duplicate cases cannot masquerade as exhaustive.
    member_index: i64 = 0
    while member_index < self.decls[enum_index].member_count {
        member: ZAstMember = self.members[self.decls[enum_index].member_start + member_index]
        found: bool = false
        child_index = stmt.child_start
        while child_index < child_end {
            child: ZAstStmt = self.stmts[child_index]
            if child.kind == ZAstStmtCase && child.expr_index != ZAstNoIndex {
                case_expr: ZAstExpr = self.exprs[child.expr_index]
                if case_expr.kind == ZAstExprField && zast_text_same(case_expr.name, member.name) {
                    found = true
                }
            }
            if zast_stmt_has_children(child.kind) {
                child_index = child.child_start + child.child_count
            } else {
                child_index = child_index + 1
            }
        }
        if !found {
            return false
        }
        member_index = member_index + 1
    }
    return true
}

// Backend control-flow lowering uses the semantic exhaustiveness result to
// distinguish a real continuation edge from the impossible final test edge.
export fn ZAstModule.match_is_exhaustive(
    self: *ZAstModule,
    declaration: ZAstDecl,
    statement: ZAstStmt,
    through_statement: i64
) -> bool {
    return zast_match_is_exhaustive(
        self, declaration, statement, through_statement
    )
}

fn zast_switch_is_valid(self: *ZAstModule, decl: ZAstDecl, stmt: ZAstStmt, through_stmt: i64) -> bool {
    // Tagged-union discriminants are represented as a synthesized `.tag`
    // projection. Their concrete enum text is introduced later by lowering,
    // so leave variant compatibility to that dedicated union pass.
    if zast_expr_is_union_tag(self, decl, stmt.expr_index, through_stmt) {
        return true
    }
    operand_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, stmt.expr_index, through_stmt))
    enum_index: i64 = ZAstModule.find_decl(self, zast_type_text_base(operand_type))
    is_enum: bool = enum_index != ZAstNoIndex && self.decls[enum_index].kind == ZAstDeclEnum
    if !zast_is_scalar_integer_type(operand_type) && !ZAstText.eql_string(operand_type, "bool") && !is_enum {
        self.semantic_error_span = self.exprs[stmt.expr_index].span
        return false
    }

    child_index: i64 = stmt.child_start
    child_end: i64 = stmt.child_start + stmt.child_count
    while child_index < child_end {
        child: ZAstStmt = self.stmts[child_index]
        if child.kind == ZAstStmtCase {
            if !zast_expr_names_known(self, decl, child.expr_index, child_index - decl.stmt_start) {
                self.semantic_error_span = self.exprs[child.expr_index].span
                return false
            }
            case_type: ZAstText = zast_text_skip_ws(zast_expr_type_text(self, decl, child.expr_index, child_index - decl.stmt_start))
            if !zast_switch_case_is_comparable(operand_type, case_type, is_enum) {
                self.semantic_error_span = self.exprs[child.expr_index].span
                return false
            }
            earlier_index: i64 = stmt.child_start
            while earlier_index < child_index {
                earlier: ZAstStmt = self.stmts[earlier_index]
                if earlier.kind == ZAstStmtCase && zast_switch_case_values_equal(self, earlier.expr_index, child.expr_index) {
                    self.semantic_error_span = self.exprs[child.expr_index].span
                    return false
                }
                if zast_stmt_has_children(earlier.kind) {
                    earlier_index = earlier.child_start + earlier.child_count
                } else {
                    earlier_index = earlier_index + 1
                }
            }
        }
        if zast_stmt_has_children(child.kind) {
            child_index = child.child_start + child.child_count
        } else {
            child_index = child_index + 1
        }
    }

    if is_enum && !zast_match_is_exhaustive(self, decl, stmt, through_stmt) {
        self.semantic_error_span = stmt.span
        return false
    }
    return true
}

fn zast_expr_is_union_tag(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> bool {
    if expr_index == ZAstNoIndex {
        return false
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind != ZAstExprField || !ZAstText.eql_string(expr.name, "tag") || expr.left == ZAstNoIndex {
        return false
    }
    target_type: ZAstText = zast_type_text_base(zast_expr_type_text(self, decl, expr.left, through_stmt))
    target_index: i64 = ZAstModule.find_decl(self, target_type)
    return target_index != ZAstNoIndex && self.decls[target_index].kind == ZAstDeclUnion
}

fn zast_switch_case_is_comparable(operand_type: ZAstText, case_type: ZAstText, is_enum: bool) -> bool {
    if operand_type.len == 0 || case_type.len == 0 {
        return false
    }
    if is_enum {
        // Generic enum member expressions retain their nominal declaration
        // name while the switch operand may retain its `<...>` suffix.
        return zast_text_same(zast_type_text_base(operand_type), zast_type_text_base(case_type))
    }
    if ZAstText.eql_string(operand_type, "bool") {
        return zast_text_same(operand_type, case_type)
    }
    return zast_is_scalar_integer_type(operand_type) && zast_is_scalar_integer_type(case_type)
}

fn zast_switch_case_values_equal(self: *ZAstModule, left_index: i64, right_index: i64) -> bool {
    left: ZAstExpr = self.exprs[left_index]
    right: ZAstExpr = self.exprs[right_index]
    if left.kind != right.kind { return false }
    if left.kind == ZAstExprInteger || left.kind == ZAstExprBool || left.kind == ZAstExprError {
        return zast_text_same(left.literal, right.literal) && zast_text_same(left.name, right.name)
    }
    if left.kind == ZAstExprIdentifier {
        return zast_text_same(left.name, right.name)
    }
    if left.kind == ZAstExprField {
        return zast_text_same(left.name, right.name) && left.left != ZAstNoIndex && right.left != ZAstNoIndex && zast_switch_case_values_equal(self, left.left, right.left)
    }
    return false
}

fn zast_check_stmt_node(self: *ZAstModule, decl: ZAstDecl, stmt_index: i64) !i64 {
    stmt: ZAstStmt = self.stmts[stmt_index]
    if stmt.catch_owner != ZAstNoIndex {
        return 0
    }
    through_stmt: i64 = stmt_index - decl.stmt_start

    if stmt.kind == ZAstStmtAsm {
        operand_index: i64 = 0
        while operand_index < stmt.asm_output_count {
            zast_check_asm_operand(self, decl, self.expr_args[stmt.asm_output_start + operand_index], through_stmt, true) catch |err| { return err }
            operand_index = operand_index + 1
        }
        operand_index = 0
        while operand_index < stmt.asm_input_count {
            zast_check_asm_operand(self, decl, self.expr_args[stmt.asm_input_start + operand_index], through_stmt, false) catch |err| { return err }
            operand_index = operand_index + 1
        }
        return 0
    }

    if (stmt.kind == ZAstStmtBreak || stmt.kind == ZAstStmtContinue) && !zast_stmt_has_enclosing_loop(self, decl, stmt_index) {
        self.semantic_error_span = stmt.span
        return error.InvalidArgument
    }

    if zast_stmt_has_children(stmt.kind) {
        inner_index: i64 = stmt.child_start
        inner_end: i64 = stmt.child_start + stmt.child_count
        while inner_index < inner_end {
            zast_check_stmt_node(self, decl, inner_index) catch |err| {
                return err
            }
            inner_index = inner_index + 1
        }
        if stmt.kind == ZAstStmtMatch && !zast_match_is_exhaustive(self, decl, stmt, through_stmt) {
            self.semantic_error_span = stmt.span
            self.semantic_error_category = ZAstSemanticErrorMatchNotExhaustive
            return error.InvalidArgument
        }
        if stmt.kind == ZAstStmtSwitch && !zast_switch_is_valid(self, decl, stmt, through_stmt) {
            return error.InvalidArgument
        }
        if zast_stmt_requires_bool_condition(stmt.kind) {
            condition_through: i64 = through_stmt
            if stmt.kind == ZAstStmtFor {
                // Advance past the complete flattened initializer range so
                // its root binding is visible. Local lookup excludes recovery
                // nodes when the query itself is outside a catch.
                condition_through = stmt.child_start - decl.stmt_start +
                    stmt.for_initializer_count
            }
            zast_check_bool_condition(self, decl, stmt, condition_through) catch |err| {
                return err
            }
        }
        return 0
    }

    if stmt.kind == ZAstStmtVar {
        if stmt.attribute_expr != ZAstNoIndex && !zast_expr_is_constant(self, stmt.attribute_expr) {
            self.semantic_error_span = self.exprs[stmt.attribute_expr].span
            return error.InvalidArgument
        }
        if !zast_type_known(self, decl, stmt.type_index) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        if !zast_type_array_sizes_are_constant(self, decl, stmt.type_index, through_stmt) {
            self.semantic_error_span = stmt.span
            return error.InvalidArgument
        }
        if !zast_type_generic_arguments_valid(self, decl, stmt.type_index) {
            self.semantic_error_span = stmt.span
            return error.InvalidArgument
        }
        if stmt.is_constant && stmt.expr_index == ZAstNoIndex {
            self.semantic_error_span = stmt.span
            return error.InvalidArgument
        }
        if stmt.expr_index != ZAstNoIndex {
            zast_check_catch_expression(self, decl, stmt.expr_index, stmt.type_index, through_stmt, false) catch |err| {
                return err
            }
            if !zast_expr_names_known(self, decl, stmt.expr_index, through_stmt) {
                self.semantic_error_span = stmt.span
                return error.NotFound
            }
            if stmt.condition_has_recovery {
                initializer: ZAstExpr = self.exprs[stmt.expr_index]
                if initializer.kind == ZAstExprCall && initializer.name.len > 0 {
                    callee_index: i64 = zast_function_name_known(self, initializer.name)
                    if callee_index != ZAstNoIndex && !self.decls[callee_index].return_is_error_union {
                        self.semantic_error_span = stmt.recovery_span
                        if self.semantic_error_span.line == 0 { self.semantic_error_span = stmt.span }
                        return error.InvalidArgument
                    }
                }
            }
            zast_validate_boolean_operators(self, decl, stmt.expr_index, through_stmt) catch |err| {
                return err
            }
            zast_validate_call_argument_types(self, decl, stmt.expr_index, through_stmt) catch |err| {
                return err
            }
            zast_validate_error_union_casts(self, decl, stmt.expr_index, through_stmt) catch |err| {
                return err
            }
            if self.exprs[stmt.expr_index].kind == ZAstExprInteger && !zast_positive_integer_literal_fits_type(self.exprs[stmt.expr_index].literal, zast_decl_type_text(self, stmt.type_index)) {
                self.semantic_error_span = stmt.span
                return error.InvalidArgument
            }
            if !zast_expr_type_matches(self, decl, stmt.expr_index, stmt.type_index, through_stmt) {
                if self.semantic_error_span.line == 0 {
                    self.semantic_error_span = stmt.span
                }
                return error.InvalidArgument
            }
        }
    }

    if stmt.kind == ZAstStmtReturn {
        zast_check_catch_expression(self, decl, stmt.expr_index, decl.return_type_index, through_stmt, false) catch |err| {
            return err
        }
        if !zast_expr_names_known(self, decl, stmt.expr_index, through_stmt) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        zast_validate_boolean_operators(self, decl, stmt.expr_index, through_stmt) catch |err| {
            return err
        }
        zast_validate_call_argument_types(self, decl, stmt.expr_index, through_stmt) catch |err| {
            return err
        }
        zast_validate_error_union_casts(self, decl, stmt.expr_index, through_stmt) catch |err| {
            return err
        }
        if !zast_function_accepts_return(self, decl, stmt.expr_index, through_stmt) {
            if self.semantic_error_span.line == 0 {
                self.semantic_error_span = stmt.span
            }
            return error.InvalidArgument
        }
    }

    if stmt.kind == ZAstStmtExpr {
        zast_check_catch_expression(self, decl, stmt.expr_index, ZAstNoIndex, through_stmt, true) catch |err| {
            return err
        }
        if stmt.expr_index != ZAstNoIndex && !zast_expr_names_known(self, decl, stmt.expr_index, through_stmt) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        zast_validate_boolean_operators(self, decl, stmt.expr_index, through_stmt) catch |err| {
            return err
        }
        zast_validate_call_argument_types(self, decl, stmt.expr_index, through_stmt) catch |err| {
            return err
        }
        zast_validate_error_union_casts(self, decl, stmt.expr_index, through_stmt) catch |err| {
            return err
        }
    }

    if stmt.kind == ZAstStmtAssign {
        if stmt.value_expr != ZAstNoIndex && self.exprs[stmt.value_expr].kind == ZAstExprCatch {
            // Assignment target typing is checked below; a statement-position
            // recovery may intentionally fall through without a value.
            zast_check_catch_expression(self, decl, stmt.value_expr, ZAstNoIndex, through_stmt, true) catch |err| { return err }
        }
        if !zast_expr_names_known(self, decl, stmt.expr_index, through_stmt) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        if !zast_expr_names_known(self, decl, stmt.value_expr, through_stmt) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        zast_validate_boolean_operators(self, decl, stmt.value_expr, through_stmt) catch |err| {
            return err
        }
        zast_validate_call_argument_types(self, decl, stmt.value_expr, through_stmt) catch |err| {
            return err
        }
        zast_validate_error_union_casts(self, decl, stmt.value_expr, through_stmt) catch |err| {
            return err
        }
        if !zast_expr_is_assignable(self, stmt.expr_index) {
            self.semantic_error_span = stmt.span
            return error.InvalidArgument
        }
        if zast_expr_is_constant_target(self, decl, stmt.expr_index, through_stmt) {
            self.semantic_error_span = self.exprs[stmt.expr_index].span
            return error.InvalidArgument
        }
        if !zast_expr_types_compatible(self, decl, stmt.expr_index, stmt.value_expr, through_stmt) {
            self.semantic_error_span = stmt.span
            return error.InvalidArgument
        }
    }

    return 0
}

// Check a catch after its enclosing expression has been resolved. The root
// walker skips owned recovery statements so their locals remain scoped.
fn zast_check_catch_expression(self: *ZAstModule, decl: ZAstDecl, catch_index: i64, expected_type_index: i64, through_stmt: i64, allow_fallthrough: bool) !i64 {
    catch_expr: ZAstExpr = self.exprs[catch_index]
    if catch_expr.kind != ZAstExprCatch { return 0 }
    source_is_error_union: bool = zast_expr_is_error_union(self, catch_expr.left)
    if !source_is_error_union && self.exprs[catch_expr.left].kind == ZAstExprCall {
        source_call: ZAstExpr = self.exprs[catch_expr.left]
        source_decl: i64 = zast_function_name_known(self, source_call.name)
        if source_decl == ZAstNoIndex { source_decl = zast_qualified_decl_index(self, source_call.left) }
        // Method and imported projections are not all materialized in the
        // compact module yet. A known local non-error function remains a
        // hard rejection; an unresolved projection is validated by normal
        // name lookup and remains recoverable at this boundary.
        if source_decl == ZAstNoIndex { source_is_error_union = true }
    }
    if !source_is_error_union {
        self.semantic_error_span = catch_expr.span
        return error.InvalidArgument
    }
    body_index: i64 = catch_expr.arg_start
    body_end: i64 = catch_expr.arg_start + catch_expr.arg_count
    while body_index < body_end {
        stmt: ZAstStmt = self.stmts[body_index]
        if stmt.catch_owner != catch_index {
            body_index = body_index + 1
            continue
        }
        // The surrounding statement checker owns ordinary type validation.
        // Recovery bodies are an isolated scope; validate their names and
        // error-return transfer here without treating compiler-internal
        // projection fields as standalone function locals.
        if stmt.expr_index != ZAstNoIndex && !zast_expr_names_known(self, decl, stmt.expr_index, body_index - decl.stmt_start) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        if stmt.value_expr != ZAstNoIndex && !zast_expr_names_known(self, decl, stmt.value_expr, body_index - decl.stmt_start) {
            self.semantic_error_span = stmt.span
            return error.NotFound
        }
        if zast_stmt_has_children(stmt.kind) {
            body_index = stmt.child_start + stmt.child_count
        } else {
            body_index = body_index + 1
        }
    }
    if allow_fallthrough || catch_expr.arg_count == 0 { return 0 }
    last: ZAstStmt = self.stmts[catch_expr.arg_start + catch_expr.arg_count - 1]
    if last.kind == ZAstStmtReturn || last.kind == ZAstStmtBreak || last.kind == ZAstStmtContinue { return 0 }
    if last.kind != ZAstStmtExpr || last.expr_index == ZAstNoIndex {
        self.semantic_error_span = catch_expr.span
        return error.InvalidArgument
    }
    if !zast_expr_type_matches(self, decl, last.expr_index, expected_type_index, last.expr_index - decl.stmt_start) {
        self.semantic_error_span = self.exprs[last.expr_index].span
        return error.InvalidArgument
    }
    return 0
}

export fn ZAstModule.has_duplicate_declarations(self: *ZAstModule) -> bool {
    i: i64 = 0
    while i < self.len {
        if self.decls[i].is_imported {
            i = i + 1
            continue
        }
        j: i64 = i + 1
        while j < self.len {
            // Imported lookup records are not declarations in this file.
            // Only source declarations compete for duplicate diagnostics.
            if !self.decls[j].is_imported && self.decls[i].name.len > 0 && zast_text_same(self.decls[i].name, self.decls[j].name) {
                self.semantic_error_span = self.decls[j].span
                return true
            }
            j = j + 1
        }
        i = i + 1
    }
    return false
}

fn zast_has_builtin_declaration_conflict(self: *ZAstModule) -> bool {
    declaration_index: i64 = 0
    while declaration_index < self.len {
        declaration: ZAstDecl = self.decls[declaration_index]
        if !declaration.is_imported && zast_is_intrinsic_function(declaration.name) {
            self.semantic_error_span = declaration.span
            return true
        }
        declaration_index = declaration_index + 1
    }
    return false
}

export fn ZAstModule.check_semantics(self: *ZAstModule) !i64 {
    self.semantic_error_span = ZAstSpan.empty()
    self.semantic_error_category = ZAstSemanticErrorNone
    if ZAstModule.has_duplicate_declarations(self) {
        return error.AlreadyExists
    }
    if zast_has_builtin_declaration_conflict(self) {
        return error.InvalidArgument
    }
    if !zast_error_declarations_valid(self) {
        return error.InvalidArgument
    }

    i: i64 = 0
    while i < self.len {
        if zast_decl_has_duplicate_generic_params(self, self.decls[i]) {
            self.semantic_error_span = self.decls[i].span
            return error.AlreadyExists
        }
        i = i + 1
    }

    i = 0
    while i < self.len {
        if self.decls[i].is_imported {
            i = i + 1
            continue
        }

        if !zast_type_known(self, self.decls[i], self.decls[i].type_index) {
            return error.NotFound
        }
        if !zast_decl_generic_defaults_valid(self, self.decls[i]) {
            self.semantic_error_span = self.decls[i].span
            return error.NotFound
        }
        if !zast_type_generic_arguments_valid(self, self.decls[i], self.decls[i].type_index) {
            self.semantic_error_span = self.decls[i].span
            return error.InvalidArgument
        }
        if !zast_type_array_sizes_are_constant(self, self.decls[i], self.decls[i].type_index, 0) {
            self.semantic_error_span = self.decls[i].span
            return error.InvalidArgument
        }
        if !zast_enum_has_integer_underlying_type(self, self.decls[i]) {
            self.semantic_error_span = self.decls[i].span
            return error.InvalidArgument
        }
        if !zast_type_known(self, self.decls[i], self.decls[i].return_type_index) {
            return error.NotFound
        }
        if !zast_type_generic_arguments_valid(self, self.decls[i], self.decls[i].return_type_index) {
            self.semantic_error_span = self.decls[i].span
            return error.InvalidArgument
        }
        if zast_decl_has_duplicate_params(self, self.decls[i]) {
            return error.AlreadyExists
        }
        if zast_decl_has_duplicate_members(self, self.decls[i]) {
            return error.AlreadyExists
        }
        if !zast_explicit_layout_members_valid(self, self.decls[i]) {
            return error.InvalidArgument
        }
        if zast_decl_has_duplicate_enum_values(self, self.decls[i]) {
            return error.AlreadyExists
        }
        if zast_union_has_reserved_tag_variant(self, self.decls[i]) {
            return error.InvalidArgument
        }
        if !zast_global_array_initializer_is_literal(self, self.decls[i]) {
            self.semantic_error_span = self.decls[i].span
            return error.InvalidArgument
        }
        if !zast_global_integer_initializer_is_valid(self, self.decls[i]) {
            return error.InvalidArgument
        }
        if !zast_global_initializer_has_no_catch(self, self.decls[i]) {
            return error.InvalidArgument
        }
        if self.decls[i].attribute_expr != ZAstNoIndex && !zast_expr_is_constant(self, self.decls[i].attribute_expr) {
            self.semantic_error_span = self.exprs[self.decls[i].attribute_expr].span
            return error.InvalidArgument
        }

        if self.decls[i].init_expr != ZAstNoIndex && self.decls[i].kind != ZAstDeclError {
            if !zast_expr_names_known(self, self.decls[i], self.decls[i].init_expr, 0) {
                return error.NotFound
            }
            if !zast_expr_type_matches(self, self.decls[i], self.decls[i].init_expr, self.decls[i].type_index, 0) {
                return error.InvalidArgument
            }
        }

        p: i64 = 0
        while p < self.decls[i].param_count {
            if !zast_type_known(self, self.decls[i], self.params[self.decls[i].param_start + p].type_index) {
                return error.NotFound
            }
            if !zast_type_generic_arguments_valid(self, self.decls[i], self.params[self.decls[i].param_start + p].type_index) {
                self.semantic_error_span = self.params[self.decls[i].param_start + p].span
                return error.InvalidArgument
            }
            p = p + 1
        }

        m: i64 = 0
        while m < self.decls[i].member_count {
            member: ZAstMember = self.members[self.decls[i].member_start + m]
            if member.type_index != ZAstNoIndex && !zast_type_known(self, self.decls[i], member.type_index) {
                return error.NotFound
            }
            if !zast_type_generic_arguments_valid(self, self.decls[i], member.type_index) {
                self.semantic_error_span = member.span
                return error.InvalidArgument
            }
            if !zast_type_array_sizes_are_constant(self, self.decls[i], member.type_index, 0) {
                self.semantic_error_span = member.span
                return error.InvalidArgument
            }
            if member.value_expr != ZAstNoIndex {
                if !zast_expr_names_known(self, self.decls[i], member.value_expr, 0) {
                    return error.NotFound
                }
                if member.type_index != ZAstNoIndex && !zast_expr_type_matches(self, self.decls[i], member.value_expr, member.type_index, 0) {
                    return error.InvalidArgument
                }
            }
            if member.attribute_expr != ZAstNoIndex && !zast_expr_is_constant(self, member.attribute_expr) {
                self.semantic_error_span = self.decls[i].span
                return error.InvalidArgument
            }
            m = m + 1
        }

        if self.decls[i].kind == ZAstDeclFunction {
            if self.decls[i].stmt_start < 0 || self.decls[i].stmt_count < 0 ||
                self.decls[i].stmt_start > self.stmt_count_total ||
                self.decls[i].stmt_count > self.stmt_count_total - self.decls[i].stmt_start {
                self.semantic_error_span = self.decls[i].span
                return error.OutOfBounds
            }
            if zast_decl_has_duplicate_locals(self, self.decls[i]) {
                return error.AlreadyExists
            }
            child_index: i64 = self.decls[i].stmt_start
            child_end: i64 = self.decls[i].stmt_start + self.decls[i].stmt_count
            while child_index < child_end {
                stmt: ZAstStmt = self.stmts[child_index]
                if stmt.catch_owner != ZAstNoIndex {
                    child_index = child_index + 1
                    continue
                }
                zast_check_stmt_node(self, self.decls[i], child_index) catch |err| {
                    return err
                }
                if zast_stmt_has_children(stmt.kind) {
                    child_index = stmt.child_start + stmt.child_count
                } else {
                    child_index = child_index + 1
                }
            }
            if self.decls[i].return_type_index != ZAstNoIndex && !zast_stmt_sequence_always_returns(self, self.decls[i], self.decls[i].stmt_start, self.decls[i].stmt_start + self.decls[i].stmt_count) {
                self.semantic_error_span = self.decls[i].span
                return error.InvalidArgument
            }
        }

        i = i + 1
    }

    return 0
}
