import "../runtime/std/errors.zorb"
import "../runtime/std/mem.zorb"
import "../runtime/std/str.zorb"
import "token.zorb"

export const ZAstDeclImport: i64 = 1
export const ZAstDeclExternFunction: i64 = 2
export const ZAstDeclError: i64 = 3
export const ZAstDeclConst: i64 = 4
export const ZAstDeclGlobal: i64 = 5
export const ZAstDeclStruct: i64 = 6
export const ZAstDeclEnum: i64 = 7
export const ZAstDeclUnion: i64 = 8
export const ZAstDeclFunction: i64 = 9
export const ZAstDeclExternType: i64 = 10

export const ZAstExprMissing: i64 = 0
export const ZAstExprIdentifier: i64 = 1
export const ZAstExprInteger: i64 = 2
export const ZAstExprString: i64 = 3
export const ZAstExprBool: i64 = 4
export const ZAstExprBinary: i64 = 5
export const ZAstExprCall: i64 = 6
export const ZAstExprUnary: i64 = 7
export const ZAstExprField: i64 = 8
export const ZAstExprIndex: i64 = 9
export const ZAstExprCast: i64 = 10
export const ZAstExprError: i64 = 11
// A struct literal keeps its type expression in `left`, field values in
// `expr_args`, and field names/spans in the compact literal-field arena.
export const ZAstExprStructLiteral: i64 = 12
// Array literals retain their full declared array type in `type_index` and
// element expressions in `expr_args`, mirroring the ownership model used by
// calls and struct literals.
export const ZAstExprArrayLiteral: i64 = 13
// Catch owns a protected expression, a scoped error binding, and a contiguous
// range of recovery statements in the function statement arena.
export const ZAstExprCatch: i64 = 14

export const ZAstStmtVar: i64 = 1
export const ZAstStmtReturn: i64 = 2
export const ZAstStmtExpr: i64 = 3
export const ZAstStmtBlock: i64 = 4
export const ZAstStmtAssign: i64 = 5
export const ZAstStmtMatch: i64 = 6
export const ZAstStmtCase: i64 = 7
export const ZAstStmtElse: i64 = 8
export const ZAstStmtFor: i64 = 9
export const ZAstStmtIf: i64 = 10
export const ZAstStmtWhile: i64 = 11
export const ZAstStmtSwitch: i64 = 12
export const ZAstStmtBreak: i64 = 13
export const ZAstStmtContinue: i64 = 14
export const ZAstStmtAsm: i64 = 15

export const ZAstNoIndex: i64 = -1
export const ZAstSemanticErrorNone: i64 = 0
export const ZAstSemanticErrorArrayElementCount: i64 = 1
export const ZAstSemanticErrorMatchNotExhaustive: i64 = 2
export const ZAstSemanticErrorConditionNotBool: i64 = 3
export const ZAstSemanticErrorUnionLiteralVariantCount: i64 = 4
// A constrained generic call was rejected before substitution can produce a
// complete call type. This is a type-validation failure, not an unknown name.
export const ZAstSemanticErrorGenericConstraint: i64 = 5
export const ZAstCallExplicitTypeArguments: i64 = 1

export struct ZAstText {
    ptr: *u8,
    len: i64
}

// AST nodes retain their own source extent rather than relying on a caller's
// current token.  The frontend works one source file at a time, so a span only
// needs the one-based location and byte length; the owning source is supplied
// by the module/session.
export struct ZAstSpan {
    line: i64,
    column: i64,
    length: i64
}

export struct ZAstType {
    text: ZAstText,
    // Absolute statement position and owning declaration start captured where
    // the type was written. Array-bound constant lookup uses this lexical
    // context instead of scanning unrelated functions by local name.
    scope_declaration_start: i64,
    scope_statement: i64
}

export struct ZAstParam {
    name: ZAstText,
    type_index: i64,
    span: ZAstSpan
}

export struct ZAstMember {
    name: ZAstText,
    type_index: i64,
    value_expr: i64,
    attribute_expr: i64,
    span: ZAstSpan
}

export struct ZAstLiteralField {
    name: ZAstText,
    span: ZAstSpan,
    next_index: i64,
    value_expr: i64
}

export struct ZAstExpr {
    kind: i64,
    span: ZAstSpan,
    name: ZAstText,
    literal: ZAstText,
    op: i64,
    left: i64,
    right: i64,
    type_index: i64,
    arg_start: i64,
    arg_count: i64
    field_start: i64
}

export struct ZAstStmt {
    kind: i64,
    span: ZAstSpan,
    name: ZAstText,
    type_index: i64,
    expr_index: i64,
    value_expr: i64,
    // Statement-level alignment retains its expression separately from the
    // initializer so local declarations can be validated like globals.
    attribute_expr: i64,
    is_constant: bool,
    // Recovery expressions retain only their prefix until catch receives a
    // dedicated expression node. Their condition type is therefore unknown.
    condition_has_recovery: bool,
    recovery_span: ZAstSpan,
    // Non-root statements in a catch recovery are checked through their
    // owning expression, never as independent function-body statements.
    catch_owner: i64,
    asm_output_start: i64,
    asm_output_count: i64,
    asm_input_start: i64,
    asm_input_count: i64,
    asm_clobber_start: i64,
    asm_clobber_count: i64,
    // A for statement owns initializer, update, and body statements in one
    // flattened child range. Explicit clause counts keep those regions
    // unambiguous for semantic consumers and Backend IR lowering.
    for_initializer_count: i64,
    for_update_count: i64,
    child_start: i64,
    child_count: i64
}

export struct ZAstDecl {
    kind: i64,
    span: ZAstSpan,
    exported: bool,
    name: ZAstText,
    path: ZAstText,
    alias: ZAstText,
    is_c_import: bool,
    // Imported declarations are symbol projections owned by another module.
    // They participate in lookup but are never re-checked or re-exported from
    // the importing module.
    is_imported: bool,
    // Imported projections retain the defining declaration's identity so
    // graph-wide lowering can resolve an alias without emitting the projection.
    canonical_name: ZAstText,
    type_index: i64,
    return_type_index: i64,
    return_is_error_union: bool,
    init_expr: i64,
    // Declaration alignment retains its expression for the same constant
    // validation applied to local and member alignment attributes.
    attribute_expr: i64,
    initializer_has_catch: bool,
    initializer_catch_span: ZAstSpan,
    generic_param_start: i64,
    generic_param_count: i64,
    generic_required_param_count: i64,
    has_generic_constraints: bool,
    has_explicit_layout: bool,
    param_start: i64,
    param_count: i64,
    member_start: i64,
    member_count: i64,
    stmt_start: i64,
    stmt_count: i64,
    local_count: i64,
    return_count: i64,
    call_count: i64,
    binary_count: i64
}

export struct ZAstModule {
    decls: *ZAstDecl,
    len: i64,
    capacity: i64,
    types: *ZAstType,
    type_count: i64,
    type_capacity: i64,
    generic_params: *ZAstText,
    // Parallel to generic_params: ZAstNoIndex means required/no default.
    generic_default_types: *i64,
    generic_param_count_total: i64,
    generic_param_capacity: i64,
    params: *ZAstParam,
    param_count_total: i64,
    param_capacity: i64,
    members: *ZAstMember,
    member_count_total: i64,
    member_capacity: i64,
    stmts: *ZAstStmt,
    stmt_count_total: i64,
    stmt_capacity: i64,
    exprs: *ZAstExpr,
    expr_count: i64,
    expr_capacity: i64,
    expr_args: *i64,
    expr_arg_count: i64,
    expr_arg_capacity: i64,
    literal_fields: *ZAstLiteralField,
    literal_field_count: i64,
    literal_field_capacity: i64,
    import_count: i64,
    extern_count: i64,
    error_count: i64,
    const_count: i64,
    global_count: i64,
    struct_count: i64,
    enum_count: i64,
    union_count: i64,
    function_count: i64
    semantic_error_span: ZAstSpan
    semantic_error_category: i64
}

export fn ZAstText.from_token(token: ZToken) -> ZAstText {
    return ZAstText{
        ptr: token.ptr,
        len: token.len
    }
}

export fn ZAstText.from_range(start: ZToken, end: ZToken) -> ZAstText {
    text: ZAstText = ZAstText{
        ptr: start.ptr,
        len: 0
    }
    cursor: *u8 = start.ptr
    while cursor != end.ptr {
        text.len = text.len + 1
        cursor = cursor + 1
    }
    text.len = text.len + end.len
    return text
}

export fn ZAstText.empty() -> ZAstText {
    return ZAstText{
        ptr: cast(*u8, 0),
        len: 0
    }
}

export fn ZAstSpan.empty() -> ZAstSpan {
    return ZAstSpan{
        line: 0,
        column: 0,
        length: 0
    }
}

export fn ZAstText.eql(self: ZAstText, other: ZAstText) -> bool {
    a: []u8
    a.ptr = self.ptr
    a.len = self.len
    b: []u8
    b.ptr = other.ptr
    b.len = other.len
    return std.str.slice_eql(a, b)
}

fn zast_text_same(a: ZAstText, b: ZAstText) -> bool {
    if a.len != b.len {
        return false
    }
    i: i64 = 0
    while i < a.len {
        if a.ptr[i] != b.ptr[i] {
            return false
        }
        i = i + 1
    }
    return true
}

fn zast_text_parent_path(text: ZAstText) -> ZAstText {
    index: i64 = text.len
    while index > 0 {
        index = index - 1
        if text.ptr[index] == 46 {
            parent: ZAstText
            parent.ptr = text.ptr
            parent.len = index
            return parent
        }
    }
    return ZAstText.empty()
}

fn zast_text_last_path_segment_same(text: ZAstText, segment: ZAstText) -> bool {
    start: i64 = 0
    index: i64 = 0
    while index < text.len {
        if text.ptr[index] == 46 {
            start = index + 1
        }
        index = index + 1
    }
    if text.len - start != segment.len {
        return false
    }
    index = 0
    while index < segment.len {
        if text.ptr[start + index] != segment.ptr[index] {
            return false
        }
        index = index + 1
    }
    return true
}

fn zast_text_from_string(value: string) -> ZAstText {
    text: ZAstText
    text.ptr = cast(*u8, value)
    text.len = std.str.len(value)
    return text
}

fn zast_text_skip_ws(text: ZAstText) -> ZAstText {
    start: i64 = 0
    while start < text.len {
        ch: u8 = text.ptr[start]
        if ch != 32 && ch != 9 && ch != 10 && ch != 13 {
            break
        }
        start = start + 1
    }

    trimmed: ZAstText
    trimmed.ptr = text.ptr + start
    trimmed.len = text.len - start
    return trimmed
}

fn zast_type_text_has_volatile_qualifier(text: ZAstText) -> bool {
    return text.len > 8 && text.ptr[0] == 118 && text.ptr[1] == 111 &&
        text.ptr[2] == 108 && text.ptr[3] == 97 && text.ptr[4] == 116 &&
        text.ptr[5] == 105 && text.ptr[6] == 108 && text.ptr[7] == 101 &&
        (text.ptr[8] == 32 || text.ptr[8] == 9 || text.ptr[8] == 10 || text.ptr[8] == 13 ||
            text.ptr[8] == 42 || text.ptr[8] == 91)
}

fn zast_type_text_unwrap(text: ZAstText) -> ZAstText {
    text = zast_text_skip_ws(text)
    if text.len == 0 {
        return text
    }

    if text.ptr[0] == 33 {
        unwrapped: ZAstText
        unwrapped.ptr = text.ptr + 1
        unwrapped.len = text.len - 1
        return zast_type_text_unwrap(unwrapped)
    }

    if zast_type_text_has_volatile_qualifier(text) {
        unwrapped: ZAstText
        unwrapped.ptr = text.ptr + 8
        unwrapped.len = text.len - 8
        return zast_type_text_unwrap(unwrapped)
    }

    if text.ptr[0] == 42 {
        index: i64 = 0
        while index < text.len && (text.ptr[index] == 42 || text.ptr[index] == 32 || text.ptr[index] == 9 || text.ptr[index] == 10 || text.ptr[index] == 13) {
            index = index + 1
        }
        if index >= text.len {
            return text
        }
        unwrapped: ZAstText
        unwrapped.ptr = text.ptr + index
        unwrapped.len = text.len - index
        return zast_type_text_unwrap(unwrapped)
    }

    if text.ptr[0] == 91 {
        index: i64 = 1
        while index < text.len && text.ptr[index] != 93 {
            index = index + 1
        }
        if index >= text.len {
            return text
        }
        index = index + 1
        while index < text.len && (text.ptr[index] == 32 || text.ptr[index] == 9 || text.ptr[index] == 10 || text.ptr[index] == 13) {
            index = index + 1
        }
        if index >= text.len {
            return text
        }
        unwrapped: ZAstText
        unwrapped.ptr = text.ptr + index
        unwrapped.len = text.len - index
        return zast_type_text_unwrap(unwrapped)
    }

    return text
}

// Preserve nominal generic identity while looking up its declaration. For
// example, `Box<i64>` and `Box<u64>` resolve to `Box` here; concrete argument
// comparison remains the responsibility of generic instantiation.
fn zast_type_text_base(text: ZAstText) -> ZAstText {
    text = zast_type_text_unwrap(text)
    index: i64 = 0
    while index < text.len {
        if text.ptr[index] == 60 {
            base: ZAstText
            base.ptr = text.ptr
            base.len = index
            return zast_text_skip_ws(base)
        }
        index = index + 1
    }
    return text
}

// The parser stores explicit postfix arguments on the expression prefix (for
// example the `Mode` part of `Mode<i64>.Busy`). Compare that retained suffix
// against the expected nominal type without allocating a temporary joined
// `Mode<i64>` string.
fn zast_expr_generic_specializes_type(self: *ZAstModule, prefix_index: i64, expected: ZAstText) -> bool {
    if prefix_index == ZAstNoIndex {
        return false
    }
    expected = zast_text_skip_ws(expected)
    expected_base: ZAstText = zast_type_text_base(expected)
    if expected_base.len >= expected.len {
        return false
    }
    prefix: ZAstExpr = self.exprs[prefix_index]
    if prefix.type_index == ZAstNoIndex || !zast_expr_matches_qualified_name(self, prefix_index, expected_base) {
        return false
    }
    expected_suffix: ZAstText
    expected_suffix.ptr = expected.ptr + expected_base.len
    expected_suffix.len = expected.len - expected_base.len
    return ZAstText.eql(self.types[prefix.type_index].text, expected_suffix)
}

fn zast_decl_generic_param_index(self: *ZAstModule, decl: ZAstDecl, name: ZAstText) -> i64 {
    index: i64 = 0
    while index < decl.generic_param_count {
        if zast_text_same(self.generic_params[decl.generic_param_start + index], name) {
            return index
        }
        index = index + 1
    }
    return ZAstNoIndex
}

fn zast_decl_generic_default_type(self: *ZAstModule, decl: ZAstDecl, generic_index: i64) -> ZAstText {
    if generic_index < 0 || generic_index >= decl.generic_param_count { return ZAstText.empty() }
    type_index: i64 = self.generic_default_types[decl.generic_param_start + generic_index]
    if type_index == ZAstNoIndex { return ZAstText.empty() }
    default_type: ZAstText = zast_decl_type_text(self, type_index)
    linked_index: i64 = zast_decl_generic_param_index(self, decl, default_type)
    if linked_index != ZAstNoIndex && linked_index != generic_index {
        linked_default: ZAstText = zast_decl_generic_default_type(self, decl, linked_index)
        if linked_default.len > 0 { return linked_default }
    }
    return default_type
}

export fn ZAstModule.generic_default_argument(
    self: *ZAstModule,
    declaration: ZAstDecl,
    generic_index: i64
) -> ZAstText {
    return zast_decl_generic_default_type(self, declaration, generic_index)
}

// Return one top-level argument from the retained `<...>` suffix. Nested
// generic arguments may contain their own commas, so only commas at depth
// zero separate arguments.
fn zast_generic_argument_at(suffix: ZAstText, wanted: i64) -> ZAstText {
    suffix = zast_text_skip_ws(suffix)
    if suffix.len < 3 || suffix.ptr[0] != 60 || wanted < 0 {
        return ZAstText.empty()
    }
    depth: i64 = 0
    argument: i64 = 0
    start: i64 = 1
    index: i64 = 1
    while index < suffix.len {
        ch: u8 = suffix.ptr[index]
        if ch == 60 || ch == 40 || ch == 91 { depth = depth + 1 }
        if ch == 62 || ch == 41 || ch == 93 {
            if ch == 62 && depth == 0 {
                if argument == wanted {
                    result: ZAstText
                    result.ptr = suffix.ptr + start
                    result.len = index - start
                    return zast_text_skip_ws(result)
                }
                return ZAstText.empty()
            }
            if depth > 0 { depth = depth - 1 }
        }
        if ch == 44 && depth == 0 {
            if argument == wanted {
                result: ZAstText
                result.ptr = suffix.ptr + start
                result.len = index - start
                return zast_text_skip_ws(result)
            }
            argument = argument + 1
            start = index + 1
        }
        index = index + 1
    }
    return ZAstText.empty()
}

fn zast_generic_argument_count(suffix: ZAstText) -> i64 {
    suffix = zast_text_skip_ws(suffix)
    if suffix.len == 0 { return 0 }
    count: i64 = 0
    while zast_generic_argument_at(suffix, count).len > 0 {
        count = count + 1
    }
    return count
}

fn zast_generic_default_type_known(
    self: *ZAstModule,
    decl: ZAstDecl,
    type_text: ZAstText,
    generic_index: i64
) -> bool {
    type_text = zast_type_text_unwrap(type_text)
    base: ZAstText = zast_type_text_base(type_text)
    parameter_index: i64 = zast_decl_generic_param_index(self, decl, base)
    if parameter_index != ZAstNoIndex {
        return parameter_index < generic_index
    }
    if !zast_is_builtin_type(base) && !zast_is_function_type(base) &&
        ZAstModule.find_decl(self, base) == ZAstNoIndex {
        return false
    }

    suffix: ZAstText = ZAstText.empty()
    if base.len < type_text.len && type_text.ptr[base.len] == 60 {
        suffix.ptr = type_text.ptr + base.len
        suffix.len = type_text.len - base.len
    }
    argument_index: i64 = 0
    argument: ZAstText = zast_generic_argument_at(suffix, argument_index)
    while argument.len > 0 {
        if !zast_generic_default_type_known(
            self, decl, argument, generic_index
        ) {
            return false
        }
        argument_index = argument_index + 1
        argument = zast_generic_argument_at(suffix, argument_index)
    }
    return true
}

fn zast_decl_generic_defaults_valid(self: *ZAstModule, decl: ZAstDecl) -> bool {
    generic_index: i64 = 0
    while generic_index < decl.generic_param_count {
        type_index: i64 = self.generic_default_types[
            decl.generic_param_start + generic_index
        ]
        if type_index != ZAstNoIndex && !zast_generic_default_type_known(
            self, decl, zast_decl_type_text(self, type_index), generic_index
        ) {
            return false
        }
        generic_index = generic_index + 1
    }
    return true
}

// Generic suffixes are retained in the type text. Validate their declaration
// arity and direct argument names without allocating substituted types.
fn zast_type_generic_arguments_valid(self: *ZAstModule, decl: ZAstDecl, type_index: i64) -> bool {
    if type_index == ZAstNoIndex { return true }
    type_text: ZAstText = zast_text_skip_ws(self.types[type_index].text)
    base: ZAstText = zast_type_text_base(type_text)
    if base.len == 0 || zast_is_builtin_type(base) || zast_is_function_type(base) || zast_decl_has_generic_param(self, decl, base) {
        return true
    }
    declaration_index: i64 = ZAstModule.find_decl(self, base)
    if declaration_index == ZAstNoIndex { return true }
    target: ZAstDecl = self.decls[declaration_index]
    // Import projections do not own the source module's generic parameter
    // arena. Their qualified symbol is known, while arity/default validation
    // remains at the import boundary until that metadata is copied.
    if target.is_imported { return true }
    has_suffix: bool = base.len < type_text.len && type_text.ptr[base.len] == 60
    if !has_suffix {
        return target.generic_required_param_count == 0
    }
    suffix: ZAstText
    suffix.ptr = type_text.ptr + base.len
    suffix.len = type_text.len - base.len
    supplied_count: i64 = zast_generic_argument_count(suffix)
    if supplied_count < target.generic_required_param_count || supplied_count > target.generic_param_count {
        return false
    }
    argument_index: i64 = 0
    while argument_index < supplied_count {
        argument: ZAstText = zast_type_text_base(zast_generic_argument_at(suffix, argument_index))
        if argument.len == 0 || (!zast_is_builtin_type(argument) && !zast_decl_has_generic_param(self, decl, argument) && ZAstModule.find_decl(self, argument) == ZAstNoIndex) {
            return false
        }
        argument_index = argument_index + 1
    }
    return true
}

fn zast_call_generic_arguments_valid(self: *ZAstModule, expr: ZAstExpr) -> bool {
    if expr.name.len == 0 || expr.left == ZAstNoIndex { return true }
    function_index: i64 = zast_function_name_known(self, expr.name)
    if function_index == ZAstNoIndex { return true }
    function_decl: ZAstDecl = self.decls[function_index]
    callee: ZAstExpr = self.exprs[expr.left]
    if callee.type_index == ZAstNoIndex {
        return true
    }
    suffix: ZAstText = self.types[callee.type_index].text
    if function_decl.generic_param_count == 0 {
        return false
    }
    supplied_count: i64 = zast_generic_argument_count(suffix)
    return supplied_count >= function_decl.generic_required_param_count && supplied_count <= function_decl.generic_param_count
}

// Resolve the directly returned generic parameter from either an explicit
// suffix or the call argument whose declared parameter is that same generic
// parameter. This is the allocation-free core used by generic `T -> T` and
// `(..., U) -> U` inference.
fn zast_call_direct_generic_result_type(self: *ZAstModule, decl: ZAstDecl, call: ZAstExpr, through_decl: ZAstDecl, through_stmt: i64) -> ZAstText {
    result_type: ZAstText = zast_decl_type_text(self, decl.return_type_index)
    generic_index: i64 = zast_decl_generic_param_index(self, decl, result_type)
    if generic_index == ZAstNoIndex { return ZAstText.empty() }
    if call.left != ZAstNoIndex {
        callee: ZAstExpr = self.exprs[call.left]
        if callee.type_index != ZAstNoIndex {
            explicit_argument: ZAstText = zast_generic_argument_at(self.types[callee.type_index].text, generic_index)
            if explicit_argument.len > 0 { return explicit_argument }
        }
    }
    parameter_index: i64 = 0
    while parameter_index < decl.param_count && parameter_index < call.arg_count {
        parameter_type: ZAstText = zast_decl_type_text(self, self.params[decl.param_start + parameter_index].type_index)
        if zast_decl_generic_param_index(self, decl, parameter_type) == generic_index {
            return zast_expr_type_text(self, through_decl, self.expr_args[call.arg_start + parameter_index], through_stmt)
        }
        if zast_decl_generic_param_index(self, decl, zast_type_text_unwrap(parameter_type)) == generic_index {
            argument_type: ZAstText = zast_expr_type_text(self, through_decl, self.expr_args[call.arg_start + parameter_index], through_stmt)
            return zast_type_text_unwrap(argument_type)
        }
        parameter_index = parameter_index + 1
    }
    return zast_decl_generic_default_type(self, decl, generic_index)
}

// Return the concrete argument selected for one generic call parameter. This
// exposes the checked call's explicit, inferred, or defaulted evidence to
// backend lowering without making lowering reimplement semantic inference.
export fn ZAstModule.call_generic_argument(
    self: *ZAstModule,
    through_declaration: ZAstDecl,
    call: ZAstExpr,
    function_declaration: ZAstDecl,
    generic_index: i64,
    through_statement: i64
) -> ZAstText {
    if generic_index < 0 || generic_index >= function_declaration.generic_param_count {
        return ZAstText.empty()
    }
    if call.left != ZAstNoIndex {
        callee: ZAstExpr = self.exprs[call.left]
        if callee.type_index != ZAstNoIndex {
            explicit_argument: ZAstText = zast_generic_argument_at(
                self.types[callee.type_index].text, generic_index
            )
            if explicit_argument.len > 0 { return explicit_argument }
        }
    }
    generic_name: ZAstText = self.generic_params[
        function_declaration.generic_param_start + generic_index
    ]
    parameter_index: i64 = 0
    while parameter_index < function_declaration.param_count &&
        parameter_index < call.arg_count {
        parameter_type: ZAstText = zast_decl_type_text(
            self,
            self.params[function_declaration.param_start + parameter_index].type_index
        )
        direct_match: bool = zast_text_same(parameter_type, generic_name)
        wrapped_match: bool = zast_text_same(
            zast_type_text_unwrap(parameter_type), generic_name
        )
        if direct_match || wrapped_match {
            argument_type: ZAstText = zast_expr_type_text(
                self,
                through_declaration,
                self.expr_args[call.arg_start + parameter_index],
                through_statement
            )
            if argument_type.len == 0 {
                argument_expression: ZAstExpr = self.exprs[
                    self.expr_args[call.arg_start + parameter_index]
                ]
                if argument_expression.kind == ZAstExprInteger {
                    argument_type = zast_text_from_string("i64")
                }
                if argument_expression.kind == ZAstExprBool {
                    argument_type = zast_text_from_string("bool")
                }
                if argument_expression.kind == ZAstExprString {
                    argument_type = zast_text_from_string("string")
                }
            }
            if wrapped_match && !direct_match {
                argument_type = zast_type_text_unwrap(argument_type)
            }
            if argument_type.len > 0 { return argument_type }
        }
        parameter_index = parameter_index + 1
    }
    return zast_decl_generic_default_type(
        self, function_declaration, generic_index
    )
}

// Resolve a member whose declared type is a direct generic parameter. Wrapped
// forms are handled by their consuming operator (index/dereference) because
// the compact text-slice AST deliberately avoids allocating rewritten types.
fn zast_direct_generic_member_argument(self: *ZAstModule, target_type: ZAstText, target_decl: ZAstDecl, member_type: ZAstText) -> ZAstText {
    member_type = zast_text_skip_ws(member_type)
    // Do not collapse `[N]T`, `*T`, or `[]T` while resolving a field. Their
    // wrapper is semantic information consumed by indexing/dereference.
    if !ZAstText.eql(member_type, zast_type_text_unwrap(member_type)) {
        return ZAstText.empty()
    }
    generic_index: i64 = zast_decl_generic_param_index(self, target_decl, member_type)
    if generic_index == ZAstNoIndex {
        return ZAstText.empty()
    }
    target_type = zast_text_skip_ws(target_type)
    target_base: ZAstText = zast_type_text_base(target_type)
    if target_base.len >= target_type.len {
        return zast_decl_generic_default_type(self, target_decl, generic_index)
    }
    suffix: ZAstText
    suffix.ptr = target_type.ptr + target_base.len
    suffix.len = target_type.len - target_base.len
    return zast_generic_argument_at(suffix, generic_index)
}

fn zast_field_member_declaration(self: *ZAstModule, decl: ZAstDecl, field_index: i64, through_stmt: i64) -> i64 {
    field: ZAstExpr = self.exprs[field_index]
    if field.kind != ZAstExprField || field.left == ZAstNoIndex {
        return ZAstNoIndex
    }
    target_type: ZAstText = zast_type_text_base(zast_expr_type_text(self, decl, field.left, through_stmt))
    target_decl_index: i64 = ZAstModule.find_owning_decl(self, target_type)
    if target_decl_index == ZAstNoIndex { return ZAstNoIndex }
    target_decl: ZAstDecl = self.decls[target_decl_index]
    if target_decl.kind != ZAstDeclStruct && target_decl.kind != ZAstDeclUnion { return ZAstNoIndex }
    member_index: i64 = 0
    while member_index < target_decl.member_count {
        if zast_text_same(self.members[target_decl.member_start + member_index].name, field.name) {
            return target_decl.member_start + member_index
        }
        member_index = member_index + 1
    }
    return ZAstNoIndex
}

fn zast_field_wrapped_generic_element_type(self: *ZAstModule, decl: ZAstDecl, field_index: i64, through_stmt: i64) -> ZAstText {
    field: ZAstExpr = self.exprs[field_index]
    member_index: i64 = zast_field_member_declaration(self, decl, field_index, through_stmt)
    if member_index == ZAstNoIndex { return ZAstText.empty() }
    target_type: ZAstText = zast_expr_type_text(self, decl, field.left, through_stmt)
    target_decl_index: i64 = ZAstModule.find_decl(self, zast_type_text_base(target_type))
    if target_decl_index == ZAstNoIndex { return ZAstText.empty() }
    return zast_direct_generic_member_argument(self, target_type, self.decls[target_decl_index], zast_type_text_unwrap(zast_decl_type_text(self, self.members[member_index].type_index)))
}

// Case patterns are calls in the compact AST (`Value.Number(binding)`). This
// resolves a binding only within that case's child range and substitutes a
// direct generic union member parameter from the concrete pattern suffix.
fn zast_case_pattern_binding_type(self: *ZAstModule, decl: ZAstDecl, name: ZAstText, through_stmt: i64) -> ZAstText {
    query_index: i64 = decl.stmt_start + through_stmt
    stmt_index: i64 = decl.stmt_start
    stmt_end: i64 = decl.stmt_start + decl.stmt_count
    while stmt_index < stmt_end {
        case_stmt: ZAstStmt = self.stmts[stmt_index]
        if case_stmt.kind == ZAstStmtCase && query_index >= case_stmt.child_start && query_index < case_stmt.child_start + case_stmt.child_count && case_stmt.expr_index != ZAstNoIndex {
            pattern: ZAstExpr = self.exprs[case_stmt.expr_index]
            if pattern.kind == ZAstExprCall && pattern.left != ZAstNoIndex {
                arg_index: i64 = 0
                while arg_index < pattern.arg_count {
                    binding: ZAstExpr = self.exprs[self.expr_args[pattern.arg_start + arg_index]]
                    if binding.kind == ZAstExprIdentifier && zast_text_same(binding.name, name) {
                        callee: ZAstExpr = self.exprs[pattern.left]
                        if callee.kind != ZAstExprField || callee.left == ZAstNoIndex { return ZAstText.empty() }
                        union_prefix: ZAstExpr = self.exprs[callee.left]
                        if union_prefix.kind != ZAstExprIdentifier { return ZAstText.empty() }
                        union_index: i64 = ZAstModule.find_decl(self, union_prefix.name)
                        if union_index == ZAstNoIndex || self.decls[union_index].kind != ZAstDeclUnion { return ZAstText.empty() }
                        member_index: i64 = 0
                        while member_index < self.decls[union_index].member_count {
                            member: ZAstMember = self.members[self.decls[union_index].member_start + member_index]
                            if zast_text_same(member.name, callee.name) {
                                member_type: ZAstText = zast_decl_type_text(self, member.type_index)
                                generic_index: i64 = zast_decl_generic_param_index(self, self.decls[union_index], member_type)
                                if generic_index != ZAstNoIndex && union_prefix.type_index != ZAstNoIndex {
                                    return zast_generic_argument_at(self.types[union_prefix.type_index].text, generic_index)
                                }
                                return member_type
                            }
                            member_index = member_index + 1
                        }
                    }
                    arg_index = arg_index + 1
                }
            }
        }
        stmt_index = stmt_index + 1
    }
    return ZAstText.empty()
}

export fn ZAstText.eql_string(self: ZAstText, value: string) -> bool {
    a: []u8
    a.ptr = self.ptr
    a.len = self.len
    b: []u8
    b.ptr = cast(*u8, value)
    b.len = std.str.len(value)
    return std.str.slice_eql(a, b)
}

export fn ZAstDecl.init(kind: i64, exported: bool) -> ZAstDecl {
    return ZAstDecl{
        kind: kind,
        span: ZAstSpan.empty(),
        exported: exported,
        name: ZAstText.empty(),
        path: ZAstText.empty(),
        alias: ZAstText.empty(),
        is_c_import: false,
        is_imported: false,
        canonical_name: ZAstText.empty(),
        type_index: ZAstNoIndex,
        return_type_index: ZAstNoIndex,
        return_is_error_union: false,
        init_expr: ZAstNoIndex,
        attribute_expr: ZAstNoIndex,
        initializer_has_catch: false,
        initializer_catch_span: ZAstSpan.empty(),
        generic_param_start: 0,
        generic_param_count: 0,
        generic_required_param_count: 0,
        has_generic_constraints: false,
        has_explicit_layout: false,
        param_start: 0,
        param_count: 0,
        member_start: 0,
        member_count: 0,
        stmt_start: 0,
        stmt_count: 0,
        local_count: 0,
        return_count: 0,
        call_count: 0,
        binary_count: 0
    }
}

export fn ZAstExpr.init(kind: i64) -> ZAstExpr {
    return ZAstExpr{
        kind: kind,
        span: ZAstSpan.empty(),
        name: ZAstText.empty(),
        literal: ZAstText.empty(),
        op: ZAstNoIndex,
        left: ZAstNoIndex,
        right: ZAstNoIndex,
        type_index: ZAstNoIndex,
        arg_start: 0,
        arg_count: 0,
        field_start: 0
    }
}

export fn ZAstStmt.init(kind: i64) -> ZAstStmt {
    return ZAstStmt{
        kind: kind,
        span: ZAstSpan.empty(),
        name: ZAstText.empty(),
        type_index: ZAstNoIndex,
        expr_index: ZAstNoIndex,
        value_expr: ZAstNoIndex,
        attribute_expr: ZAstNoIndex,
        is_constant: false,
        condition_has_recovery: false,
        recovery_span: ZAstSpan.empty(),
        catch_owner: ZAstNoIndex,
        asm_output_start: 0,
        asm_output_count: 0,
        asm_input_start: 0,
        asm_input_count: 0,
        asm_clobber_start: 0,
        asm_clobber_count: 0,
        for_initializer_count: 0,
        for_update_count: 0,
        child_start: 0,
        child_count: 0
    }
}

fn zast_next_capacity(current: i64, needed: i64) -> i64 {
    capacity: i64 = current
    if capacity < 16 {
        capacity = 16
    }

    while capacity < needed {
        capacity = capacity * 2
    }

    return capacity
}

export fn ZAstModule.init(allocator: *std.mem.HeapAllocator, initial_capacity: i64) !ZAstModule {
    module: ZAstModule = ZAstModule{
        decls: cast(*ZAstDecl, 0),
        len: 0,
        capacity: 0,
        types: cast(*ZAstType, 0),
        type_count: 0,
        type_capacity: 0,
        generic_params: cast(*ZAstText, 0),
        generic_default_types: cast(*i64, 0),
        generic_param_count_total: 0,
        generic_param_capacity: 0,
        params: cast(*ZAstParam, 0),
        param_count_total: 0,
        param_capacity: 0,
        members: cast(*ZAstMember, 0),
        member_count_total: 0,
        member_capacity: 0,
        stmts: cast(*ZAstStmt, 0),
        stmt_count_total: 0,
        stmt_capacity: 0,
        exprs: cast(*ZAstExpr, 0),
        expr_count: 0,
        expr_capacity: 0,
        expr_args: cast(*i64, 0),
        expr_arg_count: 0,
        expr_arg_capacity: 0,
        literal_fields: cast(*ZAstLiteralField, 0),
        literal_field_count: 0,
        literal_field_capacity: 0,
        import_count: 0,
        extern_count: 0,
        error_count: 0,
        const_count: 0,
        global_count: 0,
        struct_count: 0,
        enum_count: 0,
        union_count: 0,
        function_count: 0,
        semantic_error_span: ZAstSpan.empty(),
        semantic_error_category: ZAstSemanticErrorNone
    }

    if initial_capacity < 0 {
        return error.InvalidSize
    }

    if initial_capacity > 0 {
        ZAstModule.reserve(&module, allocator, initial_capacity) catch |err| {
            if err == error.InvalidSize {
                return error.InvalidSize
            }
            return error.OutOfMemory
        }
    }

    return module
}

export fn ZAstModule.reserve(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed < 0 {
        return error.InvalidSize
    }

    if needed <= self.capacity {
        return 0
    }

    new_capacity: i64 = zast_next_capacity(self.capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstDecl)) catch |err| {
        return error.OutOfMemory
    }
    new_decls: *ZAstDecl = cast(*ZAstDecl, raw)

    i: i64 = 0
    while i < self.len {
        new_decls[i] = self.decls[i]
        i = i + 1
    }

    self.decls = new_decls
    self.capacity = new_capacity
    return 0
}

fn zast_reserve_types(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.type_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.type_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstType)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstType = cast(*ZAstType, raw)
    i: i64 = 0
    while i < self.type_count {
        new_items[i] = self.types[i]
        i = i + 1
    }
    self.types = new_items
    self.type_capacity = new_capacity
    return 0
}

fn zast_reserve_params(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.param_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.param_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstParam)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstParam = cast(*ZAstParam, raw)
    i: i64 = 0
    while i < self.param_count_total {
        new_items[i] = self.params[i]
        i = i + 1
    }
    self.params = new_items
    self.param_capacity = new_capacity
    return 0
}

fn zast_reserve_generic_params(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.generic_param_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.generic_param_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstText)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstText = cast(*ZAstText, raw)
    default_raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(i64)) catch |err| {
        return error.OutOfMemory
    }
    new_defaults: *i64 = cast(*i64, default_raw)
    i: i64 = 0
    while i < self.generic_param_count_total {
        new_items[i] = self.generic_params[i]
        new_defaults[i] = self.generic_default_types[i]
        i = i + 1
    }
    self.generic_params = new_items
    self.generic_default_types = new_defaults
    self.generic_param_capacity = new_capacity
    return 0
}

fn zast_reserve_members(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.member_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.member_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstMember)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstMember = cast(*ZAstMember, raw)
    i: i64 = 0
    while i < self.member_count_total {
        new_items[i] = self.members[i]
        i = i + 1
    }
    self.members = new_items
    self.member_capacity = new_capacity
    return 0
}

fn zast_reserve_stmts(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.stmt_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.stmt_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstStmt)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstStmt = cast(*ZAstStmt, raw)
    i: i64 = 0
    while i < self.stmt_count_total {
        new_items[i] = self.stmts[i]
        i = i + 1
    }
    self.stmts = new_items
    self.stmt_capacity = new_capacity
    return 0
}

fn zast_reserve_exprs(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.expr_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.expr_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstExpr)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstExpr = cast(*ZAstExpr, raw)
    i: i64 = 0
    while i < self.expr_count {
        new_items[i] = self.exprs[i]
        i = i + 1
    }
    self.exprs = new_items
    self.expr_capacity = new_capacity
    return 0
}

fn zast_reserve_expr_args(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.expr_arg_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.expr_arg_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(i64)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *i64 = cast(*i64, raw)
    i: i64 = 0
    while i < self.expr_arg_count {
        new_items[i] = self.expr_args[i]
        i = i + 1
    }
    self.expr_args = new_items
    self.expr_arg_capacity = new_capacity
    return 0
}

fn zast_reserve_literal_fields(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.literal_field_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.literal_field_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstLiteralField)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstLiteralField = cast(*ZAstLiteralField, raw)
    i: i64 = 0
    while i < self.literal_field_count {
        new_items[i] = self.literal_fields[i]
        i = i + 1
    }
    self.literal_fields = new_items
    self.literal_field_capacity = new_capacity
    return 0
}

export fn ZAstModule.reserve_arenas(
    self: *ZAstModule,
    allocator: *std.mem.HeapAllocator,
    needed: i64
) !i64 {
    if needed < 0 { return error.InvalidSize }
    ZAstModule.reserve(self, allocator, needed) catch |err| { return err }
    zast_reserve_types(self, allocator, needed) catch |err| { return err }
    zast_reserve_generic_params(self, allocator, needed) catch |err| { return err }
    zast_reserve_params(self, allocator, needed) catch |err| { return err }
    zast_reserve_members(self, allocator, needed) catch |err| { return err }
    zast_reserve_stmts(self, allocator, needed) catch |err| { return err }
    zast_reserve_exprs(self, allocator, needed) catch |err| { return err }
    zast_reserve_expr_args(self, allocator, needed) catch |err| { return err }
    zast_reserve_literal_fields(self, allocator, needed) catch |err| { return err }
    return 0
}

export fn ZAstModule.append_type(self: *ZAstModule, allocator: *std.mem.HeapAllocator, text: ZAstText) !i64 {
    zast_reserve_types(self, allocator, self.type_count + 1) catch |err| {
        return err
    }
    index: i64 = self.type_count
    self.types[index].text = text
    self.types[index].scope_declaration_start = ZAstNoIndex
    self.types[index].scope_statement = ZAstNoIndex
    self.type_count = self.type_count + 1
    return index
}

export fn ZAstModule.append_param(self: *ZAstModule, allocator: *std.mem.HeapAllocator, param: ZAstParam) !i64 {
    zast_reserve_params(self, allocator, self.param_count_total + 1) catch |err| {
        return err
    }
    index: i64 = self.param_count_total
    self.params[index] = param
    self.param_count_total = self.param_count_total + 1
    return index
}

export fn ZAstModule.append_generic_param(self: *ZAstModule, allocator: *std.mem.HeapAllocator, name: ZAstText) !i64 {
    zast_reserve_generic_params(self, allocator, self.generic_param_count_total + 1) catch |err| {
        return err
    }
    index: i64 = self.generic_param_count_total
    self.generic_params[index] = name
    self.generic_default_types[index] = ZAstNoIndex
    self.generic_param_count_total = self.generic_param_count_total + 1
    return index
}

export fn ZAstModule.append_member(self: *ZAstModule, allocator: *std.mem.HeapAllocator, member: ZAstMember) !i64 {
    zast_reserve_members(self, allocator, self.member_count_total + 1) catch |err| {
