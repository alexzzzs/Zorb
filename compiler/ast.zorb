export fn ZAstModule.append_literal_field(self: *ZAstModule, allocator: *std.mem.HeapAllocator, field: ZAstLiteralField) !i64 {
    zast_reserve_literal_fields(self, allocator, self.literal_field_count + 1) catch |err| {
        return err
