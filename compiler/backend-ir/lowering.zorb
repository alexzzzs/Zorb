import "../../runtime/std/errors.zorb"
import "../../runtime/std/collections.zorb"
import "../../runtime/std/mem.zorb"
import "../../runtime/std/str.zorb"
import "../ast.zorb"
import "../token.zorb"
import "model.zorb"

const ZBACKEND_IR_MAX_I64: i64 = 9223372036854775807
const ZBACKEND_IR_INITIAL_BLOCK_CAPACITY: i64 = 8
const ZBACKEND_IR_INITIAL_INSTRUCTION_CAPACITY: i64 = 8
const ZBACKEND_IR_NO_TYPE_ID: i64 = 0
const ZBACKEND_IR_INITIAL_TYPE_CAPACITY: i64 = 16
// Array-to-slice conversion emits zero, index_address, length, aggregate, and
// may materialize a temporary alloca/store for a non-addressable array value.
const ZBACKEND_IR_CONTEXTUAL_COERCION_INSTRUCTION_OVERHEAD: i64 = 6
const ZBACKEND_IR_MAX_CONSTANT_EVALUATION_DEPTH: i64 = 64

struct ZBackendIrTypeLayout {
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    target_triple: string,
    constant_scope_declaration_start: i64,
    constant_scope_statement: i64,
    types: *ZBackendIrType,
    type_count: i64,
    type_capacity: i64,
    bool_type_id: i64,
    error_type_id: i64,
    void_type_id: i64,
    active_generic_declaration: i64,
    active_generic_suffix: ZAstText,
    generic_context_declarations: *i64,
    generic_context_suffixes: *ZAstText,
    generic_context_count: i64,
    generic_context_capacity: i64,
    generic_instance_declarations: *i64,
    generic_instance_suffixes: *ZAstText,
    generic_instance_count: i64,
    concrete_function_count: i64
}

fn zbackend_ir_copy_text(allocator: *std.mem.HeapAllocator, text: ZAstText) !string {
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, text.len + 1) catch |err| {
        return error.OutOfMemory
    }
    index: i64 = 0
    while text.len > index {
        raw[index] = text.ptr[index]
        index = index + 1
    }
    raw[text.len] = 0
    return cast(string, raw)
}

fn zbackend_ir_join_text(
    allocator: *std.mem.HeapAllocator,
    prefix: ZAstText,
    suffix: ZAstText
) !ZAstText {
    raw: *u8 = std.mem.HeapAllocator.alloc(
        allocator, prefix.len + suffix.len + 1
    ) catch |err| { return error.OutOfMemory }
    index: i64 = 0
    while prefix.len > index {
        raw[index] = prefix.ptr[index]
        index = index + 1
    }
    suffix_index: i64 = 0
    while suffix.len > suffix_index {
        raw[index] = suffix.ptr[suffix_index]
        index = index + 1
        suffix_index = suffix_index + 1
    }
    raw[index] = 0
    return ZAstText{ ptr: raw, len: index }
}

fn zbackend_ir_parse_positive_integer(text: ZAstText) !i64 {
    if text.len == 0 { return error.InvalidArgument }
    value: i64 = 0
    index: i64 = 0
    while text.len > index {
        byte: i64 = cast(i64, text.ptr[index])
        if byte < 48 || byte > 57 { return error.InvalidArgument }
        digit: i64 = byte - 48
        if (value > (ZBACKEND_IR_MAX_I64 - digit) / 10) { return error.Overflow }
        value = value * 10 + digit
        index = index + 1
    }
    return value
}

fn zbackend_ir_parse_negative_integer(magnitude: ZAstText) !i64 {
    if ZAstText.eql_string(magnitude, "9223372036854775808") {
        return 0 - ZBACKEND_IR_MAX_I64 - 1
    }
    value: i64 = zbackend_ir_parse_positive_integer(
        magnitude
    ) catch |err| { return err }
    return 0 - value
}

fn zbackend_ir_canonical_declaration_name(ast: *ZAstModule, name: ZAstText) -> ZAstText {
    declaration_index: i64 = ZAstModule.find_decl(ast, name)
    if declaration_index == ZAstNoIndex { return name }
    declaration: ZAstDecl = ast.decls[declaration_index]
    if declaration.is_imported && declaration.canonical_name.len > 0 {
        return declaration.canonical_name
    }
    return name
}

fn zbackend_ir_owning_declaration_index(ast: *ZAstModule, name: ZAstText) -> i64 {
    name = zbackend_ir_canonical_declaration_name(ast, name)
    index: i64 = 0
    while index < ast.len {
        if !ast.decls[index].is_imported && ZAstText.eql(ast.decls[index].name, name) {
            return index
        }
        index = index + 1
    }
    return ZAstNoIndex
}

fn zbackend_ir_type_layout_push_generic_context(
    type_layout: *ZBackendIrTypeLayout,
    declaration_index: i64,
    suffix: ZAstText
) !i64 {
    if type_layout.generic_context_count >= type_layout.generic_context_capacity {
        return error.OutOfBounds
    }
    type_layout.generic_context_declarations[type_layout.generic_context_count] =
        type_layout.active_generic_declaration
    type_layout.generic_context_suffixes[type_layout.generic_context_count] =
        type_layout.active_generic_suffix
    type_layout.generic_context_count = type_layout.generic_context_count + 1
    type_layout.active_generic_declaration = declaration_index
    type_layout.active_generic_suffix = suffix
    return 0
}

fn zbackend_ir_type_layout_pop_generic_context(
    type_layout: *ZBackendIrTypeLayout
) !i64 {
    if type_layout.generic_context_count <= 0 { return error.InvalidArgument }
    type_layout.generic_context_count = type_layout.generic_context_count - 1
    type_layout.active_generic_declaration = type_layout.generic_context_declarations[
        type_layout.generic_context_count
    ]
    type_layout.active_generic_suffix = type_layout.generic_context_suffixes[
        type_layout.generic_context_count
    ]
    return 0
}

fn zbackend_ir_function_count(module: *ZAstModule) -> i64 {
    count: i64 = 0
    index: i64 = 0
    while index < module.len {
        declaration: ZAstDecl = module.decls[index]
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            !declaration.is_imported &&
            declaration.generic_param_count == 0 {
            count = count + 1
        }
        index = index + 1
    }
    return count
}

fn zbackend_ir_global_count(module: *ZAstModule) -> i64 {
    count: i64 = 0
    index: i64 = 0
    while index < module.len {
        declaration: ZAstDecl = module.decls[index]
        if (declaration.kind == ZAstDeclGlobal || declaration.kind == ZAstDeclConst) &&
            !declaration.is_imported {
            count = count + 1
        }
        index = index + 1
    }
    return count
}

fn zbackend_ir_global_declaration(ast: *ZAstModule, name: ZAstText) !ZAstDecl {
    name = zbackend_ir_canonical_declaration_name(ast, name)
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclGlobal || declaration.kind == ZAstDeclConst) &&
            !declaration.is_imported && ZAstText.eql(declaration.name, name) {
            return declaration
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_is_global_name(ast: *ZAstModule, name: ZAstText) -> bool {
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclGlobal || declaration.kind == ZAstDeclConst) &&
            ZAstText.eql(declaration.name, name) {
            return true
        }
        index = index + 1
    }
    return false
}

fn zbackend_ir_global_id(ast: *ZAstModule, name: ZAstText) !i64 {
    name = zbackend_ir_canonical_declaration_name(ast, name)
    global_id: i64 = 1
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclGlobal || declaration.kind == ZAstDeclConst) &&
            !declaration.is_imported {
            if ZAstText.eql(declaration.name, name) { return global_id }
            global_id = global_id + 1
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_resolved_global_name(
    type_layout: *ZBackendIrTypeLayout,
    expression_index: i64
) !ZAstText {
    if expression_index < 0 || expression_index >= type_layout.ast.expr_count {
        return error.InvalidArgument
    }
    expression: ZAstExpr = type_layout.ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier &&
        zbackend_ir_is_global_name(type_layout.ast, expression.name) {
        return zbackend_ir_canonical_declaration_name(
            type_layout.ast, expression.name
        )
    }
    if expression.kind != ZAstExprField { return ZAstText.empty() }
    length: i64 = zbackend_ir_qualified_expression_length(
        type_layout.ast, expression_index
    ) catch |err| { return ZAstText.empty() }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    zbackend_ir_write_qualified_expression(
        type_layout.ast, expression_index, raw, &offset
    ) catch |err| { return ZAstText.empty() }
    raw[length] = 0
    candidate: ZAstText = ZAstText{ ptr: raw, len: length }
    if !zbackend_ir_is_global_name(type_layout.ast, candidate) {
        return ZAstText.empty()
    }
    return zbackend_ir_canonical_declaration_name(
        type_layout.ast, candidate
    )
}

fn zbackend_ir_first_function(module: *ZAstModule) !ZAstDecl {
    index: i64 = 0
    while index < module.len {
        declaration: ZAstDecl = module.decls[index]
        if declaration.kind == ZAstDeclFunction && !declaration.is_imported &&
            declaration.generic_param_count == 0 { return declaration }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_parameter_id(ast: *ZAstModule, declaration: ZAstDecl, name: ZAstText) !i64 {
    index: i64 = 0
    while declaration.param_count > index {
        parameter: ZAstParam = ast.params[declaration.param_start + index]
        if ZAstText.eql(parameter.name, name) { return index + 1 }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_function_id(ast: *ZAstModule, name: ZAstText) !i64 {
    name = zbackend_ir_canonical_declaration_name(ast, name)
    function_id: i64 = 1
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            !declaration.is_imported &&
            declaration.generic_param_count == 0 {
            if ZAstText.eql(declaration.name, name) { return function_id }
            function_id = function_id + 1
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_find_generic_instance_id(
    type_layout: *ZBackendIrTypeLayout,
    declaration_name: ZAstText,
    suffix: ZAstText
) -> i64 {
    declaration_name = zbackend_ir_canonical_declaration_name(
        type_layout.ast, declaration_name
    )
    declaration_index: i64 = zbackend_ir_owning_declaration_index(
        type_layout.ast, declaration_name
    )
    if declaration_index == ZAstNoIndex { return 0 }
    instance_index: i64 = 0
    while instance_index < type_layout.generic_instance_count {
        if type_layout.generic_instance_declarations[instance_index] == declaration_index &&
            ZAstText.eql(type_layout.generic_instance_suffixes[instance_index], suffix) {
            return type_layout.concrete_function_count + instance_index + 1
        }
        instance_index = instance_index + 1
    }
    return 0
}

fn zbackend_ir_generic_instance_id(
    type_layout: *ZBackendIrTypeLayout,
    declaration_name: ZAstText,
    suffix: ZAstText
) !i64 {
    instance_id: i64 = zbackend_ir_find_generic_instance_id(
        type_layout, declaration_name, suffix
    )
    if instance_id == 0 { return error.NotImplemented }
    return instance_id
}

fn zbackend_ir_call_function_id(
    type_layout: *ZBackendIrTypeLayout,
    expression: ZAstExpr,
    generic_suffix: ZAstText
) !i64 {
    if generic_suffix.len > 0 {
        return zbackend_ir_generic_instance_id(
            type_layout, expression.name, generic_suffix
        ) catch |err| { return err }
    }
    if expression.left != ZAstNoIndex {
        callee: ZAstExpr = type_layout.ast.exprs[expression.left]
        if callee.type_index != ZAstNoIndex {
            declaration: ZAstDecl = zbackend_ir_function_declaration(
                type_layout.ast, expression.name
            ) catch |err| { return err }
            if declaration.generic_param_count > 0 {
                return zbackend_ir_generic_instance_id(
                    type_layout,
                    expression.name,
                    type_layout.ast.types[callee.type_index].text
                ) catch |err| { return err }
            }
        }
    }
    return zbackend_ir_function_id(
        type_layout.ast, expression.name
    ) catch |err| { return err }
}

fn zbackend_ir_function_declaration(ast: *ZAstModule, name: ZAstText) !ZAstDecl {
    name = zbackend_ir_canonical_declaration_name(ast, name)
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            !declaration.is_imported && ZAstText.eql(declaration.name, name) {
            return declaration
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_is_function_name(ast: *ZAstModule, name: ZAstText) -> bool {
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            ZAstText.eql(declaration.name, name) {
            return true
        }
        index = index + 1
    }
    return false
}

fn zbackend_ir_name_matches_qualified_suffix(name: ZAstText, suffix: ZAstText) -> bool {
    if ZAstText.eql(name, suffix) { return true }
    if name.len <= suffix.len { return false }
    start: i64 = name.len - suffix.len
    if start <= 0 || name.ptr[start - 1] != 46 { return false }
    return ZAstText.eql(
        ZAstText{ ptr: name.ptr + start, len: suffix.len }, suffix
    )
}

fn zbackend_ir_is_error_name(ast: *ZAstModule, name: ZAstText) -> bool {
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if declaration.kind == ZAstDeclError &&
            zbackend_ir_name_matches_qualified_suffix(name, declaration.name) {
            return true
        }
        index = index + 1
    }
    return false
}

fn zbackend_ir_qualified_expression_length(ast: *ZAstModule, expression_index: i64) !i64 {
    if expression_index < 0 || expression_index >= ast.expr_count { return error.InvalidArgument }
    expression: ZAstExpr = ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier { return expression.name.len }
    if expression.kind != ZAstExprField || expression.left == ZAstNoIndex {
        return error.NotImplemented
    }
    prefix_length: i64 = zbackend_ir_qualified_expression_length(
        ast, expression.left
    ) catch |err| { return err }
    return prefix_length + 1 + expression.name.len
}

fn zbackend_ir_write_qualified_expression(
    ast: *ZAstModule,
    expression_index: i64,
    destination: *u8,
    offset: *i64
) !i64 {
    expression: ZAstExpr = ast.exprs[expression_index]
    if expression.kind == ZAstExprField {
        zbackend_ir_write_qualified_expression(
            ast, expression.left, destination, offset
        ) catch |err| { return err }
        destination[offset[0]] = 46
        offset[0] = offset[0] + 1
    } else if expression.kind != ZAstExprIdentifier {
        return error.NotImplemented
    }
    index: i64 = 0
    while index < expression.name.len {
        destination[offset[0]] = expression.name.ptr[index]
        offset[0] = offset[0] + 1
        index = index + 1
    }
    return 0
}

fn zbackend_ir_resolved_call_name(
    type_layout: *ZBackendIrTypeLayout,
    expression: ZAstExpr
) !ZAstText {
    if zbackend_ir_is_function_name(type_layout.ast, expression.name) {
        return zbackend_ir_canonical_declaration_name(
            type_layout.ast, expression.name
        )
    }
    if expression.left == ZAstNoIndex { return expression.name }
    length: i64 = zbackend_ir_qualified_expression_length(
        type_layout.ast, expression.left
    ) catch |err| { return expression.name }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    zbackend_ir_write_qualified_expression(
        type_layout.ast, expression.left, raw, &offset
    ) catch |err| { return expression.name }
    raw[length] = 0
    candidate: ZAstText = ZAstText{ ptr: raw, len: length }
    if zbackend_ir_is_function_name(type_layout.ast, candidate) {
        return zbackend_ir_canonical_declaration_name(
            type_layout.ast, candidate
        )
    }
    return expression.name
}

fn zbackend_ir_resolved_function_value_name(
    type_layout: *ZBackendIrTypeLayout,
    expression_index: i64
) !ZAstText {
    if expression_index < 0 || expression_index >= type_layout.ast.expr_count {
        return error.InvalidArgument
    }
    expression: ZAstExpr = type_layout.ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier &&
        zbackend_ir_is_function_name(type_layout.ast, expression.name) {
        return zbackend_ir_canonical_declaration_name(
            type_layout.ast, expression.name
        )
    }
    if expression.kind != ZAstExprField { return ZAstText.empty() }
    length: i64 = zbackend_ir_qualified_expression_length(
        type_layout.ast, expression_index
    ) catch |err| { return ZAstText.empty() }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    zbackend_ir_write_qualified_expression(
        type_layout.ast, expression_index, raw, &offset
    ) catch |err| { return ZAstText.empty() }
    raw[length] = 0
    candidate: ZAstText = ZAstText{ ptr: raw, len: length }
    if !zbackend_ir_is_function_name(type_layout.ast, candidate) {
        return ZAstText.empty()
    }
    return zbackend_ir_canonical_declaration_name(
        type_layout.ast, candidate
    )
}

fn zbackend_ir_expression_is_function_value(
    type_layout: *ZBackendIrTypeLayout,
    expression_index: i64
) -> bool {
    resolved: ZAstText = zbackend_ir_resolved_function_value_name(
        type_layout, expression_index
    ) catch |err| { return false }
    return resolved.len > 0
}

fn zbackend_ir_is_builtin_field(ast: *ZAstModule, expression: ZAstExpr) -> bool {
    if expression.kind != ZAstExprField || expression.left == ZAstNoIndex { return false }
    base: ZAstExpr = ast.exprs[expression.left]
    return base.kind == ZAstExprIdentifier && ZAstText.eql_string(base.name, "Builtin")
}

fn zbackend_ir_is_builtin_sizeof(ast: *ZAstModule, expression: ZAstExpr) -> bool {
    if expression.kind != ZAstExprCall || expression.left == ZAstNoIndex { return false }
    callee: ZAstExpr = ast.exprs[expression.left]
    return zbackend_ir_is_builtin_field(ast, callee) && ZAstText.eql_string(callee.name, "sizeof")
}

fn zbackend_ir_string_contains(value: string, part: string) -> bool {
    value_len: i64 = std.str.len(value)
    part_len: i64 = std.str.len(part)
    if part_len == 0 { return true }
    value_ptr: *u8 = cast(*u8, value)
    part_ptr: *u8 = cast(*u8, part)
    start: i64 = 0
    while start + part_len <= value_len {
        index: i64 = 0
        while index < part_len && value_ptr[start + index] == part_ptr[index] {
            index = index + 1
        }
        if index == part_len { return true }
        start = start + 1
    }
    return false
}

fn zbackend_ir_builtin_platform_value(type_layout: *ZBackendIrTypeLayout, name: ZAstText) !i64 {
    triple: string = type_layout.target_triple
    if ZAstText.eql_string(name, "IsX86_64") {
        if std.str.starts_with(triple, "x86_64") { return 1 }
        return 0
    }
    if ZAstText.eql_string(name, "IsAArch64") {
        if std.str.starts_with(triple, "aarch64") { return 1 }
        return 0
    }
    if ZAstText.eql_string(name, "IsLinux") {
        if zbackend_ir_string_contains(triple, "linux") { return 1 }
        return 0
    }
    if ZAstText.eql_string(name, "IsWindows") {
        if zbackend_ir_string_contains(triple, "windows") { return 1 }
        return 0
    }
    if ZAstText.eql_string(name, "IsMacOS") {
        if zbackend_ir_string_contains(triple, "darwin") ||
            zbackend_ir_string_contains(triple, "macos") { return 1 }
        return 0
    }
    if ZAstText.eql_string(name, "IsBareMetal") {
        if zbackend_ir_string_contains(triple, "none") { return 1 }
        if zbackend_ir_string_contains(triple, "bare") { return 1 }
        if zbackend_ir_string_contains(triple, "freestanding") { return 1 }
        return 0
    }
    return error.NotImplemented
}

fn zbackend_ir_constant_bool_expression(
    type_layout: *ZBackendIrTypeLayout,
    ast: *ZAstModule,
    expression_index: i64
) -> i64 {
    if expression_index < 0 || expression_index >= ast.expr_count { return -1 }
    expression: ZAstExpr = ast.exprs[expression_index]
    if expression.kind == ZAstExprBool {
        if expression.literal.len == 4 { return 1 }
        return 0
    }
    if expression.kind == ZAstExprField && zbackend_ir_is_builtin_field(ast, expression) {
        return zbackend_ir_builtin_platform_value(
            type_layout, expression.name
        ) catch |err| { return -1 }
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenBang {
        operand: i64 = zbackend_ir_constant_bool_expression(
            type_layout, ast, expression.left
        )
        if operand < 0 { return -1 }
        if operand == 0 { return 1 }
        return 0
    }
    if expression.kind == ZAstExprBinary && expression.op == ZTokenAndAnd {
        lhs: i64 = zbackend_ir_constant_bool_expression(type_layout, ast, expression.left)
        if lhs == 0 { return 0 }
        if lhs < 0 { return -1 }
        return zbackend_ir_constant_bool_expression(type_layout, ast, expression.right)
    }
    if expression.kind == ZAstExprBinary && expression.op == ZTokenOrOr {
        lhs: i64 = zbackend_ir_constant_bool_expression(type_layout, ast, expression.left)
        if lhs == 1 { return 1 }
        if lhs < 0 { return -1 }
        return zbackend_ir_constant_bool_expression(type_layout, ast, expression.right)
    }
    return -1
}

fn zbackend_ir_expression_is_error_union_call(
    type_layout: *ZBackendIrTypeLayout,
    expression: ZAstExpr
) -> bool {
    if expression.kind != ZAstExprCall || expression.name.len == 0 { return false }
    resolved_name: ZAstText = zbackend_ir_resolved_call_name(
        type_layout, expression
    ) catch |err| { return false }
    declaration: ZAstDecl = zbackend_ir_function_declaration(
        type_layout.ast, resolved_name
    ) catch |err| {
        return false
    }
    return declaration.return_is_error_union
}

fn zbackend_ir_supported_scalar_name(text: ZAstText) !string {
    if ZAstText.eql_string(text, "bool") { return "bool" }
    if ZAstText.eql_string(text, "i8") { return "i8" }
    if ZAstText.eql_string(text, "u8") { return "u8" }
    if ZAstText.eql_string(text, "i16") { return "i16" }
    if ZAstText.eql_string(text, "u16") { return "u16" }
    if ZAstText.eql_string(text, "i32") { return "i32" }
    if ZAstText.eql_string(text, "u32") { return "u32" }
    if ZAstText.eql_string(text, "i64") { return "i64" }
    if ZAstText.eql_string(text, "u64") { return "u64" }
    return error.NotImplemented
}

fn zbackend_ir_is_supported_scalar_text(text: ZAstText) -> bool {
    return ZAstText.eql_string(text, "bool") || ZAstText.eql_string(text, "i8") ||
        ZAstText.eql_string(text, "u8") || ZAstText.eql_string(text, "i16") ||
        ZAstText.eql_string(text, "u16") || ZAstText.eql_string(text, "i32") ||
        ZAstText.eql_string(text, "u32") || ZAstText.eql_string(text, "i64") ||
        ZAstText.eql_string(text, "u64")
}

fn zbackend_ir_is_slice_type_text(text: ZAstText) -> bool {
    text = zbackend_ir_trim_type_text(text)
    return text.len > 2 && text.ptr[0] == 91 && text.ptr[1] == 93
}

fn zbackend_ir_is_function_type_text(text: ZAstText) -> bool {
    text = zbackend_ir_trim_type_text(text)
    return text.len >= 3 && text.ptr[0] == 102 && text.ptr[1] == 110 && text.ptr[2] == 40
}

fn zbackend_ir_function_type_param_count(text: ZAstText) -> i64 {
    text = zbackend_ir_trim_type_text(text)
    index: i64 = 3
    if index < text.len && text.ptr[index] == 41 { return 0 }
    count: i64 = 1
    paren_depth: i64 = 1
    bracket_depth: i64 = 0
    angle_depth: i64 = 0
    while index < text.len {
        if text.ptr[index] == 40 { paren_depth = paren_depth + 1 }
        if text.ptr[index] == 41 {
            paren_depth = paren_depth - 1
            if paren_depth == 0 { return count }
        }
        if text.ptr[index] == 91 { bracket_depth = bracket_depth + 1 }
        if text.ptr[index] == 93 && bracket_depth > 0 { bracket_depth = bracket_depth - 1 }
        if text.ptr[index] == 60 { angle_depth = angle_depth + 1 }
        if text.ptr[index] == 62 && angle_depth > 0 { angle_depth = angle_depth - 1 }
        if text.ptr[index] == 44 && paren_depth == 1 && bracket_depth == 0 && angle_depth == 0 {
            count = count + 1
        }
        index = index + 1
    }
    return -1
}

fn zbackend_ir_function_type_param(text: ZAstText, wanted: i64) -> ZAstText {
    text = zbackend_ir_trim_type_text(text)
    start: i64 = 3
    index: i64 = start
    current: i64 = 0
    paren_depth: i64 = 1
    bracket_depth: i64 = 0
    angle_depth: i64 = 0
    while index < text.len {
        if text.ptr[index] == 40 { paren_depth = paren_depth + 1 }
        if text.ptr[index] == 41 {
            paren_depth = paren_depth - 1
            if paren_depth == 0 {
                if current == wanted {
                    return zbackend_ir_trim_type_text(ZAstText{
                        ptr: text.ptr + start, len: index - start
                    })
                }
                return ZAstText.empty()
            }
        }
        if text.ptr[index] == 91 { bracket_depth = bracket_depth + 1 }
        if text.ptr[index] == 93 && bracket_depth > 0 { bracket_depth = bracket_depth - 1 }
        if text.ptr[index] == 60 { angle_depth = angle_depth + 1 }
        if text.ptr[index] == 62 && angle_depth > 0 { angle_depth = angle_depth - 1 }
        if text.ptr[index] == 44 && paren_depth == 1 && bracket_depth == 0 && angle_depth == 0 {
            if current == wanted {
                return zbackend_ir_trim_type_text(ZAstText{
                    ptr: text.ptr + start, len: index - start
                })
            }
            current = current + 1
            start = index + 1
        }
        index = index + 1
    }
    return ZAstText.empty()
}

fn zbackend_ir_function_type_return(text: ZAstText) -> ZAstText {
    text = zbackend_ir_trim_type_text(text)
    index: i64 = 2
    paren_depth: i64 = 0
    while index + 1 < text.len {
        if text.ptr[index] == 40 { paren_depth = paren_depth + 1 }
        if text.ptr[index] == 41 && paren_depth > 0 { paren_depth = paren_depth - 1 }
        if paren_depth == 0 && text.ptr[index] == 45 && text.ptr[index + 1] == 62 {
            return zbackend_ir_trim_type_text(ZAstText{
                ptr: text.ptr + index + 2,
                len: text.len - index - 2
            })
        }
        index = index + 1
    }
    return ZAstText.empty()
}

fn zbackend_ir_trim_type_text(text: ZAstText) -> ZAstText {
    start: i64 = 0
    while start < text.len && (text.ptr[start] == 32 || text.ptr[start] == 9 ||
        text.ptr[start] == 10 || text.ptr[start] == 13) {
        start = start + 1
    }
    end: i64 = text.len
    while end > start && (text.ptr[end - 1] == 32 || text.ptr[end - 1] == 9 ||
        text.ptr[end - 1] == 10 || text.ptr[end - 1] == 13) {
        end = end - 1
    }
    return ZAstText{ ptr: text.ptr + start, len: end - start }
}

fn zbackend_ir_volatile_payload(text: ZAstText) -> ZAstText {
    text = zbackend_ir_trim_type_text(text)
    if text.len <= 8 || text.ptr[0] != 118 || text.ptr[1] != 111 ||
        text.ptr[2] != 108 || text.ptr[3] != 97 || text.ptr[4] != 116 ||
        text.ptr[5] != 105 || text.ptr[6] != 108 || text.ptr[7] != 101 {
        return ZAstText.empty()
    }
    boundary: u8 = text.ptr[8]
    if boundary != 32 && boundary != 9 && boundary != 10 && boundary != 13 &&
        boundary != 42 && boundary != 91 {
        return ZAstText.empty()
    }
    return zbackend_ir_trim_type_text(ZAstText{
        ptr: text.ptr + 8, len: text.len - 8
    })
}

fn zbackend_ir_nominal_base(text: ZAstText) -> ZAstText {
    text = zbackend_ir_trim_type_text(text)
    index: i64 = 0
    while index < text.len {
        if text.ptr[index] == 60 {
            return zbackend_ir_trim_type_text(ZAstText{
                ptr: text.ptr, len: index
            })
        }
        index = index + 1
    }
    return text
}

fn zbackend_ir_nominal_suffix(text: ZAstText) -> ZAstText {
    text = zbackend_ir_trim_type_text(text)
    index: i64 = 0
    while index < text.len {
        if text.ptr[index] == 60 {
            return ZAstText{ ptr: text.ptr + index, len: text.len - index }
        }
        index = index + 1
    }
    return ZAstText.empty()
}

fn zbackend_ir_generic_argument_at(suffix: ZAstText, wanted: i64) -> ZAstText {
    suffix = zbackend_ir_trim_type_text(suffix)
    if suffix.len < 3 || suffix.ptr[0] != 60 || wanted < 0 { return ZAstText.empty() }
    depth: i64 = 0
    argument: i64 = 0
    start: i64 = 1
    index: i64 = 1
    while index < suffix.len {
        ch: u8 = suffix.ptr[index]
        if ch == 60 || ch == 40 || ch == 91 { depth = depth + 1 }
        if ch == 62 || ch == 41 || ch == 93 {
            if ch == 62 && depth == 0 {
                if argument == wanted {
                    return zbackend_ir_trim_type_text(ZAstText{
                        ptr: suffix.ptr + start, len: index - start
                    })
                }
                return ZAstText.empty()
            }
            if depth > 0 { depth = depth - 1 }
        }
        if ch == 44 && depth == 0 {
            if argument == wanted {
                return zbackend_ir_trim_type_text(ZAstText{
                    ptr: suffix.ptr + start, len: index - start
                })
            }
            argument = argument + 1
            start = index + 1
        }
        index = index + 1
    }
    return ZAstText.empty()
}

// Resolve a generic parameter forwarded by the active monomorphization. A
// replacement may itself name a parameter in the parent generic context.
fn zbackend_ir_resolve_active_generic_argument(
    type_layout: *ZBackendIrTypeLayout,
    argument: ZAstText
) -> ZAstText {
    declaration_index: i64 = type_layout.active_generic_declaration
    suffix: ZAstText = type_layout.active_generic_suffix
    parent_count: i64 = type_layout.generic_context_count
    while declaration_index != ZAstNoIndex {
        declaration: ZAstDecl = type_layout.ast.decls[declaration_index]
        generic_index: i64 = zbackend_ir_generic_parameter_index(
            type_layout.ast, declaration, argument
        )
        if generic_index == ZAstNoIndex { return argument }
        replacement: ZAstText = zbackend_ir_generic_argument_at(
            suffix, generic_index
        )
        if replacement.len == 0 { return ZAstText.empty() }
        argument = replacement
        if parent_count <= 0 { return argument }
        parent_count = parent_count - 1
        declaration_index = type_layout.generic_context_declarations[parent_count]
        suffix = type_layout.generic_context_suffixes[parent_count]
    }
    return argument
}

fn zbackend_ir_resolve_call_generic_suffix(
    type_layout: *ZBackendIrTypeLayout,
    through_declaration: ZAstDecl,
    call: ZAstExpr,
    function_declaration: ZAstDecl,
    through_statement: i64
) !ZAstText {
    if function_declaration.generic_param_count <= 0 { return ZAstText.empty() }
    total_length: i64 = 2
    generic_index: i64 = 0
    while generic_index < function_declaration.generic_param_count {
        argument: ZAstText = ZAstModule.call_generic_argument(
            type_layout.ast,
            through_declaration,
            call,
            function_declaration,
            generic_index,
            through_statement
        )
        argument = zbackend_ir_resolve_active_generic_argument(
            type_layout, argument
        )
        if argument.len == 0 { return error.InvalidArgument }
        total_length = total_length + argument.len
        if generic_index > 0 { total_length = total_length + 1 }
        generic_index = generic_index + 1
    }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, total_length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    raw[offset] = 60
    offset = offset + 1
    generic_index = 0
    while generic_index < function_declaration.generic_param_count {
        if generic_index > 0 {
            raw[offset] = 44
            offset = offset + 1
        }
        argument: ZAstText = ZAstModule.call_generic_argument(
            type_layout.ast,
            through_declaration,
            call,
            function_declaration,
            generic_index,
            through_statement
        )
        argument = zbackend_ir_resolve_active_generic_argument(
            type_layout, argument
        )
        if argument.len == 0 { return error.InvalidArgument }
        argument_index: i64 = 0
        while argument_index < argument.len {
            raw[offset] = argument.ptr[argument_index]
            offset = offset + 1
            argument_index = argument_index + 1
        }
        generic_index = generic_index + 1
    }
    raw[offset] = 62
    raw[offset + 1] = 0
    return ZAstText{ ptr: raw, len: offset + 1 }
}

fn zbackend_ir_default_generic_suffix(
    type_layout: *ZBackendIrTypeLayout,
    declaration: ZAstDecl
) !ZAstText {
    total_length: i64 = 2
    generic_index: i64 = 0
    while generic_index < declaration.generic_param_count {
        argument: ZAstText = ZAstModule.generic_default_argument(
            type_layout.ast, declaration, generic_index
        )
        if argument.len == 0 { return error.InvalidArgument }
        total_length = total_length + argument.len
        if generic_index > 0 { total_length = total_length + 1 }
        generic_index = generic_index + 1
    }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, total_length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    raw[offset] = 60
    offset = offset + 1
    generic_index = 0
    while generic_index < declaration.generic_param_count {
        if generic_index > 0 {
            raw[offset] = 44
            offset = offset + 1
        }
        argument: ZAstText = ZAstModule.generic_default_argument(
            type_layout.ast, declaration, generic_index
        )
        argument_index: i64 = 0
        while argument_index < argument.len {
            raw[offset] = argument.ptr[argument_index]
            offset = offset + 1
            argument_index = argument_index + 1
        }
        generic_index = generic_index + 1
    }
    raw[offset] = 62
    raw[offset + 1] = 0
    return ZAstText{ ptr: raw, len: offset + 1 }
}

fn zbackend_ir_complete_generic_suffix(
    type_layout: *ZBackendIrTypeLayout,
    declaration: ZAstDecl,
    suffix: ZAstText
) !ZAstText {
    supplied_count: i64 = 0
    while zbackend_ir_generic_argument_at(suffix, supplied_count).len > 0 {
        supplied_count = supplied_count + 1
    }
    if supplied_count < declaration.generic_required_param_count ||
        supplied_count > declaration.generic_param_count {
        return error.InvalidArgument
    }
    if supplied_count == declaration.generic_param_count { return suffix }
    total_length: i64 = 2
    generic_index: i64 = 0
    while generic_index < declaration.generic_param_count {
        argument: ZAstText = ZAstText.empty()
        if generic_index < supplied_count {
            argument = zbackend_ir_generic_argument_at(suffix, generic_index)
        } else {
            argument = ZAstModule.generic_default_argument(
                type_layout.ast, declaration, generic_index
            )
        }
        if argument.len == 0 { return error.InvalidArgument }
        total_length = total_length + argument.len
        if generic_index > 0 { total_length = total_length + 1 }
        generic_index = generic_index + 1
    }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, total_length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    raw[offset] = 60
    offset = offset + 1
    generic_index = 0
    while generic_index < declaration.generic_param_count {
        if generic_index > 0 {
            raw[offset] = 44
            offset = offset + 1
        }
        argument: ZAstText = ZAstText.empty()
        if generic_index < supplied_count {
            argument = zbackend_ir_generic_argument_at(suffix, generic_index)
        } else {
            argument = ZAstModule.generic_default_argument(
                type_layout.ast, declaration, generic_index
            )
        }
        argument_index: i64 = 0
        while argument_index < argument.len {
            raw[offset] = argument.ptr[argument_index]
            offset = offset + 1
            argument_index = argument_index + 1
        }
        generic_index = generic_index + 1
    }
    raw[offset] = 62
    raw[offset + 1] = 0
    return ZAstText{ ptr: raw, len: offset + 1 }
}

fn zbackend_ir_type_id_text(
    type_layout: *ZBackendIrTypeLayout,
    type_id: i64
) -> ZAstText {
    if type_id <= 0 || type_id > type_layout.type_count { return ZAstText.empty() }
    item: ZBackendIrType = type_layout.types[type_id - 1]
    if item.scalar != "" {
        return ZAstText{ ptr: cast(*u8, item.scalar), len: std.str.len(item.scalar) }
    }
    if item.name != "" {
        return ZAstText{ ptr: cast(*u8, item.name), len: std.str.len(item.name) }
    }
    return ZAstText.empty()
}

fn zbackend_ir_function_value_generic_suffix(
    type_layout: *ZBackendIrTypeLayout,
    declaration: ZAstDecl,
    function_type_id: i64
) !ZAstText {
    if function_type_id <= 0 || function_type_id > type_layout.type_count {
        return error.InvalidArgument
    }
    function_type: ZBackendIrType = type_layout.types[function_type_id - 1]
    if function_type.kind != "function" ||
        function_type.field_count != declaration.param_count {
        return error.InvalidArgument
    }
    arguments_raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator,
        declaration.generic_param_count * Builtin.sizeof(ZAstText)
    ) catch |err| { return error.OutOfMemory }
    arguments: *ZAstText = cast(*ZAstText, arguments_raw)
    total_length: i64 = 2
    generic_index: i64 = 0
    while generic_index < declaration.generic_param_count {
        generic_name: ZAstText = type_layout.ast.generic_params[
            declaration.generic_param_start + generic_index
        ]
        argument: ZAstText = ZAstText.empty()
        parameter_index: i64 = 0
        while parameter_index < declaration.param_count {
            parameter: ZAstParam = type_layout.ast.params[
                declaration.param_start + parameter_index
            ]
            if ZAstText.eql(
                zbackend_ir_trim_type_text(type_layout.ast.types[parameter.type_index].text),
                generic_name
            ) {
                argument = zbackend_ir_type_id_text(
                    type_layout, function_type.fields[parameter_index].type_id
                )
            }
            parameter_index = parameter_index + 1
        }
        if argument.len == 0 && declaration.return_type_index != ZAstNoIndex &&
            ZAstText.eql(
                zbackend_ir_trim_type_text(
                    type_layout.ast.types[declaration.return_type_index].text
                ),
                generic_name
            ) {
            argument = zbackend_ir_type_id_text(
                type_layout, function_type.element_type
            )
        }
        if argument.len == 0 {
            argument = ZAstModule.generic_default_argument(
                type_layout.ast, declaration, generic_index
            )
        }
        if argument.len == 0 { return error.InvalidArgument }
        arguments[generic_index] = argument
        total_length = total_length + argument.len
        if generic_index > 0 { total_length = total_length + 1 }
        generic_index = generic_index + 1
    }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, total_length + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    raw[offset] = 60
    offset = offset + 1
    generic_index = 0
    while generic_index < declaration.generic_param_count {
        if generic_index > 0 {
            raw[offset] = 44
            offset = offset + 1
        }
        argument_index: i64 = 0
        while argument_index < arguments[generic_index].len {
            raw[offset] = arguments[generic_index].ptr[argument_index]
            offset = offset + 1
            argument_index = argument_index + 1
        }
        generic_index = generic_index + 1
    }
    raw[offset] = 62
    raw[offset + 1] = 0
    return ZAstText{ ptr: raw, len: offset + 1 }
}

fn zbackend_ir_generic_parameter_index(
    ast: *ZAstModule,
    declaration: ZAstDecl,
    text: ZAstText
) -> i64 {
    index: i64 = 0
    while index < declaration.generic_param_count {
        if ZAstText.eql(
            ast.generic_params[declaration.generic_param_start + index],
            zbackend_ir_trim_type_text(text)
        ) { return index }
        index = index + 1
    }
    return ZAstNoIndex
}

fn zbackend_ir_append_generic_instance(
    type_layout: *ZBackendIrTypeLayout,
    declaration_index: i64,
    suffix: ZAstText
) !i64 {
    if suffix.len == 0 { return error.InvalidArgument }
    instance_index: i64 = 0
    while instance_index < type_layout.generic_instance_count {
        if type_layout.generic_instance_declarations[instance_index] == declaration_index &&
            ZAstText.eql(type_layout.generic_instance_suffixes[instance_index], suffix) {
            return 0
        }
        instance_index = instance_index + 1
    }
    if type_layout.generic_instance_count >= type_layout.ast.expr_count {
        return error.OutOfBounds
    }
    type_layout.generic_instance_declarations[type_layout.generic_instance_count] = declaration_index
    type_layout.generic_instance_suffixes[type_layout.generic_instance_count] = suffix
    type_layout.generic_instance_count = type_layout.generic_instance_count + 1
    return 0
}

fn zbackend_ir_ensure_generic_instance_id(
    type_layout: *ZBackendIrTypeLayout,
    declaration_name: ZAstText,
    suffix: ZAstText
) !i64 {
    existing: i64 = zbackend_ir_find_generic_instance_id(
        type_layout, declaration_name, suffix
    )
    if existing > 0 { return existing }
    declaration_index: i64 = zbackend_ir_owning_declaration_index(
        type_layout.ast, declaration_name
    )
    if declaration_index == ZAstNoIndex { return error.InvalidArgument }
    zbackend_ir_append_generic_instance(
        type_layout, declaration_index, suffix
    ) catch |err| { return err }
    return zbackend_ir_generic_instance_id(
        type_layout, declaration_name, suffix
    ) catch |err| { return err }
}

fn zbackend_ir_register_generic_calls_in_expression(
    type_layout: *ZBackendIrTypeLayout,
    through_declaration: ZAstDecl,
    through_statement: i64,
    root_expression: i64,
    stack: *i64,
    visited: *i64,
    generation: i64
) !i64 {
    if root_expression == ZAstNoIndex { return 0 }
    if root_expression < 0 || root_expression >= type_layout.ast.expr_count {
        return error.InvalidArgument
    }
    stack_count: i64 = 1
    stack[0] = root_expression
    visited[root_expression] = generation
    while stack_count > 0 {
        stack_count = stack_count - 1
        expression_index: i64 = stack[stack_count]
        if expression_index < 0 || expression_index >= type_layout.ast.expr_count {
            return error.InvalidArgument
        }
        expression: ZAstExpr = type_layout.ast.exprs[expression_index]
        if expression.kind == ZAstExprCall {
            resolved_name: ZAstText = zbackend_ir_resolved_call_name(
                type_layout, expression
            ) catch |err| { return err }
            if zbackend_ir_is_function_name(type_layout.ast, resolved_name) {
                function_declaration: ZAstDecl = zbackend_ir_function_declaration(
                    type_layout.ast, resolved_name
                ) catch |err| { return err }
                if function_declaration.generic_param_count > 0 {
                expression.name = resolved_name
                declaration_index: i64 = zbackend_ir_owning_declaration_index(
                    type_layout.ast, resolved_name
                )
                if declaration_index == ZAstNoIndex { return error.InvalidArgument }
                suffix: ZAstText = zbackend_ir_resolve_call_generic_suffix(
                    type_layout,
                    through_declaration,
                    expression,
                    function_declaration,
                    through_statement
                ) catch |err| { return err }
                zbackend_ir_append_generic_instance(
                    type_layout, declaration_index, suffix
                ) catch |err| { return err }
                }
            }
        }
        if expression.left != ZAstNoIndex {
            if expression.left < 0 || expression.left >= type_layout.ast.expr_count {
                return error.InvalidArgument
            }
            if visited[expression.left] != generation {
                if stack_count >= type_layout.ast.expr_count { return error.OutOfBounds }
                visited[expression.left] = generation
                stack[stack_count] = expression.left
                stack_count = stack_count + 1
            }
        }
        if expression.right != ZAstNoIndex {
            if expression.right < 0 || expression.right >= type_layout.ast.expr_count {
                return error.InvalidArgument
            }
            if visited[expression.right] != generation {
                if stack_count >= type_layout.ast.expr_count { return error.OutOfBounds }
                visited[expression.right] = generation
                stack[stack_count] = expression.right
                stack_count = stack_count + 1
            }
        }
        argument_index: i64 = 0
        while argument_index < expression.arg_count {
            child_expression: i64 = type_layout.ast.expr_args[
                expression.arg_start + argument_index
            ]
            if child_expression < 0 || child_expression >= type_layout.ast.expr_count {
                return error.InvalidArgument
            }
            if visited[child_expression] != generation {
                if stack_count >= type_layout.ast.expr_count { return error.OutOfBounds }
                visited[child_expression] = generation
                stack[stack_count] = child_expression
                stack_count = stack_count + 1
            }
            argument_index = argument_index + 1
        }
        literal_field_index: i64 = ZAstNoIndex
        if expression.kind == ZAstExprStructLiteral {
            literal_field_index = expression.field_start
        }
        while literal_field_index != ZAstNoIndex {
            if literal_field_index < 0 ||
                literal_field_index >= type_layout.ast.literal_field_count {
                return error.InvalidArgument
            }
            literal_field: ZAstLiteralField = type_layout.ast.literal_fields[literal_field_index]
            if literal_field.value_expr < 0 ||
                literal_field.value_expr >= type_layout.ast.expr_count {
                return error.InvalidArgument
            }
            if visited[literal_field.value_expr] != generation {
                if stack_count >= type_layout.ast.expr_count { return error.OutOfBounds }
                visited[literal_field.value_expr] = generation
                stack[stack_count] = literal_field.value_expr
                stack_count = stack_count + 1
            }
            literal_field_index = literal_field.next_index
        }
    }
    return 0
}

fn zbackend_ir_register_generic_calls_in_statement(
    type_layout: *ZBackendIrTypeLayout,
    through_declaration: ZAstDecl,
    through_statement: i64,
    statement: ZAstStmt,
    stack: *i64,
    visited: *i64,
    generation: i64
) !i64 {
    zbackend_ir_register_generic_calls_in_expression(
        type_layout, through_declaration, through_statement,
        statement.expr_index, stack, visited, generation
    ) catch |err| { return err }
    generation = generation + 1
    zbackend_ir_register_generic_calls_in_expression(
        type_layout, through_declaration, through_statement,
        statement.value_expr, stack, visited, generation
    ) catch |err| { return err }
    generation = generation + 1
    zbackend_ir_register_generic_calls_in_expression(
        type_layout, through_declaration, through_statement,
        statement.attribute_expr, stack, visited, generation
    ) catch |err| { return err }
    return generation + 1
}

fn zbackend_ir_register_generic_instances(type_layout: *ZBackendIrTypeLayout) !i64 {
    capacity: i64 = type_layout.ast.expr_count
    if capacity <= 0 { return 0 }
    declarations_raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, capacity * Builtin.sizeof(i64)
    ) catch |err| { return error.OutOfMemory }
    suffixes_raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, capacity * Builtin.sizeof(ZAstText)
    ) catch |err| { return error.OutOfMemory }
    type_layout.generic_instance_declarations = cast(*i64, declarations_raw)
    type_layout.generic_instance_suffixes = cast(*ZAstText, suffixes_raw)
    expression_index: i64 = 0
    while expression_index < type_layout.ast.expr_count {
        expression: *ZAstExpr = type_layout.ast.exprs + expression_index
        candidate: *ZAstExpr = expression
        declaration_name: ZAstText = expression[0].name
        if expression[0].kind == ZAstExprCall && expression[0].left >= 0 &&
            expression[0].left < type_layout.ast.expr_count {
            candidate = type_layout.ast.exprs + expression[0].left
            declaration_name = zbackend_ir_resolved_call_name(
                type_layout, expression[0]
            ) catch |err| { return err }
        }
        if expression[0].kind != ZAstExprCall &&
            (candidate[0].kind == ZAstExprIdentifier || candidate[0].kind == ZAstExprField) &&
            candidate[0].type_index >= 0 && candidate[0].type_index < type_layout.ast.type_count {
            declaration_index: i64 = zbackend_ir_owning_declaration_index(
                type_layout.ast, declaration_name
            )
            if declaration_index != ZAstNoIndex {
                declaration: ZAstDecl = type_layout.ast.decls[declaration_index]
                if declaration.kind == ZAstDeclFunction && declaration.generic_param_count > 0 {
                    suffix: ZAstText = type_layout.ast.types[candidate[0].type_index].text
                    if zbackend_ir_generic_argument_at(
                        suffix, declaration.generic_param_count - 1
                    ).len == 0 || zbackend_ir_generic_argument_at(
                        suffix, declaration.generic_param_count
                    ).len > 0 {
                        expression_index = expression_index + 1
                        continue
                    }
                    duplicate: bool = false
                    instance_index: i64 = 0
                    while instance_index < type_layout.generic_instance_count {
                        if type_layout.generic_instance_declarations[instance_index] == declaration_index &&
                            ZAstText.eql(type_layout.generic_instance_suffixes[instance_index], suffix) {
                            duplicate = true
                        }
                        instance_index = instance_index + 1
                    }
                    if !duplicate {
                        type_layout.generic_instance_declarations[type_layout.generic_instance_count] = declaration_index
                        type_layout.generic_instance_suffixes[type_layout.generic_instance_count] = suffix
                        type_layout.generic_instance_count = type_layout.generic_instance_count + 1
                    }
                }
            }
        }
        expression_index = expression_index + 1
    }
    stack_raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, type_layout.ast.expr_count * Builtin.sizeof(i64)
    ) catch |err| { return error.OutOfMemory }
    stack: *i64 = cast(*i64, stack_raw)
    visited_raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, type_layout.ast.expr_count * Builtin.sizeof(i64)
    ) catch |err| { return error.OutOfMemory }
    visited: *i64 = cast(*i64, visited_raw)
    visited_index: i64 = 0
    while visited_index < type_layout.ast.expr_count {
        visited[visited_index] = 0
        visited_index = visited_index + 1
    }
    generation: i64 = 1
    declaration_scan_index: i64 = 0
    while declaration_scan_index < type_layout.ast.len {
        through_declaration: ZAstDecl = type_layout.ast.decls[declaration_scan_index]
        if through_declaration.kind == ZAstDeclFunction &&
            !through_declaration.is_imported &&
            through_declaration.generic_param_count == 0 {
            statement_index: i64 = through_declaration.stmt_start
            statement_end: i64 = through_declaration.stmt_start +
                through_declaration.stmt_count
            while statement_index < statement_end {
                statement: ZAstStmt = type_layout.ast.stmts[statement_index]
                through_statement: i64 = statement_index - through_declaration.stmt_start
                generation = zbackend_ir_register_generic_calls_in_statement(
                    type_layout, through_declaration, through_statement,
                    statement, stack, visited, generation
                ) catch |err| { return err }
                statement_index = statement_index + 1
            }
        }
        declaration_scan_index = declaration_scan_index + 1
    }
    // Generic bodies must be scanned in a concrete monomorphization context.
    // Scanning their template expressions above would register suffixes such
    // as <T>; walking the growing instance list instead discovers <i64> and
    // transitively reaches any further forwarded generic calls.
    instance_index: i64 = 0
    while instance_index < type_layout.generic_instance_count {
        instance_declaration_index: i64 =
            type_layout.generic_instance_declarations[instance_index]
        through_declaration: ZAstDecl =
            type_layout.ast.decls[instance_declaration_index]
        type_layout.active_generic_declaration = instance_declaration_index
        type_layout.active_generic_suffix =
            type_layout.generic_instance_suffixes[instance_index]
        statement_index: i64 = through_declaration.stmt_start
        statement_end: i64 = through_declaration.stmt_start +
            through_declaration.stmt_count
        while statement_index < statement_end {
            statement: ZAstStmt = type_layout.ast.stmts[statement_index]
            through_statement: i64 = statement_index - through_declaration.stmt_start
            generation = zbackend_ir_register_generic_calls_in_statement(
                type_layout, through_declaration, through_statement,
                statement, stack, visited, generation
            ) catch |err| { return err }
            statement_index = statement_index + 1
        }
        instance_index = instance_index + 1
    }
    type_layout.active_generic_declaration = ZAstNoIndex
    type_layout.active_generic_suffix = ZAstText.empty()
    return 0
}

fn zbackend_ir_eval_constant_integer(
    ast: *ZAstModule,
    expression_index: i64,
    remaining_depth: i64,
    scope_declaration_start: i64,
    scope_statement: i64
) !i64 {
    if expression_index == ZAstNoIndex || remaining_depth <= 0 {
        return error.InvalidArgument
    }
    expression: ZAstExpr = ast.exprs[expression_index]
    if expression.kind == ZAstExprInteger {
        return zbackend_ir_parse_positive_integer(expression.literal) catch |err| { return err }
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenMinus {
        if expression.left != ZAstNoIndex &&
            ast.exprs[expression.left].kind == ZAstExprInteger {
            return zbackend_ir_parse_negative_integer(
                ast.exprs[expression.left].literal
            ) catch |err| { return err }
        }
        value: i64 = zbackend_ir_eval_constant_integer(
            ast, expression.left, remaining_depth - 1,
            scope_declaration_start, scope_statement
        ) catch |err| { return err }
        return 0 - value
    }
    if expression.kind == ZAstExprIdentifier {
        declaration_index: i64 = ZAstModule.find_decl(ast, expression.name)
        if declaration_index != ZAstNoIndex && ast.decls[declaration_index].kind == ZAstDeclConst {
            return zbackend_ir_eval_constant_integer(
                ast, ast.decls[declaration_index].init_expr, remaining_depth - 1,
                scope_declaration_start, scope_statement
            ) catch |err| { return err }
        }
        local_expression: i64 = ZAstModule.local_constant_expression(
            ast, scope_declaration_start, scope_statement, expression.name
        )
        if local_expression != ZAstNoIndex {
            return zbackend_ir_eval_constant_integer(
                ast, local_expression, remaining_depth - 1,
                scope_declaration_start, scope_statement
            ) catch |err| { return err }
        }
        return error.NotImplemented
    }
    if expression.kind == ZAstExprBinary {
        lhs: i64 = zbackend_ir_eval_constant_integer(
            ast, expression.left, remaining_depth - 1,
            scope_declaration_start, scope_statement
        ) catch |err| { return err }
        rhs: i64 = zbackend_ir_eval_constant_integer(
            ast, expression.right, remaining_depth - 1,
            scope_declaration_start, scope_statement
        ) catch |err| { return err }
        if expression.op == ZTokenPlus { return lhs + rhs }
        if expression.op == ZTokenMinus { return lhs - rhs }
        if expression.op == ZTokenStar { return lhs * rhs }
        if expression.op == ZTokenSlash {
            if rhs == 0 { return error.InvalidArgument }
            return lhs / rhs
        }
        if expression.op == ZTokenPercent {
            if rhs == 0 { return error.InvalidArgument }
            return lhs % rhs
        }
    }
    return error.NotImplemented
}

fn zbackend_ir_constant_integer_for_name(
    ast: *ZAstModule,
    name: ZAstText,
    scope_declaration_start: i64,
    scope_statement: i64
) !i64 {
    declaration_index: i64 = ZAstModule.find_decl(ast, name)
    if declaration_index != ZAstNoIndex && ast.decls[declaration_index].kind == ZAstDeclConst {
        return zbackend_ir_eval_constant_integer(
            ast, ast.decls[declaration_index].init_expr,
            ZBACKEND_IR_MAX_CONSTANT_EVALUATION_DEPTH,
            scope_declaration_start, scope_statement
        ) catch |err| { return err }
    }
    local_expression: i64 = ZAstModule.local_constant_expression(
        ast, scope_declaration_start, scope_statement, name
    )
    if local_expression != ZAstNoIndex {
        return zbackend_ir_eval_constant_integer(
            ast, local_expression,
            ZBACKEND_IR_MAX_CONSTANT_EVALUATION_DEPTH,
            scope_declaration_start, scope_statement
        ) catch |err| { return err }
    }
    return error.NotImplemented
}

fn zbackend_ir_eval_integer_text(
    ast: *ZAstModule,
    text: ZAstText,
    scope_declaration_start: i64,
    scope_statement: i64
) !i64 {
    text = zbackend_ir_trim_type_text(text)
    if text.len == 0 { return error.InvalidArgument }
    outer_group: bool = false
    if text.ptr[0] == 40 && text.ptr[text.len - 1] == 41 {
        group_depth: i64 = 0
        group_index: i64 = 0
        while group_index < text.len {
            if text.ptr[group_index] == 40 { group_depth = group_depth + 1 }
            if text.ptr[group_index] == 41 { group_depth = group_depth - 1 }
            if group_depth == 0 {
                outer_group = group_index == text.len - 1
                break
            }
            group_index = group_index + 1
        }
    }
    if outer_group {
        return zbackend_ir_eval_integer_text(
            ast, ZAstText{ ptr: text.ptr + 1, len: text.len - 2 },
            scope_declaration_start, scope_statement
        ) catch |err| { return err }
    }
    depth: i64 = 0
    index: i64 = text.len
    while index > 0 {
        index = index - 1
        ch: u8 = text.ptr[index]
        if ch == 41 { depth = depth + 1 }
        if ch == 40 { depth = depth - 1 }
        if depth == 0 && index > 0 && (ch == 43 || ch == 45) {
            lhs: i64 = zbackend_ir_eval_integer_text(
                ast, ZAstText{ ptr: text.ptr, len: index },
                scope_declaration_start, scope_statement
            ) catch |err| { return err }
            rhs: i64 = zbackend_ir_eval_integer_text(
                ast, ZAstText{ ptr: text.ptr + index + 1, len: text.len - index - 1 },
                scope_declaration_start, scope_statement
            ) catch |err| { return err }
            if ch == 43 { return lhs + rhs }
            return lhs - rhs
        }
    }
    depth = 0
    index = text.len
    while index > 0 {
        index = index - 1
        ch: u8 = text.ptr[index]
        if ch == 41 { depth = depth + 1 }
        if ch == 40 { depth = depth - 1 }
        if depth == 0 && (ch == 42 || ch == 47 || ch == 37) {
            lhs: i64 = zbackend_ir_eval_integer_text(
                ast, ZAstText{ ptr: text.ptr, len: index },
                scope_declaration_start, scope_statement
            ) catch |err| { return err }
            rhs: i64 = zbackend_ir_eval_integer_text(
                ast, ZAstText{ ptr: text.ptr + index + 1, len: text.len - index - 1 },
                scope_declaration_start, scope_statement
            ) catch |err| { return err }
            if ch == 42 { return lhs * rhs }
            if rhs == 0 { return error.InvalidArgument }
            if ch == 47 { return lhs / rhs }
            return lhs % rhs
        }
    }
    // Split literals from identifiers before invoking either fallible helper.
    // Besides avoiding exception-driven parsing, this keeps the recovery path
    // flat for self-hosted lowering (a catch nested inside another catch would
    // otherwise obscure the call that resolves a named constant).
    if text.ptr[0] >= 48 && text.ptr[0] <= 57 {
        return zbackend_ir_parse_positive_integer(text) catch |err| { return err }
    }
    return zbackend_ir_constant_integer_for_name(
        ast, text, scope_declaration_start, scope_statement
    ) catch |name_err| { return error.InvalidArgument }
}

fn zbackend_ir_array_type_parts(
    type_layout: *ZBackendIrTypeLayout,
    text: ZAstText,
    element: *ZAstText,
    length: *i64
) -> bool {
    text = zbackend_ir_trim_type_text(text)
    if text.len < 4 || text.ptr[0] != 91 { return false }
    close: i64 = 1
    while close < text.len && text.ptr[close] != 93 { close = close + 1 }
    if close <= 1 || close >= text.len - 1 { return false }
    length_text: ZAstText = ZAstText{ ptr: text.ptr + 1, len: close - 1 }
    parsed_length: i64 = zbackend_ir_eval_integer_text(
        type_layout.ast, length_text,
        type_layout.constant_scope_declaration_start,
        type_layout.constant_scope_statement
    ) catch |err| { return false }
    if parsed_length <= 0 { return false }
    element[0] = zbackend_ir_trim_type_text(ZAstText{
        ptr: text.ptr + close + 1,
        len: text.len - close - 1
    })
    if element.len == 0 { return false }
    length[0] = parsed_length
    return true
}

fn zbackend_ir_is_supported_type_text(type_layout: *ZBackendIrTypeLayout, text: ZAstText) -> bool {
    text = zbackend_ir_trim_type_text(text)
    if zbackend_ir_is_supported_scalar_text(text) { return true }
    if ZAstText.eql_string(text, "string") { return true }
    if zbackend_ir_is_slice_type_text(text) {
        return zbackend_ir_is_supported_type_text(type_layout, ZAstText{
            ptr: text.ptr + 2, len: text.len - 2
        })
    }
    if text.len > 1 && text.ptr[0] == 42 {
        return zbackend_ir_is_supported_type_text(type_layout, ZAstText{
            ptr: text.ptr + 1, len: text.len - 1
        })
    }
    element: ZAstText = ZAstText.empty()
    length: i64 = 0
    if zbackend_ir_array_type_parts(type_layout, text, &element, &length) {
        return zbackend_ir_is_supported_type_text(type_layout, element)
    }
    return false
}

fn zbackend_ir_scalar_name_is_signed(name: string) -> bool {
    return name == "i8" || name == "i16" || name == "i32" || name == "i64"
}

fn zbackend_ir_scalar_bit_width(name: string) -> i64 {
    if name == "bool" || name == "i32" || name == "u32" { return 32 }
    if name == "i8" || name == "u8" { return 8 }
    if name == "i16" || name == "u16" { return 16 }
    if name == "i64" || name == "u64" { return 64 }
    return 0
}

fn zbackend_ir_type_layout_reserve(
    type_layout: *ZBackendIrTypeLayout,
    needed: i64
) !i64 {
    if needed <= type_layout.type_capacity { return 0 }
    new_capacity: i64 = type_layout.type_capacity
    if new_capacity < ZBACKEND_IR_INITIAL_TYPE_CAPACITY {
        new_capacity = ZBACKEND_IR_INITIAL_TYPE_CAPACITY
    }
    while new_capacity < needed { new_capacity = new_capacity * 2 }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, new_capacity * Builtin.sizeof(ZBackendIrType)
    ) catch |err| { return error.OutOfMemory }
    new_types: *ZBackendIrType = cast(*ZBackendIrType, raw)
    index: i64 = 0
    while index < type_layout.type_count {
        new_types[index] = type_layout.types[index]
        index = index + 1
    }
    type_layout.types = new_types
    type_layout.type_capacity = new_capacity
    return 0
}

fn zbackend_ir_type_layout_find_scalar(
    type_layout: *ZBackendIrTypeLayout,
    scalar_name: string
) -> i64 {
    index: i64 = 0
    while index < type_layout.type_count {
        item: ZBackendIrType = type_layout.types[index]
        if item.kind == "scalar" && item.scalar == scalar_name { return item.id }
        index = index + 1
    }
    return ZBACKEND_IR_NO_TYPE_ID
}

fn zbackend_ir_type_layout_intern_scalar(
    type_layout: *ZBackendIrTypeLayout,
    scalar_name: string
) !i64 {
    existing: i64 = zbackend_ir_type_layout_find_scalar(type_layout, scalar_name)
    if existing != ZBACKEND_IR_NO_TYPE_ID { return existing }
    zbackend_ir_type_layout_reserve(
        type_layout, type_layout.type_count + 1
    ) catch |err| { return err }
    id: i64 = type_layout.type_count + 1
    type_layout.types[type_layout.type_count] = ZBackendIrType{
        id: id,
        kind: "scalar",
        name: "",
        scalar: scalar_name,
        element_type: ZBACKEND_IR_NO_TYPE_ID,
        length: 0,
        fields: cast(*ZBackendIrTypeField, 0),
        field_count: 0,
        is_packed: false
    }
    type_layout.type_count = type_layout.type_count + 1
    return id
}

fn zbackend_ir_type_layout_find_derived(
    type_layout: *ZBackendIrTypeLayout,
    kind: string,
    element_type: i64,
    length: i64
) -> i64 {
    index: i64 = 0
    while index < type_layout.type_count {
        item: ZBackendIrType = type_layout.types[index]
        if item.kind == kind && item.element_type == element_type && item.length == length {
            return item.id
        }
        index = index + 1
    }
    return ZBACKEND_IR_NO_TYPE_ID
}

fn zbackend_ir_type_layout_intern_derived(
    type_layout: *ZBackendIrTypeLayout,
    kind: string,
    element_type: i64,
    length: i64
) !i64 {
    existing: i64 = zbackend_ir_type_layout_find_derived(
        type_layout, kind, element_type, length
    )
    if existing != ZBACKEND_IR_NO_TYPE_ID { return existing }
    zbackend_ir_type_layout_reserve(
        type_layout, type_layout.type_count + 1
    ) catch |err| { return err }
    id: i64 = type_layout.type_count + 1
    name: string = ""
    if kind == "slice" {
        builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
            type_layout.allocator, 24
        ) catch |err| { return error.OutOfMemory }
        std.collections.StringBuilder.append(
            &builder, type_layout.allocator, "zorb.slice."
        ) catch |err| { return error.OutOfMemory }
        std.collections.StringBuilder.append_i64(
            &builder, type_layout.allocator, id
        ) catch |err| { return error.OutOfMemory }
        name = cast(string, std.collections.StringBuilder.c_string(
            &builder, type_layout.allocator
        ) catch |err| { return error.OutOfMemory })
    }
    type_layout.types[type_layout.type_count] = ZBackendIrType{
        id: id,
        kind: kind,
        name: name,
        scalar: "",
        element_type: element_type,
        length: length,
        fields: cast(*ZBackendIrTypeField, 0),
        field_count: 0,
        is_packed: false
    }
    type_layout.type_count = type_layout.type_count + 1
    return id
}

fn zbackend_ir_type_layout_find_named(
    type_layout: *ZBackendIrTypeLayout,
    name: ZAstText
) -> i64 {
    index: i64 = 0
    while index < type_layout.type_count {
        item: ZBackendIrType = type_layout.types[index]
        if item.name != "" && ZAstText.eql_string(name, item.name) { return item.id }
        index = index + 1
    }
    return ZBACKEND_IR_NO_TYPE_ID
}

fn zbackend_ir_specialize_nominal_text(
    type_layout: *ZBackendIrTypeLayout,
    text: ZAstText
) !ZAstText {
    suffix: ZAstText = zbackend_ir_nominal_suffix(text)
    if suffix.len == 0 || type_layout.active_generic_declaration == ZAstNoIndex {
        return text
    }
    declaration: ZAstDecl = type_layout.ast.decls[
        type_layout.active_generic_declaration
    ]
    changed: bool = false
    total_length: i64 = zbackend_ir_nominal_base(text).len + 2
    argument_count: i64 = 0
    while true {
        argument: ZAstText = zbackend_ir_generic_argument_at(suffix, argument_count)
        if argument.len == 0 { break }
        generic_index: i64 = zbackend_ir_generic_parameter_index(
            type_layout.ast, declaration, argument
        )
        if generic_index != ZAstNoIndex {
            replacement: ZAstText = zbackend_ir_generic_argument_at(
                type_layout.active_generic_suffix, generic_index
            )
            if replacement.len == 0 { return error.InvalidArgument }
            argument = replacement
            changed = true
        }
        total_length = total_length + argument.len
        if argument_count > 0 { total_length = total_length + 1 }
        argument_count = argument_count + 1
    }
    if !changed || argument_count == 0 { return text }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, total_length + 1
    ) catch |err| { return error.OutOfMemory }
    base: ZAstText = zbackend_ir_nominal_base(text)
    offset: i64 = 0
    index: i64 = 0
    while index < base.len {
        raw[offset] = base.ptr[index]
        offset = offset + 1
        index = index + 1
    }
    raw[offset] = 60
    offset = offset + 1
    index = 0
    while index < argument_count {
        if index > 0 {
            raw[offset] = 44
            offset = offset + 1
        }
        argument: ZAstText = zbackend_ir_generic_argument_at(suffix, index)
        generic_index: i64 = zbackend_ir_generic_parameter_index(
            type_layout.ast, declaration, argument
        )
        if generic_index != ZAstNoIndex {
            argument = zbackend_ir_generic_argument_at(
                type_layout.active_generic_suffix, generic_index
            )
        }
        argument_index: i64 = 0
        while argument_index < argument.len {
            raw[offset] = argument.ptr[argument_index]
            offset = offset + 1
            argument_index = argument_index + 1
        }
        index = index + 1
    }
    raw[offset] = 62
    raw[offset + 1] = 0
    return ZAstText{ ptr: raw, len: offset + 1 }
}

fn zbackend_ir_type_layout_intern_nominal(
    type_layout: *ZBackendIrTypeLayout,
    text: ZAstText
) !i64 {
    text = zbackend_ir_specialize_nominal_text(
        type_layout, text
    ) catch |err| { return err }
    base_text: ZAstText = zbackend_ir_nominal_base(text)
    suffix: ZAstText = zbackend_ir_nominal_suffix(text)
    base_text = zbackend_ir_canonical_declaration_name(
        type_layout.ast, base_text
    )
    declaration_index: i64 = zbackend_ir_owning_declaration_index(
        type_layout.ast, base_text
    )
    if declaration_index == ZAstNoIndex { return error.NotImplemented }
    declaration: ZAstDecl = type_layout.ast.decls[declaration_index]
    kind: string = ""
    if declaration.kind == ZAstDeclStruct { kind = "struct" }
    if declaration.kind == ZAstDeclEnum { kind = "enum" }
    if declaration.kind == ZAstDeclUnion { kind = "union" }
    if declaration.kind == ZAstDeclExternType {
        return zbackend_ir_type_layout_intern_scalar(
            type_layout, "i64"
        ) catch |err| { return err }
    }
    if kind == "" { return error.NotImplemented }
    if declaration.generic_param_count > 0 && suffix.len == 0 {
        if declaration.generic_required_param_count > 0 { return error.InvalidArgument }
        suffix = zbackend_ir_default_generic_suffix(
            type_layout, declaration
        ) catch |err| { return err }
    }
    if declaration.generic_param_count > 0 && suffix.len > 0 {
        suffix = zbackend_ir_complete_generic_suffix(
            type_layout, declaration, suffix
        ) catch |err| { return err }
    }
    if declaration.generic_param_count == 0 && suffix.len > 0 { return error.InvalidArgument }
    canonical_text: ZAstText = base_text
    if suffix.len > 0 {
        canonical_text = zbackend_ir_join_text(
            type_layout.allocator, base_text, suffix
        ) catch |err| { return err }
    }
    existing: i64 = zbackend_ir_type_layout_find_named(
        type_layout, canonical_text
    )
    if existing != ZBACKEND_IR_NO_TYPE_ID { return existing }
    zbackend_ir_type_layout_reserve(
        type_layout, type_layout.type_count + 1
    ) catch |err| { return err }
    id: i64 = type_layout.type_count + 1
    owned_name: string = zbackend_ir_copy_text(
        type_layout.allocator, canonical_text
    ) catch |err| { return err }
    type_layout.types[type_layout.type_count] = ZBackendIrType{
        id: id,
        kind: kind,
        name: owned_name,
        scalar: "",
        element_type: ZBACKEND_IR_NO_TYPE_ID,
        length: 0,
        fields: cast(*ZBackendIrTypeField, 0),
        field_count: 0,
        is_packed: false
    }
    type_layout.type_count = type_layout.type_count + 1
    pushed_generic_context: bool = false
    if declaration.generic_param_count > 0 {
        zbackend_ir_type_layout_push_generic_context(
            type_layout, declaration_index, suffix
        ) catch |err| { return err }
        pushed_generic_context = true
    }
    if declaration.kind == ZAstDeclEnum {
        if declaration.type_index == ZAstNoIndex { return error.InvalidArgument }
        underlying_type: i64 = zbackend_ir_type_layout_intern_text(
            type_layout, type_layout.ast.types[declaration.type_index].text
        ) catch |err| { return err }
        type_layout.types[id - 1].element_type = underlying_type
        if pushed_generic_context {
            zbackend_ir_type_layout_pop_generic_context(type_layout) catch |err| { return err }
        }
        return id
    }
    fields: *ZBackendIrTypeField = cast(*ZBackendIrTypeField, 0)
    if declaration.member_count > 0 {
        raw: *u8 = std.mem.HeapAllocator.alloc(
            type_layout.allocator,
            declaration.member_count * Builtin.sizeof(ZBackendIrTypeField)
        ) catch |err| { return error.OutOfMemory }
        fields = cast(*ZBackendIrTypeField, raw)
    }
    type_layout.types[id - 1].fields = fields
    type_layout.types[id - 1].field_count = declaration.member_count
    member_index: i64 = 0
    while member_index < declaration.member_count {
        member: ZAstMember = type_layout.ast.members[declaration.member_start + member_index]
        if member.type_index == ZAstNoIndex { return error.InvalidArgument }
        fields[member_index] = ZBackendIrTypeField{
            name: zbackend_ir_copy_text(
                type_layout.allocator, member.name
            ) catch |err| { return err },
            type_id: zbackend_ir_type_layout_intern_text(
                type_layout, type_layout.ast.types[member.type_index].text
            ) catch |err| { return err }
        }
        member_index = member_index + 1
    }
    if pushed_generic_context {
        zbackend_ir_type_layout_pop_generic_context(type_layout) catch |err| { return err }
    }
    return id
}

fn zbackend_ir_type_layout_intern_function(
    type_layout: *ZBackendIrTypeLayout,
    text: ZAstText
) !i64 {
    parameter_count: i64 = zbackend_ir_function_type_param_count(text)
    if parameter_count < 0 { return error.InvalidArgument }
    return_text: ZAstText = zbackend_ir_function_type_return(text)
    if return_text.len == 0 { return error.InvalidArgument }
    return_type_id: i64 = zbackend_ir_type_layout_intern_text(
        type_layout, return_text
    ) catch |err| { return err }
    parameter_type_ids: *i64 = cast(*i64, 0)
    if parameter_count > 0 {
        raw: *u8 = std.mem.HeapAllocator.alloc(
            type_layout.allocator, parameter_count * Builtin.sizeof(i64)
        ) catch |err| { return error.OutOfMemory }
        parameter_type_ids = cast(*i64, raw)
        parameter_index: i64 = 0
        while parameter_index < parameter_count {
            parameter_type_ids[parameter_index] = zbackend_ir_type_layout_intern_text(
                type_layout, zbackend_ir_function_type_param(text, parameter_index)
            ) catch |err| { return err }
            parameter_index = parameter_index + 1
        }
    }
    existing_index: i64 = 0
    while existing_index < type_layout.type_count {
        existing: ZBackendIrType = type_layout.types[existing_index]
        if existing.kind == "function" && existing.element_type == return_type_id &&
            existing.field_count == parameter_count {
            matches: bool = true
            parameter_index: i64 = 0
            while parameter_index < parameter_count {
                if existing.fields[parameter_index].type_id != parameter_type_ids[parameter_index] {
                    matches = false
                }
                parameter_index = parameter_index + 1
            }
            if matches { return existing.id }
        }
        existing_index = existing_index + 1
    }
    zbackend_ir_type_layout_reserve(
        type_layout, type_layout.type_count + 1
    ) catch |err| { return err }
    id: i64 = type_layout.type_count + 1
    fields: *ZBackendIrTypeField = cast(*ZBackendIrTypeField, 0)
    if parameter_count > 0 {
        fields_raw: *u8 = std.mem.HeapAllocator.alloc(
            type_layout.allocator, parameter_count * Builtin.sizeof(ZBackendIrTypeField)
        ) catch |err| { return error.OutOfMemory }
        fields = cast(*ZBackendIrTypeField, fields_raw)
        parameter_index: i64 = 0
        while parameter_index < parameter_count {
            fields[parameter_index] = ZBackendIrTypeField{
                name: "",
                type_id: parameter_type_ids[parameter_index]
            }
            parameter_index = parameter_index + 1
        }
    }
    builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
        type_layout.allocator, 20
    ) catch |err| { return error.OutOfMemory }
    std.collections.StringBuilder.append(
        &builder, type_layout.allocator, "zorb.fn."
    ) catch |err| { return error.OutOfMemory }
    std.collections.StringBuilder.append_i64(
        &builder, type_layout.allocator, id
    ) catch |err| { return error.OutOfMemory }
    name: string = cast(string, std.collections.StringBuilder.c_string(
        &builder, type_layout.allocator
    ) catch |err| { return error.OutOfMemory })
    type_layout.types[type_layout.type_count] = ZBackendIrType{
        id: id,
        kind: "function",
        name: name,
        scalar: "",
        element_type: return_type_id,
        length: 0,
        fields: fields,
        field_count: parameter_count,
        is_packed: false
    }
    type_layout.type_count = type_layout.type_count + 1
    return id
}

fn zbackend_ir_type_layout_intern_text(
    type_layout: *ZBackendIrTypeLayout,
    text: ZAstText
) !i64 {
    text = zbackend_ir_trim_type_text(text)
    volatile_payload: ZAstText = zbackend_ir_volatile_payload(text)
    if volatile_payload.len > 0 {
        return zbackend_ir_type_layout_intern_text(
            type_layout, volatile_payload
        ) catch |err| { return err }
    }
    if type_layout.active_generic_declaration != ZAstNoIndex {
        declaration: ZAstDecl = type_layout.ast.decls[type_layout.active_generic_declaration]
        generic_index: i64 = zbackend_ir_generic_parameter_index(
            type_layout.ast, declaration, text
        )
        if generic_index != ZAstNoIndex {
            argument: ZAstText = zbackend_ir_generic_argument_at(
                type_layout.active_generic_suffix, generic_index
            )
            if argument.len == 0 { return error.InvalidArgument }
            current_declaration: i64 = type_layout.active_generic_declaration
            current_suffix: ZAstText = type_layout.active_generic_suffix
            use_parent_context: bool = ZAstText.eql(argument, text) &&
                type_layout.generic_context_count > 0
            if ZAstText.eql(argument, text) && !use_parent_context {
                return error.InvalidArgument
            }
            if use_parent_context {
                parent_index: i64 = type_layout.generic_context_count - 1
                type_layout.active_generic_declaration =
                    type_layout.generic_context_declarations[parent_index]
                type_layout.active_generic_suffix =
                    type_layout.generic_context_suffixes[parent_index]
            }
            result: i64 = zbackend_ir_type_layout_intern_text(
                type_layout, argument
            ) catch |err| { return err }
            if use_parent_context {
                type_layout.active_generic_declaration = current_declaration
                type_layout.active_generic_suffix = current_suffix
            }
            return result
        }
    }
    if ZAstText.eql_string(text, "void") {
        if type_layout.void_type_id == ZBACKEND_IR_NO_TYPE_ID {
            type_layout.void_type_id = zbackend_ir_type_layout_intern_scalar(
                type_layout, "void"
            ) catch |err| { return err }
        }
        return type_layout.void_type_id
    }
    if zbackend_ir_is_supported_scalar_text(text) {
        scalar_name: string = zbackend_ir_supported_scalar_name(text) catch |err| { return err }
        return zbackend_ir_type_layout_intern_scalar(
            type_layout, scalar_name
        ) catch |err| { return err }
    }
    if ZAstText.eql_string(text, "string") {
        u8_type: i64 = zbackend_ir_type_layout_intern_scalar(
            type_layout, "u8"
        ) catch |err| { return err }
        return zbackend_ir_type_layout_intern_derived(
            type_layout, "string", u8_type, 0
        ) catch |err| { return err }
    }
    if text.len > 1 && text.ptr[0] == 33 {
        if type_layout.error_type_id == ZBACKEND_IR_NO_TYPE_ID {
            type_layout.error_type_id = zbackend_ir_type_layout_intern_scalar(
                type_layout, "i32"
            ) catch |err| { return err }
        }
        payload_type_id: i64 = zbackend_ir_type_layout_intern_text(
            type_layout, ZAstText{ ptr: text.ptr + 1, len: text.len - 1 }
        ) catch |err| { return err }
        return zbackend_ir_type_layout_intern_error_union(
            type_layout, payload_type_id
        ) catch |err| { return err }
    }
    if zbackend_ir_is_function_type_text(text) {
        return zbackend_ir_type_layout_intern_function(
            type_layout, text
        ) catch |err| { return err }
    }
    if zbackend_ir_is_slice_type_text(text) {
        element_type: i64 = zbackend_ir_type_layout_intern_text(
            type_layout, ZAstText{ ptr: text.ptr + 2, len: text.len - 2 }
        ) catch |err| { return err }
        return zbackend_ir_type_layout_intern_derived(
            type_layout, "slice", element_type, 0
        ) catch |err| { return err }
    }
    if text.len > 1 && text.ptr[0] == 42 {
        pointee_type: i64 = zbackend_ir_type_layout_intern_text(
            type_layout, ZAstText{ ptr: text.ptr + 1, len: text.len - 1 }
        ) catch |err| { return err }
        return zbackend_ir_type_layout_intern_derived(
            type_layout, "pointer", pointee_type, 0
        ) catch |err| { return err }
    }
    element: ZAstText = ZAstText.empty()
    length: i64 = 0
    if zbackend_ir_array_type_parts(type_layout, text, &element, &length) {
        element_type: i64 = zbackend_ir_type_layout_intern_text(
            type_layout, element
        ) catch |err| { return err }
        return zbackend_ir_type_layout_intern_derived(
            type_layout, "array", element_type, length
        ) catch |err| { return err }
    }
    return zbackend_ir_type_layout_intern_nominal(
        type_layout, text
    ) catch |err| { return err }
}

fn zbackend_ir_error_union_type_name(
    type_layout: *ZBackendIrTypeLayout,
    payload_type_id: i64
) !string {
    if payload_type_id <= 0 || payload_type_id > type_layout.type_count {
        return error.InvalidArgument
    }
    payload_type: ZBackendIrType = type_layout.types[payload_type_id - 1]
    scalar_name: string = payload_type.scalar
    if scalar_name == "bool" { return "zorb.result.bool" }
    if scalar_name == "i8" { return "zorb.result.i8" }
    if scalar_name == "u8" { return "zorb.result.u8" }
    if scalar_name == "i16" { return "zorb.result.i16" }
    if scalar_name == "u16" { return "zorb.result.u16" }
    if scalar_name == "i32" { return "zorb.result.i32" }
    if scalar_name == "u32" { return "zorb.result.u32" }
    if scalar_name == "i64" { return "zorb.result.i64" }
    if scalar_name == "u64" { return "zorb.result.u64" }
    builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
        type_layout.allocator, 24
    ) catch |err| { return error.OutOfMemory }
    std.collections.StringBuilder.append(
        &builder, type_layout.allocator, "zorb.result.type."
    ) catch |err| { return error.OutOfMemory }
    std.collections.StringBuilder.append_i64(
        &builder, type_layout.allocator, payload_type_id
    ) catch |err| { return error.OutOfMemory }
    return cast(string, std.collections.StringBuilder.c_string(
        &builder, type_layout.allocator
    ) catch |err| { return error.OutOfMemory })
}

fn zbackend_ir_type_layout_find_error_union(
    type_layout: *ZBackendIrTypeLayout,
    payload_type_id: i64
) -> i64 {
    index: i64 = 0
    while index < type_layout.type_count {
        item: ZBackendIrType = type_layout.types[index]
        if item.kind == "error_union" && item.element_type == payload_type_id { return item.id }
        index = index + 1
    }
    return ZBACKEND_IR_NO_TYPE_ID
}

fn zbackend_ir_type_layout_intern_error_union(
    type_layout: *ZBackendIrTypeLayout,
    payload_type_id: i64
) !i64 {
    existing: i64 = zbackend_ir_type_layout_find_error_union(type_layout, payload_type_id)
    if existing != ZBACKEND_IR_NO_TYPE_ID { return existing }
    zbackend_ir_type_layout_reserve(
        type_layout, type_layout.type_count + 1
    ) catch |err| { return err }
    id: i64 = type_layout.type_count + 1
    name: string = zbackend_ir_error_union_type_name(
        type_layout, payload_type_id
    ) catch |err| { return err }
    type_layout.types[type_layout.type_count] = ZBackendIrType{
        id: id,
        kind: "error_union",
        name: name,
        scalar: "",
        element_type: payload_type_id,
        length: 0,
        fields: cast(*ZBackendIrTypeField, 0),
        field_count: 0,
        is_packed: false
    }
    type_layout.type_count = type_layout.type_count + 1
    return id
}

fn zbackend_ir_type_layout_type_id(
    type_layout: *ZBackendIrTypeLayout,
    ast: *ZAstModule,
    type_index: i64
) !i64 {
    if type_index == ZAstNoIndex { return type_layout.void_type_id }
    previous_declaration_start: i64 = type_layout.constant_scope_declaration_start
    previous_statement: i64 = type_layout.constant_scope_statement
    type_layout.constant_scope_declaration_start =
        ast.types[type_index].scope_declaration_start
    type_layout.constant_scope_statement = ast.types[type_index].scope_statement
    result: i64 = zbackend_ir_type_layout_intern_text(
        type_layout, ast.types[type_index].text
    ) catch |err| {
        type_layout.constant_scope_declaration_start = previous_declaration_start
        type_layout.constant_scope_statement = previous_statement
        return err
    }
    type_layout.constant_scope_declaration_start = previous_declaration_start
    type_layout.constant_scope_statement = previous_statement
    return result
}

fn zbackend_ir_type_layout_is_signed(
    type_layout: *ZBackendIrTypeLayout,
    type_id: i64
) -> bool {
    if type_id <= 0 || type_id > type_layout.type_count { return false }
    return zbackend_ir_scalar_name_is_signed(type_layout.types[type_id - 1].scalar)
}

fn zbackend_ir_type_layout_element_type(
    type_layout: *ZBackendIrTypeLayout,
    type_id: i64
) !i64 {
    if type_id <= 0 || type_id > type_layout.type_count { return error.InvalidArgument }
    item: ZBackendIrType = type_layout.types[type_id - 1]
    if item.kind != "pointer" && item.kind != "array" && item.kind != "slice" &&
        item.kind != "string" { return error.InvalidArgument }
    return item.element_type
}

fn zbackend_ir_type_layout_pointer_to(
    type_layout: *ZBackendIrTypeLayout,
    element_type: i64
) !i64 {
    return zbackend_ir_type_layout_intern_derived(
        type_layout, "pointer", element_type, 0
    ) catch |err| { return err }
}

fn zbackend_ir_module_type_layout(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    target_triple: string
) !ZBackendIrTypeLayout {
    type_layout: ZBackendIrTypeLayout = ZBackendIrTypeLayout{
        allocator: allocator,
        ast: ast,
        target_triple: target_triple,
        constant_scope_declaration_start: ZAstNoIndex,
        constant_scope_statement: ZAstNoIndex,
        types: cast(*ZBackendIrType, 0),
        type_count: 0,
        type_capacity: 0,
        bool_type_id: ZBACKEND_IR_NO_TYPE_ID,
        error_type_id: ZBACKEND_IR_NO_TYPE_ID,
        void_type_id: ZBACKEND_IR_NO_TYPE_ID,
        active_generic_declaration: ZAstNoIndex,
        active_generic_suffix: ZAstText.empty(),
        generic_context_declarations: cast(*i64, 0),
        generic_context_suffixes: cast(*ZAstText, 0),
        generic_context_count: 0,
        generic_context_capacity: ast.len + ast.expr_count + 1,
        generic_instance_declarations: cast(*i64, 0),
        generic_instance_suffixes: cast(*ZAstText, 0),
        generic_instance_count: 0,
        concrete_function_count: zbackend_ir_function_count(ast)
    }
    generic_context_declarations_raw: *u8 = std.mem.HeapAllocator.alloc(
        allocator, type_layout.generic_context_capacity * Builtin.sizeof(i64)
    ) catch |err| { return error.OutOfMemory }
    generic_context_suffixes_raw: *u8 = std.mem.HeapAllocator.alloc(
        allocator, type_layout.generic_context_capacity * Builtin.sizeof(ZAstText)
    ) catch |err| { return error.OutOfMemory }
    type_layout.generic_context_declarations = cast(*i64, generic_context_declarations_raw)
    type_layout.generic_context_suffixes = cast(*ZAstText, generic_context_suffixes_raw)
    has_void: bool = false
    has_error_union: bool = false
    has_slice: bool = false
    scan_type_index: i64 = 0
    while scan_type_index < ast.type_count {
        if zbackend_ir_is_slice_type_text(ast.types[scan_type_index].text) {
            has_slice = true
        }
        scan_type_index = scan_type_index + 1
    }
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            !declaration.is_imported &&
            declaration.generic_param_count == 0 {
            if declaration.return_type_index == ZAstNoIndex {
                has_void = true
            } else {
                zbackend_ir_type_layout_intern_text(
                    &type_layout, ast.types[declaration.return_type_index].text
                ) catch |err| { return err }
            }
            if declaration.return_is_error_union { has_error_union = true }
            parameter_index: i64 = 0
            while parameter_index < declaration.param_count {
                parameter: ZAstParam = ast.params[declaration.param_start + parameter_index]
                if parameter.type_index == ZAstNoIndex { return error.NotImplemented }
                zbackend_ir_type_layout_intern_text(
                    &type_layout, ast.types[parameter.type_index].text
                ) catch |err| { return err }
                parameter_index = parameter_index + 1
            }
        }
        index = index + 1
    }
    if type_layout.type_count == 0 {
        zbackend_ir_type_layout_intern_scalar(
            &type_layout, "void"
        ) catch |err| { return err }
    }
    type_layout.bool_type_id = zbackend_ir_type_layout_intern_scalar(
        &type_layout, "bool"
    ) catch |err| { return err }
    if has_error_union || has_slice || ast.error_count > 0 {
        type_layout.error_type_id = zbackend_ir_type_layout_intern_scalar(
            &type_layout, "i32"
        ) catch |err| { return err }
    }
    if has_void || has_slice {
        type_layout.void_type_id = zbackend_ir_type_layout_intern_scalar(
            &type_layout, "void"
        ) catch |err| { return err }
    }
    zbackend_ir_register_generic_instances(&type_layout) catch |err| { return err }
    if type_layout.error_type_id == ZBACKEND_IR_NO_TYPE_ID {
        generic_error_index: i64 = 0
        while generic_error_index < type_layout.generic_instance_count {
            if ast.decls[type_layout.generic_instance_declarations[generic_error_index]].return_is_error_union {
                type_layout.error_type_id = zbackend_ir_type_layout_intern_scalar(
                    &type_layout, "i32"
                ) catch |err| { return err }
                generic_error_index = type_layout.generic_instance_count
            } else {
                generic_error_index = generic_error_index + 1
            }
        }
    }
    index = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            !declaration.is_imported &&
            declaration.return_is_error_union &&
            declaration.generic_param_count == 0 {
            payload_type_id: i64 = zbackend_ir_type_layout_type_id(
                &type_layout, ast, declaration.return_type_index
            ) catch |err| { return err }
            zbackend_ir_type_layout_intern_error_union(
                &type_layout, payload_type_id
            ) catch |err| { return err }
        }
        index = index + 1
    }
    generic_instance_index: i64 = 0
    while generic_instance_index < type_layout.generic_instance_count {
        declaration_index: i64 = type_layout.generic_instance_declarations[generic_instance_index]
        declaration: ZAstDecl = ast.decls[declaration_index]
        if declaration.return_is_error_union {
            type_layout.active_generic_declaration = declaration_index
            type_layout.active_generic_suffix = type_layout.generic_instance_suffixes[generic_instance_index]
            payload_type_id: i64 = zbackend_ir_type_layout_type_id(
                &type_layout, ast, declaration.return_type_index
            ) catch |err| { return err }
            zbackend_ir_type_layout_intern_error_union(
                &type_layout, payload_type_id
            ) catch |err| { return err }
        }
        generic_instance_index = generic_instance_index + 1
    }
    type_layout.active_generic_declaration = ZAstNoIndex
    type_layout.active_generic_suffix = ZAstText.empty()
    // Locals and future casts can introduce native types that do not appear
    // in a function signature. Intern every supported reference retained by the
    // checked AST after the stable signature/error-union prefix.
    type_index: i64 = 0
    while type_index < ast.type_count {
        type_text: ZAstText = ast.types[type_index].text
        type_layout.constant_scope_declaration_start =
            ast.types[type_index].scope_declaration_start
        type_layout.constant_scope_statement = ast.types[type_index].scope_statement
        if zbackend_ir_is_supported_type_text(&type_layout, type_text) {
            zbackend_ir_type_layout_intern_text(
                &type_layout, type_text
            ) catch |err| { return err }
        }
        type_index = type_index + 1
    }
    type_layout.constant_scope_declaration_start = ZAstNoIndex
    type_layout.constant_scope_statement = ZAstNoIndex
    return type_layout
}

fn zbackend_ir_function_payload_type_id(
    type_layout: *ZBackendIrTypeLayout,
    ast: *ZAstModule,
    declaration: ZAstDecl
) !i64 {
    if declaration.return_type_index == ZAstNoIndex {
        if type_layout.void_type_id == ZBACKEND_IR_NO_TYPE_ID {
            type_layout.void_type_id = zbackend_ir_type_layout_intern_scalar(
                type_layout, "void"
            ) catch |err| { return err }
        }
        return type_layout.void_type_id
    }
    return zbackend_ir_type_layout_type_id(
        type_layout, ast, declaration.return_type_index
    ) catch |err| { return err }
}

fn zbackend_ir_function_return_type_id(
    type_layout: *ZBackendIrTypeLayout,
    ast: *ZAstModule,
    declaration: ZAstDecl
) !i64 {
    payload_type_id: i64 = zbackend_ir_function_payload_type_id(
        type_layout, ast, declaration
    ) catch |err| { return err }
    if !declaration.return_is_error_union { return payload_type_id }
    error_union_type_id: i64 = zbackend_ir_type_layout_find_error_union(
        type_layout, payload_type_id
    )
    if error_union_type_id == ZBACKEND_IR_NO_TYPE_ID { return error.NotImplemented }
    return error_union_type_id
}

fn zbackend_ir_call_return_type_id(
    type_layout: *ZBackendIrTypeLayout,
    expression: ZAstExpr,
    declaration: ZAstDecl,
    generic_suffix: ZAstText
) !i64 {
    previous_declaration: i64 = type_layout.active_generic_declaration
    previous_suffix: ZAstText = type_layout.active_generic_suffix
    if declaration.generic_param_count > 0 {
        if generic_suffix.len == 0 {
            if expression.left == ZAstNoIndex { return error.InvalidArgument }
            callee: ZAstExpr = type_layout.ast.exprs[expression.left]
            if callee.type_index == ZAstNoIndex { return error.InvalidArgument }
            generic_suffix = type_layout.ast.types[callee.type_index].text
        }
        declaration_index: i64 = zbackend_ir_owning_declaration_index(
            type_layout.ast, declaration.name
        )
        if declaration_index == ZAstNoIndex { return error.InvalidArgument }
        type_layout.active_generic_declaration = declaration_index
        type_layout.active_generic_suffix = generic_suffix
    }
    result: i64 = zbackend_ir_function_return_type_id(
        type_layout, type_layout.ast, declaration
    ) catch |err| { return err }
    type_layout.active_generic_declaration = previous_declaration
    type_layout.active_generic_suffix = previous_suffix
    return result
}

fn zbackend_ir_binary_op(token: i64, is_signed: bool) !string {
    if token == ZTokenPlus { return "add" }
    if token == ZTokenMinus { return "sub" }
    if token == ZTokenStar { return "mul" }
    if token == ZTokenSlash {
        if is_signed { return "signed_div" }
        return "unsigned_div"
    }
    if token == ZTokenPercent {
        if is_signed { return "signed_rem" }
        return "unsigned_rem"
    }
    if token == ZTokenAmp { return "bit_and" }
    if token == ZTokenPipe { return "bit_or" }
    if token == ZTokenCaret { return "bit_xor" }
    if token == ZTokenLShift { return "shift_left" }
    if token == ZTokenRShift {
        if is_signed { return "arithmetic_shift_right" }
        return "logical_shift_right"
    }
    return error.NotImplemented
}

fn zbackend_ir_is_comparison(token: i64) -> bool {
    return token == ZTokenEqualEqual || token == ZTokenBangEqual || token == ZTokenLess ||
        token == ZTokenLessEqual || token == ZTokenGreater || token == ZTokenGreaterEqual
}

fn zbackend_ir_compare_op(token: i64, is_signed: bool) !string {
    if token == ZTokenEqualEqual { return "equal" }
    if token == ZTokenBangEqual { return "not_equal" }
    if token == ZTokenLess {
        if is_signed { return "signed_less" }
        return "unsigned_less"
    }
    if token == ZTokenLessEqual {
        if is_signed { return "signed_less_equal" }
        return "unsigned_less_equal"
    }
    if token == ZTokenGreater {
        if is_signed { return "signed_greater" }
        return "unsigned_greater"
    }
    if token == ZTokenGreaterEqual {
        if is_signed { return "signed_greater_equal" }
        return "unsigned_greater_equal"
    }
    return error.NotImplemented
}

struct ZBackendIrExpressionLowering {
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    declaration: ZAstDecl,
    instructions: *ZBackendIrInstruction,
    instruction_capacity: i64,
    instruction_count: i64,
    next_value_id: i64,
    value_type_id: i64,
    bool_type_id: i64,
    type_layout: *ZBackendIrTypeLayout,
    value_is_signed: bool,
    local_names: *ZAstText,
    local_addresses: *i64,
    local_type_ids: *i64,
    local_count: i64,
    current_statement_index: i64
}

fn zbackend_ir_new_instruction(id: i64, op: string, type_id: i64) -> ZBackendIrInstruction {
    return ZBackendIrInstruction{
        id: id,
        op: op,
        type_id: type_id,
        integer: 0,
        text: "",
        binary_op: "",
        compare_op: "",
        cast_op: "",
        lhs: 0,
        rhs: 0,
        callee: 0,
        arguments: cast(*i64, 0),
        argument_count: 0,
        incoming_values: cast(*i64, 0),
        incoming_blocks: cast(*i64, 0),
        incoming_count: 0,
        field_index: 0,
        source_type: ZBACKEND_IR_NO_TYPE_ID,
        global_id: 0,
        asm_template: "",
        constraints: "",
        output_types: cast(*i64, 0),
        output_addresses: cast(*i64, 0),
        output_count: 0
    }
}

fn zbackend_ir_new_terminator(op: string) -> ZBackendIrTerminator {
    return ZBackendIrTerminator{
        op: op,
        value: 0,
        target: 0,
        condition: 0,
        true_target: 0,
        false_target: 0
    }
}

fn zbackend_ir_return_terminator(value: i64) -> ZBackendIrTerminator {
    terminator: ZBackendIrTerminator = zbackend_ir_new_terminator("return_value")
    terminator.value = value
    return terminator
}

fn zbackend_ir_branch_terminator(target: i64) -> ZBackendIrTerminator {
    terminator: ZBackendIrTerminator = zbackend_ir_new_terminator("branch")
    terminator.target = target
    return terminator
}

fn zbackend_ir_expression_context(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    declaration: ZAstDecl,
    instructions: *ZBackendIrInstruction,
    instruction_capacity: i64,
    next_value_id: i64,
    value_type_id: i64,
    bool_type_id: i64,
    type_layout: *ZBackendIrTypeLayout,
    value_is_signed: bool,
    current_statement_index: i64
) -> ZBackendIrExpressionLowering {
    return ZBackendIrExpressionLowering{
        allocator: allocator,
        ast: ast,
        declaration: declaration,
        instructions: instructions,
        instruction_capacity: instruction_capacity,
        instruction_count: 0,
        next_value_id: next_value_id,
        value_type_id: value_type_id,
        bool_type_id: bool_type_id,
        type_layout: type_layout,
        value_is_signed: value_is_signed,
        local_names: cast(*ZAstText, 0),
        local_addresses: cast(*i64, 0),
        local_type_ids: cast(*i64, 0),
        local_count: 0,
        current_statement_index: current_statement_index
    }
}

fn zbackend_ir_has_local(local_names: *ZAstText, local_count: i64, name: ZAstText) -> bool {
    index: i64 = local_count
    while index > 0 {
        index = index - 1
        if ZAstText.eql(local_names[index], name) { return true }
    }
    return false
}

fn zbackend_ir_append_instruction(context: *ZBackendIrExpressionLowering, instruction: ZBackendIrInstruction) !i64 {
    if context.instruction_count >= context.instruction_capacity { return error.OutOfBounds }
    context.instructions[context.instruction_count] = instruction
    context.instruction_count = context.instruction_count + 1
    return instruction.id
}

fn zbackend_ir_set_locals(
    context: *ZBackendIrExpressionLowering,
    local_names: *ZAstText,
    local_addresses: *i64,
    local_type_ids: *i64,
    local_count: i64
) {
    context.local_names = local_names
    context.local_addresses = local_addresses
    context.local_type_ids = local_type_ids
    context.local_count = local_count
}

fn zbackend_ir_local_address(context: *ZBackendIrExpressionLowering, name: ZAstText) !i64 {
    return zbackend_ir_local_address_from_arrays(
        context.local_names, context.local_addresses, context.local_count, name
    ) catch |err| { return err }
}

fn zbackend_ir_expression_parameter_type_id(
    context: *ZBackendIrExpressionLowering,
    name: ZAstText
) !i64 {
    index: i64 = 0
    while index < context.declaration.param_count {
        parameter: ZAstParam = context.ast.params[context.declaration.param_start + index]
        if ZAstText.eql(parameter.name, name) {
            return zbackend_ir_type_layout_type_id(
                context.type_layout, context.ast, parameter.type_index
            ) catch |err| { return err }
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_literal_nominal_type_id(
    type_layout: *ZBackendIrTypeLayout,
    ast: *ZAstModule,
    expression: ZAstExpr
) !i64 {
    if expression.left == ZAstNoIndex { return error.NotImplemented }
    prefix: ZAstExpr = ast.exprs[expression.left]
    if prefix.kind != ZAstExprIdentifier && prefix.kind != ZAstExprField {
        return error.NotImplemented
    }
    base_length: i64 = zbackend_ir_qualified_expression_length(
        ast, expression.left
    ) catch |err| { return err }
    suffix: ZAstText = ZAstText.empty()
    if prefix.type_index != ZAstNoIndex {
        suffix = ast.types[prefix.type_index].text
    }
    raw: *u8 = std.mem.HeapAllocator.alloc(
        type_layout.allocator, base_length + suffix.len + 1
    ) catch |err| { return error.OutOfMemory }
    offset: i64 = 0
    zbackend_ir_write_qualified_expression(
        ast, expression.left, raw, &offset
    ) catch |err| { return err }
    suffix_index: i64 = 0
    while suffix_index < suffix.len {
        raw[offset] = suffix.ptr[suffix_index]
        offset = offset + 1
        suffix_index = suffix_index + 1
    }
    raw[offset] = 0
    return zbackend_ir_type_layout_intern_text(
        type_layout, ZAstText{ ptr: raw, len: offset }
    ) catch |err| { return err }
}

fn zbackend_ir_type_field_index(
    type_layout: *ZBackendIrTypeLayout,
    type_id: i64,
    name: ZAstText
) !i64 {
    if type_id <= 0 || type_id > type_layout.type_count { return error.InvalidArgument }
    item: ZBackendIrType = type_layout.types[type_id - 1]
    index: i64 = 0
    while index < item.field_count {
        if ZAstText.eql_string(name, item.fields[index].name) { return index }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_field_is_static_enum(ast: *ZAstModule, expression: ZAstExpr) -> bool {
    if expression.kind != ZAstExprField || expression.left == ZAstNoIndex { return false }
    declaration_index: i64 = ZAstModule.find_qualified_decl(ast, expression.left)
    return declaration_index != ZAstNoIndex && ast.decls[declaration_index].kind == ZAstDeclEnum
}

fn zbackend_ir_static_union_tag_declaration_index(
    ast: *ZAstModule,
    expression: ZAstExpr
) -> i64 {
    if expression.kind != ZAstExprField || expression.left == ZAstNoIndex {
        return ZAstNoIndex
    }
    tag_expression: ZAstExpr = ast.exprs[expression.left]
    if tag_expression.kind != ZAstExprField || tag_expression.left == ZAstNoIndex ||
        !ZAstText.eql_string(tag_expression.name, "Tag") {
        return ZAstNoIndex
    }
    declaration_index: i64 = ZAstModule.find_qualified_decl(
        ast, tag_expression.left
    )
    if declaration_index == ZAstNoIndex { return ZAstNoIndex }
    declaration: ZAstDecl = ast.decls[declaration_index]
    if declaration.is_imported && declaration.canonical_name.len > 0 {
        declaration_index = zbackend_ir_owning_declaration_index(
            ast, declaration.canonical_name
        )
        if declaration_index == ZAstNoIndex { return ZAstNoIndex }
        declaration = ast.decls[declaration_index]
    }
    if declaration.kind != ZAstDeclUnion { return ZAstNoIndex }
    return declaration_index
}

fn zbackend_ir_field_is_static_union_tag(
    ast: *ZAstModule,
    expression: ZAstExpr
) -> bool {
    return zbackend_ir_static_union_tag_declaration_index(ast, expression) != ZAstNoIndex
}

fn zbackend_ir_union_tag_field_value(
    ast: *ZAstModule,
    expression: ZAstExpr
) !i64 {
    declaration_index: i64 = zbackend_ir_static_union_tag_declaration_index(
        ast, expression
    )
    if declaration_index == ZAstNoIndex { return error.NotImplemented }
    declaration: ZAstDecl = ast.decls[declaration_index]
    member_index: i64 = 0
    while member_index < declaration.member_count {
        if ZAstText.eql(
            ast.members[declaration.member_start + member_index].name,
            expression.name
        ) { return member_index }
        member_index = member_index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_field_is_static_error(ast: *ZAstModule, expression: ZAstExpr) -> bool {
    if expression.kind != ZAstExprField || expression.left == ZAstNoIndex { return false }
    return zbackend_ir_is_error_name(ast, expression.name)
}

fn zbackend_ir_enum_field_value(
    ast: *ZAstModule,
    expression: ZAstExpr
) !i64 {
    declaration_index: i64 = ZAstModule.find_qualified_decl(ast, expression.left)
    if declaration_index == ZAstNoIndex { return error.NotImplemented }
    declaration: ZAstDecl = ast.decls[declaration_index]
    if declaration.is_imported && declaration.canonical_name.len > 0 {
        canonical_index: i64 = zbackend_ir_owning_declaration_index(
            ast, declaration.canonical_name
        )
        if canonical_index != ZAstNoIndex { declaration = ast.decls[canonical_index] }
    }
    value: i64 = 0
    member_index: i64 = 0
    while member_index < declaration.member_count {
        member: ZAstMember = ast.members[declaration.member_start + member_index]
        if member.value_expr != ZAstNoIndex {
            initializer: ZAstExpr = ast.exprs[member.value_expr]
            if initializer.kind != ZAstExprInteger { return error.NotImplemented }
            value = zbackend_ir_parse_positive_integer(
                initializer.literal
            ) catch |err| { return err }
        }
        if ZAstText.eql(member.name, expression.name) { return value }
        value = value + 1
        member_index = member_index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_expression_type_id(
    context: *ZBackendIrExpressionLowering,
    expression_index: i64,
    fallback_type_id: i64
) !i64 {
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier {
        if zbackend_ir_is_error_name(context.ast, expression.name) {
            return context.type_layout.error_type_id
        }
        if zbackend_ir_has_local(context.local_names, context.local_count, expression.name) {
            return zbackend_ir_local_type_from_arrays(
                context.local_names, context.local_type_ids, context.local_count, expression.name
            ) catch |err| { return err }
        }
        if !zbackend_ir_is_global_name(context.ast, expression.name) {
            if zbackend_ir_is_function_name(context.ast, expression.name) {
                return fallback_type_id
            }
            return zbackend_ir_expression_parameter_type_id(
                context, expression.name
            ) catch |err| { return err }
        }
        global_declaration: ZAstDecl = zbackend_ir_global_declaration(
            context.ast, expression.name
        ) catch |err| { return err }
        return zbackend_ir_type_layout_type_id(
            context.type_layout, context.ast, global_declaration.type_index
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprInteger { return fallback_type_id }
    if expression.kind == ZAstExprBool { return context.bool_type_id }
    if expression.kind == ZAstExprError { return context.type_layout.error_type_id }
    if expression.kind == ZAstExprString {
        return zbackend_ir_type_layout_intern_text(
            context.type_layout, ZAstText{ ptr: cast(*u8, "string"), len: 6 }
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprUnary {
        operand_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if expression.op == ZTokenAmp {
            operand_type: ZBackendIrType = context.type_layout.types[operand_type_id - 1]
            if operand_type.kind == "array" {
                return zbackend_ir_type_layout_pointer_to(
                    context.type_layout, operand_type.element_type
                ) catch |err| { return err }
            }
            return zbackend_ir_type_layout_pointer_to(
                context.type_layout, operand_type_id
            ) catch |err| { return err }
        }
        if expression.op == ZTokenStar {
            return zbackend_ir_type_layout_element_type(
                context.type_layout, operand_type_id
            ) catch |err| { return err }
        }
        return operand_type_id
    }
    if expression.kind == ZAstExprIndex {
        target_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        return zbackend_ir_type_layout_element_type(
            context.type_layout, target_type_id
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprArrayLiteral {
        return zbackend_ir_type_layout_type_id(
            context.type_layout, context.ast, expression.type_index
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprCast {
        return zbackend_ir_type_layout_type_id(
            context.type_layout, context.ast, expression.type_index
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprStructLiteral {
        return zbackend_ir_literal_nominal_type_id(
            context.type_layout, context.ast, expression
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprField {
        if zbackend_ir_field_is_static_enum(context.ast, expression) {
            return fallback_type_id
        }
        resolved_global: ZAstText = zbackend_ir_resolved_global_name(
            context.type_layout, expression_index
        ) catch |err| { return err }
        if resolved_global.len > 0 {
            global_declaration: ZAstDecl = zbackend_ir_global_declaration(
                context.ast, resolved_global
            ) catch |err| { return err }
            return zbackend_ir_type_layout_type_id(
                context.type_layout, context.ast, global_declaration.type_index
            ) catch |err| { return err }
        }
        resolved_function_value: ZAstText = zbackend_ir_resolved_function_value_name(
            context.type_layout, expression_index
        ) catch |err| { return err }
        if resolved_function_value.len > 0 {
            return fallback_type_id
        }
        if zbackend_ir_is_builtin_field(context.ast, expression) {
            return context.bool_type_id
        }
        if zbackend_ir_field_is_static_error(context.ast, expression) {
            return context.type_layout.error_type_id
        }
        if zbackend_ir_field_is_static_union_tag(context.ast, expression) {
            return fallback_type_id
        }
        target_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
            context.type_layout.types[target_type_id - 1].kind == "slice" {
            if ZAstText.eql_string(expression.name, "len") {
                return zbackend_ir_type_layout_intern_scalar(
                    context.type_layout, "i64"
                ) catch |err| { return err }
            }
            if ZAstText.eql_string(expression.name, "ptr") {
                return zbackend_ir_type_layout_pointer_to(
                    context.type_layout,
                    context.type_layout.types[target_type_id - 1].element_type
                ) catch |err| { return err }
            }
        }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
            context.type_layout.types[target_type_id - 1].kind == "error_union" {
            if ZAstText.eql_string(expression.name, "value") {
                return context.type_layout.types[target_type_id - 1].element_type
            }
            if ZAstText.eql_string(expression.name, "error") {
                return context.type_layout.error_type_id
            }
        }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count {
            target_type: ZBackendIrType = context.type_layout.types[target_type_id - 1]
            if target_type.kind == "pointer" {
                target_type_id = target_type.element_type
                target_type = context.type_layout.types[target_type_id - 1]
            }
            if target_type.kind == "struct" || target_type.kind == "union" {
                if target_type.kind == "union" &&
                    ZAstText.eql_string(expression.name, "tag") {
                    return zbackend_ir_type_layout_intern_scalar(
                        context.type_layout, "i32"
                    ) catch |err| { return err }
                }
                field_index: i64 = zbackend_ir_type_field_index(
                    context.type_layout, target_type_id, expression.name
                ) catch |err| { return err }
                return target_type.fields[field_index].type_id
            }
        }
    }
    if expression.kind == ZAstExprBinary {
        if zbackend_ir_is_comparison(expression.op) { return context.bool_type_id }
        left_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if context.ast.exprs[expression.left].kind != ZAstExprInteger { return left_type_id }
        return zbackend_ir_expression_type_id(
            context, expression.right, fallback_type_id
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprCall {
        expression.name = zbackend_ir_resolved_call_name(
            context.type_layout, expression
        ) catch |err| { return err }
        if ZAstText.eql_string(expression.name, "syscall") {
            return zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i64"
            ) catch |err| { return err }
        }
        if zbackend_ir_is_builtin_sizeof(context.ast, expression) {
            return zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i64"
            ) catch |err| { return err }
        }
        if expression.left != ZAstNoIndex &&
            !zbackend_ir_is_function_name(context.ast, expression.name) {
            callee_type_id: i64 = zbackend_ir_expression_type_id(
                context, expression.left, fallback_type_id
            ) catch |err| { return err }
            if callee_type_id > 0 && callee_type_id <= context.type_layout.type_count &&
                context.type_layout.types[callee_type_id - 1].kind == "function" {
                return context.type_layout.types[callee_type_id - 1].element_type
            }
        }
        declaration: ZAstDecl = zbackend_ir_function_declaration(
            context.ast, expression.name
        ) catch |err| { return err }
        return zbackend_ir_call_return_type_id(
            context.type_layout, expression, declaration, ZAstText.empty()
        ) catch |err| { return err }
    }
    return fallback_type_id
}

fn zbackend_ir_expression_operand_type_id(
    context: *ZBackendIrExpressionLowering,
    expression_index: i64,
    fallback_type_id: i64
) !i64 {
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind == ZAstExprBinary && zbackend_ir_is_comparison(expression.op) {
        left_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if context.ast.exprs[expression.left].kind != ZAstExprInteger { return left_type_id }
        return zbackend_ir_expression_type_id(
            context, expression.right, fallback_type_id
        ) catch |err| { return err }
    }
    return zbackend_ir_expression_type_id(
        context, expression_index, fallback_type_id
    ) catch |err| { return err }
}

fn zbackend_ir_local_type_from_arrays(
    local_names: *ZAstText,
    local_type_ids: *i64,
    local_count: i64,
    name: ZAstText
) !i64 {
    index: i64 = local_count
    while index > 0 {
        index = index - 1
        if ZAstText.eql(local_names[index], name) { return local_type_ids[index] }
    }
    return error.NotImplemented
}

fn zbackend_ir_local_is_catch_error(
    local_names: *ZAstText,
    local_is_catch_errors: *i64,
    local_count: i64,
    name: ZAstText
) -> bool {
    index: i64 = local_count
    while index > 0 {
        index = index - 1
        if ZAstText.eql(local_names[index], name) {
            return local_is_catch_errors[index] != 0
        }
    }
    return false
}

fn zbackend_ir_expression_emit_index_address(
    context: *ZBackendIrExpressionLowering,
    base_address: i64,
    index: i64,
    source_type: i64,
    element_type: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "index_address", element_type
    )
    instruction.source_type = source_type
    instruction.lhs = base_address
    instruction.rhs = index
    return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_expression_lower_array_to_slice(
    context: *ZBackendIrExpressionLowering,
    expression_index: i64,
    array_type_id: i64,
    slice_type_id: i64
) !i64 {
    array_type: ZBackendIrType = context.type_layout.types[array_type_id - 1]
    if array_type.kind != "array" { return error.InvalidArgument }
    index_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
        context.type_layout, "i64"
    ) catch |err| { return err }
    zero_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    zero: ZBackendIrInstruction = zbackend_ir_new_instruction(
        zero_id, "integer_constant", index_type_id
    )
    zero.integer = 0
    zbackend_ir_append_instruction(context, zero) catch |err| { return err }
    previous_value_type_id: i64 = context.value_type_id
    previous_value_is_signed: bool = context.value_is_signed
    context.value_type_id = array_type_id
    context.value_is_signed = false
    array_address: i64 = zbackend_ir_expression_lower_address(
        context, expression_index
    ) catch |err| { return err }
    context.value_type_id = previous_value_type_id
    context.value_is_signed = previous_value_is_signed
    pointer: i64 = zbackend_ir_expression_emit_index_address(
        context, array_address, zero_id, array_type_id, array_type.element_type
    ) catch |err| { return err }
    length_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    length: ZBackendIrInstruction = zbackend_ir_new_instruction(
        length_id, "integer_constant", index_type_id
    )
    length.integer = array_type.length
    zbackend_ir_append_instruction(context, length) catch |err| { return err }
    values_raw: *u8 = std.mem.HeapAllocator.alloc(
        context.allocator, 2 * Builtin.sizeof(i64)
    ) catch |err| { return error.OutOfMemory }
    values: *i64 = cast(*i64, values_raw)
    values[0] = pointer
    values[1] = length_id
    aggregate_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    aggregate: ZBackendIrInstruction = zbackend_ir_new_instruction(
        aggregate_id, "aggregate", slice_type_id
    )
    aggregate.arguments = values
    aggregate.argument_count = 2
    return zbackend_ir_append_instruction(context, aggregate) catch |err| { return err }
}

fn zbackend_ir_expression_lower_array_to_pointer(
    context: *ZBackendIrExpressionLowering,
    expression_index: i64,
    array_type_id: i64
) !i64 {
    array_type: ZBackendIrType = context.type_layout.types[array_type_id - 1]
    if array_type.kind != "array" { return error.InvalidArgument }
    index_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
        context.type_layout, "i64"
    ) catch |err| { return err }
    zero_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    zero: ZBackendIrInstruction = zbackend_ir_new_instruction(
        zero_id, "integer_constant", index_type_id
    )
    zero.integer = 0
    zbackend_ir_append_instruction(context, zero) catch |err| { return err }
    array_address: i64 = zbackend_ir_expression_lower_address(
        context, expression_index
    ) catch |err| { return err }
    return zbackend_ir_expression_emit_index_address(
        context, array_address, zero_id, array_type_id, array_type.element_type
    ) catch |err| { return err }
}

fn zbackend_ir_expression_lower_address(
    context: *ZBackendIrExpressionLowering,
    expression_index: i64
) !i64 {
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier {
        if zbackend_ir_is_error_name(context.ast, expression.name) {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            constant: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "integer_constant", context.type_layout.error_type_id
            )
            constant.integer = zbackend_ir_error_value(
                context.ast, expression.name
            ) catch |err| { return err }
            return zbackend_ir_append_instruction(context, constant) catch |err| { return err }
        }
        if zbackend_ir_has_local(context.local_names, context.local_count, expression.name) {
            return zbackend_ir_local_address(context, expression.name) catch |err| { return err }
        }
        if zbackend_ir_is_global_name(context.ast, expression.name) {
            global_id: i64 = zbackend_ir_global_id(
                context.ast, expression.name
            ) catch |err| { return err }
            global_declaration: ZAstDecl = zbackend_ir_global_declaration(
                context.ast, expression.name
            ) catch |err| { return err }
            global_type_id: i64 = zbackend_ir_type_layout_type_id(
                context.type_layout, context.ast, global_declaration.type_index
            ) catch |err| { return err }
            address_id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            global_address: ZBackendIrInstruction = zbackend_ir_new_instruction(
                address_id, "global_address", global_type_id
            )
            global_address.global_id = global_id
            return zbackend_ir_append_instruction(
                context, global_address
            ) catch |err| { return err }
        }
        parameter_type: i64 = zbackend_ir_expression_parameter_type_id(
            context, expression.name
        ) catch |err| { return err }
        address_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        alloca: ZBackendIrInstruction = zbackend_ir_new_instruction(
            address_id, "alloca", parameter_type
        )
        zbackend_ir_append_instruction(context, alloca) catch |err| { return err }
        store_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        store: ZBackendIrInstruction = zbackend_ir_new_instruction(store_id, "store", parameter_type)
        store.lhs = address_id
        store.rhs = zbackend_ir_parameter_id(
            context.ast, context.declaration, expression.name
        ) catch |err| { return err }
        zbackend_ir_append_instruction(context, store) catch |err| { return err }
        return address_id
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenStar {
        return zbackend_ir_lower_expression(context, expression.left) catch |err| { return err }
    }
    if expression.kind == ZAstExprIndex {
        target_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, context.value_type_id
        ) catch |err| { return err }
        if target_type_id <= 0 || target_type_id > context.type_layout.type_count {
            return error.InvalidArgument
        }
        target_type: ZBackendIrType = context.type_layout.types[target_type_id - 1]
        index_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
            context.type_layout, "i64"
        ) catch |err| { return err }
        previous_value_type_id: i64 = context.value_type_id
        previous_value_is_signed: bool = context.value_is_signed
        context.value_type_id = index_type_id
        context.value_is_signed = true
        index_value: i64 = zbackend_ir_lower_expression(
            context, expression.right
        ) catch |err| { return err }
        context.value_type_id = previous_value_type_id
        context.value_is_signed = previous_value_is_signed
        if target_type.kind == "array" {
            base_address: i64 = zbackend_ir_expression_lower_address(
                context, expression.left
            ) catch |err| { return err }
            return zbackend_ir_expression_emit_index_address(
                context, base_address, index_value, target_type_id, target_type.element_type
            ) catch |err| { return err }
        }
        if target_type.kind == "pointer" {
            base_address: i64 = zbackend_ir_lower_expression(
                context, expression.left
            ) catch |err| { return err }
            return zbackend_ir_expression_emit_index_address(
                context, base_address, index_value, target_type.element_type, target_type.element_type
            ) catch |err| { return err }
        }
    }
    if expression.kind == ZAstExprField {
        target_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, context.value_type_id
        ) catch |err| { return err }
        container_type_id: i64 = target_type_id
        base_address: i64 = 0
        target_type: ZBackendIrType = context.type_layout.types[target_type_id - 1]
        if target_type.kind == "pointer" {
            container_type_id = target_type.element_type
            base_address = zbackend_ir_lower_expression(
                context, expression.left
            ) catch |err| { return err }
        } else {
            base_address = zbackend_ir_expression_lower_address(
                context, expression.left
            ) catch |err| { return err }
        }
        if target_type.kind == "slice" {
            field_index: i64 = 0
            field_type_id: i64 = zbackend_ir_type_layout_pointer_to(
                context.type_layout, target_type.element_type
            ) catch |err| { return err }
            if ZAstText.eql_string(expression.name, "len") {
                field_index = 1
                field_type_id = zbackend_ir_type_layout_intern_scalar(
                    context.type_layout, "i64"
                ) catch |err| { return err }
            } else if !ZAstText.eql_string(expression.name, "ptr") {
                return error.NotImplemented
            }
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            slice_field_address: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "field_address", field_type_id
            )
            slice_field_address.source_type = target_type_id
            slice_field_address.field_index = field_index
            slice_field_address.lhs = base_address
            return zbackend_ir_append_instruction(
                context, slice_field_address
            ) catch |err| { return err }
        }
        field_index: i64 = zbackend_ir_type_field_index(
            context.type_layout, container_type_id, expression.name
        ) catch |err| { return err }
        container_type: ZBackendIrType = context.type_layout.types[container_type_id - 1]
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        field_address: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "field_address", container_type.fields[field_index].type_id
        )
        field_address.source_type = container_type_id
        field_address.field_index = field_index
        if container_type.kind == "union" {
            field_address.field_index = field_index + 1
        }
        field_address.lhs = base_address
        return zbackend_ir_append_instruction(context, field_address) catch |err| { return err }
    }
    temporary_type: i64 = zbackend_ir_expression_type_id(
        context, expression_index, context.value_type_id
    ) catch |err| { return err }
    temporary_value: i64 = zbackend_ir_lower_expression(
        context, expression_index
    ) catch |err| { return err }
    address_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    alloca: ZBackendIrInstruction = zbackend_ir_new_instruction(
        address_id, "alloca", temporary_type
    )
    zbackend_ir_append_instruction(context, alloca) catch |err| { return err }
    store_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    store: ZBackendIrInstruction = zbackend_ir_new_instruction(
        store_id, "store", temporary_type
    )
    store.lhs = address_id
    store.rhs = temporary_value
    zbackend_ir_append_instruction(context, store) catch |err| { return err }
    return address_id
}

fn zbackend_ir_lower_logical_not(
    context: *ZBackendIrExpressionLowering,
    operand_expression: i64
) !i64 {
    operand: i64 = zbackend_ir_lower_expression(
        context, operand_expression
    ) catch |err| { return err }
    zero_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    zero: ZBackendIrInstruction = zbackend_ir_new_instruction(
        zero_id, "integer_constant", context.bool_type_id
    )
    zero.integer = 0
    zbackend_ir_append_instruction(context, zero) catch |err| { return err }
    result_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    comparison: ZBackendIrInstruction = zbackend_ir_new_instruction(
        result_id, "compare", context.bool_type_id
    )
    comparison.compare_op = "equal"
    comparison.lhs = operand
    comparison.rhs = zero_id
    return zbackend_ir_append_instruction(context, comparison) catch |err| { return err }
}

fn zbackend_ir_lower_error_expression(
    context: *ZBackendIrExpressionLowering,
    expression: ZAstExpr
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "integer_constant", context.type_layout.error_type_id
    )
    instruction.integer = zbackend_ir_error_value(
        context.ast, expression.name
    ) catch |err| { return err }
    return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cast_op(
    type_layout: *ZBackendIrTypeLayout,
    source_type_id: i64,
    target_type_id: i64
) !string {
    if source_type_id == target_type_id { return "" }
    source_type: ZBackendIrType = type_layout.types[source_type_id - 1]
    target_type: ZBackendIrType = type_layout.types[target_type_id - 1]
    if (source_type.kind == "pointer" || source_type.kind == "string") &&
        (target_type.kind == "pointer" || target_type.kind == "string") { return "" }
    if (source_type.kind == "pointer" || source_type.kind == "string") &&
        target_type.kind == "scalar" { return "pointer_to_integer" }
    if source_type.kind == "scalar" && target_type.kind == "pointer" {
        return "integer_to_pointer"
    }
    if source_type.kind != "scalar" || target_type.kind != "scalar" {
        return error.NotImplemented
    }
    source_width: i64 = zbackend_ir_scalar_bit_width(source_type.scalar)
    target_width: i64 = zbackend_ir_scalar_bit_width(target_type.scalar)
    if source_width == 0 || target_width == 0 { return error.NotImplemented }
    if target_width < source_width { return "truncate" }
    if target_width > source_width {
        if zbackend_ir_scalar_name_is_signed(source_type.scalar) { return "sign_extend" }
        return "zero_extend"
    }
    return ""
}

fn zbackend_ir_expression_emit_cast_value(
    context: *ZBackendIrExpressionLowering,
    value: i64,
    source_type_id: i64,
    target_type_id: i64
) !i64 {
    cast_op: string = zbackend_ir_cast_op(
        context.type_layout, source_type_id, target_type_id
    ) catch |err| { return err }
    if std.str.len(cast_op) == 0 { return value }
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "cast", target_type_id
    )
    instruction.cast_op = cast_op
    instruction.lhs = value
    return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_lower_expression(context: *ZBackendIrExpressionLowering, expression_index: i64) !i64 {
    if expression_index == ZAstNoIndex { return error.NotImplemented }
    expression: ZAstExpr = context.ast.exprs[expression_index]
    actual_type_id: i64 = zbackend_ir_expression_type_id(
        context, expression_index, context.value_type_id
    ) catch |err| { return err }
    expected_type: ZBackendIrType = context.type_layout.types[context.value_type_id - 1]
    actual_type: ZBackendIrType = context.type_layout.types[actual_type_id - 1]
    if expected_type.kind == "slice" && actual_type.kind == "array" &&
        expected_type.element_type == actual_type.element_type {
        return zbackend_ir_expression_lower_array_to_slice(
            context, expression_index, actual_type_id, context.value_type_id
        ) catch |err| { return err }
    }
    if expected_type.kind == "pointer" && actual_type.kind == "array" &&
        expected_type.element_type == actual_type.element_type {
        return zbackend_ir_expression_lower_array_to_pointer(
            context, expression_index, actual_type_id
        ) catch |err| { return err }
    }
    global_value_name: ZAstText = zbackend_ir_resolved_global_name(
        context.type_layout, expression_index
    ) catch |err| { return err }
    if global_value_name.len > 0 && expression.kind == ZAstExprField &&
        !zbackend_ir_field_is_static_enum(context.ast, expression) &&
        !zbackend_ir_field_is_static_union_tag(context.ast, expression) &&
        !zbackend_ir_field_is_static_error(context.ast, expression) &&
        !zbackend_ir_is_builtin_field(context.ast, expression) {
        address_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        address: ZBackendIrInstruction = zbackend_ir_new_instruction(
            address_id, "global_address", actual_type_id
        )
        address.global_id = zbackend_ir_global_id(
            context.ast, global_value_name
        ) catch |err| { return err }
        zbackend_ir_append_instruction(context, address) catch |err| { return err }
        load_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        load: ZBackendIrInstruction = zbackend_ir_new_instruction(
            load_id, "load", actual_type_id
        )
        load.lhs = address_id
        return zbackend_ir_append_instruction(context, load) catch |err| { return err }
    }
    function_value_name: ZAstText = zbackend_ir_resolved_function_value_name(
        context.type_layout, expression_index
    ) catch |err| { return err }
    if function_value_name.len > 0 {
        declaration: ZAstDecl = zbackend_ir_function_declaration(
            context.ast, function_value_name
        ) catch |err| { return err }
        callee: i64 = 0
        if declaration.generic_param_count > 0 {
            suffix: ZAstText = ZAstText.empty()
            if expression.type_index != ZAstNoIndex {
                candidate_suffix: ZAstText = context.ast.types[expression.type_index].text
                if candidate_suffix.len > 0 && candidate_suffix.ptr[0] == 60 {
                    suffix = candidate_suffix
                }
            }
            if suffix.len == 0 {
                suffix = zbackend_ir_function_value_generic_suffix(
                    context.type_layout, declaration, context.value_type_id
                ) catch |err| { return err }
            }
            callee = zbackend_ir_ensure_generic_instance_id(
                context.type_layout, function_value_name, suffix
            ) catch |err| { return err }
        } else {
            callee = zbackend_ir_function_id(
                context.ast, function_value_name
            ) catch |err| { return err }
        }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        function_address: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "function_address", context.value_type_id
        )
        function_address.callee = callee
        return zbackend_ir_append_instruction(
            context, function_address
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprIdentifier {
        if zbackend_ir_has_local(context.local_names, context.local_count, expression.name) {
            local_address: i64 = zbackend_ir_local_address(context, expression.name) catch |err| { return err }
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            local_type_id: i64 = zbackend_ir_local_type_from_arrays(
                context.local_names, context.local_type_ids, context.local_count, expression.name
            ) catch |err| { return err }
            instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "load", local_type_id)
            instruction.lhs = local_address
            return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
        }
        if zbackend_ir_is_global_name(context.ast, expression.name) {
            address: i64 = zbackend_ir_expression_lower_address(
                context, expression_index
            ) catch |err| { return err }
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            load: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "load", actual_type_id
            )
            load.lhs = address
            return zbackend_ir_append_instruction(context, load) catch |err| { return err }
        }
        if zbackend_ir_is_function_name(context.ast, expression.name) {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            function_address: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "function_address", actual_type_id
            )
            declaration: ZAstDecl = zbackend_ir_function_declaration(
                context.ast, expression.name
            ) catch |err| { return err }
            if declaration.generic_param_count > 0 {
                if expression.type_index == ZAstNoIndex { return error.InvalidArgument }
                function_address.callee = zbackend_ir_generic_instance_id(
                    context.type_layout,
                    expression.name,
                    context.ast.types[expression.type_index].text
                ) catch |err| { return err }
            } else {
                function_address.callee = zbackend_ir_function_id(
                    context.ast, expression.name
                ) catch |err| { return err }
            }
            return zbackend_ir_append_instruction(
                context, function_address
            ) catch |err| { return err }
        }
        return zbackend_ir_parameter_id(context.ast, context.declaration, expression.name) catch |err| { return err }
    }
    if expression.kind == ZAstExprInteger || expression.kind == ZAstExprBool {
        integer: i64 = 0
        type_id: i64 = context.value_type_id
        if expression.kind == ZAstExprInteger {
            integer = zbackend_ir_parse_positive_integer(expression.literal) catch |err| { return err }
        } else {
            if expression.literal.len == 4 { integer = 1 }
            type_id = context.bool_type_id
        }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "integer_constant", type_id)
        instruction.integer = integer
        return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
    }
    if expression.kind == ZAstExprError {
        return zbackend_ir_lower_error_expression(
            context, expression
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprCast && expression.left != ZAstNoIndex {
        target_type_id: i64 = zbackend_ir_type_layout_type_id(
            context.type_layout, context.ast, expression.type_index
        ) catch |err| { return err }
        target_type: ZBackendIrType = context.type_layout.types[target_type_id - 1]
        operand_expression: ZAstExpr = context.ast.exprs[expression.left]
        if target_type.kind == "pointer" && operand_expression.kind == ZAstExprInteger {
            integer: i64 = zbackend_ir_parse_positive_integer(
                operand_expression.literal
            ) catch |err| { return err }
            if integer == 0 {
                zero_id: i64 = context.next_value_id
                context.next_value_id = context.next_value_id + 1
                return zbackend_ir_append_instruction(
                    context, zbackend_ir_new_instruction(zero_id, "zero_constant", target_type_id)
                ) catch |err| { return err }
            }
        }
        source_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, target_type_id
        ) catch |err| { return err }
        source_type: ZBackendIrType = context.type_layout.types[source_type_id - 1]
        previous_value_type_id: i64 = context.value_type_id
        previous_value_is_signed: bool = context.value_is_signed
        context.value_type_id = source_type_id
        context.value_is_signed = zbackend_ir_type_layout_is_signed(
            context.type_layout, source_type_id
        )
        operand: i64 = zbackend_ir_lower_expression(
            context, expression.left
        ) catch |err| { return err }
        context.value_type_id = previous_value_type_id
        context.value_is_signed = previous_value_is_signed
        cast_op: string = zbackend_ir_cast_op(
            context.type_layout, source_type_id, target_type_id
        ) catch |err| { return err }
        if std.str.len(cast_op) == 0 { return operand }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        cast_instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "cast", target_type_id
        )
        cast_instruction.cast_op = cast_op
        cast_instruction.lhs = operand
        return zbackend_ir_append_instruction(
            context, cast_instruction
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprString {
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "string_constant", actual_type_id
        )
        instruction.text = zbackend_ir_copy_text(
            context.allocator, expression.literal
        ) catch |err| { return err }
        return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
    }
    if expression.kind == ZAstExprField &&
        zbackend_ir_is_builtin_field(context.ast, expression) {
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "integer_constant", context.bool_type_id
        )
        instruction.integer = zbackend_ir_builtin_platform_value(
            context.type_layout, expression.name
        ) catch |err| { return err }
        return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenAmp {
        operand_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, context.value_type_id
        ) catch |err| { return err }
        address: i64 = zbackend_ir_expression_lower_address(
            context, expression.left
        ) catch |err| { return err }
        operand_type: ZBackendIrType = context.type_layout.types[operand_type_id - 1]
        if operand_type.kind != "array" { return address }
        index_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
            context.type_layout, "i64"
        ) catch |err| { return err }
        zero_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        zero: ZBackendIrInstruction = zbackend_ir_new_instruction(
            zero_id, "integer_constant", index_type_id
        )
        zero.integer = 0
        zbackend_ir_append_instruction(context, zero) catch |err| { return err }
        return zbackend_ir_expression_emit_index_address(
            context, address, zero_id, operand_type_id, operand_type.element_type
        ) catch |err| { return err }
    }
    if (expression.kind == ZAstExprUnary && expression.op == ZTokenStar) ||
        expression.kind == ZAstExprIndex {
        address: i64 = zbackend_ir_expression_lower_address(
            context, expression_index
        ) catch |err| { return err }
        type_id: i64 = zbackend_ir_expression_type_id(
            context, expression_index, context.value_type_id
        ) catch |err| { return err }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        load: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "load", type_id)
        load.lhs = address
        return zbackend_ir_append_instruction(context, load) catch |err| { return err }
    }
    if expression.kind == ZAstExprArrayLiteral {
        array_type_id: i64 = zbackend_ir_type_layout_type_id(
            context.type_layout, context.ast, expression.type_index
        ) catch |err| { return err }
        element_type_id: i64 = zbackend_ir_type_layout_element_type(
            context.type_layout, array_type_id
        ) catch |err| { return err }
        arguments: *i64 = cast(*i64, 0)
        if expression.arg_count > 0 {
            raw: *u8 = std.mem.HeapAllocator.alloc(
                context.allocator, expression.arg_count * Builtin.sizeof(i64)
            ) catch |err| { return error.OutOfMemory }
            arguments = cast(*i64, raw)
        }
        previous_value_type_id: i64 = context.value_type_id
        previous_value_is_signed: bool = context.value_is_signed
        context.value_type_id = element_type_id
        context.value_is_signed = zbackend_ir_type_layout_is_signed(
            context.type_layout, element_type_id
        )
        argument_index: i64 = 0
        while argument_index < expression.arg_count {
            arguments[argument_index] = zbackend_ir_lower_expression(
                context, context.ast.expr_args[expression.arg_start + argument_index]
            ) catch |err| { return err }
            argument_index = argument_index + 1
        }
        context.value_type_id = previous_value_type_id
        context.value_is_signed = previous_value_is_signed
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        aggregate: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "aggregate", array_type_id
        )
        aggregate.arguments = arguments
        aggregate.argument_count = expression.arg_count
        return zbackend_ir_append_instruction(context, aggregate) catch |err| { return err }
    }
    if expression.kind == ZAstExprStructLiteral {
        struct_type_id: i64 = zbackend_ir_literal_nominal_type_id(
            context.type_layout, context.ast, expression
        ) catch |err| { return err }
        struct_type: ZBackendIrType = context.type_layout.types[struct_type_id - 1]
        if struct_type.kind == "union" {
            if expression.arg_count != 1 || expression.field_start == ZAstNoIndex {
                return error.InvalidArgument
            }
            literal_field: ZAstLiteralField = context.ast.literal_fields[expression.field_start]
            variant_index: i64 = zbackend_ir_type_field_index(
                context.type_layout, struct_type_id, literal_field.name
            ) catch |err| { return err }
            values_raw: *u8 = std.mem.HeapAllocator.alloc(
                context.allocator, (struct_type.field_count + 1) * Builtin.sizeof(i64)
            ) catch |err| { return error.OutOfMemory }
            values: *i64 = cast(*i64, values_raw)
            tag_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i32"
            ) catch |err| { return err }
            tag_id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            tag: ZBackendIrInstruction = zbackend_ir_new_instruction(
                tag_id, "integer_constant", tag_type_id
            )
            tag.integer = variant_index
            zbackend_ir_append_instruction(context, tag) catch |err| { return err }
            values[0] = tag_id
            field_index: i64 = 0
            while field_index < struct_type.field_count {
                value_id: i64 = 0
                if field_index == variant_index {
                    previous_value_type_id: i64 = context.value_type_id
                    previous_value_is_signed: bool = context.value_is_signed
                    context.value_type_id = struct_type.fields[field_index].type_id
                    context.value_is_signed = zbackend_ir_type_layout_is_signed(
                        context.type_layout, context.value_type_id
                    )
                    value_id = zbackend_ir_lower_expression(
                        context, context.ast.literal_fields[expression.field_start].value_expr
                    ) catch |err| { return err }
                    context.value_type_id = previous_value_type_id
                    context.value_is_signed = previous_value_is_signed
                } else {
                    value_id = context.next_value_id
                    context.next_value_id = context.next_value_id + 1
                    zero: ZBackendIrInstruction = zbackend_ir_new_instruction(
                        value_id, "zero_constant", struct_type.fields[field_index].type_id
                    )
                    zbackend_ir_append_instruction(context, zero) catch |err| { return err }
                }
                values[field_index + 1] = value_id
                field_index = field_index + 1
            }
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            aggregate: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "aggregate", struct_type_id
            )
            aggregate.arguments = values
            aggregate.argument_count = struct_type.field_count + 1
            return zbackend_ir_append_instruction(context, aggregate) catch |err| { return err }
        }
        if struct_type.kind != "struct" { return error.NotImplemented }
        values: *i64 = cast(*i64, 0)
        if struct_type.field_count > 0 {
            raw: *u8 = std.mem.HeapAllocator.alloc(
                context.allocator, struct_type.field_count * Builtin.sizeof(i64)
            ) catch |err| { return error.OutOfMemory }
            values = cast(*i64, raw)
        }
        field_index: i64 = 0
        while field_index < struct_type.field_count {
            literal_field_index: i64 = expression.field_start
            found_expression: i64 = ZAstNoIndex
            while literal_field_index != ZAstNoIndex {
                literal_field: ZAstLiteralField = context.ast.literal_fields[literal_field_index]
                if ZAstText.eql_string(literal_field.name, struct_type.fields[field_index].name) {
                    found_expression = literal_field.value_expr
                    literal_field_index = ZAstNoIndex
                } else {
                    literal_field_index = literal_field.next_index
                }
            }
            if found_expression == ZAstNoIndex { return error.InvalidArgument }
            previous_value_type_id: i64 = context.value_type_id
            previous_value_is_signed: bool = context.value_is_signed
            context.value_type_id = struct_type.fields[field_index].type_id
            context.value_is_signed = zbackend_ir_type_layout_is_signed(
                context.type_layout, context.value_type_id
            )
            values[field_index] = zbackend_ir_lower_expression(
                context, found_expression
            ) catch |err| { return err }
            context.value_type_id = previous_value_type_id
            context.value_is_signed = previous_value_is_signed
            field_index = field_index + 1
        }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        aggregate: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "aggregate", struct_type_id
        )
        aggregate.arguments = values
        aggregate.argument_count = struct_type.field_count
        return zbackend_ir_append_instruction(context, aggregate) catch |err| { return err }
    }
    if expression.kind == ZAstExprField {
        if zbackend_ir_field_is_static_error(context.ast, expression) {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            constant: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "integer_constant", context.type_layout.error_type_id
            )
            constant.integer = zbackend_ir_error_value(
                context.ast, expression.name
            ) catch |err| { return err }
            return zbackend_ir_append_instruction(context, constant) catch |err| { return err }
        }
        if zbackend_ir_field_is_static_enum(context.ast, expression) {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            constant: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "integer_constant", actual_type_id
            )
            constant.integer = zbackend_ir_enum_field_value(
                context.ast, expression
            ) catch |err| { return err }
            return zbackend_ir_append_instruction(context, constant) catch |err| { return err }
        }
        if zbackend_ir_field_is_static_union_tag(context.ast, expression) {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            constant: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "integer_constant", actual_type_id
            )
            constant.integer = zbackend_ir_union_tag_field_value(
                context.ast, expression
            ) catch |err| { return err }
            return zbackend_ir_append_instruction(context, constant) catch |err| { return err }
        }
        target_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression.left, context.value_type_id
        ) catch |err| { return err }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
            context.type_layout.types[target_type_id - 1].kind == "slice" {
            previous_value_type_id: i64 = context.value_type_id
            previous_value_is_signed: bool = context.value_is_signed
            context.value_type_id = target_type_id
            context.value_is_signed = false
            slice: i64 = zbackend_ir_lower_expression(
                context, expression.left
            ) catch |err| { return err }
            context.value_type_id = previous_value_type_id
            context.value_is_signed = previous_value_is_signed
            field_type_id: i64 = zbackend_ir_expression_type_id(
                context, expression_index, context.value_type_id
            ) catch |err| { return err }
            field_index: i64 = 0
            if ZAstText.eql_string(expression.name, "len") { field_index = 1 }
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            extract: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "extract_value", field_type_id
            )
            extract.lhs = slice
            extract.field_index = field_index
            return zbackend_ir_append_instruction(context, extract) catch |err| { return err }
        }
        address: i64 = zbackend_ir_expression_lower_address(
            context, expression_index
        ) catch |err| { return err }
        field_type_id: i64 = zbackend_ir_expression_type_id(
            context, expression_index, context.value_type_id
        ) catch |err| { return err }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        load: ZBackendIrInstruction = zbackend_ir_new_instruction(
            id, "load", field_type_id
        )
        load.lhs = address
        return zbackend_ir_append_instruction(context, load) catch |err| { return err }
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenMinus {
        if expression.left != ZAstNoIndex &&
            context.ast.exprs[expression.left].kind == ZAstExprInteger {
            literal_id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            literal: ZBackendIrInstruction = zbackend_ir_new_instruction(
                literal_id, "integer_constant", context.value_type_id
            )
            literal.integer = zbackend_ir_parse_negative_integer(
                context.ast.exprs[expression.left].literal
            ) catch |err| { return err }
            return zbackend_ir_append_instruction(
                context, literal
            ) catch |err| { return err }
        }
        operand_id: i64 = zbackend_ir_lower_expression(context, expression.left) catch |err| { return err }
        zero_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        zero: ZBackendIrInstruction = zbackend_ir_new_instruction(zero_id, "integer_constant", context.value_type_id)
        zero.integer = 0
        zbackend_ir_append_instruction(context, zero) catch |err| { return err }

        result_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        subtraction: ZBackendIrInstruction = zbackend_ir_new_instruction(result_id, "binary", context.value_type_id)
        subtraction.binary_op = "sub"
        subtraction.lhs = zero_id
        subtraction.rhs = operand_id
        return zbackend_ir_append_instruction(context, subtraction) catch |err| { return err }
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenBang {
        return zbackend_ir_lower_logical_not(
            context, expression.left
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprBinary {
        lhs: i64 = zbackend_ir_lower_expression(context, expression.left) catch |err| { return err }
        rhs: i64 = zbackend_ir_lower_expression(context, expression.right) catch |err| { return err }
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        if zbackend_ir_is_comparison(expression.op) {
            compare_op: string = zbackend_ir_compare_op(
                expression.op, context.value_is_signed
            ) catch |err| { return err }
            comparison: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "compare", context.bool_type_id)
            comparison.compare_op = compare_op
            comparison.lhs = lhs
            comparison.rhs = rhs
            return zbackend_ir_append_instruction(context, comparison) catch |err| { return err }
        }
        binary_op: string = zbackend_ir_binary_op(
            expression.op, context.value_is_signed
        ) catch |err| { return err }
        instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "binary", context.value_type_id)
        instruction.binary_op = binary_op
        instruction.lhs = lhs
        instruction.rhs = rhs
        return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
    }
    if expression.kind == ZAstExprCall {
        expression.name = zbackend_ir_resolved_call_name(
            context.type_layout, expression
        ) catch |err| { return err }
        if ZAstText.eql_string(expression.name, "syscall") {
            if expression.arg_count < 1 || expression.arg_count > 7 { return error.InvalidArgument }
            syscall_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i64"
            ) catch |err| { return err }
            arguments: *i64 = cast(*i64, 0)
            raw: *u8 = std.mem.HeapAllocator.alloc(
                context.allocator, expression.arg_count * Builtin.sizeof(i64)
            ) catch |err| { return error.OutOfMemory }
            arguments = cast(*i64, raw)
            previous_value_type_id: i64 = context.value_type_id
            previous_value_is_signed: bool = context.value_is_signed
            context.value_type_id = syscall_type_id
            context.value_is_signed = true
            argument_index: i64 = 0
            while argument_index < expression.arg_count {
                argument_expression_index: i64 = context.ast.expr_args[
                    expression.arg_start + argument_index
                ]
                argument_type_id: i64 = zbackend_ir_expression_operand_type_id(
                    context, argument_expression_index, syscall_type_id
                ) catch |err| { return err }
                context.value_type_id = argument_type_id
                context.value_is_signed = zbackend_ir_type_layout_is_signed(
                    context.type_layout, argument_type_id
                )
                argument_value: i64 = zbackend_ir_lower_expression(
                    context, argument_expression_index
                ) catch |err| { return err }
                arguments[argument_index] = zbackend_ir_expression_emit_cast_value(
                    context, argument_value, argument_type_id, syscall_type_id
                ) catch |err| { return err }
                argument_index = argument_index + 1
            }
            context.value_type_id = previous_value_type_id
            context.value_is_signed = previous_value_is_signed
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "syscall", syscall_type_id
            )
            instruction.arguments = arguments
            instruction.argument_count = expression.arg_count
            return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
        }
        if zbackend_ir_is_builtin_sizeof(context.ast, expression) {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            size_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i64"
            ) catch |err| { return err }
            instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "size_of", size_type_id
            )
            instruction.source_type = zbackend_ir_type_layout_type_id(
                context.type_layout, context.ast, expression.type_index
            ) catch |err| { return err }
            return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
        }
        if expression.left != ZAstNoIndex &&
            !zbackend_ir_is_function_name(context.ast, expression.name) {
            callee_type_id: i64 = zbackend_ir_expression_type_id(
                context, expression.left, context.value_type_id
            ) catch |err| { return err }
            if callee_type_id > 0 && callee_type_id <= context.type_layout.type_count &&
                context.type_layout.types[callee_type_id - 1].kind == "function" {
                function_type: ZBackendIrType = context.type_layout.types[callee_type_id - 1]
                callee: i64 = zbackend_ir_lower_expression(
                    context, expression.left
                ) catch |err| { return err }
                if expression.arg_count != function_type.field_count { return error.InvalidArgument }
                arguments: *i64 = cast(*i64, 0)
                if expression.arg_count > 0 {
                    raw: *u8 = std.mem.HeapAllocator.alloc(
                        context.allocator, expression.arg_count * Builtin.sizeof(i64)
                    ) catch |err| { return error.OutOfMemory }
                    arguments = cast(*i64, raw)
                }
                previous_value_type_id: i64 = context.value_type_id
                previous_value_is_signed: bool = context.value_is_signed
                argument_index: i64 = 0
                while argument_index < expression.arg_count {
                    context.value_type_id = function_type.fields[argument_index].type_id
                    context.value_is_signed = zbackend_ir_type_layout_is_signed(
                        context.type_layout, context.value_type_id
                    )
                    arguments[argument_index] = zbackend_ir_lower_expression(
                        context, context.ast.expr_args[expression.arg_start + argument_index]
                    ) catch |err| { return err }
                    argument_index = argument_index + 1
                }
                context.value_type_id = previous_value_type_id
                context.value_is_signed = previous_value_is_signed
                id: i64 = context.next_value_id
                context.next_value_id = context.next_value_id + 1
                call: ZBackendIrInstruction = zbackend_ir_new_instruction(
                    id, "indirect_call", function_type.element_type
                )
                call.source_type = callee_type_id
                call.lhs = callee
                call.arguments = arguments
                call.argument_count = expression.arg_count
                return zbackend_ir_append_instruction(context, call) catch |err| { return err }
            }
        }
        if expression.name.len == 0 { return error.NotImplemented }
        callee_declaration: ZAstDecl = zbackend_ir_function_declaration(
            context.ast, expression.name
        ) catch |err| { return err }
        if expression.arg_count != callee_declaration.param_count { return error.InvalidArgument }
        previous_generic_declaration: i64 = context.type_layout.active_generic_declaration
        previous_generic_suffix: ZAstText = context.type_layout.active_generic_suffix
        call_generic_suffix: ZAstText = ZAstText.empty()
        if callee_declaration.generic_param_count > 0 {
            declaration_index: i64 = zbackend_ir_owning_declaration_index(
                context.ast, callee_declaration.name
            )
            if declaration_index == ZAstNoIndex { return error.InvalidArgument }
            call_generic_suffix = zbackend_ir_resolve_call_generic_suffix(
                context.type_layout,
                context.declaration,
                expression,
                callee_declaration,
                context.current_statement_index - context.declaration.stmt_start
            ) catch |err| { return err }
            context.type_layout.active_generic_declaration = declaration_index
            context.type_layout.active_generic_suffix = call_generic_suffix
        }
        arguments: *i64 = cast(*i64, 0)
        if expression.arg_count > 0 {
            arguments_raw: *u8 = std.mem.HeapAllocator.alloc(
                context.allocator,
                expression.arg_count * Builtin.sizeof(i64)
            ) catch |err| { return error.OutOfMemory }
            arguments = cast(*i64, arguments_raw)
            argument_index: i64 = 0
            while expression.arg_count > argument_index {
                if argument_index >= callee_declaration.param_count { return error.InvalidArgument }
                parameter: ZAstParam = context.ast.params[
                    callee_declaration.param_start + argument_index
                ]
                argument_type_id: i64 = zbackend_ir_type_layout_type_id(
                    context.type_layout, context.ast, parameter.type_index
                ) catch |err| { return err }
                argument_operand_type_id: i64 = zbackend_ir_expression_operand_type_id(
                    context,
                    context.ast.expr_args[expression.arg_start + argument_index],
                    argument_type_id
                ) catch |err| { return err }
                expected_argument_type: ZBackendIrType = context.type_layout.types[argument_type_id - 1]
                actual_argument_type: ZBackendIrType = context.type_layout.types[argument_operand_type_id - 1]
                if expected_argument_type.kind == "slice" && actual_argument_type.kind == "array" &&
                    expected_argument_type.element_type == actual_argument_type.element_type {
                    argument_operand_type_id = argument_type_id
                }
                if expected_argument_type.kind == "pointer" && actual_argument_type.kind == "array" &&
                    expected_argument_type.element_type == actual_argument_type.element_type {
                    argument_operand_type_id = argument_type_id
                }
                previous_value_type_id: i64 = context.value_type_id
                previous_value_is_signed: bool = context.value_is_signed
                context.value_type_id = argument_operand_type_id
                context.value_is_signed = zbackend_ir_type_layout_is_signed(
                    context.type_layout, argument_operand_type_id
                )
                argument_value: i64 = zbackend_ir_lower_expression(
                    context,
                    context.ast.expr_args[expression.arg_start + argument_index]
                ) catch |err| { return err }
                arguments[argument_index] = zbackend_ir_expression_emit_cast_value(
                    context, argument_value, argument_operand_type_id, argument_type_id
                ) catch |err| { return err }
                context.value_type_id = previous_value_type_id
                context.value_is_signed = previous_value_is_signed
                argument_index = argument_index + 1
            }
        }
        callee: i64 = zbackend_ir_call_function_id(
            context.type_layout, expression, call_generic_suffix
        ) catch |err| { return err }
        call_type_id: i64 = zbackend_ir_function_return_type_id(
            context.type_layout, context.ast, callee_declaration
        ) catch |err| { return err }
        context.type_layout.active_generic_declaration = previous_generic_declaration
        context.type_layout.active_generic_suffix = previous_generic_suffix
        id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "call", call_type_id)
        instruction.callee = callee
        instruction.arguments = arguments
        instruction.argument_count = expression.arg_count
        return zbackend_ir_append_instruction(context, instruction) catch |err| { return err }
    }
    return error.NotImplemented
}

struct ZBackendIrBlockBuilder {
    id: i64,
    name: string,
    instructions: *ZBackendIrInstruction,
    instruction_count: i64,
    instruction_capacity: i64,
    terminator: ZBackendIrTerminator,
    is_terminated: bool
}

struct ZBackendIrControlFlowLowering {
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    declaration: ZAstDecl,
    type_layout: *ZBackendIrTypeLayout,
    bool_type_id: i64,
    error_type_id: i64,
    error_union_type_id: i64,
    return_payload_type_id: i64,
    return_type_id: i64,
    returns_error_union: bool,
    returns_void: bool,
    blocks: *ZBackendIrBlockBuilder,
    block_count: i64,
    block_capacity: i64,
    current_block: i64,
    next_value_id: i64,
    local_names: *ZAstText,
    local_addresses: *i64,
    local_type_ids: *i64,
    local_is_catch_errors: *i64,
    local_count: i64,
    local_capacity: i64,
    scope_starts: *i64,
    scope_count: i64,
    scope_capacity: i64,
    break_targets: *i64,
    continue_targets: *i64,
    loop_count: i64,
    loop_capacity: i64,
    active_catch_owner: i64,
    current_statement_index: i64
}

fn zbackend_ir_next_capacity(current: i64, needed: i64, initial: i64) -> i64 {
    capacity: i64 = current
    if capacity < initial { capacity = initial }
    while capacity < needed { capacity = capacity * 2 }
    return capacity
}

fn zbackend_ir_cfg_reserve_blocks(context: *ZBackendIrControlFlowLowering, needed: i64) !i64 {
    if needed <= context.block_capacity { return 0 }
    new_capacity: i64 = zbackend_ir_next_capacity(
        context.block_capacity, needed, ZBACKEND_IR_INITIAL_BLOCK_CAPACITY
    )
    raw: *u8 = std.mem.HeapAllocator.alloc(
        context.allocator, new_capacity * Builtin.sizeof(ZBackendIrBlockBuilder)
    ) catch |err| { return error.OutOfMemory }
    new_blocks: *ZBackendIrBlockBuilder = cast(*ZBackendIrBlockBuilder, raw)
    index: i64 = 0
    while index < context.block_count {
        new_blocks[index] = context.blocks[index]
        index = index + 1
    }
    context.blocks = new_blocks
    context.block_capacity = new_capacity
    return 0
}

fn zbackend_ir_cfg_create_block(context: *ZBackendIrControlFlowLowering, name: string) !i64 {
    zbackend_ir_cfg_reserve_blocks(context, context.block_count + 1) catch |err| { return err }
    id: i64 = context.block_count + 1
    context.blocks[context.block_count] = ZBackendIrBlockBuilder{
        id: id,
        name: name,
        instructions: cast(*ZBackendIrInstruction, 0),
        instruction_count: 0,
        instruction_capacity: 0,
        terminator: zbackend_ir_new_terminator(""),
        is_terminated: false
    }
    context.block_count = context.block_count + 1
    return id
}

fn zbackend_ir_cfg_activate_block(context: *ZBackendIrControlFlowLowering, block_id: i64) !i64 {
    if block_id <= 0 || block_id > context.block_count { return error.OutOfBounds }
    if context.blocks[block_id - 1].is_terminated { return error.InvalidArgument }
    context.current_block = block_id - 1
    return 0
}

fn zbackend_ir_cfg_reserve_instructions(
    context: *ZBackendIrControlFlowLowering,
    block_index: i64,
    needed: i64
) !i64 {
    if block_index < 0 || block_index >= context.block_count { return error.OutOfBounds }
    if needed <= context.blocks[block_index].instruction_capacity { return 0 }
    new_capacity: i64 = zbackend_ir_next_capacity(
        context.blocks[block_index].instruction_capacity,
        needed,
        ZBACKEND_IR_INITIAL_INSTRUCTION_CAPACITY
    )
    raw: *u8 = std.mem.HeapAllocator.alloc(
        context.allocator, new_capacity * Builtin.sizeof(ZBackendIrInstruction)
    ) catch |err| { return error.OutOfMemory }
    new_instructions: *ZBackendIrInstruction = cast(*ZBackendIrInstruction, raw)
    index: i64 = 0
    while index < context.blocks[block_index].instruction_count {
        new_instructions[index] = context.blocks[block_index].instructions[index]
        index = index + 1
    }
    context.blocks[block_index].instructions = new_instructions
    context.blocks[block_index].instruction_capacity = new_capacity
    return 0
}

fn zbackend_ir_cfg_append_instruction(
    context: *ZBackendIrControlFlowLowering,
    instruction: ZBackendIrInstruction
) !i64 {
    if context.current_block < 0 { return error.InvalidArgument }
    block_index: i64 = context.current_block
    needed: i64 = context.blocks[block_index].instruction_count + 1
    zbackend_ir_cfg_reserve_instructions(context, block_index, needed) catch |err| { return err }
    context.blocks[block_index].instructions[needed - 1] = instruction
    context.blocks[block_index].instruction_count = needed
    return instruction.id
}

fn zbackend_ir_cfg_emit_integer_constant(
    context: *ZBackendIrControlFlowLowering,
    value: i64,
    type_id: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "integer_constant", type_id)
    instruction.integer = value
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cfg_emit_cast_value(
    context: *ZBackendIrControlFlowLowering,
    value: i64,
    source_type_id: i64,
    target_type_id: i64
) !i64 {
    cast_op: string = zbackend_ir_cast_op(
        context.type_layout, source_type_id, target_type_id
    ) catch |err| { return err }
    if std.str.len(cast_op) == 0 { return value }
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "cast", target_type_id
    )
    instruction.cast_op = cast_op
    instruction.lhs = value
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cfg_emit_zero_constant(
    context: *ZBackendIrControlFlowLowering,
    type_id: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    return zbackend_ir_cfg_append_instruction(
        context, zbackend_ir_new_instruction(id, "zero_constant", type_id)
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_emit_aggregate(
    context: *ZBackendIrControlFlowLowering,
    type_id: i64,
    values: *i64,
    value_count: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "aggregate", type_id)
    instruction.arguments = values
    instruction.argument_count = value_count
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cfg_emit_extract_value(
    context: *ZBackendIrControlFlowLowering,
    aggregate: i64,
    type_id: i64,
    field_index: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "extract_value", type_id)
    instruction.lhs = aggregate
    instruction.field_index = field_index
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cfg_emit_phi(
    context: *ZBackendIrControlFlowLowering,
    type_id: i64,
    incoming_values: *i64,
    incoming_blocks: *i64,
    incoming_count: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "phi", type_id)
    instruction.incoming_values = incoming_values
    instruction.incoming_blocks = incoming_blocks
    instruction.incoming_count = incoming_count
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_error_value(ast: *ZAstModule, name: ZAstText) !i64 {
    index: i64 = 0
    while index < ast.len {
        declaration: ZAstDecl = ast.decls[index]
        if declaration.kind == ZAstDeclError &&
            zbackend_ir_name_matches_qualified_suffix(name, declaration.name) &&
            declaration.init_expr != ZAstNoIndex {
            expression: ZAstExpr = ast.exprs[declaration.init_expr]
            if expression.kind != ZAstExprInteger { return error.NotImplemented }
            return zbackend_ir_parse_positive_integer(expression.literal) catch |err| { return err }
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_cfg_type_id(
    context: *ZBackendIrControlFlowLowering,
    type_index: i64
) !i64 {
    return zbackend_ir_type_layout_type_id(
        context.type_layout, context.ast, type_index
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_parameter_type_id(
    context: *ZBackendIrControlFlowLowering,
    name: ZAstText
) !i64 {
    index: i64 = 0
    while index < context.declaration.param_count {
        parameter: ZAstParam = context.ast.params[context.declaration.param_start + index]
        if ZAstText.eql(parameter.name, name) {
            return zbackend_ir_cfg_type_id(context, parameter.type_index) catch |err| { return err }
        }
        index = index + 1
    }
    return error.NotImplemented
}

fn zbackend_ir_cfg_expression_type_id(
    context: *ZBackendIrControlFlowLowering,
    expression_index: i64,
    fallback_type_id: i64
) !i64 {
    if expression_index == ZAstNoIndex { return error.NotImplemented }
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier {
        if zbackend_ir_is_error_name(context.ast, expression.name) {
            return context.error_type_id
        }
        if zbackend_ir_has_local(context.local_names, context.local_count, expression.name) {
            return zbackend_ir_local_type_from_arrays(
                context.local_names, context.local_type_ids, context.local_count, expression.name
            ) catch |err| { return err }
        }
        if !zbackend_ir_is_global_name(context.ast, expression.name) {
            if zbackend_ir_is_function_name(context.ast, expression.name) {
                return fallback_type_id
            }
            return zbackend_ir_cfg_parameter_type_id(
                context, expression.name
            ) catch |err| { return err }
        }
        global_declaration: ZAstDecl = zbackend_ir_global_declaration(
            context.ast, expression.name
        ) catch |err| { return err }
        return zbackend_ir_cfg_type_id(
            context, global_declaration.type_index
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprInteger { return fallback_type_id }
    if expression.kind == ZAstExprBool { return context.bool_type_id }
    if expression.kind == ZAstExprError { return context.error_type_id }
    if expression.kind == ZAstExprString {
        return zbackend_ir_type_layout_intern_text(
            context.type_layout, ZAstText{ ptr: cast(*u8, "string"), len: 6 }
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprUnary {
        operand_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if expression.op == ZTokenAmp {
            operand_type: ZBackendIrType = context.type_layout.types[operand_type_id - 1]
            if operand_type.kind == "array" {
                return zbackend_ir_type_layout_pointer_to(
                    context.type_layout, operand_type.element_type
                ) catch |err| { return err }
            }
            return zbackend_ir_type_layout_pointer_to(
                context.type_layout, operand_type_id
            ) catch |err| { return err }
        }
        if expression.op == ZTokenStar {
            return zbackend_ir_type_layout_element_type(
                context.type_layout, operand_type_id
            ) catch |err| { return err }
        }
        return operand_type_id
    }
    if expression.kind == ZAstExprIndex {
        target_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        return zbackend_ir_type_layout_element_type(
            context.type_layout, target_type_id
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprArrayLiteral {
        return zbackend_ir_cfg_type_id(context, expression.type_index) catch |err| { return err }
    }
    if expression.kind == ZAstExprCast {
        return zbackend_ir_cfg_type_id(context, expression.type_index) catch |err| { return err }
    }
    if expression.kind == ZAstExprStructLiteral {
        return zbackend_ir_literal_nominal_type_id(
            context.type_layout, context.ast, expression
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprField {
        if zbackend_ir_field_is_static_enum(context.ast, expression) {
            return fallback_type_id
        }
        resolved_global: ZAstText = zbackend_ir_resolved_global_name(
            context.type_layout, expression_index
        ) catch |err| { return err }
        if resolved_global.len > 0 {
            global_declaration: ZAstDecl = zbackend_ir_global_declaration(
                context.ast, resolved_global
            ) catch |err| { return err }
            return zbackend_ir_cfg_type_id(
                context, global_declaration.type_index
            ) catch |err| { return err }
        }
        resolved_function_value: ZAstText = zbackend_ir_resolved_function_value_name(
            context.type_layout, expression_index
        ) catch |err| { return err }
        if resolved_function_value.len > 0 {
            return fallback_type_id
        }
        if zbackend_ir_is_builtin_field(context.ast, expression) {
            return context.bool_type_id
        }
        if zbackend_ir_field_is_static_error(context.ast, expression) {
            return context.error_type_id
        }
        if zbackend_ir_field_is_static_union_tag(context.ast, expression) {
            return fallback_type_id
        }
        target_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
            context.type_layout.types[target_type_id - 1].kind == "slice" {
            if ZAstText.eql_string(expression.name, "len") {
                return zbackend_ir_type_layout_intern_scalar(
                    context.type_layout, "i64"
                ) catch |err| { return err }
            }
            if ZAstText.eql_string(expression.name, "ptr") {
                return zbackend_ir_type_layout_pointer_to(
                    context.type_layout,
                    context.type_layout.types[target_type_id - 1].element_type
                ) catch |err| { return err }
            }
        }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
            context.type_layout.types[target_type_id - 1].kind == "error_union" {
            if ZAstText.eql_string(expression.name, "value") {
                return context.type_layout.types[target_type_id - 1].element_type
            }
            if ZAstText.eql_string(expression.name, "error") {
                return context.error_type_id
            }
        }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count {
            target_type: ZBackendIrType = context.type_layout.types[target_type_id - 1]
            if target_type.kind == "pointer" {
                target_type_id = target_type.element_type
                target_type = context.type_layout.types[target_type_id - 1]
            }
            if target_type.kind == "struct" || target_type.kind == "union" {
                if target_type.kind == "union" &&
                    ZAstText.eql_string(expression.name, "tag") {
                    return zbackend_ir_type_layout_intern_scalar(
                        context.type_layout, "i32"
                    ) catch |err| { return err }
                }
                field_index: i64 = zbackend_ir_type_field_index(
                    context.type_layout, target_type_id, expression.name
                ) catch |err| { return err }
                return target_type.fields[field_index].type_id
            }
        }
    }
    if expression.kind == ZAstExprBinary {
        if zbackend_ir_is_comparison(expression.op) { return context.bool_type_id }
        left_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if context.ast.exprs[expression.left].kind != ZAstExprInteger { return left_type_id }
        return zbackend_ir_cfg_expression_type_id(
            context, expression.right, fallback_type_id
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprCall {
        expression.name = zbackend_ir_resolved_call_name(
            context.type_layout, expression
        ) catch |err| { return err }
        if ZAstText.eql_string(expression.name, "syscall") {
            return zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i64"
            ) catch |err| { return err }
        }
        if zbackend_ir_is_builtin_sizeof(context.ast, expression) {
            return zbackend_ir_type_layout_intern_scalar(
                context.type_layout, "i64"
            ) catch |err| { return err }
        }
        if expression.left != ZAstNoIndex &&
            !zbackend_ir_is_function_name(context.ast, expression.name) {
            callee_type_id: i64 = zbackend_ir_cfg_expression_type_id(
                context, expression.left, fallback_type_id
            ) catch |err| { return err }
            if callee_type_id > 0 && callee_type_id <= context.type_layout.type_count &&
                context.type_layout.types[callee_type_id - 1].kind == "function" {
                return context.type_layout.types[callee_type_id - 1].element_type
            }
        }
        declaration: ZAstDecl = zbackend_ir_function_declaration(
            context.ast, expression.name
        ) catch |err| { return err }
        generic_suffix: ZAstText = ZAstText.empty()
        if declaration.generic_param_count > 0 {
            generic_suffix = zbackend_ir_resolve_call_generic_suffix(
                context.type_layout,
                context.declaration,
                expression,
                declaration,
                context.current_statement_index - context.declaration.stmt_start
            ) catch |err| { return err }
        }
        return zbackend_ir_call_return_type_id(
            context.type_layout, expression, declaration, generic_suffix
        ) catch |err| { return err }
    }
    if expression.kind == ZAstExprCatch {
        protected_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if protected_type_id <= 0 || protected_type_id > context.type_layout.type_count {
            return error.InvalidArgument
        }
        protected_type: ZBackendIrType = context.type_layout.types[protected_type_id - 1]
        if protected_type.kind != "error_union" { return error.InvalidArgument }
        return protected_type.element_type
    }
    return fallback_type_id
}

fn zbackend_ir_cfg_expression_operand_type_id(
    context: *ZBackendIrControlFlowLowering,
    expression_index: i64,
    fallback_type_id: i64
) !i64 {
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind == ZAstExprBinary && zbackend_ir_is_comparison(expression.op) {
        left_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, fallback_type_id
        ) catch |err| { return err }
        if context.ast.exprs[expression.left].kind != ZAstExprInteger { return left_type_id }
        return zbackend_ir_cfg_expression_type_id(
            context, expression.right, fallback_type_id
        ) catch |err| { return err }
    }
    return zbackend_ir_cfg_expression_type_id(
        context, expression_index, fallback_type_id
    ) catch |err| { return err }
}

fn zbackend_ir_expression_instruction_capacity(ast: *ZAstModule, expression_index: i64) !i64 {
    if expression_index == ZAstNoIndex { return error.NotImplemented }
    expression: ZAstExpr = ast.exprs[expression_index]
    if expression.kind == ZAstExprIdentifier || expression.kind == ZAstExprInteger ||
        expression.kind == ZAstExprBool || expression.kind == ZAstExprString ||
        expression.kind == ZAstExprError { return 1 }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenMinus {
        operand_capacity: i64 = zbackend_ir_expression_instruction_capacity(ast, expression.left) catch |err| { return err }
        return operand_capacity + 2
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenBang {
        operand_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.left
        ) catch |err| { return err }
        return operand_capacity + 2
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenAmp {
        operand_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.left
        ) catch |err| { return 4 }
        return operand_capacity + 4
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenStar {
        operand_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.left
        ) catch |err| { return err }
        return operand_capacity + 1
    }
    if expression.kind == ZAstExprIndex {
        target_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.left
        ) catch |err| { return 8 }
        index_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.right
        ) catch |err| { return err }
        return target_capacity + index_capacity + 2
    }
    if expression.kind == ZAstExprArrayLiteral {
        capacity: i64 = 1
        element_index: i64 = 0
        while element_index < expression.arg_count {
            element_capacity: i64 = zbackend_ir_expression_instruction_capacity(
                ast, ast.expr_args[expression.arg_start + element_index]
            ) catch |err| { return err }
            capacity = capacity + element_capacity
            element_index = element_index + 1
        }
        return capacity
    }
    if expression.kind == ZAstExprCast {
        operand_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.left
        ) catch |err| { return err }
        return operand_capacity + 1
    }
    if expression.kind == ZAstExprStructLiteral {
        capacity: i64 = 1
        argument_index: i64 = 0
        while argument_index < expression.arg_count {
            argument_capacity: i64 = zbackend_ir_expression_instruction_capacity(
                ast, ast.expr_args[expression.arg_start + argument_index]
            ) catch |err| { return err }
            capacity = capacity + argument_capacity
            argument_index = argument_index + 1
        }
        return capacity
    }
    if expression.kind == ZAstExprField {
        target_capacity: i64 = zbackend_ir_expression_instruction_capacity(
            ast, expression.left
        ) catch |err| { return err }
        return target_capacity + 1
    }
    if expression.kind == ZAstExprBinary {
        left_capacity: i64 = zbackend_ir_expression_instruction_capacity(ast, expression.left) catch |err| { return err }
        right_capacity: i64 = zbackend_ir_expression_instruction_capacity(ast, expression.right) catch |err| { return err }
        return left_capacity + right_capacity + 1
    }
    if expression.kind == ZAstExprCall {
        capacity: i64 = 1
        if expression.left != ZAstNoIndex {
            callee_capacity: i64 = zbackend_ir_expression_instruction_capacity(
                ast, expression.left
            ) catch |err| { return err }
            capacity = capacity + callee_capacity
        }
        argument_index: i64 = 0
        while argument_index < expression.arg_count {
            argument_capacity: i64 = zbackend_ir_expression_instruction_capacity(
                ast, ast.expr_args[expression.arg_start + argument_index]
            ) catch |err| { return err }
            capacity = capacity + argument_capacity
            capacity = capacity + ZBACKEND_IR_CONTEXTUAL_COERCION_INSTRUCTION_OVERHEAD
            argument_index = argument_index + 1
        }
        return capacity
    }
    return error.NotImplemented
}

fn zbackend_ir_cfg_lower_logical_expression(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr
) !i64 {
    lhs: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.left, context.bool_type_id
    ) catch |err| { return err }
    lhs_block: i64 = context.current_block + 1
    rhs_block: i64 = zbackend_ir_cfg_create_block(
        context, "logical.rhs"
    ) catch |err| { return err }
    merge_block: i64 = zbackend_ir_cfg_create_block(
        context, "logical.merge"
    ) catch |err| { return err }
    branch: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
    branch.condition = lhs
    if expression.op == ZTokenAndAnd {
        branch.true_target = rhs_block
        branch.false_target = merge_block
    } else {
        branch.true_target = merge_block
        branch.false_target = rhs_block
    }
    zbackend_ir_cfg_terminate(context, branch) catch |err| { return err }
    zbackend_ir_cfg_activate_block(context, rhs_block) catch |err| { return err }
    rhs: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.right, context.bool_type_id
    ) catch |err| { return err }
    rhs_predecessor: i64 = context.current_block + 1
    zbackend_ir_cfg_branch(context, merge_block) catch |err| { return err }
    zbackend_ir_cfg_activate_block(context, merge_block) catch |err| { return err }
    incoming_values: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, 2
    ) catch |err| { return err }
    incoming_blocks: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, 2
    ) catch |err| { return err }
    incoming_values[0] = lhs
    incoming_values[1] = rhs
    incoming_blocks[0] = lhs_block
    incoming_blocks[1] = rhs_predecessor
    return zbackend_ir_cfg_emit_phi(
        context, context.bool_type_id, incoming_values, incoming_blocks, 2
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_cast_expression(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr
) !i64 {
    target_type_id: i64 = zbackend_ir_cfg_type_id(
        context, expression.type_index
    ) catch |err| { return err }
    target_type: ZBackendIrType = context.type_layout.types[target_type_id - 1]
    operand_expression: ZAstExpr = context.ast.exprs[expression.left]
    if target_type.kind == "pointer" && operand_expression.kind == ZAstExprInteger {
        integer: i64 = zbackend_ir_parse_positive_integer(
            operand_expression.literal
        ) catch |err| { return err }
        if integer == 0 {
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            return zbackend_ir_cfg_append_instruction(
                context, zbackend_ir_new_instruction(id, "zero_constant", target_type_id)
            ) catch |err| { return err }
        }
    }
    source_type_id: i64 = zbackend_ir_cfg_expression_type_id(
        context, expression.left, target_type_id
    ) catch |err| { return err }
    operand: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.left, source_type_id
    ) catch |err| { return err }
    cast_op: string = zbackend_ir_cast_op(
        context.type_layout, source_type_id, target_type_id
    ) catch |err| { return err }
    if std.str.len(cast_op) == 0 { return operand }
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    cast_instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "cast", target_type_id
    )
    cast_instruction.cast_op = cast_op
    cast_instruction.lhs = operand
    return zbackend_ir_cfg_append_instruction(
        context, cast_instruction
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_logical_not_expression(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr
) !i64 {
    operand: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.left, context.bool_type_id
    ) catch |err| { return err }
    zero: i64 = zbackend_ir_cfg_emit_integer_constant(
        context, 0, context.bool_type_id
    ) catch |err| { return err }
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    comparison: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "compare", context.bool_type_id
    )
    comparison.compare_op = "equal"
    comparison.lhs = operand
    comparison.rhs = zero
    return zbackend_ir_cfg_append_instruction(
        context, comparison
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_direct_call_expression(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr
) !i64 {
    callee_declaration: ZAstDecl = zbackend_ir_function_declaration(
        context.ast, expression.name
    ) catch |err| { return err }
    if expression.arg_count != callee_declaration.param_count { return error.InvalidArgument }
    previous_generic_declaration: i64 = context.type_layout.active_generic_declaration
    previous_generic_suffix: ZAstText = context.type_layout.active_generic_suffix
    call_generic_suffix: ZAstText = ZAstText.empty()
    if callee_declaration.generic_param_count > 0 {
        declaration_index: i64 = zbackend_ir_owning_declaration_index(
            context.ast, callee_declaration.name
        )
        if declaration_index == ZAstNoIndex { return error.InvalidArgument }
        call_generic_suffix = zbackend_ir_resolve_call_generic_suffix(
            context.type_layout,
            context.declaration,
            expression,
            callee_declaration,
            context.current_statement_index - context.declaration.stmt_start
        ) catch |err| { return err }
        context.type_layout.active_generic_declaration = declaration_index
        context.type_layout.active_generic_suffix = call_generic_suffix
    }
    arguments: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, expression.arg_count
    ) catch |err| { return err }
    argument_index: i64 = 0
    while argument_index < expression.arg_count {
        if argument_index >= callee_declaration.param_count { return error.InvalidArgument }
        parameter: ZAstParam = context.ast.params[
            callee_declaration.param_start + argument_index
        ]
        argument_type_id: i64 = zbackend_ir_type_layout_type_id(
            context.type_layout, context.ast, parameter.type_index
        ) catch |err| { return err }
        argument_expression_index: i64 = context.ast.expr_args[
            expression.arg_start + argument_index
        ]
        argument_operand_type_id: i64 = zbackend_ir_cfg_expression_operand_type_id(
            context, argument_expression_index, argument_type_id
        ) catch |err| { return err }
        expected_argument_type: ZBackendIrType = context.type_layout.types[argument_type_id - 1]
        actual_argument_type: ZBackendIrType = context.type_layout.types[argument_operand_type_id - 1]
        if expected_argument_type.kind == "slice" && actual_argument_type.kind == "array" &&
            expected_argument_type.element_type == actual_argument_type.element_type {
            argument_operand_type_id = argument_type_id
        }
        if expected_argument_type.kind == "pointer" && actual_argument_type.kind == "array" &&
            expected_argument_type.element_type == actual_argument_type.element_type {
            argument_operand_type_id = argument_type_id
        }
        argument_value: i64 = zbackend_ir_cfg_lower_expression_as(
            context, argument_expression_index, argument_operand_type_id
        ) catch |err| { return err }
        cast_op: string = zbackend_ir_cast_op(
            context.type_layout, argument_operand_type_id, argument_type_id
        ) catch |err| { return err }
        if std.str.len(cast_op) > 0 {
            cast_id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            cast_instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
                cast_id, "cast", argument_type_id
            )
            cast_instruction.cast_op = cast_op
            cast_instruction.lhs = argument_value
            argument_value = zbackend_ir_cfg_append_instruction(
                context, cast_instruction
            ) catch |err| { return err }
        }
        arguments[argument_index] = argument_value
        argument_index = argument_index + 1
    }
    callee: i64 = zbackend_ir_call_function_id(
        context.type_layout, expression, call_generic_suffix
    ) catch |err| { return err }
    call_type_id: i64 = zbackend_ir_function_return_type_id(
        context.type_layout, context.ast, callee_declaration
    ) catch |err| { return err }
    context.type_layout.active_generic_declaration = previous_generic_declaration
    context.type_layout.active_generic_suffix = previous_generic_suffix
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "call", call_type_id
    )
    instruction.callee = callee
    instruction.arguments = arguments
    instruction.argument_count = expression.arg_count
    return zbackend_ir_cfg_append_instruction(
        context, instruction
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_pointer_arithmetic(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr,
    pointer_type_id: i64
) !i64 {
    pointer_type: ZBackendIrType = context.type_layout.types[pointer_type_id - 1]
    if pointer_type.kind != "pointer" { return error.InvalidArgument }
    index_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
        context.type_layout, "i64"
    ) catch |err| { return err }
    pointer: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.left, pointer_type_id
    ) catch |err| { return err }
    index: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.right, index_type_id
    ) catch |err| { return err }
    if expression.op == ZTokenMinus {
        zero: i64 = zbackend_ir_cfg_emit_integer_constant(
            context, 0, index_type_id
        ) catch |err| { return err }
        negated_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        negated: ZBackendIrInstruction = zbackend_ir_new_instruction(
            negated_id, "binary", index_type_id
        )
        negated.binary_op = "sub"
        negated.lhs = zero
        negated.rhs = index
        index = zbackend_ir_cfg_append_instruction(
            context, negated
        ) catch |err| { return err }
    }
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    address: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "index_address", pointer_type.element_type
    )
    address.source_type = pointer_type.element_type
    address.lhs = pointer
    address.rhs = index
    return zbackend_ir_cfg_append_instruction(context, address) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_struct_literal_expression(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr
) !i64 {
    struct_type_id: i64 = zbackend_ir_literal_nominal_type_id(
        context.type_layout, context.ast, expression
    ) catch |err| { return err }
    struct_type: ZBackendIrType = context.type_layout.types[struct_type_id - 1]
    if struct_type.kind == "union" {
        if expression.arg_count != 1 { return error.InvalidArgument }
        variant_index: i64 = zbackend_ir_type_field_index(
            context.type_layout, struct_type_id,
            context.ast.literal_fields[expression.field_start].name
        ) catch |err| { return err }
        values: *i64 = zbackend_ir_cfg_allocate_i64_array(
            context.allocator, struct_type.field_count + 1
        ) catch |err| { return err }
        tag_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
            context.type_layout, "i32"
        ) catch |err| { return err }
        values[0] = zbackend_ir_cfg_emit_integer_constant(
            context, variant_index, tag_type_id
        ) catch |err| { return err }
        field_index: i64 = 0
        while field_index < struct_type.field_count {
            if field_index == variant_index {
                values[field_index + 1] = zbackend_ir_cfg_lower_expression_as(
                    context,
                    context.ast.literal_fields[expression.field_start].value_expr,
                    struct_type.fields[field_index].type_id
                ) catch |err| { return err }
            } else {
                id: i64 = context.next_value_id
                context.next_value_id = context.next_value_id + 1
                values[field_index + 1] = zbackend_ir_cfg_append_instruction(
                    context,
                    zbackend_ir_new_instruction(
                        id, "zero_constant", struct_type.fields[field_index].type_id
                    )
                ) catch |err| { return err }
            }
            field_index = field_index + 1
        }
        return zbackend_ir_cfg_emit_aggregate(
            context, struct_type_id, values, struct_type.field_count + 1
        ) catch |err| { return err }
    }
    if struct_type.kind != "struct" { return error.NotImplemented }
    values: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, struct_type.field_count
    ) catch |err| { return err }
    field_index: i64 = 0
    while field_index < struct_type.field_count {
        literal_field_index: i64 = expression.field_start
        found_expression: i64 = ZAstNoIndex
        while literal_field_index != ZAstNoIndex {
            literal_field: ZAstLiteralField = context.ast.literal_fields[literal_field_index]
            if ZAstText.eql_string(literal_field.name, struct_type.fields[field_index].name) {
                found_expression = literal_field.value_expr
                literal_field_index = ZAstNoIndex
            } else {
                literal_field_index = literal_field.next_index
            }
        }
        if found_expression == ZAstNoIndex { return error.InvalidArgument }
        values[field_index] = zbackend_ir_cfg_lower_expression_as(
            context, found_expression, struct_type.fields[field_index].type_id
        ) catch |err| { return err }
        field_index = field_index + 1
    }
    return zbackend_ir_cfg_emit_aggregate(
        context, struct_type_id, values, struct_type.field_count
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_expression_as(
    context: *ZBackendIrControlFlowLowering,
    expression_index: i64,
    value_type_id: i64
) !i64 {
    if context.current_block < 0 { return error.InvalidArgument }
    if expression_index != ZAstNoIndex && context.ast.exprs[expression_index].kind == ZAstExprCatch {
        protected_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, context.ast.exprs[expression_index].left, value_type_id
        ) catch |err| { return err }
        if protected_type_id <= 0 || protected_type_id > context.type_layout.type_count {
            return error.InvalidArgument
        }
        protected_type: ZBackendIrType = context.type_layout.types[protected_type_id - 1]
        if protected_type.kind != "error_union" { return error.InvalidArgument }
        result: i64 = zbackend_ir_cfg_lower_catch_expression(
            context, expression_index, false, protected_type_id
        ) catch |err| { return err }
        return zbackend_ir_cfg_emit_cast_value(
            context, result, protected_type.element_type, value_type_id
        ) catch |err| { return err }
    }
    if expression_index != ZAstNoIndex {
        expression: ZAstExpr = context.ast.exprs[expression_index]
        if expression.kind == ZAstExprBinary &&
            (expression.op == ZTokenAndAnd || expression.op == ZTokenOrOr) {
            return zbackend_ir_cfg_lower_logical_expression(
                context, expression
            ) catch |err| { return err }
        }
        if expression.kind == ZAstExprCast {
            return zbackend_ir_cfg_lower_cast_expression(
                context, expression
            ) catch |err| { return err }
        }
        if expression.kind == ZAstExprUnary && expression.op == ZTokenBang {
            return zbackend_ir_cfg_lower_logical_not_expression(
                context, expression
            ) catch |err| { return err }
        }
        if expression.kind == ZAstExprStructLiteral {
            return zbackend_ir_cfg_lower_struct_literal_expression(
                context, expression
            ) catch |err| { return err }
        }
        if expression.kind == ZAstExprCall {
            expression.name = zbackend_ir_resolved_call_name(
                context.type_layout, expression
            ) catch |err| { return err }
            if zbackend_ir_is_function_name(context.ast, expression.name) {
                return zbackend_ir_cfg_lower_direct_call_expression(
                    context, expression
                ) catch |err| { return err }
            }
        }
        if expression.kind == ZAstExprBinary {
            lhs_type_id: i64 = zbackend_ir_cfg_expression_type_id(
                context, expression.left, value_type_id
            ) catch |err| { return err }
            rhs_type_id: i64 = zbackend_ir_cfg_expression_type_id(
                context, expression.right, value_type_id
            ) catch |err| { return err }
            lhs_is_pointer: bool = lhs_type_id > 0 && lhs_type_id <= context.type_layout.type_count &&
                context.type_layout.types[lhs_type_id - 1].kind == "pointer"
            rhs_is_pointer: bool = rhs_type_id > 0 && rhs_type_id <= context.type_layout.type_count &&
                context.type_layout.types[rhs_type_id - 1].kind == "pointer"
            if (expression.op == ZTokenPlus || expression.op == ZTokenMinus) && lhs_is_pointer {
                return zbackend_ir_cfg_lower_pointer_arithmetic(
                    context, expression, lhs_type_id
                ) catch |err| { return err }
            }
            if expression.op == ZTokenPlus && rhs_is_pointer {
                normalized: ZAstExpr = expression
                normalized.left = expression.right
                normalized.right = expression.left
                return zbackend_ir_cfg_lower_pointer_arithmetic(
                    context, normalized, rhs_type_id
                ) catch |err| { return err }
            }
            operand_type_id: i64 = lhs_type_id
            if context.ast.exprs[expression.left].kind == ZAstExprInteger {
                operand_type_id = rhs_type_id
            } else if context.ast.exprs[expression.right].kind != ZAstExprInteger &&
                lhs_type_id > 0 && rhs_type_id > 0 &&
                lhs_type_id <= context.type_layout.type_count && rhs_type_id <= context.type_layout.type_count {
                lhs_type: ZBackendIrType = context.type_layout.types[lhs_type_id - 1]
                rhs_type: ZBackendIrType = context.type_layout.types[rhs_type_id - 1]
                if lhs_type.kind == "scalar" && rhs_type.kind == "scalar" &&
                    zbackend_ir_scalar_bit_width(rhs_type.scalar) > zbackend_ir_scalar_bit_width(lhs_type.scalar) {
                    operand_type_id = rhs_type_id
                }
            }
            lhs: i64 = zbackend_ir_cfg_lower_expression_as(
                context, expression.left, operand_type_id
            ) catch |err| { return err }
            rhs: i64 = zbackend_ir_cfg_lower_expression_as(
                context, expression.right, operand_type_id
            ) catch |err| { return err }
            id: i64 = context.next_value_id
            context.next_value_id = context.next_value_id + 1
            if zbackend_ir_is_comparison(expression.op) {
                compare: ZBackendIrInstruction = zbackend_ir_new_instruction(
                    id, "compare", context.bool_type_id
                )
                compare.compare_op = zbackend_ir_compare_op(
                    expression.op,
                    zbackend_ir_type_layout_is_signed(context.type_layout, operand_type_id)
                ) catch |err| { return err }
                compare.lhs = lhs
                compare.rhs = rhs
                return zbackend_ir_cfg_append_instruction(context, compare) catch |err| { return err }
            }
            binary: ZBackendIrInstruction = zbackend_ir_new_instruction(
                id, "binary", operand_type_id
            )
            binary.binary_op = zbackend_ir_binary_op(
                expression.op,
                zbackend_ir_type_layout_is_signed(context.type_layout, operand_type_id)
            ) catch |err| { return err }
            binary.lhs = lhs
            binary.rhs = rhs
            return zbackend_ir_cfg_append_instruction(context, binary) catch |err| { return err }
        }
        if expression.kind == ZAstExprIndex {
            target_type_id: i64 = zbackend_ir_cfg_expression_type_id(
                context, expression.left, value_type_id
            ) catch |err| { return err }
            if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
                context.type_layout.types[target_type_id - 1].kind == "slice" {
                address: i64 = zbackend_ir_cfg_lower_slice_index_address(
                    context, expression, target_type_id
                ) catch |err| { return err }
                id: i64 = context.next_value_id
                context.next_value_id = context.next_value_id + 1
                load: ZBackendIrInstruction = zbackend_ir_new_instruction(
                    id,
                    "load",
                    context.type_layout.types[target_type_id - 1].element_type
                )
                load.lhs = address
                return zbackend_ir_cfg_append_instruction(context, load) catch |err| { return err }
            }
        }
        if expression.kind == ZAstExprField &&
            !zbackend_ir_expression_is_function_value(
                context.type_layout, expression_index
            ) &&
            !zbackend_ir_field_is_static_enum(context.ast, expression) &&
            !zbackend_ir_field_is_static_union_tag(context.ast, expression) &&
            !zbackend_ir_field_is_static_error(context.ast, expression) &&
            !zbackend_ir_is_builtin_field(context.ast, expression) {
            target_type_id: i64 = zbackend_ir_cfg_expression_type_id(
                context, expression.left, value_type_id
            ) catch |err| { return err }
            if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
                context.type_layout.types[target_type_id - 1].kind == "slice" {
                slice: i64 = zbackend_ir_cfg_lower_expression_as(
                    context, expression.left, target_type_id
                ) catch |err| { return err }
                if ZAstText.eql_string(expression.name, "ptr") {
                    pointer_type_id: i64 = zbackend_ir_type_layout_pointer_to(
                        context.type_layout,
                        context.type_layout.types[target_type_id - 1].element_type
                    ) catch |err| { return err }
                    return zbackend_ir_cfg_emit_extract_value(
                        context, slice, pointer_type_id, 0
                    ) catch |err| { return err }
                }
                if ZAstText.eql_string(expression.name, "len") {
                    length_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
                        context.type_layout, "i64"
                    ) catch |err| { return err }
                    return zbackend_ir_cfg_emit_extract_value(
                        context, slice, length_type_id, 1
                    ) catch |err| { return err }
                }
            }
            if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
                context.type_layout.types[target_type_id - 1].kind == "error_union" {
                aggregate: i64 = zbackend_ir_cfg_lower_expression_as(
                    context, expression.left, target_type_id
                ) catch |err| { return err }
                if ZAstText.eql_string(expression.name, "value") {
                    return zbackend_ir_cfg_emit_extract_value(
                        context, aggregate,
                        context.type_layout.types[target_type_id - 1].element_type, 0
                    ) catch |err| { return err }
                }
                if ZAstText.eql_string(expression.name, "error") {
                    return zbackend_ir_cfg_emit_extract_value(
                        context, aggregate, context.error_type_id, 1
                    ) catch |err| { return err }
                }
            }
            if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
                context.type_layout.types[target_type_id - 1].kind == "union" &&
                ZAstText.eql_string(expression.name, "tag") {
                aggregate: i64 = zbackend_ir_cfg_lower_expression_as(
                    context, expression.left, target_type_id
                ) catch |err| { return err }
                tag_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
                    context.type_layout, "i32"
                ) catch |err| { return err }
                return zbackend_ir_cfg_emit_extract_value(
                    context, aggregate, tag_type_id, 0
                ) catch |err| { return err }
            }
        }
    }
    if expression_index != ZAstNoIndex && zbackend_ir_expression_is_error_union_call(
        context.type_layout, context.ast.exprs[expression_index]
    ) {
        call_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression_index, value_type_id
        ) catch |err| { return err }
        if value_type_id != call_type_id { return error.NotImplemented }
    }
    capacity: i64 = zbackend_ir_expression_instruction_capacity(
        context.ast, expression_index
    ) catch |err| { return err }
    capacity = capacity + ZBACKEND_IR_CONTEXTUAL_COERCION_INSTRUCTION_OVERHEAD
    block_index: i64 = context.current_block
    instruction_start: i64 = context.blocks[block_index].instruction_count
    zbackend_ir_cfg_reserve_instructions(
        context, block_index, instruction_start + capacity
    ) catch |err| { return err }
    expression_context: ZBackendIrExpressionLowering = zbackend_ir_expression_context(
        context.allocator,
        context.ast,
        context.declaration,
        context.blocks[block_index].instructions + instruction_start,
        context.blocks[block_index].instruction_capacity - instruction_start,
        context.next_value_id,
        value_type_id,
        context.bool_type_id,
        context.type_layout,
        zbackend_ir_type_layout_is_signed(context.type_layout, value_type_id),
        context.current_statement_index
    )
    zbackend_ir_set_locals(
        &expression_context,
        context.local_names,
        context.local_addresses,
        context.local_type_ids,
        context.local_count
    )
    result: i64 = zbackend_ir_lower_expression(
        &expression_context, expression_index
    ) catch |err| { return err }
    actual_type_id: i64 = zbackend_ir_expression_type_id(
        &expression_context, expression_index, value_type_id
    ) catch |err| { return err }
    if actual_type_id != value_type_id {
        expected_type: ZBackendIrType = context.type_layout.types[value_type_id - 1]
        actual_type: ZBackendIrType = context.type_layout.types[actual_type_id - 1]
        if expected_type.kind == "slice" && actual_type.kind == "array" &&
            expected_type.element_type == actual_type.element_type {
            actual_type_id = value_type_id
        }
        if expected_type.kind == "pointer" && actual_type.kind == "array" &&
            expected_type.element_type == actual_type.element_type {
            actual_type_id = value_type_id
        }
    }
    result = zbackend_ir_expression_emit_cast_value(
        &expression_context, result, actual_type_id, value_type_id
    ) catch |err| { return err }
    context.blocks[block_index].instruction_count = instruction_start + expression_context.instruction_count
    context.next_value_id = expression_context.next_value_id
    return result
}

fn zbackend_ir_cfg_lower_slice_index_address(
    context: *ZBackendIrControlFlowLowering,
    expression: ZAstExpr,
    slice_type_id: i64
) !i64 {
    slice_type: ZBackendIrType = context.type_layout.types[slice_type_id - 1]
    if slice_type.kind != "slice" { return error.InvalidArgument }
    pointer_type_id: i64 = zbackend_ir_type_layout_pointer_to(
        context.type_layout, slice_type.element_type
    ) catch |err| { return err }
    index_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
        context.type_layout, "i64"
    ) catch |err| { return err }
    slice: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.left, slice_type_id
    ) catch |err| { return err }
    pointer: i64 = zbackend_ir_cfg_emit_extract_value(
        context, slice, pointer_type_id, 0
    ) catch |err| { return err }
    length: i64 = zbackend_ir_cfg_emit_extract_value(
        context, slice, index_type_id, 1
    ) catch |err| { return err }
    actual_index_type_id: i64 = zbackend_ir_cfg_expression_type_id(
        context, expression.right, index_type_id
    ) catch |err| { return err }
    index: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.right, actual_index_type_id
    ) catch |err| { return err }
    index = zbackend_ir_cfg_emit_cast_value(
        context, index, actual_index_type_id, index_type_id
    ) catch |err| { return err }
    zero: i64 = zbackend_ir_cfg_emit_integer_constant(
        context, 0, index_type_id
    ) catch |err| { return err }
    past_end_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    past_end: ZBackendIrInstruction = zbackend_ir_new_instruction(
        past_end_id, "compare", context.bool_type_id
    )
    past_end.compare_op = "unsigned_greater_equal"
    past_end.lhs = index
    past_end.rhs = length
    zbackend_ir_cfg_append_instruction(context, past_end) catch |err| { return err }
    failed: i64 = past_end_id
    if zbackend_ir_type_layout_is_signed(context.type_layout, actual_index_type_id) {
        negative_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        negative: ZBackendIrInstruction = zbackend_ir_new_instruction(
            negative_id, "compare", context.bool_type_id
        )
        negative.compare_op = "signed_less"
        negative.lhs = index
        negative.rhs = zero
        zbackend_ir_cfg_append_instruction(context, negative) catch |err| { return err }
        failed_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        combined: ZBackendIrInstruction = zbackend_ir_new_instruction(
            failed_id, "binary", context.bool_type_id
        )
        combined.binary_op = "bit_or"
        combined.lhs = negative_id
        combined.rhs = past_end_id
        zbackend_ir_cfg_append_instruction(context, combined) catch |err| { return err }
        failed = failed_id
    }
    failure_block: i64 = zbackend_ir_cfg_create_block(
        context, "slice.oob"
    ) catch |err| { return err }
    success_block: i64 = zbackend_ir_cfg_create_block(
        context, "slice.index"
    ) catch |err| { return err }
    branch: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
    branch.condition = failed
    branch.true_target = failure_block
    branch.false_target = success_block
    zbackend_ir_cfg_terminate(context, branch) catch |err| { return err }
    zbackend_ir_cfg_activate_block(context, failure_block) catch |err| { return err }
    exit_code: i64 = zbackend_ir_cfg_emit_integer_constant(
        context, 1, context.error_type_id
    ) catch |err| { return err }
    exit_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    exit: ZBackendIrInstruction = zbackend_ir_new_instruction(
        exit_id, "process_exit", context.type_layout.void_type_id
    )
    exit.lhs = exit_code
    zbackend_ir_cfg_append_instruction(context, exit) catch |err| { return err }
    zbackend_ir_cfg_terminate(
        context, zbackend_ir_new_terminator("unreachable")
    ) catch |err| { return err }
    zbackend_ir_cfg_activate_block(context, success_block) catch |err| { return err }
    address_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    address: ZBackendIrInstruction = zbackend_ir_new_instruction(
        address_id, "index_address", slice_type.element_type
    )
    address.source_type = slice_type.element_type
    address.lhs = pointer
    address.rhs = index
    return zbackend_ir_cfg_append_instruction(context, address) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_address(
    context: *ZBackendIrControlFlowLowering,
    expression_index: i64,
    value_type_id: i64
) !i64 {
    if context.current_block < 0 || expression_index == ZAstNoIndex {
        return error.InvalidArgument
    }
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind == ZAstExprIndex {
        target_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression.left, value_type_id
        ) catch |err| { return err }
        if target_type_id > 0 && target_type_id <= context.type_layout.type_count &&
            context.type_layout.types[target_type_id - 1].kind == "slice" {
            return zbackend_ir_cfg_lower_slice_index_address(
                context, expression, target_type_id
            ) catch |err| { return err }
        }
    }
    capacity: i64 = zbackend_ir_expression_instruction_capacity(
        context.ast, expression_index
    ) catch |err| { return 8 }
    capacity = capacity + 4
    block_index: i64 = context.current_block
    instruction_start: i64 = context.blocks[block_index].instruction_count
    zbackend_ir_cfg_reserve_instructions(
        context, block_index, instruction_start + capacity
    ) catch |err| { return err }
    expression_context: ZBackendIrExpressionLowering = zbackend_ir_expression_context(
        context.allocator,
        context.ast,
        context.declaration,
        context.blocks[block_index].instructions + instruction_start,
        context.blocks[block_index].instruction_capacity - instruction_start,
        context.next_value_id,
        value_type_id,
        context.bool_type_id,
        context.type_layout,
        zbackend_ir_type_layout_is_signed(context.type_layout, value_type_id),
        context.current_statement_index
    )
    zbackend_ir_set_locals(
        &expression_context,
        context.local_names,
        context.local_addresses,
        context.local_type_ids,
        context.local_count
    )
    result: i64 = zbackend_ir_expression_lower_address(
        &expression_context, expression_index
    ) catch |err| { return err }
    context.blocks[block_index].instruction_count = instruction_start + expression_context.instruction_count
    context.next_value_id = expression_context.next_value_id
    return result
}

fn zbackend_ir_cfg_lower_expression(
    context: *ZBackendIrControlFlowLowering,
    expression_index: i64
) !i64 {
    operand_type_id: i64 = zbackend_ir_cfg_expression_operand_type_id(
        context, expression_index, context.return_payload_type_id
    ) catch |err| { return err }
    return zbackend_ir_cfg_lower_expression_as(
        context,
        expression_index,
        operand_type_id
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_terminate(
    context: *ZBackendIrControlFlowLowering,
    terminator: ZBackendIrTerminator
) !i64 {
    if context.current_block < 0 || context.blocks[context.current_block].is_terminated {
        return error.InvalidArgument
    }
    context.blocks[context.current_block].terminator = terminator
    context.blocks[context.current_block].is_terminated = true
    context.current_block = -1
    return 0
}

fn zbackend_ir_cfg_branch(context: *ZBackendIrControlFlowLowering, target: i64) !i64 {
    return zbackend_ir_cfg_terminate(context, zbackend_ir_branch_terminator(target)) catch |err| { return err }
}

fn zbackend_ir_cfg_branch_from(
    context: *ZBackendIrControlFlowLowering,
    block_index: i64,
    target: i64
) !i64 {
    if block_index < 0 { return 0 }
    zbackend_ir_cfg_activate_block(context, block_index + 1) catch |err| { return err }
    return zbackend_ir_cfg_branch(context, target) catch |err| { return err }
}

fn zbackend_ir_cfg_push_scope(context: *ZBackendIrControlFlowLowering) !i64 {
    if context.scope_count >= context.scope_capacity { return error.OutOfBounds }
    context.scope_starts[context.scope_count] = context.local_count
    context.scope_count = context.scope_count + 1
    return 0
}

fn zbackend_ir_cfg_pop_scope(context: *ZBackendIrControlFlowLowering) !i64 {
    if context.scope_count <= 0 { return error.InvalidArgument }
    context.scope_count = context.scope_count - 1
    context.local_count = context.scope_starts[context.scope_count]
    return 0
}

fn zbackend_ir_cfg_declare_local(
    context: *ZBackendIrControlFlowLowering,
    name: ZAstText,
    address: i64,
    type_id: i64,
    is_catch_error: bool
) !i64 {
    if context.local_count >= context.local_capacity { return error.OutOfBounds }
    context.local_names[context.local_count] = name
    context.local_addresses[context.local_count] = address
    context.local_type_ids[context.local_count] = type_id
    if is_catch_error {
        context.local_is_catch_errors[context.local_count] = 1
    } else {
        context.local_is_catch_errors[context.local_count] = 0
    }
    context.local_count = context.local_count + 1
    return 0
}

fn zbackend_ir_cfg_push_loop(
    context: *ZBackendIrControlFlowLowering,
    break_target: i64,
    continue_target: i64
) !i64 {
    if context.loop_count >= context.loop_capacity { return error.OutOfBounds }
    context.break_targets[context.loop_count] = break_target
    context.continue_targets[context.loop_count] = continue_target
    context.loop_count = context.loop_count + 1
    return 0
}

fn zbackend_ir_cfg_pop_loop(context: *ZBackendIrControlFlowLowering) !i64 {
    if context.loop_count <= 0 { return error.InvalidArgument }
    context.loop_count = context.loop_count - 1
    return 0
}

fn zbackend_ir_cfg_lower_variable(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    if statement.type_index == ZAstNoIndex { return error.NotImplemented }
    type_id: i64 = zbackend_ir_cfg_type_id(context, statement.type_index) catch |err| { return err }
    address: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    zbackend_ir_cfg_append_instruction(
        context, zbackend_ir_new_instruction(address, "alloca", type_id)
    ) catch |err| { return err }
    if statement.expr_index != ZAstNoIndex {
    initializer: i64 = zbackend_ir_cfg_lower_expression_as(
        context, statement.expr_index, type_id
    ) catch |err| { return err }
        store_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        store: ZBackendIrInstruction = zbackend_ir_new_instruction(store_id, "store", type_id)
        store.lhs = address
        store.rhs = initializer
        zbackend_ir_cfg_append_instruction(context, store) catch |err| { return err }
    }
    return zbackend_ir_cfg_declare_local(
        context, statement.name, address, type_id, false
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_assignment(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    if statement.expr_index == ZAstNoIndex || statement.value_expr == ZAstNoIndex { return error.NotImplemented }
    type_id: i64 = zbackend_ir_cfg_expression_type_id(
        context, statement.expr_index, context.return_payload_type_id
    ) catch |err| { return err }
    address: i64 = zbackend_ir_cfg_lower_address(
        context, statement.expr_index, type_id
    ) catch |err| { return err }
    value: i64 = zbackend_ir_cfg_lower_expression_as(
        context, statement.value_expr, type_id
    ) catch |err| { return err }
    store_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    store: ZBackendIrInstruction = zbackend_ir_new_instruction(store_id, "store", type_id)
    store.lhs = address
    store.rhs = value
    return zbackend_ir_cfg_append_instruction(context, store) catch |err| { return err }
}

// Zorb assembly templates use GCC-style %0/%b0 operand placeholders and a
// single '$' for target immediates. LLVM uses $0/${0:b} placeholders and '$$'
// for a literal dollar sign, so normalize at the frontend/backend boundary.
fn zbackend_ir_convert_asm_template(
    allocator: *std.mem.HeapAllocator,
    template: ZAstText
) !string {
    builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
        allocator, template.len * 2 + 1
    ) catch |err| { return error.OutOfMemory }
    index: i64 = 0
    while index < template.len {
        ch: u8 = template.ptr[index]
        if ch == 36 {
            std.collections.StringBuilder.append(
                &builder, allocator, "$$"
            ) catch |err| { return error.OutOfMemory }
            index = index + 1
            continue
        }
        if ch == 37 && index + 1 < template.len && template.ptr[index + 1] == 37 {
            std.collections.ByteList.append_byte(
                &builder.bytes, allocator, 37
            ) catch |err| { return error.OutOfMemory }
            index = index + 2
            continue
        }
        if ch == 37 {
            digit_start: i64 = index + 1
            byte_modifier: bool = false
            if digit_start < template.len && template.ptr[digit_start] == 98 {
                byte_modifier = true
                digit_start = digit_start + 1
            }
            digit_end: i64 = digit_start
            while digit_end < template.len && template.ptr[digit_end] >= 48 &&
                template.ptr[digit_end] <= 57 {
                digit_end = digit_end + 1
            }
            if digit_end > digit_start {
                std.collections.ByteList.append_byte(
                    &builder.bytes, allocator, 36
                ) catch |err| { return error.OutOfMemory }
                if byte_modifier {
                    std.collections.ByteList.append_byte(
                        &builder.bytes, allocator, 123
                    ) catch |err| { return error.OutOfMemory }
                }
                digit_index: i64 = digit_start
                while digit_index < digit_end {
                    std.collections.ByteList.append_byte(
                        &builder.bytes, allocator, template.ptr[digit_index]
                    ) catch |err| { return error.OutOfMemory }
                    digit_index = digit_index + 1
                }
                if byte_modifier {
                    std.collections.StringBuilder.append(
                        &builder, allocator, ":b}"
                    ) catch |err| { return error.OutOfMemory }
                }
                index = digit_end
                continue
            }
        }
        std.collections.ByteList.append_byte(
            &builder.bytes, allocator, ch
        ) catch |err| { return error.OutOfMemory }
        index = index + 1
    }
    return cast(string, std.collections.StringBuilder.c_string(
        &builder, allocator
    ) catch |err| { return error.OutOfMemory })
}

// LLVM treats single-letter GCC register constraints as register classes.
// Preserve output modifiers while spelling the fixed x86 registers explicitly,
// matching the stage-0 lowering contract.
fn zbackend_ir_convert_asm_constraint(
    allocator: *std.mem.HeapAllocator,
    constraint: string,
    is_x86: bool
) !string {
    constraint_bytes: *u8 = cast(*u8, constraint)
    prefix_length: i64 = 0
    while prefix_length < std.str.len(constraint) &&
        (constraint_bytes[prefix_length] == 61 || constraint_bytes[prefix_length] == 43 ||
        constraint_bytes[prefix_length] == 38) {
        // LLVM output constraints do not support GCC's read-write '+' modifier.
        if constraint_bytes[prefix_length] == 43 { return error.NotImplemented }
        prefix_length = prefix_length + 1
    }
    if !is_x86 { return constraint }
    body_length: i64 = std.str.len(constraint) - prefix_length
    if body_length != 1 { return constraint }
    register_name: string = ""
    body: u8 = constraint_bytes[prefix_length]
    if body == 97 { register_name = "ax" }
    else if body == 98 { register_name = "bx" }
    else if body == 99 { register_name = "cx" }
    else if body == 100 { register_name = "dx" }
    else if body == 83 { register_name = "si" }
    else if body == 68 { register_name = "di" }
    if std.str.len(register_name) == 0 { return constraint }

    builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
        allocator, prefix_length + std.str.len(register_name) + 3
    ) catch |err| { return error.OutOfMemory }
    index: i64 = 0
    while index < prefix_length {
        std.collections.ByteList.append_byte(
            &builder.bytes, allocator, constraint_bytes[index]
        ) catch |err| { return error.OutOfMemory }
        index = index + 1
    }
    std.collections.StringBuilder.append(
        &builder, allocator, "{"
    ) catch |err| { return error.OutOfMemory }
    std.collections.StringBuilder.append(
        &builder, allocator, register_name
    ) catch |err| { return error.OutOfMemory }
    std.collections.StringBuilder.append(
        &builder, allocator, "}"
    ) catch |err| { return error.OutOfMemory }
    return cast(string, std.collections.StringBuilder.c_string(
        &builder, allocator
    ) catch |err| { return error.OutOfMemory })
}

fn zbackend_ir_cfg_lower_asm(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    output_types: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, statement.asm_output_count
    ) catch |err| { return err }
    output_addresses: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, statement.asm_output_count
    ) catch |err| { return err }
    operand_index: i64 = 0
    while operand_index < statement.asm_output_count {
        expression_index: i64 = context.ast.expr_args[statement.asm_output_start + operand_index]
        output_types[operand_index] = zbackend_ir_cfg_expression_type_id(
            context, expression_index, context.return_payload_type_id
        ) catch |err| { return err }
        output_addresses[operand_index] = zbackend_ir_cfg_lower_address(
            context, expression_index, output_types[operand_index]
        ) catch |err| { return err }
        operand_index = operand_index + 1
    }
    arguments: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, statement.asm_input_count
    ) catch |err| { return err }
    operand_index = 0
    while operand_index < statement.asm_input_count {
        expression_index: i64 = context.ast.expr_args[statement.asm_input_start + operand_index]
        input_type_id: i64 = zbackend_ir_cfg_expression_type_id(
            context, expression_index, context.return_payload_type_id
        ) catch |err| { return err }
        arguments[operand_index] = zbackend_ir_cfg_lower_expression_as(
            context, expression_index, input_type_id
        ) catch |err| { return err }
        input_type: ZBackendIrType = context.type_layout.types[input_type_id - 1]
        if input_type.kind == "scalar" && zbackend_ir_scalar_bit_width(input_type.scalar) > 0 &&
            zbackend_ir_scalar_bit_width(input_type.scalar) < 32 {
            promoted_name: string = "u32"
            if zbackend_ir_scalar_name_is_signed(input_type.scalar) { promoted_name = "i32" }
            promoted_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
                context.type_layout, promoted_name
            ) catch |err| { return err }
            arguments[operand_index] = zbackend_ir_cfg_emit_cast_value(
                context, arguments[operand_index], input_type_id, promoted_type_id
            ) catch |err| { return err }
        }
        operand_index = operand_index + 1
    }
    constraint_builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
        context.allocator, 32
    ) catch |err| { return error.OutOfMemory }
    constraint_index: i64 = 0
    total_constraints: i64 = statement.asm_output_count + statement.asm_input_count +
        statement.asm_clobber_count
    while constraint_index < total_constraints {
        if constraint_index > 0 {
            std.collections.StringBuilder.append(
                &constraint_builder, context.allocator, ","
            ) catch |err| { return error.OutOfMemory }
        }
        expression_index: i64 = 0
        if constraint_index < statement.asm_output_count {
            expression_index = context.ast.expr_args[statement.asm_output_start + constraint_index]
        } else if constraint_index < statement.asm_output_count + statement.asm_input_count {
            expression_index = context.ast.expr_args[
                statement.asm_input_start + constraint_index - statement.asm_output_count
            ]
        } else {
            expression_index = context.ast.expr_args[
                statement.asm_clobber_start + constraint_index -
                    statement.asm_output_count - statement.asm_input_count
            ]
        }
        constraint: string = zbackend_ir_copy_text(
            context.allocator, context.ast.exprs[expression_index].literal
        ) catch |err| { return err }
        if constraint_index >= statement.asm_output_count + statement.asm_input_count {
            std.collections.StringBuilder.append(
                &constraint_builder, context.allocator, "~{"
            ) catch |err| { return error.OutOfMemory }
            std.collections.StringBuilder.append(
                &constraint_builder, context.allocator, constraint
            ) catch |err| { return error.OutOfMemory }
            std.collections.StringBuilder.append(
                &constraint_builder, context.allocator, "}"
            ) catch |err| { return error.OutOfMemory }
        } else {
            constraint = zbackend_ir_convert_asm_constraint(
                context.allocator, constraint,
                std.str.starts_with(context.type_layout.target_triple, "x86_64-")
            ) catch |err| { return err }
            std.collections.StringBuilder.append(
                &constraint_builder, context.allocator, constraint
            ) catch |err| { return error.OutOfMemory }
        }
        constraint_index = constraint_index + 1
    }
    constraints: string = cast(string, std.collections.StringBuilder.c_string(
        &constraint_builder, context.allocator
    ) catch |err| { return error.OutOfMemory })
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(
        id, "inline_asm", context.type_layout.void_type_id
    )
    instruction.asm_template = zbackend_ir_convert_asm_template(
        context.allocator, statement.name
    ) catch |err| { return err }
    instruction.constraints = constraints
    instruction.arguments = arguments
    instruction.argument_count = statement.asm_input_count
    instruction.output_types = output_types
    instruction.output_addresses = output_addresses
    instruction.output_count = statement.asm_output_count
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_if(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt,
    statement_end: i64
) !i64 {
    if statement.expr_index == ZAstNoIndex { return error.NotImplemented }
    after_then: i64 = statement.child_start + statement.child_count
    has_else: bool = after_then < statement_end && context.ast.stmts[after_then].kind == ZAstStmtElse
    constant_condition: i64 = zbackend_ir_constant_bool_expression(
        context.type_layout, context.ast, statement.expr_index
    )
    if constant_condition >= 0 {
        if constant_condition != 0 {
            zbackend_ir_cfg_push_scope(context) catch |err| { return err }
            zbackend_ir_cfg_lower_sequence(
                context, statement.child_start, after_then
            ) catch |err| { return err }
            zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
            if !has_else { return after_then }
            else_statement: ZAstStmt = context.ast.stmts[after_then]
            return zbackend_ir_cfg_expand_else_if_end(
                context.ast,
                else_statement.child_start,
                else_statement.child_start + else_statement.child_count,
                statement_end
            )
        }
        if !has_else { return after_then }
        else_statement: ZAstStmt = context.ast.stmts[after_then]
        else_body_end: i64 = zbackend_ir_cfg_expand_else_if_end(
            context.ast,
            else_statement.child_start,
            else_statement.child_start + else_statement.child_count,
            statement_end
        )
        zbackend_ir_cfg_push_scope(context) catch |err| { return err }
        zbackend_ir_cfg_lower_sequence(
            context, else_statement.child_start, else_body_end
        ) catch |err| { return err }
        zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
        return else_body_end
    }
    condition: i64 = zbackend_ir_cfg_lower_expression(
        context, statement.expr_index
    ) catch |err| { return err }
    then_block: i64 = zbackend_ir_cfg_create_block(context, "then") catch |err| { return err }
    else_block: i64 = 0
    if has_else {
        else_block = zbackend_ir_cfg_create_block(context, "else") catch |err| { return err }
    } else {
        else_block = zbackend_ir_cfg_create_block(context, "continuation") catch |err| { return err }
    }
    terminator: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
    terminator.condition = condition
    terminator.true_target = then_block
    terminator.false_target = else_block
    zbackend_ir_cfg_terminate(context, terminator) catch |err| { return err }

    zbackend_ir_cfg_activate_block(context, then_block) catch |err| { return err }
    zbackend_ir_cfg_push_scope(context) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(
        context, statement.child_start, statement.child_start + statement.child_count
    ) catch |err| { return err }
    zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
    then_end: i64 = context.current_block

    if !has_else {
        zbackend_ir_cfg_branch_from(context, then_end, else_block) catch |err| { return err }
        zbackend_ir_cfg_activate_block(context, else_block) catch |err| { return err }
        return after_then
    }

    else_statement: ZAstStmt = context.ast.stmts[after_then]
    else_body_end: i64 = zbackend_ir_cfg_expand_else_if_end(
        context.ast,
        else_statement.child_start,
        else_statement.child_start + else_statement.child_count,
        statement_end
    )
    zbackend_ir_cfg_activate_block(context, else_block) catch |err| { return err }
    zbackend_ir_cfg_push_scope(context) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(
        context, else_statement.child_start, else_body_end
    ) catch |err| { return err }
    zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
    else_end: i64 = context.current_block
    after_else: i64 = else_body_end
    if then_end < 0 && else_end < 0 {
        context.current_block = -1
        return after_else
    }
    continuation: i64 = zbackend_ir_cfg_create_block(context, "continuation") catch |err| { return err }
    zbackend_ir_cfg_branch_from(context, then_end, continuation) catch |err| { return err }
    zbackend_ir_cfg_branch_from(context, else_end, continuation) catch |err| { return err }
    zbackend_ir_cfg_activate_block(context, continuation) catch |err| { return err }
    return after_else
}

fn zbackend_ir_cfg_expand_else_if_end(
    ast: *ZAstModule,
    body_start: i64,
    body_end: i64,
    statement_end: i64
) -> i64 {
    if body_start >= body_end || body_end >= statement_end { return body_end }
    nested_if: ZAstStmt = ast.stmts[body_start]
    if nested_if.kind != ZAstStmtIf || nested_if.child_start + nested_if.child_count != body_end ||
        ast.stmts[body_end].kind != ZAstStmtElse {
        return body_end
    }
    nested_else: ZAstStmt = ast.stmts[body_end]
    return zbackend_ir_cfg_expand_else_if_end(
        ast,
        nested_else.child_start,
        nested_else.child_start + nested_else.child_count,
        statement_end
    )
}

fn zbackend_ir_cfg_lower_while(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    if statement.expr_index == ZAstNoIndex { return error.NotImplemented }
    condition_block: i64 = zbackend_ir_cfg_create_block(context, "condition") catch |err| { return err }
    body_block: i64 = zbackend_ir_cfg_create_block(context, "body") catch |err| { return err }
    exit_block: i64 = zbackend_ir_cfg_create_block(context, "exit") catch |err| { return err }
    zbackend_ir_cfg_branch(context, condition_block) catch |err| { return err }

    zbackend_ir_cfg_activate_block(
        context, condition_block
    ) catch |err| { return err }
    condition: i64 = zbackend_ir_cfg_lower_expression(context, statement.expr_index) catch |err| { return err }
    terminator: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
    terminator.condition = condition
    terminator.true_target = body_block
    terminator.false_target = exit_block
    zbackend_ir_cfg_terminate(context, terminator) catch |err| { return err }

    zbackend_ir_cfg_push_loop(
        context, exit_block, condition_block
    ) catch |err| { return err }
    zbackend_ir_cfg_activate_block(
        context, body_block
    ) catch |err| { return err }
    zbackend_ir_cfg_push_scope(context) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(
        context, statement.child_start, statement.child_start + statement.child_count
    ) catch |err| { return err }
    zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
    if context.current_block >= 0 {
        zbackend_ir_cfg_branch(
            context, condition_block
        ) catch |err| { return err }
    }
    zbackend_ir_cfg_pop_loop(context) catch |err| { return err }
    zbackend_ir_cfg_activate_block(
        context, exit_block
    ) catch |err| { return err }
    return statement.child_start + statement.child_count
}

fn zbackend_ir_cfg_lower_for(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    child_end: i64 = statement.child_start + statement.child_count
    initializer_end: i64 = statement.child_start + statement.for_initializer_count
    update_end: i64 = initializer_end + statement.for_update_count
    if initializer_end > child_end || update_end > child_end { return error.InvalidArgument }

    zbackend_ir_cfg_push_scope(context) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(
        context, statement.child_start, initializer_end
    ) catch |err| { return err }
    if context.current_block < 0 {
        zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
        return child_end
    }

    condition_block: i64 = zbackend_ir_cfg_create_block(context, "for.condition") catch |err| { return err }
    body_block: i64 = zbackend_ir_cfg_create_block(context, "for.body") catch |err| { return err }
    update_block: i64 = zbackend_ir_cfg_create_block(context, "for.update") catch |err| { return err }
    exit_block: i64 = zbackend_ir_cfg_create_block(context, "for.exit") catch |err| { return err }
    zbackend_ir_cfg_branch(context, condition_block) catch |err| { return err }

    zbackend_ir_cfg_activate_block(context, condition_block) catch |err| { return err }
    condition: i64 = 0
    if statement.expr_index == ZAstNoIndex {
        condition = zbackend_ir_cfg_emit_integer_constant(
            context, 1, context.bool_type_id
        ) catch |err| { return err }
    } else {
        condition = zbackend_ir_cfg_lower_expression(context, statement.expr_index) catch |err| { return err }
    }
    terminator: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
    terminator.condition = condition
    terminator.true_target = body_block
    terminator.false_target = exit_block
    zbackend_ir_cfg_terminate(context, terminator) catch |err| { return err }

    zbackend_ir_cfg_push_loop(context, exit_block, update_block) catch |err| { return err }
    zbackend_ir_cfg_activate_block(context, body_block) catch |err| { return err }
    zbackend_ir_cfg_push_scope(context) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(context, update_end, child_end) catch |err| { return err }
    zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
    if context.current_block >= 0 {
        zbackend_ir_cfg_branch(context, update_block) catch |err| { return err }
    }

    zbackend_ir_cfg_activate_block(context, update_block) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(context, initializer_end, update_end) catch |err| { return err }
    if context.current_block >= 0 {
        zbackend_ir_cfg_branch(context, condition_block) catch |err| { return err }
    }
    zbackend_ir_cfg_pop_loop(context) catch |err| { return err }

    zbackend_ir_cfg_activate_block(context, exit_block) catch |err| { return err }
    zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
    return child_end
}

fn zbackend_ir_cfg_emit_equal(
    context: *ZBackendIrControlFlowLowering,
    lhs: i64,
    rhs: i64
) !i64 {
    id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    instruction: ZBackendIrInstruction = zbackend_ir_new_instruction(id, "compare", context.bool_type_id)
    instruction.compare_op = "equal"
    instruction.lhs = lhs
    instruction.rhs = rhs
    return zbackend_ir_cfg_append_instruction(context, instruction) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_ordered_cases(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt,
    statement_index: i64
) !i64 {
    if statement.expr_index == ZAstNoIndex { return error.NotImplemented }
    child_end: i64 = statement.child_start + statement.child_count
    fallthrough_blocks: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, statement.child_count + 1
    ) catch |err| { return err }
    fallthrough_count: i64 = 0
    subject_type_id: i64 = zbackend_ir_cfg_expression_type_id(
        context, statement.expr_index, context.return_payload_type_id
    ) catch |err| { return err }
    subject: i64 = zbackend_ir_cfg_lower_expression_as(
        context, statement.expr_index, subject_type_id
    ) catch |err| { return err }
    branch_index: i64 = statement.child_start
    saw_else: bool = false

    while branch_index < child_end {
        branch: ZAstStmt = context.ast.stmts[branch_index]
        next_branch: i64 = branch.child_start + branch.child_count
        if next_branch <= branch_index || next_branch > child_end { return error.InvalidArgument }

        if branch.kind == ZAstStmtCase {
            if branch.expr_index == ZAstNoIndex { return error.InvalidArgument }
            case_value: i64 = zbackend_ir_cfg_lower_expression_as(
                context, branch.expr_index, subject_type_id
            ) catch |err| { return err }
            condition: i64 = zbackend_ir_cfg_emit_equal(context, subject, case_value) catch |err| { return err }
            body_block: i64 = zbackend_ir_cfg_create_block(context, "case.body") catch |err| { return err }
            next_test_block: i64 = zbackend_ir_cfg_create_block(context, "case.next") catch |err| { return err }
            terminator: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
            terminator.condition = condition
            terminator.true_target = body_block
            terminator.false_target = next_test_block
            zbackend_ir_cfg_terminate(context, terminator) catch |err| { return err }

            zbackend_ir_cfg_activate_block(context, body_block) catch |err| { return err }
            zbackend_ir_cfg_push_scope(context) catch |err| { return err }
            zbackend_ir_cfg_lower_sequence(
                context, branch.child_start, next_branch
            ) catch |err| { return err }
            zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
            if context.current_block >= 0 {
                fallthrough_blocks[fallthrough_count] = context.current_block
                fallthrough_count = fallthrough_count + 1
                context.current_block = -1
            }
            zbackend_ir_cfg_activate_block(context, next_test_block) catch |err| { return err }
        } else if branch.kind == ZAstStmtElse {
            saw_else = true
            zbackend_ir_cfg_push_scope(context) catch |err| { return err }
            zbackend_ir_cfg_lower_sequence(
                context, branch.child_start, next_branch
            ) catch |err| { return err }
            zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
            if context.current_block >= 0 {
                fallthrough_blocks[fallthrough_count] = context.current_block
                fallthrough_count = fallthrough_count + 1
                context.current_block = -1
            }
            if next_branch != child_end { return error.InvalidArgument }
        } else {
            return error.InvalidArgument
        }
        branch_index = next_branch
    }

    if !saw_else {
        if context.current_block < 0 { return error.InvalidArgument }
        exhaustive: bool = ZAstModule.match_is_exhaustive(
            context.ast,
            context.declaration,
            statement,
            statement_index - context.declaration.stmt_start
        )
        if exhaustive {
            zbackend_ir_cfg_terminate(
                context, zbackend_ir_new_terminator("unreachable")
            ) catch |err| { return err }
        } else {
            fallthrough_blocks[fallthrough_count] = context.current_block
            fallthrough_count = fallthrough_count + 1
            context.current_block = -1
        }
    }
    if fallthrough_count == 0 { return child_end }

    continuation: i64 = zbackend_ir_cfg_create_block(context, "case.continuation") catch |err| { return err }
    fallthrough_index: i64 = 0
    while fallthrough_index < fallthrough_count {
        zbackend_ir_cfg_branch_from(
            context, fallthrough_blocks[fallthrough_index], continuation
        ) catch |err| { return err }
        fallthrough_index = fallthrough_index + 1
    }
    zbackend_ir_cfg_activate_block(context, continuation) catch |err| { return err }
    return child_end
}

fn zbackend_ir_cfg_lower_union_match(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    if statement.expr_index == ZAstNoIndex { return error.NotImplemented }
    child_end: i64 = statement.child_start + statement.child_count
    subject_type_id: i64 = zbackend_ir_cfg_expression_type_id(
        context, statement.expr_index, context.return_payload_type_id
    ) catch |err| { return err }
    if subject_type_id <= 0 || subject_type_id > context.type_layout.type_count {
        return error.InvalidArgument
    }
    union_type: ZBackendIrType = context.type_layout.types[subject_type_id - 1]
    if union_type.kind != "union" { return error.InvalidArgument }
    subject: i64 = zbackend_ir_cfg_lower_expression_as(
        context, statement.expr_index, subject_type_id
    ) catch |err| { return err }
    tag_type_id: i64 = zbackend_ir_type_layout_intern_scalar(
        context.type_layout, "i32"
    ) catch |err| { return err }
    tag: i64 = zbackend_ir_cfg_emit_extract_value(
        context, subject, tag_type_id, 0
    ) catch |err| { return err }
    fallthrough_blocks: *i64 = zbackend_ir_cfg_allocate_i64_array(
        context.allocator, statement.child_count + 1
    ) catch |err| { return err }
    fallthrough_count: i64 = 0
    branch_index: i64 = statement.child_start
    saw_else: bool = false

    while branch_index < child_end {
        branch: ZAstStmt = context.ast.stmts[branch_index]
        next_branch: i64 = branch.child_start + branch.child_count
        if next_branch <= branch_index || next_branch > child_end { return error.InvalidArgument }

        if branch.kind == ZAstStmtCase {
            if branch.expr_index == ZAstNoIndex { return error.InvalidArgument }
            pattern: ZAstExpr = context.ast.exprs[branch.expr_index]
            binding: ZAstExpr = pattern
            has_binding: bool = false
            variant_index: i64 = ZAstNoIndex
            if pattern.kind == ZAstExprCall && pattern.left != ZAstNoIndex &&
                pattern.arg_count == 1 {
                callee: ZAstExpr = context.ast.exprs[pattern.left]
                if callee.kind != ZAstExprField || callee.left == ZAstNoIndex {
                    return error.InvalidArgument
                }
                binding_index: i64 = context.ast.expr_args[pattern.arg_start]
                binding = context.ast.exprs[binding_index]
                if binding.kind != ZAstExprIdentifier { return error.InvalidArgument }
                has_binding = true
                variant_index = zbackend_ir_type_field_index(
                    context.type_layout, subject_type_id, callee.name
                ) catch |err| { return err }
            } else if zbackend_ir_field_is_static_union_tag(
                context.ast, pattern
            ) {
                variant_index = zbackend_ir_union_tag_field_value(
                    context.ast, pattern
                ) catch |err| { return err }
            } else {
                return error.NotImplemented
            }
            variant_type_id: i64 = union_type.fields[variant_index].type_id
            expected_tag: i64 = zbackend_ir_cfg_emit_integer_constant(
                context, variant_index, tag_type_id
            ) catch |err| { return err }
            condition: i64 = zbackend_ir_cfg_emit_equal(
                context, tag, expected_tag
            ) catch |err| { return err }
            body_block: i64 = zbackend_ir_cfg_create_block(
                context, "union.case.body"
            ) catch |err| { return err }
            next_test_block: i64 = zbackend_ir_cfg_create_block(
                context, "union.case.next"
            ) catch |err| { return err }
            dispatch: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
            dispatch.condition = condition
            dispatch.true_target = body_block
            dispatch.false_target = next_test_block
            zbackend_ir_cfg_terminate(context, dispatch) catch |err| { return err }

            zbackend_ir_cfg_activate_block(context, body_block) catch |err| { return err }
            zbackend_ir_cfg_push_scope(context) catch |err| { return err }
            if has_binding {
                variant_value: i64 = zbackend_ir_cfg_emit_extract_value(
                    context, subject, variant_type_id, variant_index + 1
                ) catch |err| { return err }
                address: i64 = context.next_value_id
                context.next_value_id = context.next_value_id + 1
                zbackend_ir_cfg_append_instruction(
                    context, zbackend_ir_new_instruction(address, "alloca", variant_type_id)
                ) catch |err| { return err }
                store_id: i64 = context.next_value_id
                context.next_value_id = context.next_value_id + 1
                store: ZBackendIrInstruction = zbackend_ir_new_instruction(
                    store_id, "store", variant_type_id
                )
                store.lhs = address
                store.rhs = variant_value
                zbackend_ir_cfg_append_instruction(context, store) catch |err| { return err }
                zbackend_ir_cfg_declare_local(
                    context, binding.name, address, variant_type_id, false
                ) catch |err| { return err }
            }
            zbackend_ir_cfg_lower_sequence(
                context, branch.child_start, next_branch
            ) catch |err| { return err }
            zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
            if context.current_block >= 0 {
                fallthrough_blocks[fallthrough_count] = context.current_block
                fallthrough_count = fallthrough_count + 1
                context.current_block = -1
            }
            zbackend_ir_cfg_activate_block(context, next_test_block) catch |err| { return err }
        } else if branch.kind == ZAstStmtElse {
            saw_else = true
            zbackend_ir_cfg_push_scope(context) catch |err| { return err }
            zbackend_ir_cfg_lower_sequence(
                context, branch.child_start, next_branch
            ) catch |err| { return err }
            zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
            if context.current_block >= 0 {
                fallthrough_blocks[fallthrough_count] = context.current_block
                fallthrough_count = fallthrough_count + 1
                context.current_block = -1
            }
            if next_branch != child_end { return error.InvalidArgument }
        } else {
            return error.InvalidArgument
        }
        branch_index = next_branch
    }

    if !saw_else {
        if context.current_block < 0 { return error.InvalidArgument }
        zbackend_ir_cfg_terminate(
            context, zbackend_ir_new_terminator("unreachable")
        ) catch |err| { return err }
    }
    if fallthrough_count == 0 { return child_end }

    continuation: i64 = zbackend_ir_cfg_create_block(
        context, "union.case.continuation"
    ) catch |err| { return err }
    fallthrough_index: i64 = 0
    while fallthrough_index < fallthrough_count {
        zbackend_ir_cfg_branch_from(
            context, fallthrough_blocks[fallthrough_index], continuation
        ) catch |err| { return err }
        fallthrough_index = fallthrough_index + 1
    }
    zbackend_ir_cfg_activate_block(context, continuation) catch |err| { return err }
    return child_end
}

fn zbackend_ir_cfg_lower_catch_expression(
    context: *ZBackendIrControlFlowLowering,
    expression_index: i64,
    discard_result: bool,
    known_protected_type_id: i64
) !i64 {
    if context.error_type_id == ZBACKEND_IR_NO_TYPE_ID {
        return error.NotImplemented
    }
    expression: ZAstExpr = context.ast.exprs[expression_index]
    if expression.kind != ZAstExprCatch || expression.left == ZAstNoIndex {
        return error.InvalidArgument
    }

    protected_type_id: i64 = known_protected_type_id
    if protected_type_id == ZBACKEND_IR_NO_TYPE_ID {
        protected_type_id = zbackend_ir_cfg_expression_type_id(
            context, expression.left, context.return_payload_type_id
        ) catch |err| { return err }
    }
    if protected_type_id <= 0 || protected_type_id > context.type_layout.type_count {
        return error.InvalidArgument
    }
    protected_type: ZBackendIrType = context.type_layout.types[protected_type_id - 1]
    if protected_type.kind != "error_union" { return error.InvalidArgument }
    payload_type_id: i64 = protected_type.element_type
    result: i64 = zbackend_ir_cfg_lower_expression_as(
        context, expression.left, protected_type_id
    ) catch |err| { return err }
    success_value: i64 = zbackend_ir_cfg_emit_extract_value(
        context, result, payload_type_id, 0
    ) catch |err| { return err }
    error_value: i64 = zbackend_ir_cfg_emit_extract_value(
        context, result, context.error_type_id, 1
    ) catch |err| { return err }
    zero: i64 = zbackend_ir_cfg_emit_integer_constant(
        context, 0, context.error_type_id
    ) catch |err| { return err }
    has_error: i64 = zbackend_ir_cfg_emit_equal(context, error_value, zero) catch |err| { return err }

    error_block: i64 = zbackend_ir_cfg_create_block(context, "catch.error") catch |err| { return err }
    success_block: i64 = zbackend_ir_cfg_create_block(context, "catch.success") catch |err| { return err }
    merge_block: i64 = zbackend_ir_cfg_create_block(context, "catch.end") catch |err| { return err }
    dispatch: ZBackendIrTerminator = zbackend_ir_new_terminator("conditional_branch")
    dispatch.condition = has_error
    dispatch.true_target = success_block
    dispatch.false_target = error_block
    zbackend_ir_cfg_terminate(context, dispatch) catch |err| { return err }

    zbackend_ir_cfg_activate_block(context, success_block) catch |err| { return err }
    zbackend_ir_cfg_branch(context, merge_block) catch |err| { return err }

    zbackend_ir_cfg_activate_block(context, error_block) catch |err| { return err }
    zbackend_ir_cfg_push_scope(context) catch |err| { return err }
    error_address: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    zbackend_ir_cfg_append_instruction(
        context, zbackend_ir_new_instruction(error_address, "alloca", context.error_type_id)
    ) catch |err| { return err }
    error_store_id: i64 = context.next_value_id
    context.next_value_id = context.next_value_id + 1
    error_store: ZBackendIrInstruction = zbackend_ir_new_instruction(
        error_store_id, "store", context.error_type_id
    )
    error_store.lhs = error_address
    error_store.rhs = error_value
    zbackend_ir_cfg_append_instruction(context, error_store) catch |err| { return err }
    zbackend_ir_cfg_declare_local(
        context, expression.name, error_address, context.error_type_id, true
    ) catch |err| { return err }

    body_end: i64 = expression.arg_start + expression.arg_count
    top_level_index: i64 = expression.arg_start
    fallback_statement: i64 = ZAstNoIndex
    while top_level_index < body_end {
        fallback_statement = top_level_index
        top_level: ZAstStmt = context.ast.stmts[top_level_index]
        next_top_level: i64 = top_level_index + 1
        if top_level.child_count > 0 {
            next_top_level = top_level.child_start + top_level.child_count
        }
        if next_top_level <= top_level_index || next_top_level > body_end {
            return error.InvalidArgument
        }
        top_level_index = next_top_level
    }
    fallback_expression: i64 = ZAstNoIndex
    recovery_end: i64 = body_end
    if !discard_result && fallback_statement != ZAstNoIndex &&
        context.ast.stmts[fallback_statement].kind == ZAstStmtExpr {
        fallback_expression = context.ast.stmts[fallback_statement].expr_index
        recovery_end = fallback_statement
    }

    previous_catch_owner: i64 = context.active_catch_owner
    context.active_catch_owner = expression_index
    zbackend_ir_cfg_lower_sequence(
        context, expression.arg_start, recovery_end
    ) catch |err| { return err }
    fallback_value: i64 = 0
    fallback_block: i64 = ZAstNoIndex
    if context.current_block >= 0 && fallback_expression != ZAstNoIndex {
        fallback_value = zbackend_ir_cfg_lower_expression_as(
            context, fallback_expression, payload_type_id
        ) catch |err| { return err }
        fallback_block = context.current_block + 1
        zbackend_ir_cfg_branch(context, merge_block) catch |err| { return err }
    } else if context.current_block >= 0 && discard_result {
        fallback_block = context.current_block + 1
        zbackend_ir_cfg_branch(context, merge_block) catch |err| { return err }
    } else if context.current_block >= 0 {
        return error.NotImplemented
    }
    context.active_catch_owner = previous_catch_owner
    zbackend_ir_cfg_pop_scope(context) catch |err| { return err }

    zbackend_ir_cfg_activate_block(
        context, merge_block
    ) catch |err| { return err }
    if fallback_block == ZAstNoIndex || discard_result { return success_value }
    incoming_values: *i64 = zbackend_ir_cfg_allocate_i64_array(context.allocator, 2) catch |err| { return err }
    incoming_blocks: *i64 = zbackend_ir_cfg_allocate_i64_array(context.allocator, 2) catch |err| { return err }
    incoming_values[0] = success_value
    incoming_values[1] = fallback_value
    incoming_blocks[0] = success_block
    incoming_blocks[1] = fallback_block
    return zbackend_ir_cfg_emit_phi(
        context, payload_type_id, incoming_values, incoming_blocks, 2
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_return(
    context: *ZBackendIrControlFlowLowering,
    statement: ZAstStmt
) !i64 {
    if context.returns_void {
        if statement.expr_index != ZAstNoIndex { return error.NotImplemented }
        return zbackend_ir_cfg_terminate(
            context, zbackend_ir_new_terminator("return_void")
        ) catch |err| { return err }
    }
    if statement.expr_index == ZAstNoIndex { return error.NotImplemented }
    if !context.returns_error_union {
        value: i64 = zbackend_ir_cfg_lower_expression_as(
            context, statement.expr_index, context.return_payload_type_id
        ) catch |err| { return err }
        return zbackend_ir_cfg_terminate(
            context, zbackend_ir_return_terminator(value)
        ) catch |err| { return err }
    }

    expression: ZAstExpr = context.ast.exprs[statement.expr_index]
    if zbackend_ir_expression_is_error_union_call(context.type_layout, expression) {
        result: i64 = zbackend_ir_cfg_lower_expression_as(
            context, statement.expr_index, context.error_union_type_id
        ) catch |err| { return err }
        return zbackend_ir_cfg_terminate(
            context, zbackend_ir_return_terminator(result)
        ) catch |err| { return err }
    }

    values: *i64 = zbackend_ir_cfg_allocate_i64_array(context.allocator, 2) catch |err| { return err }
    if expression.kind == ZAstExprError {
        values[0] = zbackend_ir_cfg_emit_zero_constant(
            context, context.return_payload_type_id
        ) catch |err| { return err }
        error_value: i64 = zbackend_ir_error_value(context.ast, expression.name) catch |err| { return err }
        values[1] = zbackend_ir_cfg_emit_integer_constant(
            context, error_value, context.error_type_id
        ) catch |err| { return err }
    } else if expression.kind == ZAstExprIdentifier &&
        zbackend_ir_has_local(context.local_names, context.local_count, expression.name) &&
        zbackend_ir_local_is_catch_error(
            context.local_names,
            context.local_is_catch_errors,
            context.local_count,
            expression.name
        ) {
        values[0] = zbackend_ir_cfg_emit_zero_constant(
            context, context.return_payload_type_id
        ) catch |err| { return err }
        values[1] = zbackend_ir_cfg_lower_expression_as(
            context, statement.expr_index, context.error_type_id
        ) catch |err| { return err }
    } else {
        values[0] = zbackend_ir_cfg_lower_expression_as(
            context, statement.expr_index, context.return_payload_type_id
        ) catch |err| { return err }
        values[1] = zbackend_ir_cfg_emit_integer_constant(
            context, 0, context.error_type_id
        ) catch |err| { return err }
    }
    result: i64 = zbackend_ir_cfg_emit_aggregate(
        context, context.error_union_type_id, values, 2
    ) catch |err| { return err }
    return zbackend_ir_cfg_terminate(
        context, zbackend_ir_return_terminator(result)
    ) catch |err| { return err }
}

fn zbackend_ir_cfg_lower_sequence(
    context: *ZBackendIrControlFlowLowering,
    statement_start: i64,
    statement_end: i64
) !i64 {
    statement_index: i64 = statement_start
    while statement_index < statement_end && context.current_block >= 0 {
        statement: ZAstStmt = context.ast.stmts[statement_index]
        context.current_statement_index = statement_index
        // Recovery statements share the declaration's flattened statement
        // arena. Only the catch currently being lowered owns its recovery;
        // in particular, an outer recovery must skip an inner catch's body.
        if statement.catch_owner != ZAstNoIndex &&
            statement.catch_owner != context.active_catch_owner {
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtVar {
            zbackend_ir_cfg_lower_variable(context, statement) catch |err| { return err }
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtAssign {
            zbackend_ir_cfg_lower_assignment(context, statement) catch |err| { return err }
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtAsm {
            zbackend_ir_cfg_lower_asm(context, statement) catch |err| { return err }
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtExpr {
            if context.ast.exprs[statement.expr_index].kind == ZAstExprCatch {
                zbackend_ir_cfg_lower_catch_expression(
                    context, statement.expr_index, true, ZBACKEND_IR_NO_TYPE_ID
                ) catch |err| { return err }
            } else {
                zbackend_ir_cfg_lower_expression(
                    context, statement.expr_index
                ) catch |err| { return err }
            }
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtReturn {
            zbackend_ir_cfg_lower_return(context, statement) catch |err| { return err }
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtBreak || statement.kind == ZAstStmtContinue {
            if context.loop_count <= 0 { return error.InvalidArgument }
            target: i64 = context.break_targets[context.loop_count - 1]
            if statement.kind == ZAstStmtContinue {
                target = context.continue_targets[context.loop_count - 1]
            }
            zbackend_ir_cfg_branch(context, target) catch |err| { return err }
            statement_index = statement_index + 1
            continue
        }
        if statement.kind == ZAstStmtBlock {
            zbackend_ir_cfg_push_scope(context) catch |err| { return err }
            zbackend_ir_cfg_lower_sequence(
                context, statement.child_start, statement.child_start + statement.child_count
            ) catch |err| { return err }
            zbackend_ir_cfg_pop_scope(context) catch |err| { return err }
            statement_index = statement.child_start + statement.child_count
            continue
        }
        if statement.kind == ZAstStmtIf {
            statement_index = zbackend_ir_cfg_lower_if(
                context, statement, statement_end
            ) catch |err| { return err }
            continue
        }
        if statement.kind == ZAstStmtWhile {
            statement_index = zbackend_ir_cfg_lower_while(context, statement) catch |err| { return err }
            continue
        }
        if statement.kind == ZAstStmtFor {
            statement_index = zbackend_ir_cfg_lower_for(context, statement) catch |err| { return err }
            continue
        }
        if statement.kind == ZAstStmtMatch {
            match_type_id: i64 = zbackend_ir_cfg_expression_type_id(
                context, statement.expr_index, context.return_payload_type_id
            ) catch |err| { return err }
            if match_type_id > 0 && match_type_id <= context.type_layout.type_count &&
                context.type_layout.types[match_type_id - 1].kind == "union" {
                statement_index = zbackend_ir_cfg_lower_union_match(
                    context, statement
                ) catch |err| { return err }
            } else {
                statement_index = zbackend_ir_cfg_lower_ordered_cases(
                    context, statement, statement_index
                ) catch |err| { return err }
            }
            continue
        }
        if statement.kind == ZAstStmtSwitch {
            statement_index = zbackend_ir_cfg_lower_ordered_cases(
                context, statement, statement_index
            ) catch |err| { return err }
            continue
        }
        return error.NotImplemented
    }
    return statement_index
}

fn zbackend_ir_local_address_from_arrays(
    local_names: *ZAstText,
    local_addresses: *i64,
    local_count: i64,
    name: ZAstText
) !i64 {
    index: i64 = local_count
    while index > 0 {
        index = index - 1
        if ZAstText.eql(local_names[index], name) { return local_addresses[index] }
    }
    return error.NotImplemented
}

fn zbackend_ir_cfg_allocate_i64_array(
    allocator: *std.mem.HeapAllocator,
    count: i64
) !*i64 {
    if count <= 0 { return cast(*i64, 0) }
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, count * Builtin.sizeof(i64)) catch |err| {
        return error.OutOfMemory
    }
    return cast(*i64, raw)
}

fn zbackend_ir_cfg_lower_function(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    declaration: ZAstDecl,
    function_id: i64,
    function_name: string,
    parameters: *ZBackendIrParameter,
    type_layout: *ZBackendIrTypeLayout
) !ZBackendIrFunction {
    // Catch error bindings are scoped locals but are not counted as source
    // variable declarations. The statement arena is a safe upper bound for
    // those additional bindings while the frontend keeps a compact AST.
    local_capacity: i64 = declaration.param_count + declaration.local_count + declaration.stmt_count + 1
    local_names: *ZAstText = cast(*ZAstText, 0)
    if local_capacity > 0 {
        names_raw: *u8 = std.mem.HeapAllocator.alloc(
            allocator, local_capacity * Builtin.sizeof(ZAstText)
        ) catch |err| { return error.OutOfMemory }
        local_names = cast(*ZAstText, names_raw)
    }
    local_addresses: *i64 = zbackend_ir_cfg_allocate_i64_array(allocator, local_capacity) catch |err| { return err }
    local_type_ids: *i64 = zbackend_ir_cfg_allocate_i64_array(allocator, local_capacity) catch |err| { return err }
    local_is_catch_errors: *i64 = zbackend_ir_cfg_allocate_i64_array(
        allocator, local_capacity
    ) catch |err| { return err }
    stack_capacity: i64 = declaration.stmt_count + 1
    return_payload_type_id: i64 = zbackend_ir_function_payload_type_id(
        type_layout, ast, declaration
    ) catch |err| { return err }
    return_type_id: i64 = zbackend_ir_function_return_type_id(
        type_layout, ast, declaration
    ) catch |err| { return err }
    error_union_type_id: i64 = ZBACKEND_IR_NO_TYPE_ID
    if declaration.return_is_error_union { error_union_type_id = return_type_id }
    context: ZBackendIrControlFlowLowering = ZBackendIrControlFlowLowering{
        allocator: allocator,
        ast: ast,
        declaration: declaration,
        type_layout: type_layout,
        bool_type_id: type_layout.bool_type_id,
        error_type_id: type_layout.error_type_id,
        error_union_type_id: error_union_type_id,
        return_payload_type_id: return_payload_type_id,
        return_type_id: return_type_id,
        returns_error_union: declaration.return_is_error_union,
        returns_void: declaration.return_type_index == ZAstNoIndex ||
            ZAstText.eql_string(ast.types[declaration.return_type_index].text, "void"),
        blocks: cast(*ZBackendIrBlockBuilder, 0),
        block_count: 0,
        block_capacity: 0,
        current_block: -1,
        next_value_id: declaration.param_count + 1,
        local_names: local_names,
        local_addresses: local_addresses,
        local_type_ids: local_type_ids,
        local_is_catch_errors: local_is_catch_errors,
        local_count: 0,
        local_capacity: local_capacity,
        scope_starts: zbackend_ir_cfg_allocate_i64_array(allocator, stack_capacity) catch |err| { return err },
        scope_count: 0,
        scope_capacity: stack_capacity,
        break_targets: zbackend_ir_cfg_allocate_i64_array(allocator, stack_capacity) catch |err| { return err },
        continue_targets: zbackend_ir_cfg_allocate_i64_array(allocator, stack_capacity) catch |err| { return err },
        loop_count: 0,
        loop_capacity: stack_capacity,
        active_catch_owner: ZAstNoIndex,
        current_statement_index: declaration.stmt_start
    }
    entry: i64 = zbackend_ir_cfg_create_block(&context, "entry") catch |err| { return err }
    zbackend_ir_cfg_activate_block(&context, entry) catch |err| { return err }
    parameter_index: i64 = 0
    while parameter_index < declaration.param_count {
        parameter: ZAstParam = ast.params[declaration.param_start + parameter_index]
        parameter_type_id: i64 = zbackend_ir_type_layout_type_id(
            type_layout, ast, parameter.type_index
        ) catch |err| { return err }
        address_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        zbackend_ir_cfg_append_instruction(
            &context, zbackend_ir_new_instruction(address_id, "alloca", parameter_type_id)
        ) catch |err| { return err }
        store_id: i64 = context.next_value_id
        context.next_value_id = context.next_value_id + 1
        store: ZBackendIrInstruction = zbackend_ir_new_instruction(
            store_id, "store", parameter_type_id
        )
        store.lhs = address_id
        store.rhs = parameter_index + 1
        zbackend_ir_cfg_append_instruction(&context, store) catch |err| { return err }
        zbackend_ir_cfg_declare_local(
            &context, parameter.name, address_id, parameter_type_id, false
        ) catch |err| { return err }
        parameter_index = parameter_index + 1
    }
    zbackend_ir_cfg_push_scope(&context) catch |err| { return err }
    zbackend_ir_cfg_lower_sequence(
        &context, declaration.stmt_start, declaration.stmt_start + declaration.stmt_count
    ) catch |err| { return err }
    zbackend_ir_cfg_pop_scope(&context) catch |err| { return err }
    if context.current_block >= 0 {
        if !context.returns_void { return error.NotImplemented }
        zbackend_ir_cfg_terminate(
            &context, zbackend_ir_new_terminator("return_void")
        ) catch |err| { return err }
    }

    blocks_raw: *u8 = std.mem.HeapAllocator.alloc(
        allocator, context.block_count * Builtin.sizeof(ZBackendIrBlock)
    ) catch |err| { return error.OutOfMemory }
    blocks: *ZBackendIrBlock = cast(*ZBackendIrBlock, blocks_raw)
    block_index: i64 = 0
    while block_index < context.block_count {
        builder: ZBackendIrBlockBuilder = context.blocks[block_index]
        if !builder.is_terminated { return error.InvalidArgument }
        blocks[block_index] = ZBackendIrBlock{
            id: builder.id,
            name: builder.name,
            instructions: builder.instructions,
            instruction_count: builder.instruction_count,
            terminator: builder.terminator
        }
        block_index = block_index + 1
    }
    return ZBackendIrFunction{
        id: function_id,
        name: function_name,
        linkage: "external",
        return_type: context.return_type_id,
        parameters: parameters,
        parameter_count: declaration.param_count,
        blocks: blocks,
        block_count: context.block_count
    }
}

fn zbackend_ir_lower_function(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    declaration: ZAstDecl,
    function_id: i64,
    type_layout: *ZBackendIrTypeLayout,
    generic_declaration_index: i64,
    generic_suffix: ZAstText
) !ZBackendIrFunction {
    previous_generic_declaration: i64 = type_layout.active_generic_declaration
    previous_generic_suffix: ZAstText = type_layout.active_generic_suffix
    type_layout.active_generic_declaration = generic_declaration_index
    type_layout.active_generic_suffix = generic_suffix
    function_name: string = zbackend_ir_copy_text(allocator, declaration.name) catch |err| { return err }
    if generic_declaration_index != ZAstNoIndex {
        builder: std.collections.StringBuilder = std.collections.StringBuilder.init(
            allocator, declaration.name.len + 24
        ) catch |err| { return error.OutOfMemory }
        base_name: string = zbackend_ir_copy_text(
            allocator, declaration.name
        ) catch |err| { return err }
        std.collections.StringBuilder.append(
            &builder, allocator, base_name
        ) catch |err| { return error.OutOfMemory }
        std.collections.StringBuilder.append(
            &builder, allocator, "$g$"
        ) catch |err| { return error.OutOfMemory }
        std.collections.StringBuilder.append_i64(
            &builder, allocator, function_id
        ) catch |err| { return error.OutOfMemory }
        function_name = cast(string, std.collections.StringBuilder.c_string(
            &builder, allocator
        ) catch |err| { return error.OutOfMemory })
    }

    parameters: *ZBackendIrParameter = cast(*ZBackendIrParameter, 0)
    if declaration.param_count > 0 {
        parameters_raw: *u8 = std.mem.HeapAllocator.alloc(allocator, declaration.param_count * Builtin.sizeof(ZBackendIrParameter)) catch |err| {
            return error.OutOfMemory
        }
        parameters = cast(*ZBackendIrParameter, parameters_raw)
        parameter_index: i64 = 0
        while declaration.param_count > parameter_index {
            ast_parameter: ZAstParam = ast.params[declaration.param_start + parameter_index]
            if ast_parameter.type_index == ZAstNoIndex { return error.NotImplemented }
            parameter_name: string = zbackend_ir_copy_text(allocator, ast_parameter.name) catch |err| { return err }
            parameter_type_id: i64 = zbackend_ir_type_layout_type_id(
                type_layout, ast, ast_parameter.type_index
            ) catch |err| { return err }
            parameters[parameter_index] = ZBackendIrParameter{
                id: parameter_index + 1,
                name: parameter_name,
                type_id: parameter_type_id
            }
            parameter_index = parameter_index + 1
        }
    }

    if declaration.kind == ZAstDeclExternFunction {
        result: ZBackendIrFunction = ZBackendIrFunction{
            id: function_id,
            name: function_name,
            linkage: "external",
            return_type: zbackend_ir_function_return_type_id(
                type_layout, ast, declaration
            ) catch |err| { return err },
            parameters: parameters,
            parameter_count: declaration.param_count,
            blocks: cast(*ZBackendIrBlock, 0),
            block_count: 0
        }
        type_layout.active_generic_declaration = previous_generic_declaration
        type_layout.active_generic_suffix = previous_generic_suffix
        return result
    }

    result: ZBackendIrFunction = zbackend_ir_cfg_lower_function(
        allocator, ast, declaration, function_id, function_name, parameters, type_layout
    ) catch |err| { return err }
    type_layout.active_generic_declaration = previous_generic_declaration
    type_layout.active_generic_suffix = previous_generic_suffix
    return result
}

fn zbackend_ir_zero_constant() -> ZBackendIrConstant {
    return ZBackendIrConstant{
        kind: "zero",
        integer: 0,
        text: "",
        function_id: 0,
        elements: cast(*ZBackendIrConstant, 0),
        element_count: 0
    }
}

fn zbackend_ir_lower_global_initializer(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    expression_index: i64,
    type_layout: *ZBackendIrTypeLayout,
    expected_type_id: i64
) !ZBackendIrConstant {
    if expression_index == ZAstNoIndex { return zbackend_ir_zero_constant() }
    expression: ZAstExpr = ast.exprs[expression_index]
    constant: ZBackendIrConstant = zbackend_ir_zero_constant()
    function_value_name: ZAstText = zbackend_ir_resolved_function_value_name(
        type_layout, expression_index
    ) catch |err| { return err }
    if function_value_name.len > 0 {
        declaration: ZAstDecl = zbackend_ir_function_declaration(
            ast, function_value_name
        ) catch |err| { return err }
        constant.kind = "function"
        if declaration.generic_param_count > 0 {
            suffix: ZAstText = ZAstText.empty()
            if expression.type_index != ZAstNoIndex {
                candidate_suffix: ZAstText = ast.types[expression.type_index].text
                if candidate_suffix.len > 0 && candidate_suffix.ptr[0] == 60 {
                    suffix = candidate_suffix
                }
            }
            if suffix.len == 0 {
                suffix = zbackend_ir_function_value_generic_suffix(
                    type_layout, declaration, expected_type_id
                ) catch |err| { return err }
            }
            constant.function_id = zbackend_ir_ensure_generic_instance_id(
                type_layout, function_value_name, suffix
            ) catch |err| { return err }
        } else {
            constant.function_id = zbackend_ir_function_id(
                ast, function_value_name
            ) catch |err| { return err }
        }
        return constant
    }
    if expression.kind == ZAstExprInteger {
        constant.kind = "integer"
        constant.integer = zbackend_ir_parse_positive_integer(
            expression.literal
        ) catch |err| { return err }
        return constant
    }
    if expression.kind == ZAstExprBinary ||
        (expression.kind == ZAstExprIdentifier &&
            !zbackend_ir_is_function_name(ast, expression.name)) {
        constant.kind = "integer"
        constant.integer = zbackend_ir_eval_constant_integer(
            ast, expression_index, ZBACKEND_IR_MAX_CONSTANT_EVALUATION_DEPTH,
            ZAstNoIndex, ZAstNoIndex
        ) catch |err| { return err }
        return constant
    }
    if expression.kind == ZAstExprBool {
        constant.kind = "integer"
        if expression.literal.len == 4 { constant.integer = 1 }
        return constant
    }
    if expression.kind == ZAstExprString {
        constant.kind = "string"
        constant.text = zbackend_ir_copy_text(
            allocator, expression.literal
        ) catch |err| { return err }
        return constant
    }
    if expression.kind == ZAstExprUnary && expression.op == ZTokenMinus &&
        expression.left != ZAstNoIndex {
        operand: ZAstExpr = ast.exprs[expression.left]
        if operand.kind != ZAstExprInteger { return error.NotImplemented }
        constant.kind = "integer"
        constant.integer = zbackend_ir_parse_negative_integer(
            operand.literal
        ) catch |err| { return err }
        return constant
    }
    if expression.kind == ZAstExprCast && expression.left != ZAstNoIndex {
        operand: ZAstExpr = ast.exprs[expression.left]
        if operand.kind == ZAstExprInteger {
            constant.integer = zbackend_ir_parse_positive_integer(
                operand.literal
            ) catch |err| { return err }
            if constant.integer == 0 {
                constant.kind = "zero"
            } else {
                constant.kind = "pointer_integer"
            }
            return constant
        }
        if operand.kind == ZAstExprString {
            constant.kind = "string"
            constant.text = zbackend_ir_copy_text(
                allocator, operand.literal
            ) catch |err| { return err }
            return constant
        }
    }
    if expression.kind == ZAstExprStructLiteral {
        if expected_type_id <= 0 || expected_type_id > type_layout.type_count {
            return error.InvalidArgument
        }
        nominal_type: ZBackendIrType = type_layout.types[expected_type_id - 1]
        if nominal_type.kind != "struct" && nominal_type.kind != "union" {
            return error.NotImplemented
        }
        constant.kind = "aggregate"
        if nominal_type.kind == "union" {
            if expression.arg_count != 1 { return error.InvalidArgument }
            variant_index: i64 = zbackend_ir_type_field_index(
                type_layout, expected_type_id,
                ast.literal_fields[expression.field_start].name
            ) catch |err| { return err }
            constant.element_count = nominal_type.field_count + 1
            elements_raw: *u8 = std.mem.HeapAllocator.alloc(
                allocator,
                constant.element_count * Builtin.sizeof(ZBackendIrConstant)
            ) catch |err| { return error.OutOfMemory }
            constant.elements = cast(*ZBackendIrConstant, elements_raw)
            constant.elements[0] = zbackend_ir_zero_constant()
            constant.elements[0].kind = "integer"
            constant.elements[0].integer = variant_index
            field_index: i64 = 0
            while field_index < nominal_type.field_count {
                if field_index == variant_index {
                    constant.elements[field_index + 1] =
                        zbackend_ir_lower_global_initializer(
                            allocator, ast,
                            ast.literal_fields[expression.field_start].value_expr,
                            type_layout, nominal_type.fields[field_index].type_id
                        ) catch |err| { return err }
                } else {
                    constant.elements[field_index + 1] = zbackend_ir_zero_constant()
                }
                field_index = field_index + 1
            }
            return constant
        }
        constant.element_count = nominal_type.field_count
        if constant.element_count > 0 {
            elements_raw: *u8 = std.mem.HeapAllocator.alloc(
                allocator,
                constant.element_count * Builtin.sizeof(ZBackendIrConstant)
            ) catch |err| { return error.OutOfMemory }
            constant.elements = cast(*ZBackendIrConstant, elements_raw)
        }
        field_index: i64 = 0
        while field_index < nominal_type.field_count {
            literal_field_index: i64 = expression.field_start
            found_expression: i64 = ZAstNoIndex
            while literal_field_index != ZAstNoIndex {
                literal_field: ZAstLiteralField = ast.literal_fields[literal_field_index]
                if ZAstText.eql_string(
                    literal_field.name, nominal_type.fields[field_index].name
                ) {
                    found_expression = literal_field.value_expr
                    literal_field_index = ZAstNoIndex
                } else {
                    literal_field_index = literal_field.next_index
                }
            }
            if found_expression == ZAstNoIndex { return error.InvalidArgument }
            constant.elements[field_index] = zbackend_ir_lower_global_initializer(
                allocator, ast, found_expression, type_layout,
                nominal_type.fields[field_index].type_id
            ) catch |err| { return err }
            field_index = field_index + 1
        }
        return constant
    }
    if expression.kind == ZAstExprArrayLiteral {
        constant.kind = "aggregate"
        constant.element_count = expression.arg_count
        if expression.arg_count > 0 {
            elements_raw: *u8 = std.mem.HeapAllocator.alloc(
                allocator, expression.arg_count * Builtin.sizeof(ZBackendIrConstant)
            ) catch |err| { return error.OutOfMemory }
            constant.elements = cast(*ZBackendIrConstant, elements_raw)
            element_type_id: i64 = zbackend_ir_type_layout_element_type(
                type_layout, expected_type_id
            ) catch |err| { return err }
            element_index: i64 = 0
            while element_index < expression.arg_count {
                constant.elements[element_index] = zbackend_ir_lower_global_initializer(
                    allocator,
                    ast,
                    ast.expr_args[expression.arg_start + element_index],
                    type_layout,
                    element_type_id
                ) catch |err| { return err }
                element_index = element_index + 1
            }
        }
        return constant
    }
    return error.NotImplemented
}

fn zbackend_ir_lower_global(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    declaration: ZAstDecl,
    global_id: i64,
    type_layout: *ZBackendIrTypeLayout
) !ZBackendIrGlobal {
    if declaration.type_index == ZAstNoIndex { return error.InvalidArgument }
    linkage: string = "internal"
    if declaration.exported { linkage = "external" }
    type_id: i64 = zbackend_ir_type_layout_type_id(
        type_layout, ast, declaration.type_index
    ) catch |err| { return err }
    return ZBackendIrGlobal{
        id: global_id,
        name: zbackend_ir_copy_text(
            allocator, declaration.name
        ) catch |err| { return err },
        type_id: type_id,
        linkage: linkage,
        is_constant: declaration.kind == ZAstDeclConst,
        initializer: zbackend_ir_lower_global_initializer(
            allocator, ast, declaration.init_expr, type_layout, type_id
        ) catch |err| { return err }
    }
}

// Lowering consumes the checked native AST and produces the same model accepted
// by the Zig backend. Scalar, void, and error-union types are interned once per
// module from complete function signatures; expression lowering then carries
// the relevant operand type into instruction selection.
export fn ZBackendIrLowering.lower_module(
    allocator: *std.mem.HeapAllocator,
    ast: *ZAstModule,
    module_name: string,
    target: ZBackendIrTarget,
    output_kind: string,
    output_path: string
) !ZBackendIrModule {
    concrete_function_count: i64 = zbackend_ir_function_count(ast)
    global_count: i64 = zbackend_ir_global_count(ast)
    type_layout: ZBackendIrTypeLayout = zbackend_ir_module_type_layout(
        allocator, ast, target.triple
    ) catch |err| { return err }
    function_capacity: i64 = concrete_function_count + ast.expr_count
    functions: *ZBackendIrFunction = cast(*ZBackendIrFunction, 0)
    if function_capacity > 0 {
        functions_raw: *u8 = std.mem.HeapAllocator.alloc(
            allocator, function_capacity * Builtin.sizeof(ZBackendIrFunction)
        ) catch |err| { return error.OutOfMemory }
        functions = cast(*ZBackendIrFunction, functions_raw)
    }
    globals: *ZBackendIrGlobal = cast(*ZBackendIrGlobal, 0)
    if global_count > 0 {
        globals_raw: *u8 = std.mem.HeapAllocator.alloc(
            allocator, global_count * Builtin.sizeof(ZBackendIrGlobal)
        ) catch |err| { return error.OutOfMemory }
        globals = cast(*ZBackendIrGlobal, globals_raw)
    }
    declaration_index: i64 = 0
    function_index: i64 = 0
    global_index: i64 = 0
    while declaration_index < ast.len {
        declaration: ZAstDecl = ast.decls[declaration_index]
        if (declaration.kind == ZAstDeclGlobal || declaration.kind == ZAstDeclConst) &&
            !declaration.is_imported {
            globals[global_index] = zbackend_ir_lower_global(
                allocator, ast, declaration, global_index + 1, &type_layout
            ) catch |err| { return err }
            global_index = global_index + 1
        }
        if (declaration.kind == ZAstDeclFunction || declaration.kind == ZAstDeclExternFunction) &&
            !declaration.is_imported &&
            declaration.generic_param_count == 0 {
            functions[function_index] = zbackend_ir_lower_function(
                allocator,
                ast,
                declaration,
                function_index + 1,
                &type_layout,
                ZAstNoIndex,
                ZAstText.empty()
            ) catch |err| { return err }
            function_index = function_index + 1
        }
        declaration_index = declaration_index + 1
    }
    instance_index: i64 = 0
    while instance_index < type_layout.generic_instance_count {
        instance_declaration_index: i64 = type_layout.generic_instance_declarations[instance_index]
        functions[function_index] = zbackend_ir_lower_function(
            allocator,
            ast,
            ast.decls[instance_declaration_index],
            function_index + 1,
            &type_layout,
            instance_declaration_index,
            type_layout.generic_instance_suffixes[instance_index]
        ) catch |err| { return err }
        function_index = function_index + 1
        instance_index = instance_index + 1
    }

    return ZBackendIrModule{
        module_name: module_name,
        target: target,
        output_kind: output_kind,
        output_path: output_path,
        types: type_layout.types,
        type_count: type_layout.type_count,
        globals: globals,
        global_count: global_count,
        functions: functions,
        function_count: function_index
    }
}
