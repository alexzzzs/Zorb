import "../../std/io.zorb"
import "../../std/os.zorb"

fn _start() {
    if std.os.is_linux() || std.os.is_windows() {
        std.io.print("running on ")
        std.io.print(std.os.platform_name())
        std.io.print("\n")
        std.io.eprintln("stderr ready")
        std.os.exit(0)
        return
    }

    std.io.print("unknown platform\n")
    std.os.exit(1)
}
