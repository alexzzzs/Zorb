    new_capacity: i64 = zast_next_capacity(self.expr_arg_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(i64)) catch |err| {
        return error.OutOfMemory
