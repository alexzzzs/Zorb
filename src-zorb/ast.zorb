import "../std/errors.zorb"
import "../std/mem.zorb"
import "../std/str.zorb"
import "token.zorb"

export const ZAstDeclImport: i64 = 1
export const ZAstDeclExternFunction: i64 = 2
export const ZAstDeclError: i64 = 3
export const ZAstDeclConst: i64 = 4
export const ZAstDeclGlobal: i64 = 5
export const ZAstDeclStruct: i64 = 6
export const ZAstDeclEnum: i64 = 7
export const ZAstDeclUnion: i64 = 8
export const ZAstDeclFunction: i64 = 9

export const ZAstExprMissing: i64 = 0
export const ZAstExprIdentifier: i64 = 1
export const ZAstExprInteger: i64 = 2
export const ZAstExprString: i64 = 3
export const ZAstExprBool: i64 = 4
export const ZAstExprBinary: i64 = 5
export const ZAstExprCall: i64 = 6
export const ZAstExprUnary: i64 = 7

export const ZAstStmtVar: i64 = 1
export const ZAstStmtReturn: i64 = 2
export const ZAstStmtExpr: i64 = 3
export const ZAstStmtBlock: i64 = 4

export const ZAstNoIndex: i64 = -1

export struct ZAstText {
    ptr: *u8,
    len: i64
}

export struct ZAstType {
    text: ZAstText
}

export struct ZAstParam {
    name: ZAstText,
    type_index: i64
}

export struct ZAstMember {
    name: ZAstText,
    type_index: i64,
    value_expr: i64
}

export struct ZAstExpr {
    kind: i64,
    name: ZAstText,
    literal: ZAstText,
    op: i64,
    left: i64,
    right: i64,
    arg_start: i64,
    arg_count: i64
}

export struct ZAstStmt {
    kind: i64,
    name: ZAstText,
    type_index: i64,
    expr_index: i64,
    child_start: i64,
    child_count: i64
}

export struct ZAstDecl {
    kind: i64,
    exported: bool,
    name: ZAstText,
    path: ZAstText,
    alias: ZAstText,
    is_c_import: bool,
    type_index: i64,
    return_type_index: i64,
    init_expr: i64,
    param_start: i64,
    param_count: i64,
    member_start: i64,
    member_count: i64,
    stmt_start: i64,
    stmt_count: i64,
    local_count: i64,
    return_count: i64,
    call_count: i64,
    binary_count: i64
}

export struct ZAstModule {
    decls: *ZAstDecl,
    len: i64,
    capacity: i64,
    types: *ZAstType,
    type_count: i64,
    type_capacity: i64,
    params: *ZAstParam,
    param_count_total: i64,
    param_capacity: i64,
    members: *ZAstMember,
    member_count_total: i64,
    member_capacity: i64,
    stmts: *ZAstStmt,
    stmt_count_total: i64,
    stmt_capacity: i64,
    exprs: *ZAstExpr,
    expr_count: i64,
    expr_capacity: i64,
    expr_args: *i64,
    expr_arg_count: i64,
    expr_arg_capacity: i64,
    import_count: i64,
    extern_count: i64,
    error_count: i64,
    const_count: i64,
    global_count: i64,
    struct_count: i64,
    enum_count: i64,
    union_count: i64,
    function_count: i64
}

export fn ZAstText.from_token(token: ZToken) -> ZAstText {
    text: ZAstText
    text.ptr = token.ptr
    text.len = token.len
    return text
}

export fn ZAstText.from_range(start: ZToken, end: ZToken) -> ZAstText {
    text: ZAstText
    text.ptr = start.ptr
    text.len = 0
    cursor: *u8 = start.ptr
    while cursor != end.ptr {
        text.len = text.len + 1
        cursor = cursor + 1
    }
    text.len = text.len + end.len
    return text
}

export fn ZAstText.empty() -> ZAstText {
    text: ZAstText
    text.ptr = cast(*u8, 0)
    text.len = 0
    return text
}

export fn ZAstText.eql(self: ZAstText, other: ZAstText) -> bool {
    a: []u8
    a.ptr = self.ptr
    a.len = self.len
    b: []u8
    b.ptr = other.ptr
    b.len = other.len
    return std.str.slice_eql(a, b)
}

fn zast_text_same(a: ZAstText, b: ZAstText) -> bool {
    if a.len != b.len {
        return false
    }
    i: i64 = 0
    while i < a.len {
        if a.ptr[i] != b.ptr[i] {
            return false
        }
        i = i + 1
    }
    return true
}

export fn ZAstText.eql_string(self: ZAstText, value: string) -> bool {
    a: []u8
    a.ptr = self.ptr
    a.len = self.len
    b: []u8
    b.ptr = cast(*u8, value)
    b.len = std.str.len(value)
    return std.str.slice_eql(a, b)
}

export fn ZAstDecl.init(kind: i64, exported: bool) -> ZAstDecl {
    decl: ZAstDecl
    decl.kind = kind
    decl.exported = exported
    decl.name = ZAstText.empty()
    decl.path = ZAstText.empty()
    decl.alias = ZAstText.empty()
    decl.is_c_import = false
    decl.type_index = ZAstNoIndex
    decl.return_type_index = ZAstNoIndex
    decl.init_expr = ZAstNoIndex
    decl.param_start = 0
    decl.param_count = 0
    decl.member_start = 0
    decl.member_count = 0
    decl.stmt_start = 0
    decl.stmt_count = 0
    decl.local_count = 0
    decl.return_count = 0
    decl.call_count = 0
    decl.binary_count = 0
    return decl
}

export fn ZAstExpr.init(kind: i64) -> ZAstExpr {
    expr: ZAstExpr
    expr.kind = kind
    expr.name = ZAstText.empty()
    expr.literal = ZAstText.empty()
    expr.op = ZAstNoIndex
    expr.left = ZAstNoIndex
    expr.right = ZAstNoIndex
    expr.arg_start = 0
    expr.arg_count = 0
    return expr
}

export fn ZAstStmt.init(kind: i64) -> ZAstStmt {
    stmt: ZAstStmt
    stmt.kind = kind
    stmt.name = ZAstText.empty()
    stmt.type_index = ZAstNoIndex
    stmt.expr_index = ZAstNoIndex
    stmt.child_start = 0
    stmt.child_count = 0
    return stmt
}

fn zast_next_capacity(current: i64, needed: i64) -> i64 {
    capacity: i64 = current
    if capacity < 16 {
        capacity = 16
    }

    while capacity < needed {
        capacity = capacity * 2
    }

    return capacity
}

export fn ZAstModule.init(allocator: *std.mem.HeapAllocator, initial_capacity: i64) !ZAstModule {
    module: ZAstModule
    module.decls = cast(*ZAstDecl, 0)
    module.len = 0
    module.capacity = 0
    module.types = cast(*ZAstType, 0)
    module.type_count = 0
    module.type_capacity = 0
    module.params = cast(*ZAstParam, 0)
    module.param_count_total = 0
    module.param_capacity = 0
    module.members = cast(*ZAstMember, 0)
    module.member_count_total = 0
    module.member_capacity = 0
    module.stmts = cast(*ZAstStmt, 0)
    module.stmt_count_total = 0
    module.stmt_capacity = 0
    module.exprs = cast(*ZAstExpr, 0)
    module.expr_count = 0
    module.expr_capacity = 0
    module.expr_args = cast(*i64, 0)
    module.expr_arg_count = 0
    module.expr_arg_capacity = 0
    module.import_count = 0
    module.extern_count = 0
    module.error_count = 0
    module.const_count = 0
    module.global_count = 0
    module.struct_count = 0
    module.enum_count = 0
    module.union_count = 0
    module.function_count = 0

    if initial_capacity < 0 {
        return error.InvalidSize
    }

    if initial_capacity > 0 {
        ZAstModule.reserve(&module, allocator, initial_capacity) catch |err| {
            if err == error.InvalidSize {
                return error.InvalidSize
            }
            return error.OutOfMemory
        }
    }

    return module
}

export fn ZAstModule.reserve(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed < 0 {
        return error.InvalidSize
    }

    if needed <= self.capacity {
        return 0
    }

    new_capacity: i64 = zast_next_capacity(self.capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstDecl)) catch |err| {
        return error.OutOfMemory
    }
    new_decls: *ZAstDecl = cast(*ZAstDecl, raw)

    i: i64 = 0
    while i < self.len {
        new_decls[i] = self.decls[i]
        i = i + 1
    }

    self.decls = new_decls
    self.capacity = new_capacity
    return 0
}

fn zast_reserve_types(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.type_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.type_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstType)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstType = cast(*ZAstType, raw)
    i: i64 = 0
    while i < self.type_count {
        new_items[i] = self.types[i]
        i = i + 1
    }
    self.types = new_items
    self.type_capacity = new_capacity
    return 0
}

fn zast_reserve_params(self: *ZAstModule, allocator: *std.mem.HeapAllocator, needed: i64) !i64 {
    if needed <= self.param_capacity {
        return 0
    }
    new_capacity: i64 = zast_next_capacity(self.param_capacity, needed)
    raw: *u8 = std.mem.HeapAllocator.alloc(allocator, new_capacity * Builtin.sizeof(ZAstParam)) catch |err| {
        return error.OutOfMemory
    }
    new_items: *ZAstParam = cast(*ZAstParam, raw)
    i: i64 = 0
    while i < self.param_count_total {
        new_items[i] = self.params[i]
        i = i + 1
    }
    self.params = new_items
    self.param_capacity = new_capacity
    return 0
}

