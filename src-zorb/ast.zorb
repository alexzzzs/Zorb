export fn ZAstModule.append_type(self: *ZAstModule, allocator: *std.mem.HeapAllocator, text: ZAstText) !i64 {
    zast_reserve_types(self, allocator, self.type_count + 1) catch |err| {
        return err
    }
    index: i64 = self.type_count
    self.types[index].text = text
    self.type_count = self.type_count + 1
    return index
}

export fn ZAstModule.append_param(self: *ZAstModule, allocator: *std.mem.HeapAllocator, param: ZAstParam) !i64 {
    zast_reserve_params(self, allocator, self.param_count_total + 1) catch |err| {
        return err
    }
    index: i64 = self.param_count_total
    self.params[index] = param
    self.param_count_total = self.param_count_total + 1
    return index
}

export fn ZAstModule.append_member(self: *ZAstModule, allocator: *std.mem.HeapAllocator, member: ZAstMember) !i64 {
    zast_reserve_members(self, allocator, self.member_count_total + 1) catch |err| {
        return err
    }
    index: i64 = self.member_count_total
    self.members[index] = member
    self.member_count_total = self.member_count_total + 1
    return index
}

export fn ZAstModule.append_stmt(self: *ZAstModule, allocator: *std.mem.HeapAllocator, stmt: ZAstStmt) !i64 {
    zast_reserve_stmts(self, allocator, self.stmt_count_total + 1) catch |err| {
        return err
    }
    index: i64 = self.stmt_count_total
    self.stmts[index] = stmt
    self.stmt_count_total = self.stmt_count_total + 1
    return index
}

export fn ZAstModule.append_expr(self: *ZAstModule, allocator: *std.mem.HeapAllocator, expr: ZAstExpr) !i64 {
    zast_reserve_exprs(self, allocator, self.expr_count + 1) catch |err| {
        return err
    }
    index: i64 = self.expr_count
    self.exprs[index] = expr
    self.expr_count = self.expr_count + 1
    return index
}

export fn ZAstModule.append_expr_arg(self: *ZAstModule, allocator: *std.mem.HeapAllocator, expr_index: i64) !i64 {
    zast_reserve_expr_args(self, allocator, self.expr_arg_count + 1) catch |err| {
        return err
    }
    index: i64 = self.expr_arg_count
    self.expr_args[index] = expr_index
    self.expr_arg_count = self.expr_arg_count + 1
    return index
}

export fn ZAstModule.append(self: *ZAstModule, allocator: *std.mem.HeapAllocator, decl: ZAstDecl) !i64 {
    ZAstModule.reserve(self, allocator, self.len + 1) catch |err| {
        if err == error.InvalidSize {
            return error.InvalidSize
        }
        return error.OutOfMemory
    }

    self.decls[self.len] = decl
    self.len = self.len + 1

    if decl.kind == ZAstDeclImport {
        self.import_count = self.import_count + 1
    }
    if decl.kind == ZAstDeclExternFunction {
        self.extern_count = self.extern_count + 1
    }
    if decl.kind == ZAstDeclError {
        self.error_count = self.error_count + 1
    }
    if decl.kind == ZAstDeclConst {
        self.const_count = self.const_count + 1
    }
    if decl.kind == ZAstDeclGlobal {
        self.global_count = self.global_count + 1
    }
    if decl.kind == ZAstDeclStruct {
        self.struct_count = self.struct_count + 1
    }
    if decl.kind == ZAstDeclEnum {
        self.enum_count = self.enum_count + 1
    }
    if decl.kind == ZAstDeclUnion {
        self.union_count = self.union_count + 1
    }
    if decl.kind == ZAstDeclFunction {
        self.function_count = self.function_count + 1
    }

    return self.len - 1
}

export fn ZAstModule.find_decl(self: *ZAstModule, name: ZAstText) -> i64 {
    i: i64 = 0
    while i < self.len {
        if zast_text_same(self.decls[i].name, name) {
            return i
        }
        i = i + 1
    }
    return ZAstNoIndex
}

fn zast_is_builtin_type(name: ZAstText) -> bool {
    if ZAstText.eql_string(name, "i8") { return true }
    if ZAstText.eql_string(name, "i16") { return true }
    if ZAstText.eql_string(name, "i32") { return true }
    if ZAstText.eql_string(name, "i64") { return true }
    if ZAstText.eql_string(name, "u8") { return true }
    if ZAstText.eql_string(name, "u16") { return true }
    if ZAstText.eql_string(name, "u32") { return true }
    if ZAstText.eql_string(name, "u64") { return true }
    if ZAstText.eql_string(name, "bool") { return true }
    if ZAstText.eql_string(name, "string") { return true }
    return false
}

fn zast_type_known(self: *ZAstModule, type_index: i64) -> bool {
    if type_index == ZAstNoIndex {
        return true
    }
    text: ZAstText = self.types[type_index].text
    if text.len == 0 {
        return true
    }
    if text.ptr[0] == 42 || text.ptr[0] == 91 {
        return true
    }
    if zast_is_builtin_type(text) {
        return true
    }
    decl_index: i64 = ZAstModule.find_decl(self, text)
    if decl_index == ZAstNoIndex {
        return false
    }
    kind: i64 = self.decls[decl_index].kind
    return kind == ZAstDeclStruct || kind == ZAstDeclEnum || kind == ZAstDeclUnion
}

fn zast_function_accepts_return(self: *ZAstModule, decl: ZAstDecl, expr_index: i64) -> bool {
    if decl.return_type_index == ZAstNoIndex {
        return expr_index == ZAstNoIndex
    }

    if expr_index == ZAstNoIndex {
        return false
    }

    ret: ZAstText = self.types[decl.return_type_index].text
    expr: ZAstExpr = self.exprs[expr_index]
    if ZAstText.eql_string(ret, "bool") {
        return expr.kind == ZAstExprBool || expr.kind == ZAstExprIdentifier || expr.kind == ZAstExprCall || expr.kind == ZAstExprBinary || expr.kind == ZAstExprUnary
    }
    if ZAstText.eql_string(ret, "string") {
        return expr.kind == ZAstExprString || expr.kind == ZAstExprIdentifier || expr.kind == ZAstExprCall
    }
    return expr.kind == ZAstExprInteger || expr.kind == ZAstExprIdentifier || expr.kind == ZAstExprCall || expr.kind == ZAstExprBinary || expr.kind == ZAstExprUnary
}

fn zast_function_name_known(self: *ZAstModule, name: ZAstText) -> i64 {
    i: i64 = 0
    while i < self.len {
        if zast_text_same(self.decls[i].name, name) {
            if self.decls[i].kind == ZAstDeclFunction || self.decls[i].kind == ZAstDeclExternFunction {
                return i
            }
        }
        i = i + 1
    }
    return ZAstNoIndex
}

fn zast_local_known(self: *ZAstModule, decl: ZAstDecl, name: ZAstText, through_stmt: i64) -> bool {
    p: i64 = 0
    while p < decl.param_count {
        if zast_text_same(self.params[decl.param_start + p].name, name) {
            return true
        }
        p = p + 1
    }

    s: i64 = 0
    while s < through_stmt {
        stmt: ZAstStmt = self.stmts[decl.stmt_start + s]
        if stmt.kind == ZAstStmtVar && zast_text_same(stmt.name, name) {
            return true
        }
        s = s + 1
    }

    return ZAstModule.find_decl(self, name) != ZAstNoIndex
}

fn zast_expr_names_known(self: *ZAstModule, decl: ZAstDecl, expr_index: i64, through_stmt: i64) -> bool {
    if expr_index == ZAstNoIndex {
        return true
    }
    expr: ZAstExpr = self.exprs[expr_index]
    if expr.kind == ZAstExprIdentifier {
        return zast_local_known(self, decl, expr.name, through_stmt)
    }
    if expr.kind == ZAstExprCall {
        fn_index: i64 = zast_function_name_known(self, expr.name)
        if fn_index == ZAstNoIndex {
            return false
        }
        if self.decls[fn_index].param_count != expr.arg_count {
            return false
        }
        i: i64 = 0
        while i < expr.arg_count {
            if !zast_expr_names_known(self, decl, self.expr_args[expr.arg_start + i], through_stmt) {
                return false
            }
            i = i + 1
        }
    }
    if expr.kind == ZAstExprBinary {
        return zast_expr_names_known(self, decl, expr.left, through_stmt) && zast_expr_names_known(self, decl, expr.right, through_stmt)
    }
    if expr.kind == ZAstExprUnary {
        return zast_expr_names_known(self, decl, expr.left, through_stmt)
    }
    return true
}

export fn ZAstModule.has_duplicate_declarations(self: *ZAstModule) -> bool {
    i: i64 = 0
    while i < self.len {
        j: i64 = i + 1
        while j < self.len {
            if self.decls[i].name.len > 0 && zast_text_same(self.decls[i].name, self.decls[j].name) {
                return true
            }
            j = j + 1
        }
        i = i + 1
    }
    return false
}

export fn ZAstModule.check_semantics(self: *ZAstModule) !i64 {
    if ZAstModule.has_duplicate_declarations(self) {
        return error.AlreadyExists
    }

    i: i64 = 0
    while i < self.len {
        if !zast_type_known(self, self.decls[i].type_index) {
            return error.NotFound
        }
        if !zast_type_known(self, self.decls[i].return_type_index) {
            return error.NotFound
        }

        p: i64 = 0
        while p < self.decls[i].param_count {
            if !zast_type_known(self, self.params[self.decls[i].param_start + p].type_index) {
                return error.NotFound
            }
            p = p + 1
        }

        m: i64 = 0
        while m < self.decls[i].member_count {
            if !zast_type_known(self, self.members[self.decls[i].member_start + m].type_index) {
                return error.NotFound
            }
            m = m + 1
        }

        if self.decls[i].kind == ZAstDeclFunction {
            s: i64 = 0
            while s < self.decls[i].stmt_count {
                stmt: ZAstStmt = self.stmts[self.decls[i].stmt_start + s]
                if stmt.kind == ZAstStmtVar && !zast_type_known(self, stmt.type_index) {
                    return error.NotFound
                }
                if !zast_expr_names_known(self, self.decls[i], stmt.expr_index, s) {
                    return error.NotFound
                }
                if stmt.kind == ZAstStmtReturn && !zast_function_accepts_return(self, self.decls[i], stmt.expr_index) {
                    return error.InvalidArgument
                }
                s = s + 1
            }
        }

        i = i + 1
    }

    return 0
}
